---
// src/layouts/ArticleLayoutNew.astro
import type { CollectionEntry } from "astro:content";
import { getCollection } from "astro:content";
import CardNew from "../components/cards/cardNew.astro";
import CatBadge from "../components/CatBadge.astro";
import ProgressBar from "../components/article/ProgressBar.astro";
import CopyLinkButton from "../components/article/CopyLinkButton.astro";
import TgBanner from "../components/article/TgBanner.astro";
import { slugify } from "../lib/slugify";
import { ORGANIZATION_DATA } from "../lib/seoData";

import "../styles/global_lend.css";

// типы пропсов
interface Props {
  fm: CollectionEntry<"articles">["data"] & {
    toc?: boolean;
    tocManual?: { id: string; text: string }[];
    showHeroImage?: boolean;
    videoUrl?: string;
    imageAlt?: string;
    updated?: string | Date;
  };
  slug: string;
  headings?: { depth: number; slug: string; text: string }[];
}
const { fm, slug, headings = [] } = Astro.props;

/* === окружение и базовый префикс (/academy) === */
const origin = Astro.url.origin;
const currentPath = Astro.url.pathname; // точный путь текущей статьи (с учётом слэшей)
const inAcademy = currentPath.startsWith("/academy");
const base = inAcademy ? "/academy" : "";

/* === абсолютные URL (статьи: /academy/КАТЕГОРИЯ/СЛАГ) === */
const categorySlug = slugify(String(fm.category || ""));
const articleUrl = `${origin}${base}/${categorySlug}/${slug}/`;
const articlePath = `${base}/${categorySlug}/${slug}/`;

/* === утилиты === */
function toDate(value: unknown): Date | null {
  if (value instanceof Date) return value;
  if (typeof value === "string" || typeof value === "number") {
    const d = new Date(value);
    return isNaN(d.getTime()) ? null : d;
  }
  return null;
}
const dateObj = toDate(fm.date);
const updatedObj = toDate(fm.updated) ?? null;
const showUpdated =
  updatedObj && dateObj && updatedObj.getTime() !== dateObj.getTime();

function formatDate(d: Date | null) {
  if (!d) return "";
  return d.toLocaleDateString("ru-RU", {
    year: "numeric",
    month: "long",
    day: "numeric",
  });
}

function resolveSrc(input: unknown): string | null {
  if (!input) return null;
  const s = String(input).trim();
  if (!s) return null;
  if (/^https?:\/\//i.test(s)) return s;
  if (s.startsWith("/")) return s;
  return "/" + s.replace(/^\.?\//, "");
}

/* === HERO === */
const articleImage = resolveSrc((fm as any).image) || null;
const imageAlt = fm.imageAlt ?? fm.title;

/* === TOC === */
const tocFromFM =
  Array.isArray(fm.tocManual) && fm.tocManual.length
    ? fm.tocManual.map((item: any) => ({
        ...item,
        id: slugify(item.id || item.text),
      }))
    : null;
const tocFromMD = headings
  .filter((h) => h.depth === 2)
  .map((h) => {
    // Всегда слагифицируем текст заголовка для транслитерации кириллицы
    // Это гарантирует, что id будет на транслите
    const id = slugify(h.text);
    return {
      id,
      text: h.text,
      depth: h.depth,
    };
  });
const tocItems = tocFromFM || tocFromMD;

// Строим вложенную структуру для TOC
function buildNestedToc(items: any[]) {
  const result: any[] = [];
  let currentH2: any = null;

  items.forEach((item: any) => {
    if (item.depth === 2) {
      currentH2 = { ...item, children: [] };
      result.push(currentH2);
    } else if (item.depth === 3 && currentH2) {
      currentH2.children.push(item);
    }
  });

  return result;
}

const nestedTocItems = buildNestedToc(tocItems || []);

/* === «Ещё по теме»: та же категория === */
const allArticlesRaw = await getCollection("articles", ({ data }) => {
  return data.visible !== false;
});

const allArticles = allArticlesRaw;

function getTimeSafe(p: CollectionEntry<"articles">): number {
  const v = (p.data as any)?.date;
  const d = v instanceof Date ? v : new Date(v);
  return isNaN(d.getTime()) ? 0 : d.getTime();
}
const currentCategory = String(fm.category ?? "").toLowerCase();
const sameCategoryTop = allArticles
  .filter(
    (p) =>
      p.slug !== slug &&
      String(p.data?.category ?? "").toLowerCase() === currentCategory,
  )
  .sort((a, b) => getTimeSafe(b) - getTimeSafe(a))
  .slice(0, 4);

const articlesByDate = [...allArticles].sort(
  (a, b) => getTimeSafe(b) - getTimeSafe(a),
);
const currentArticleIndex = articlesByDate.findIndex((p) => p.slug === slug);
const nextArticle =
  currentArticleIndex > 0 ? articlesByDate[currentArticleIndex - 1] : null;
const prevArticle =
  currentArticleIndex >= 0 && currentArticleIndex < articlesByDate.length - 1
    ? articlesByDate[currentArticleIndex + 1]
    : null;

function getArticleHref(post: CollectionEntry<"articles">) {
  return `${base}/${slugify(String(post.data.category || ""))}/${post.slug}/`;
}
---

<!-- Прогресс чтения -->
<ProgressBar />

<section
  class="article__section container"
  role="region"
  aria-labelledby="article-title"
>
  <div class="article__wrapper">
    <article class="article">
      <header class="article__header">
        <div class="article__meta">
          {
            dateObj && (
              <div class="article__meta-date">
                <img
                  src="/images/technical/calendar.webp"
                  alt=""
                  width="14"
                  height="14"
                  aria-hidden="true"
                />
                <time datetime={dateObj.toISOString().slice(0, 10)}>
                  {showUpdated
                    ? `Опубликовано\u00a0${formatDate(dateObj)}`
                    : formatDate(dateObj)}
                </time>
              </div>
            )
          }
          {
            showUpdated && (
              <div class="article__meta-date article__meta-date--updated">
                <img
                  src="/images/technical/calendar.webp"
                  alt=""
                  width="14"
                  height="14"
                  aria-hidden="true"
                />
                <time datetime={updatedObj!.toISOString().slice(0, 10)}>
                  Обновлено&nbsp;{formatDate(updatedObj)}
                </time>
              </div>
            )
          }
          {
            fm.readingTime && (
              <time class="article__meta-time">
                <img
                  src="/images/technical/time.webp"
                  alt=""
                  width="14"
                  height="14"
                  aria-hidden="true"
                />
                <span>{fm.readingTime} мин</span>
              </time>
            )
          }
          <div class="article__meta-category">
            <CatBadge
              name={fm.category}
              href={`${base}/${categorySlug}/`}
              variant="soft"
              size="sm"
            />
          </div>
        </div>

        <h1 id="article-title" class="article__header-title">{fm.title}</h1>

        <div class="article__header-desc-author">
          {
            fm.description && (
              <p class="article__header-description">{fm.description}</p>
            )
          }
          <div class="article__author-card">
            <img
              src={ORGANIZATION_DATA.defaultAuthor.photo}
              alt={ORGANIZATION_DATA.defaultAuthor.name}
              class="article__author-photo"
              width="64"
              height="64"
            />
            <div class="article__author-info">
              <a
                href={ORGANIZATION_DATA.defaultAuthor.url}
                target="_blank"
                rel="noopener"
                class="article__author-name"
                >{ORGANIZATION_DATA.defaultAuthor.name}</a
              >
              <div class="article__author-role">
                {ORGANIZATION_DATA.defaultAuthor.role}
              </div>
              <div class="article__author-socials">
                <a
                  href="https://t.me/+KznfEhtzkeNlZjIy"
                  target="_blank"
                  rel="noopener"
                  aria-label="Telegram"
                  class="article__author-social-link"
                >
                  <img
                    src="/images/technical/telegram.webp"
                    alt=""
                    aria-hidden="true"
                    width="20"
                    height="20"
                  />
                </a>
                <a
                  href="https://vk.com/chemistry_exam"
                  target="_blank"
                  rel="noopener"
                  aria-label="ВКонтакте"
                  class="article__author-social-link"
                >
                  <img
                    src="/images/technical/vk.webp"
                    alt=""
                    aria-hidden="true"
                    width="20"
                    height="20"
                  />
                </a>
                <a
                  href="https://www.youtube.com/@chemistry_exam"
                  target="_blank"
                  rel="noopener"
                  aria-label="YouTube"
                  class="article__author-social-link"
                >
                  <img
                    src="/images/technical/youtube.webp"
                    alt=""
                    aria-hidden="true"
                    width="20"
                    height="20"
                  />
                </a>
              </div>
            </div>
          </div>
        </div>
        {
          fm.showHeroImage !== false && articleImage && (
            <div class="article__header-image-wrapper">
              <figure class="article__header-image">
                <div id="heroBox" class="hero">
                  <img
                    class="hero__img"
                    src={articleImage}
                    alt={imageAlt}
                    loading="eager"
                    fetchpriority="high"
                    width={320}
                    height={180}
                  />
                </div>
                <figcaption class="article__header-caption">
                  {(fm as any).imageCaption ?? fm.title}
                </figcaption>
              </figure>
            </div>
          )
        }
        {
          fm.toc !== false && nestedTocItems && nestedTocItems.length > 0 && (
            <nav class="article__inside-content" aria-label="Содержание статьи">
              <h3 id="article-toc-title" class="article__content-title">
                Содержание статьи
              </h3>
              <ul class="article__content-list">
                {nestedTocItems.map((item) => (
                  <li>
                    <a href={`${currentPath}#${item.id}`}>{item.text}</a>
                    {item.children && item.children.length > 0 && (
                      <ul class="article__content-sublist">
                        {item.children.map((child: any) => (
                          <li>
                            <a href={`${currentPath}#${child.id}`}>
                              {child.text}
                            </a>
                          </li>
                        ))}
                      </ul>
                    )}
                  </li>
                ))}
              </ul>
            </nav>
          )
        }
      </header>
      <div class="article__content">
        <slot />
      </div>
      <script is:inline>
        (function () {
          // Клиентская версия slugify (должна совпадать с серверной)
          const map = {
            а: "a",
            б: "b",
            в: "v",
            г: "g",
            д: "d",
            е: "e",
            ё: "e",
            ж: "zh",
            з: "z",
            и: "i",
            й: "y",
            к: "k",
            л: "l",
            м: "m",
            н: "n",
            о: "o",
            п: "p",
            р: "r",
            с: "s",
            т: "t",
            у: "u",
            ф: "f",
            х: "h",
            ц: "c",
            ч: "ch",
            ш: "sh",
            щ: "sch",
            ъ: "",
            ы: "y",
            ь: "",
            э: "e",
            ю: "yu",
            я: "ya",
          };

          function slugify(input) {
            if (!input) return "";
            return input
              .toLowerCase()
              .replace(/[а-яё]/g, (ch) => map[ch] ?? ch)
              .replace(/[^a-z0-9]+/g, "-")
              .replace(/^-+|-+$/g, "");
          }

          // Добавляем id к заголовкам
          const content = document.querySelector(".article__content");
          if (!content) return;
          const headings = content.querySelectorAll("h2, h3");
          headings.forEach((h) => {
            const text = h.textContent || "";
            h.id = slugify(text);
          });
        })();
      </script>

      {
        fm.tags && fm.tags.length > 0 && (
          <div class="article__tags-block">
            <div class="article__tags-block-title">Теги:</div>
            <div class="article__tags-block-tags">
              {fm.tags.map((tag) => (
                <a href={`${base}/tags/${slugify(String(tag))}/`}>#{tag}</a>
              ))}
            </div>
          </div>
        )
      }
      <div class="article__divider"></div>
      <div class="article__footer">
        <div
          class="article__footer-repost"
          role="group"
          aria-label="Поделиться статьёй"
        >
          <span class="article__footer-repost-title">Поделиться:</span>
          <div class="article__footer-repost-buttons">
            <a
              href={`https://t.me/share/url?url=${encodeURIComponent(articleUrl)}&text=${encodeURIComponent(fm.title)}`}
              target="_blank"
              rel="noopener"
              aria-label="Поделиться в Telegram"
            >
              <img
                src="/images/technical/telegram.webp"
                alt=""
                aria-hidden="true"
              />
            </a>
            <a
              href={`https://vk.com/share.php?url=${encodeURIComponent(articleUrl)}`}
              target="_blank"
              rel="noopener"
              aria-label="Поделиться ВКонтакте"
            >
              <img src="/images/technical/vk.webp" alt="" aria-hidden="true" />
            </a>
            <a
              href={`https://wa.me/?text=${encodeURIComponent(fm.title + " " + articleUrl)}`}
              target="_blank"
              rel="noopener"
              aria-label="Поделиться в WhatsApp"
            >
              <img
                src="/images/technical/whatsapp.webp"
                alt=""
                aria-hidden="true"
              />
            </a>
            <CopyLinkButton />
            <a
              href={`mailto:?subject=${encodeURIComponent(fm.title)}&body=${encodeURIComponent(articleUrl)}`}
              aria-label="Поделиться по email"
            >
              <img
                src="/images/technical/mail.webp"
                alt=""
                aria-hidden="true"
              />
            </a>
          </div>
        </div>
        {
          (prevArticle || nextArticle) && (
            <nav class="article__footer-nav" aria-label="Навигация по статьям">
              {prevArticle && (
                <a
                  href={getArticleHref(prevArticle)}
                  class="article__footer-nav-card"
                >
                  <span class="article__footer-nav-label">
                    ← Предыдущая статья
                  </span>
                  <span class="article__footer-nav-title">
                    {prevArticle.data.title}
                  </span>
                </a>
              )}
              {nextArticle && (
                <a
                  href={getArticleHref(nextArticle)}
                  class="article__footer-nav-card"
                >
                  <span class="article__footer-nav-label">
                    Следующая статья →
                  </span>
                  <span class="article__footer-nav-title">
                    {nextArticle.data.title}
                  </span>
                </a>
              )}
            </nav>
          )
        }
      </div>
    </article>
    <aside class="article__sidebar" aria-label="Дополнительно">
      <div class="article__sidebar-sticky-wrapper">
        <TgBanner />
      </div>
    </aside>
  </div>
</section>
{
  sameCategoryTop.length > 0 && (
    <section
      class="article__more-section section"
      role="region"
      aria-labelledby="article-more-title"
    >
      <div class="article__more container">
        <div class="article__more-header">
          <h2 id="article-more-title" class="article__more-title">
            Ещё по теме
          </h2>
          <p class="article__more-description">
            Продолжайте изучать тему с другими статьями из категории «
            {fm.category}»
          </p>
        </div>
        <div class="article__more-content">
          {sameCategoryTop.map((post) => (
            <div class="ad-media__card">
              <CardNew post={post} />
            </div>
          ))}
        </div>
      </div>
    </section>
  )
}

<style>
  /* ===== ARTICLE MAIN GRID ===== */
  .article__wrapper {
    display: grid;
    gap: var(--space-20);
    grid-template-columns: 1fr 0.3fr;
  }

  .article {
    width: 100%;
    min-width: 0;
    background-color: var(--white);
    padding: clamp(16px, 2vw, 24px);
    border-radius: var(--radius-24);
    box-shadow: var(--shadow-1);
    border: 1px solid var(--border);
  }

  /* ===== ARTICLE HEADER ===== */
  .article__meta {
    display: flex;
    gap: clamp(12px, 2vw, 20px);
    align-items: center;
    margin-bottom: var(--space-20);
    flex-wrap: wrap;
  }

  .article__meta-date,
  .article__meta-time,
  .article__meta-category,
  .article__meta-author {
    display: flex;
    gap: var(--space-8);
    align-items: center;
    color: var(--gray);
    font-size: clamp(13px, 1vw, 14px);
  }

  .article__meta-date--updated {
    color: var(--blue, #366ef0);
  }

  .article__header-title {
    font-size: clamp(28px, 5vw, 42px);
    line-height: 1.2;
    font-weight: 700;
    margin: 0 0 var(--space-20) 0;
    color: var(--black);
  }

  /* ===== DESC + AUTHOR 2-COLUMN ===== */
  .article__header-desc-author {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-24);
    align-items: start;
    margin: 0 0 var(--space-24) 0;
  }

  .article__header-description {
    font-size: clamp(15px, 1.2vw, 18px);
    line-height: 1.6;
    margin: 0;
    color: var(--gray);
  }

  /* ===== AUTHOR CARD ===== */
  .article__author-card {
    display: grid;
    grid-template-columns: auto 1fr;
    gap: var(--space-12);
    align-items: start;
  }

  .article__author-photo {
    width: 75px;
    height: 75px;
    border-radius: 50%;
    object-fit: cover;
    border: 1px solid var(--border);
  }

  .article__author-info {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    gap: var(--space-4, 4px);
  }

  .article__author-name {
    font-size: clamp(14px, 1.2vw, 20px);
    font-weight: 700;
    color: var(--black);
    line-height: 1.3;
    text-decoration: none;
  }

  .article__author-name:hover {
    color: var(--blue);
  }

  .article__author-role {
    font-size: clamp(13px, 1vw, 16px);
    color: var(--gray);
    line-height: 1.3;
  }

  .article__author-socials {
    display: flex;
    gap: var(--space-8);
    align-items: center;
    margin-top: var(--space-4, 4px);
  }

  .article__author-social-link {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 32px;
    height: 32px;
    border-radius: 50%;
    border: 1px solid var(--border);
    transition: border-color 0.2s var(--easing);
  }

  .article__author-social-link:hover {
    border-color: var(--black);
  }

  .article__author-social-link img {
    width: 16px;
    height: 16px;
    object-fit: contain;
  }

  .article__header-image {
    margin: 0 0 clamp(32px, 5vw, 50px) 0;
    padding: 0;
  }

  /* Article Hero Styles */
  .hero {
    min-height: 200px;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .hero__img {
    display: block;
    width: 100%;
    height: auto;
    object-fit: cover;
    aspect-ratio: 16/9;
    border-radius: var(--radius-24);
  }

  .article__header-caption {
    font-size: clamp(12px, 1vw, 14px);
    font-weight: 400;
    color: var(--gray);
    text-align: center;
    margin-top: var(--space-12);
    font-style: italic;
    font-variant-numeric: lining-nums tabular-nums;
  }

  /* ===== TABLE OF CONTENTS (обтекание) ===== */
  .article__inside-content {
    float: left;
    max-width: 50%;
    min-width: 0; /* важно для корректного сжатия */
    margin: 0 var(--space-24) var(--space-20) 0;
    background-color: #e3fdff;
    padding: var(--space-20);
    border-radius: var(--radius-24);
  }

  .article__content-title {
    font-size: clamp(18px, 2vw, 24px);
    font-weight: 700;
    margin: 0 0 var(--space-16) 0;
    color: var(--black);
  }

  .article__content-list {
    list-style: none;
    padding: 0;
    margin: 0;
    color: #505050;
    font-size: clamp(14px, 1vw, 16px);
    font-weight: 500;
  }

  .article__content-list li {
    margin-bottom: var(--space-16);
  }

  .article__content-list a {
    color: inherit;
    text-decoration: none;
    display: block;
    word-wrap: break-word;
    overflow-wrap: break-word;
    transition: color 0.2s var(--easing);
  }

  .article__content-list a:hover {
    color: var(--blue);
  }

  /* Вложенный список для h3 */
  .article__content-sublist {
    list-style: none;
    padding: 0;
    margin: var(--space-8) 0 0 var(--space-20);
  }

  .article__content-sublist li {
    margin-bottom: var(--space-8);
  }

  /* Очистка float после контента */
  .article__content::after {
    content: "";
    display: table;
    clear: both;
  }

  /* ===== TAGS BLOCK ===== */
  .article__tags-block {
    margin: var(--space-32) 0;
  }

  .article__tags-block-title {
    font-size: clamp(16px, 1.5vw, 20px);
    font-weight: 700;
    margin-bottom: var(--space-12);
    color: var(--black);
  }

  .article__tags-block-tags {
    display: flex;
    gap: var(--space-8);
    flex-wrap: wrap;
  }

  .article__tags-block-tags a {
    display: inline-block;
    padding: var(--space-8) var(--space-16);
    background-color: #f0f0f0;
    color: var(--black);
    text-decoration: none;
    border-radius: 8px;
    font-size: clamp(13px, 1vw, 14px);
    transition: all 0.2s var(--easing);
  }

  .article__tags-block-tags a:hover {
    background-color: var(--blue);
    color: var(--white);
  }

  /* ===== SIDEBAR ===== */
  .article__sidebar-sticky-wrapper {
    position: sticky;
    top: var(--space-20);
    display: flex;
    flex-direction: column;
    gap: var(--space-20);
  }

  /* ===== FOOTER REPOST ===== */
  .article__divider {
    width: 100%;
    height: 1px;
    background-color: var(--border);
    margin: clamp(20px, 3vw, 32px) 0;
  }

  .article__footer-repost {
    display: flex;
    gap: var(--space-16);
    align-items: center;
    flex-wrap: wrap;
  }

  .article__footer-repost-title {
    font-size: clamp(18px, 2vw, 24px);
    font-weight: 700;
    color: var(--black);
  }

  .article__footer-repost-buttons {
    display: flex;
    gap: var(--space-12);
    align-items: center;
    flex-wrap: wrap;
  }

  .article__footer-repost-buttons img {
    border: 1px solid var(--border);
    border-radius: 10px;
    padding: var(--space-8);
    width: 40px;
