---
interface Props {
  tone?: "blue" | "green" | "yellow" | "rose" | "gray";
  padding?: "sm" | "md" | "lg";
  border?: boolean;
  fullBleed?: boolean;
}

const {
  tone = "blue",
  padding = "md",
  border = true,
  fullBleed = false,
} = Astro.props;

const toneMeta = {
  blue: { label: "INFO", mark: "i", color: "#1a3556" },
  green: { label: "ВЫВОД", mark: "✓", color: "#2f7d5b" },
  yellow: { label: "ВАЖНО", mark: "!", color: "#c9882b" },
  rose: { label: "СТОП", mark: "×", color: "#b23a14" },
  gray: { label: "ЗАМЕТКА", mark: "_", color: "#5f5548" },
};

const meta = toneMeta[tone];
---

<div
  class="accent-block"
  style={`--accent-color: ${meta.color};`}
  data-tone={tone}
  data-padding={padding}
  data-border={border ? "on" : "off"}
  data-full-bleed={fullBleed ? "on" : "off"}
>
  <div class="accent-block__head">
    <span class="accent-block__mark">{meta.mark}</span>
    <span>// {meta.label}</span>
  </div>
  <div class="accent-block__body">
    <slot />
  </div>
</div>

<style>
  .accent-block {
    margin: clamp(16px, 2.5vw, 28px) 0;
    border-radius: 0;
    background: #efe9da;
    color: #1a1410;
    font-family: "Source Serif 4", Georgia, serif;
    overflow: hidden;
  }

  .accent-block[data-border="on"] {
    border: 1px solid var(--accent-color);
  }

  .accent-block[data-border="off"] {
    border: 1px solid #c9bfac;
  }

  .accent-block[data-full-bleed="on"] {
    width: calc(100% + clamp(16px, 4vw, 36px));
    margin-left: calc(clamp(16px, 4vw, 36px) * -0.5);
    margin-right: calc(clamp(16px, 4vw, 36px) * -0.5);
  }

  .accent-block__head {
    display: flex;
    align-items: center;
    gap: 10px;
    min-height: 38px;
    /* Вертикальный паддинг: на узких экранах лейбл "// ВАЖНО" вплотную
       к верхнему/нижнему краю плашки, выглядит сжато. min-height сам
       по себе не даёт air, нужен явный padding-block. */
    padding: 8px 14px;
    border-bottom: 1px solid #1a1410;
    background: var(--accent-color);
    color: #efe9da;
    font-family: "JetBrains Mono", ui-monospace, monospace;
    font-size: 11px;
    font-weight: 700;
    letter-spacing: 0.12em;
    text-transform: uppercase;
  }

  .accent-block__mark {
    display: grid;
    place-items: center;
    width: 22px;
    height: 22px;
    border: 1px solid currentColor;
    line-height: 1;
  }

  .accent-block__body {
    position: relative;
  }

  .accent-block[data-padding="sm"] .accent-block__body {
    padding: clamp(10px, 1.5vw, 14px) clamp(12px, 1.8vw, 18px);
  }

  .accent-block[data-padding="md"] .accent-block__body {
    padding: clamp(14px, 2vw, 20px) clamp(16px, 2.3vw, 24px);
  }

  .accent-block[data-padding="lg"] .accent-block__body {
    padding: clamp(18px, 2.5vw, 28px) clamp(18px, 2.8vw, 32px);
  }

  .accent-block__body :global(> :first-child) {
    margin-top: 0;
  }

  .accent-block__body :global(> :last-child) {
    margin-bottom: 0;
  }

  @media (max-width: 768px) {
    .accent-block[data-full-bleed="on"] {
      width: calc(100% + 16px);
      margin-left: -8px;
      margin-right: -8px;
    }
  }
</style>
