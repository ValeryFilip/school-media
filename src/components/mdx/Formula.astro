---
interface Props {
  compact?: boolean;
}

const { compact = false } = Astro.props;
---

<div class="formula" data-compact={compact ? "true" : "false"}>
  <div class="formula__label" aria-hidden="true">// формула</div>
  <div class="formula__body">
    <slot />
  </div>
</div>

<style>
  .formula {
    position: relative;
    display: block;
    max-width: 100%;
    overflow-x: auto;
    margin: clamp(8px, 1.4vw, 12px) 0;
    border: 1px solid #c9bfac;
    border-radius: 0;
    background: #f7f2e4;
    color: #1a1410;
    font-family: "Times New Roman", "Cambria Math", "STIX Two Math", serif;
    font-size: clamp(16px, 1.45vw, 18px);
    line-height: 1.45;
    text-align: center;
    white-space: nowrap;
    overflow-wrap: normal;
    word-break: normal;
  }

  .formula::before,
  .formula::after {
    content: "";
    position: absolute;
    width: 12px;
    height: 12px;
    border-color: #b23a14;
    pointer-events: none;
  }

  .formula::before {
    left: 6px;
    top: 6px;
    border-left: 1px solid;
    border-top: 1px solid;
  }

  .formula::after {
    right: 6px;
    bottom: 6px;
    border-right: 1px solid;
    border-bottom: 1px solid;
  }

  .formula__label {
    position: sticky;
    left: 0;
    display: block;
    padding: 8px 12px;
    border-bottom: 1px solid #c9bfac;
    background: #efe9da;
    color: #b23a14;
    font-family: "JetBrains Mono", ui-monospace, monospace;
    font-size: 10px;
    font-weight: 700;
    letter-spacing: 0.12em;
    line-height: 1;
    text-align: left;
    text-transform: uppercase;
  }

  .formula__body {
    padding: clamp(10px, 1.5vw, 14px) clamp(14px, 2vw, 20px);
  }

  .formula[data-compact="true"] {
    margin: clamp(8px, 1.4vw, 12px) 0;
    font-size: clamp(16px, 1.45vw, 18px);
  }

  .formula[data-compact="true"] .formula__label {
    padding-block: 6px;
  }

  .formula[data-compact="true"] .formula__body {
    padding: clamp(8px, 1.3vw, 12px) clamp(12px, 1.7vw, 16px);
  }

  .formula :global(.formula-line) {
    display: inline-block;
    min-width: max-content;
    font-size: 1em;
    white-space: nowrap;
    overflow-wrap: normal;
    word-break: normal;
  }

  .formula :global(p) {
    display: inline-block;
    min-width: max-content;
    margin: 0;
    white-space: nowrap;
    overflow-wrap: normal;
    word-break: normal;
  }

  .formula :global(.formula-line + .formula-line) {
    margin-top: 0.55em;
  }

  .formula :global(.frac) {
    display: inline-flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    vertical-align: middle;
    line-height: 1.15;
    margin: 0 0.2em;
  }

  .formula :global(.frac > span:first-child) {
    display: block;
    padding: 0 0.25em 0.12em;
    border-bottom: 1.5px solid currentColor;
  }

  .formula :global(.frac > span:last-child) {
    display: block;
    padding: 0.12em 0.25em 0;
  }

  .formula :global(sub) {
    font-size: 0.68em;
    line-height: 0;
    vertical-align: sub;
  }
</style>
