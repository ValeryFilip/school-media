---
interface Props {
  compact?: boolean;
}

const { compact = false } = Astro.props;
---

<div class="formula" data-compact={compact ? "true" : "false"}>
  <slot />
</div>

<style>
  .formula {
    display: block;
    max-width: 100%;
    overflow-x: auto;
    margin: clamp(8px, 1.4vw, 12px) 0;
    padding: clamp(8px, 1.3vw, 12px) clamp(12px, 1.7vw, 16px);
    border: 1px solid rgba(54, 110, 240, 0.18);
    border-radius: 8px;
    background: #f8fbff;
    color: var(--black, #111);
    font-family: "Times New Roman", "Cambria Math", "STIX Two Math", serif;
    font-size: clamp(16px, 1.45vw, 18px);
    line-height: 1.45;
    text-align: center;
    white-space: nowrap;
    overflow-wrap: normal;
    word-break: normal;
  }

  .formula[data-compact="true"] {
    margin: clamp(8px, 1.4vw, 12px) 0;
    padding: clamp(8px, 1.3vw, 12px) clamp(12px, 1.7vw, 16px);
    font-size: clamp(16px, 1.45vw, 18px);
  }

  .formula :global(.formula-line) {
    display: inline-block;
    min-width: max-content;
    font-size: 1em;
    white-space: nowrap;
    overflow-wrap: normal;
    word-break: normal;
  }

  .formula :global(p) {
    display: inline-block;
    min-width: max-content;
    margin: 0;
    white-space: nowrap;
    overflow-wrap: normal;
    word-break: normal;
  }
  .formula :global(.formula-line + .formula-line) {
    margin-top: 0.55em;
  }

  .formula :global(.frac) {
    display: inline-flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    vertical-align: middle;
    line-height: 1.15;
    margin: 0 0.2em;
  }

  .formula :global(.frac > span:first-child) {
    display: block;
    padding: 0 0.25em 0.12em;
    border-bottom: 1.5px solid currentColor;
  }

  .formula :global(.frac > span:last-child) {
    display: block;
    padding: 0.12em 0.25em 0;
  }

  .formula :global(sub) {
    font-size: 0.68em;
    line-height: 0;
    vertical-align: sub;
  }
</style>
