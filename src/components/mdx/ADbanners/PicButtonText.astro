---
interface Props {
  title?: string;
  subtitle?: string;
  buttonText?: string;
  imageSrc?: string;
  imageAlt?: string;
  utmSource?: string;
  utmCampaign?: string;
  utmContent?: string;
}

const {
  title = "Готовим к ЕГЭ на сотку и выше",
  subtitle,
  buttonText = "Записаться на бесплатный курс",
  imageSrc,
  imageAlt,
  utmSource = "banner-article",
  utmCampaign = "banner-article",
  utmContent = "btn-A",
} = Astro.props;
---

<div class="article-ad" data-utm-content={utmContent}>
  <div class={`article-ad__grid ${!imageSrc ? "article-ad__grid--no-image" : ""}`} tabindex="0">
    <div class="article-ad__head">
      <span>[ реклама ]</span>
      <span>// free start</span>
    </div>

    <div class="article-ad__content">
      <div class="article-ad__tick" aria-hidden="true">↳</div>
      <div class="article-ad__title">{title}</div>
      {subtitle && <div class="article-ad__subtitle">{subtitle}</div>}
      <button
        id="cta-adfree-A"
        type="button"
        class="article-ad__button popup-btn"
        data-popup-id="lead-popup"
        data-source={utmSource}
        data-variant="A"
        data-campaign={utmCampaign}
      >
        <span>{buttonText}</span>
        <span aria-hidden="true">→</span>
      </button>
    </div>

    {
      imageSrc && (
        <div class="article-ad__media">
          <img class="article-ad__img" src={imageSrc} alt={imageAlt ?? ""} loading="lazy" decoding="async" />
        </div>
      )
    }
  </div>
</div>

<style>
  .article-ad {
    margin: clamp(20px, 3vw, 32px) 0;
  }

  .article-ad__grid {
    display: grid;
    grid-template-columns: minmax(0, 1.25fr) minmax(220px, 0.75fr);
    border: 1px solid #1a1410;
    background: #1a1410;
    color: #efe9da;
    cursor: pointer;
    outline: none;
  }

  .article-ad__grid--no-image {
    grid-template-columns: 1fr;
  }

  .article-ad__grid:hover,
  .article-ad__grid:focus-visible {
    background: #b23a14;
  }

  .article-ad__head {
    grid-column: 1 / -1;
    display: flex;
    justify-content: space-between;
    gap: 16px;
    min-height: 38px;
    padding: 0 14px;
    align-items: center;
    border-bottom: 1px solid #efe9da;
    font-family: "JetBrains Mono", ui-monospace, monospace;
    font-size: 11px;
    font-weight: 700;
    letter-spacing: 0.12em;
    text-transform: uppercase;
  }

  .article-ad__content {
    position: relative;
    display: grid;
    align-content: center;
    gap: 16px;
    min-height: 260px;
    padding: clamp(22px, 3vw, 34px);
  }

  .article-ad__tick {
    position: absolute;
    right: 18px;
    top: 16px;
    color: #c9882b;
    font-family: "JetBrains Mono", ui-monospace, monospace;
    font-size: 28px;
  }

  .article-ad__title {
    max-width: 14ch;
    font-family: "Space Grotesk", system-ui, sans-serif;
    font-size: clamp(28px, 5vw, 56px);
    font-weight: 700;
    line-height: 0.96;
    letter-spacing: -0.02em;
  }

  .article-ad__subtitle {
    max-width: 46ch;
    color: rgba(239, 233, 218, 0.78);
    font-size: clamp(14px, 1.5vw, 17px);
    line-height: 1.45;
  }

  .article-ad__button {
    display: inline-flex;
    align-items: center;
    justify-content: space-between;
    gap: 16px;
    width: fit-content;
    max-width: 100%;
    border: 1px solid #efe9da;
    border-radius: 0;
    padding: 13px 16px;
    background: #efe9da;
    color: #1a1410;
    font-family: "JetBrains Mono", ui-monospace, monospace;
    font-size: 12px;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    cursor: pointer;
    transition: background 0.16s ease, color 0.16s ease;
  }

  .article-ad__button:hover {
    background: transparent;
    color: #efe9da;
  }

  .article-ad__media {
    min-height: 260px;
    border-left: 1px solid #efe9da;
    background:
      linear-gradient(135deg, rgba(239, 233, 218, 0.18) 25%, transparent 25%) 0 0 / 12px 12px,
      #2e2620;
  }

  .article-ad__img {
    display: block;
    width: 100%;
    height: 100%;
    min-height: 260px;
    margin: 0;
    object-fit: cover;
    filter: grayscale(0.15) contrast(1.05);
  }

  @media (max-width: 720px) {
    .article-ad__grid {
      grid-template-columns: 1fr;
    }

    .article-ad__media {
      border-left: 0;
      border-top: 1px solid #efe9da;
      order: -1;
    }

    .article-ad__head {
      order: -2;
    }

    .article-ad__content {
      min-height: auto;
    }

    .article-ad__title {
      max-width: none;
      font-size: clamp(26px, 9vw, 42px);
    }

    .article-ad__button {
      width: 100%;
    }
  }
</style>

<script is:inline>
  (function () {
    function initArticleAds() {
      document.querySelectorAll(".article-ad__grid").forEach((bannerWrapper) => {
        if (bannerWrapper.dataset.articleAdReady === "true") return;
        bannerWrapper.dataset.articleAdReady = "true";

        bannerWrapper.addEventListener("click", function (e) {
          if (e.target.closest("button")) return;
          const button = this.querySelector("button.popup-btn");
          if (button) button.click();
        });

        bannerWrapper.addEventListener("keydown", function (e) {
          if (e.key === "Enter" || e.key === " ") {
            e.preventDefault();
            const button = this.querySelector("button.popup-btn");
            if (button) button.click();
          }
        });
      });
    }

    initArticleAds();
    document.addEventListener("astro:page-load", initArticleAds);
  })();
</script>
