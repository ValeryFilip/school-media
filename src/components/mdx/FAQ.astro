---
interface Props {
  question: string;
  open?: boolean;
}

const { question, open = false } = Astro.props;
---

<details class="faq-item" open={open}>
  <summary class="faq-question">
    <span class="faq-index" aria-hidden="true">Q:</span>
    <span class="faq-text">{question}</span>
    <span class="faq-toggle" aria-hidden="true">[ + ]</span>
  </summary>
  <div class="faq-answer">
    <span class="faq-answer__label" aria-hidden="true">A:</span>
    <slot />
  </div>
</details>

<style>
  .faq-item {
    margin: clamp(1rem, 2vw, 1.5rem) 0;
    border: 1px solid #c9bfac;
    border-radius: 0;
    background: #efe9da;
    overflow: hidden;
  }

  .faq-item:hover {
    border-color: #1a1410;
  }

  .faq-question {
    display: flex;
    align-items: center;
    gap: clamp(8px, 1.2vw, 12px);
    min-height: 48px;
    padding: 0 clamp(14px, 2vw, 18px);
    cursor: pointer;
    user-select: none;
    list-style: none;
    font-family: "JetBrains Mono", ui-monospace, monospace;
    font-weight: 700;
    font-size: clamp(12px, 1.35vw, 14px);
    color: #1a1410;
    background: #f7f2e4;
    text-transform: uppercase;
    letter-spacing: 0.04em;
    transition: background 0.16s ease, color 0.16s ease;
  }

  .faq-question:hover {
    background: #1a1410;
    color: #efe9da;
  }

  .faq-question::-webkit-details-marker {
    display: none;
  }

  .faq-index {
    display: grid;
    place-items: center;
    width: 34px;
    height: 28px;
    border: 1px solid currentColor;
    flex-shrink: 0;
  }

  .faq-text {
    flex: 1;
    min-width: 0;
  }

  .faq-toggle {
    flex-shrink: 0;
    color: #b23a14;
  }

  .faq-question:hover .faq-toggle {
    color: currentColor;
  }

  .faq-item[open] .faq-toggle {
    font-size: 0;
  }

  .faq-item[open] .faq-toggle::before {
    content: "[ - ]";
    font-size: clamp(12px, 1.35vw, 14px);
  }

  .faq-answer {
    position: relative;
    padding: clamp(16px, 2vw, 20px);
    padding-left: clamp(52px, 6vw, 68px);
    color: #2e2620;
    line-height: 1.7;
    font-size: clamp(14px, 1.5vw, 15px);
    border-top: 1px solid #c9bfac;
  }

  .faq-answer__label {
    position: absolute;
    left: 16px;
    top: 18px;
    display: grid;
    place-items: center;
    width: 34px;
    height: 28px;
    border: 1px solid #c9bfac;
    color: #b23a14;
    font-family: "JetBrains Mono", ui-monospace, monospace;
    font-size: 12px;
    font-weight: 700;
  }

  .faq-answer :global(p:first-child) {
    margin-top: 0;
  }

  .faq-answer :global(p:last-child) {
    margin-bottom: 0;
  }

  @media (max-width: 600px) {
    .faq-question {
      padding: 0 12px;
      gap: 8px;
      font-size: 12px;
    }

    .faq-answer {
      padding: 16px;
      padding-left: 52px;
      font-size: 14px;
    }
  }
</style>
