---
/**
 * Кнопка скачивания файла для статей в MDX.
 *
 * Использование:
 * <DownloadButton href="/files/guide.pdf" />
 * <DownloadButton href="/files/checklist.pdf" label="Скачать чек-лист" helper="PDF, 2.4 МБ" />
 */
interface Props {
  href: string;
  label?: string;
  helper?: string;
  filename?: string;
  variant?: "brand" | "accent";
}

const {
  href,
  label = "Скачать файл",
  helper = "Файл откроется в браузере, если скачивание запрещено настройками устройства.",
  filename,
  variant = "brand",
} = Astro.props;

if (!href || typeof href !== "string") {
  throw new Error("DownloadButton requires a non-empty `href` prop.");
}
---

<a
  class={`download-button download-button--${variant}`}
  href={href}
  download={filename}
  target="_blank"
  rel="noopener"
>
  <span class="download-button__icon" aria-hidden="true">
    <svg viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
      <path
        d="M12 4V14M12 14L8 10M12 14L16 10M5 18H19"
        stroke="currentColor"
        stroke-width="1.9"
        stroke-linecap="round"
        stroke-linejoin="round"
      />
    </svg>
  </span>

  <span class="download-button__content">
    <span class="download-button__label">{label}</span>
    {helper && <span class="download-button__helper">{helper}</span>}
  </span>

  <span class="download-button__status" aria-hidden="true">
    <span class="download-button__arrow">↓</span>
    <span class="download-button__check">✓</span>
  </span>
</a>

<script>
  function initDownloadButtons() {
    const buttons = document.querySelectorAll(".download-button");

    buttons.forEach((button) => {
      if (button.dataset.downloadButtonReady === "true") return;
      button.dataset.downloadButtonReady = "true";

      let resetTimer;

      button.addEventListener("click", () => {
        button.classList.add("is-clicked");
        window.clearTimeout(resetTimer);
        resetTimer = window.setTimeout(() => {
          button.classList.remove("is-clicked");
        }, 1800);
      });
    });
  }

  initDownloadButtons();
  document.addEventListener("astro:page-load", initDownloadButtons);
</script>

<style>
  .download-button {
    --button-bg: linear-gradient(
      135deg,
      color-mix(in oklab, var(--tone) 14%, white) 0%,
      color-mix(in oklab, var(--tone) 6%, white) 100%
    );
    --button-border: color-mix(in srgb, var(--tone) 20%, white);
    --button-shadow: 0 18px 34px color-mix(in srgb, var(--tone) 16%, transparent);
    --button-icon-bg: color-mix(in srgb, var(--tone) 12%, white);

    position: relative;
    display: grid;
    grid-template-columns: auto 1fr auto;
    align-items: center;
    gap: clamp(12px, 2vw, 18px);
    width: 100%;
    margin: clamp(1rem, 2vw, 1.5rem) 0;
    padding: clamp(16px, 2.4vw, 22px);
    border: 1px solid var(--button-border);
    border-radius: clamp(16px, 2vw, 22px);
    background: var(--button-bg);
    box-shadow: var(--button-shadow);
    color: var(--black, #111827);
    text-decoration: none;
    overflow: hidden;
    transition:
      transform 0.22s ease,
      box-shadow 0.22s ease,
      border-color 0.22s ease;
  }

  .download-button::before {
    content: "";
    position: absolute;
    inset: 0;
    background:
      radial-gradient(circle at top right, color-mix(in srgb, var(--tone) 18%, transparent), transparent 42%),
      linear-gradient(120deg, rgba(255, 255, 255, 0.5), transparent 35%);
    pointer-events: none;
  }

  .download-button:hover {
    transform: translateY(-2px);
    box-shadow: 0 22px 38px color-mix(in srgb, var(--tone) 22%, transparent);
    border-color: color-mix(in srgb, var(--tone) 34%, white);
    text-decoration: none;
  }

  .download-button:focus-visible {
    box-shadow:
      0 0 0 4px color-mix(in srgb, var(--tone) 20%, transparent),
      0 22px 38px color-mix(in srgb, var(--tone) 22%, transparent);
  }

  .download-button--brand {
    --tone: var(--blue, #366ef0);
  }

  .download-button--accent {
    --tone: #f09936;
  }

  .download-button__icon,
  .download-button__content,
  .download-button__status {
    position: relative;
    z-index: 1;
  }

  .download-button__icon {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: clamp(46px, 5vw, 56px);
    height: clamp(46px, 5vw, 56px);
    border-radius: 16px;
    background: var(--button-icon-bg);
    color: var(--tone);
    box-shadow: inset 0 1px 0 rgba(255, 255, 255, 0.7);
  }

  .download-button__icon svg {
    width: 24px;
    height: 24px;
  }

  .download-button__content {
    display: grid;
    gap: 4px;
    min-width: 0;
  }

  .download-button__label {
    font-size: clamp(16px, 1.8vw, 18px);
    font-weight: 800;
    line-height: 1.25;
  }

  .download-button__helper {
    font-size: clamp(12px, 1.3vw, 14px);
    line-height: 1.5;
    color: color-mix(in srgb, var(--black, #111827) 70%, white);
  }

  .download-button__status {
    position: relative;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 36px;
    height: 36px;
    flex-shrink: 0;
  }

  .download-button__arrow,
  .download-button__check {
    position: absolute;
    inset: 0;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    border-radius: 999px;
    background: rgba(255, 255, 255, 0.7);
    font-size: 20px;
    font-weight: 700;
    transition:
      transform 0.22s ease,
      opacity 0.22s ease,
      background-color 0.22s ease,
      color 0.22s ease;
  }

  .download-button__arrow {
    color: var(--tone);
    opacity: 0.88;
    transform: translate3d(0, 0, 0) scale(1);
  }

  .download-button__check {
    color: #16a34a;
    background: rgba(240, 253, 244, 0.96);
    opacity: 0;
    transform: translate3d(0, 4px, 0) scale(0.82);
  }

  .download-button:hover .download-button__arrow {
    transform: translate3d(4px, 2px, 0);
    opacity: 1;
    background: rgba(255, 255, 255, 0.92);
  }

  .download-button.is-clicked .download-button__arrow {
    opacity: 0;
    transform: translate3d(0, -6px, 0) scale(0.82);
  }

  .download-button.is-clicked .download-button__check {
    opacity: 1;
    transform: translate3d(0, 0, 0) scale(1);
  }

  @media (max-width: 600px) {
    .download-button {
      grid-template-columns: auto 1fr;
    }

    .download-button__status {
      display: none;
    }
  }
</style>
