---
interface Props {
  href: string;
  label?: string;
  helper?: string;
  filename?: string;
  variant?: "brand" | "accent";
}

const {
  href,
  label = "Скачать файл",
  helper = "Файл откроется в браузере, если скачивание запрещено настройками устройства.",
  filename,
  variant = "brand",
} = Astro.props;

if (!href || typeof href !== "string") {
  throw new Error("DownloadButton requires a non-empty `href` prop.");
}

const ext = (filename || href.split("?")[0].split("#")[0].split(".").pop() || "file")
  .toUpperCase()
  .slice(0, 4);
---

<a
  class={`download-button download-button--${variant}`}
  href={href}
  download={filename}
  target="_blank"
  rel="noopener"
>
  <span class="download-button__file" aria-hidden="true">[ {ext} ]</span>

  <span class="download-button__content">
    <span class="download-button__label">{label}</span>
    {helper && <span class="download-button__helper">{helper}</span>}
  </span>

  <span class="download-button__status" aria-hidden="true">
    <span class="download-button__arrow">↓</span>
    <span class="download-button__check">✓</span>
  </span>
</a>

<script>
  function initDownloadButtons() {
    const buttons = document.querySelectorAll(".download-button");

    buttons.forEach((button) => {
      if (button.dataset.downloadButtonReady === "true") return;
      button.dataset.downloadButtonReady = "true";

      let resetTimer;

      button.addEventListener("click", () => {
        button.classList.add("is-clicked");
        window.clearTimeout(resetTimer);
        resetTimer = window.setTimeout(() => {
          button.classList.remove("is-clicked");
        }, 1800);
      });
    });
  }

  initDownloadButtons();
  document.addEventListener("astro:page-load", initDownloadButtons);
</script>

<style>
  .download-button {
    --tone: #b23a14;
    position: relative;
    display: grid;
    grid-template-columns: auto 1fr auto;
    align-items: stretch;
    gap: 0;
    width: 100%;
    margin: clamp(1rem, 2vw, 1.5rem) 0;
    border: 1px solid #1a1410;
    border-radius: 0;
    background: #efe9da;
    color: #1a1410;
    text-decoration: none;
    overflow: hidden;
    transition: background 0.16s ease, color 0.16s ease;
  }

  .download-button--accent {
    --tone: #c9882b;
  }

  .download-button:hover {
    background: #1a1410;
    color: #efe9da;
    text-decoration: none;
  }

  .download-button:focus-visible {
    outline: 2px solid var(--tone);
    outline-offset: 2px;
  }

  .download-button__file,
  .download-button__status {
    display: grid;
    place-items: center;
    min-width: 78px;
    border-right: 1px solid #1a1410;
    background: var(--tone);
    color: #efe9da;
    font-family: "JetBrains Mono", ui-monospace, monospace;
    font-size: 12px;
    font-weight: 700;
    letter-spacing: 0.08em;
  }

  .download-button__status {
    min-width: 54px;
    border-right: 0;
    border-left: 1px solid #1a1410;
    background: transparent;
    color: var(--tone);
  }

  .download-button:hover .download-button__status {
    color: #efe9da;
  }

  .download-button__content {
    display: grid;
    gap: 4px;
    min-width: 0;
    padding: 14px 16px;
  }

  .download-button__label {
    font-family: "Space Grotesk", system-ui, sans-serif;
    font-size: clamp(16px, 1.8vw, 18px);
    font-weight: 700;
    line-height: 1.25;
  }

  .download-button__helper {
    font-family: "JetBrains Mono", ui-monospace, monospace;
    font-size: clamp(11px, 1.3vw, 13px);
    line-height: 1.5;
    color: #8a7f70;
  }

  .download-button:hover .download-button__helper {
    color: rgba(239, 233, 218, 0.72);
  }

  .download-button__status {
    position: relative;
  }

  .download-button__arrow,
  .download-button__check {
    position: absolute;
    inset: 0;
    display: grid;
    place-items: center;
    font-size: 22px;
    font-weight: 700;
    transition: opacity 0.18s ease, transform 0.18s ease;
  }

  .download-button__check {
    opacity: 0;
    transform: translateY(4px);
  }

  .download-button.is-clicked .download-button__arrow {
    opacity: 0;
    transform: translateY(-4px);
  }

  .download-button.is-clicked .download-button__check {
    opacity: 1;
    transform: translateY(0);
  }

  @media (max-width: 600px) {
    .download-button {
      grid-template-columns: 1fr auto;
    }

    .download-button__file {
      grid-column: 1 / -1;
      min-height: 34px;
      border-right: 0;
      border-bottom: 1px solid #1a1410;
    }
  }
</style>
