---
export interface CourseData {
  title: string;
  image: string;
  pins?: string[];
  description?: string;
  features: string[];
  price: string;
  oldPrice?: string;
  discount?: string;
  link: string;
  buttonText?: string;
}

interface Props {
  title: string;
  description?: string;
  courses: CourseData[];
}

const { title, description, courses } = Astro.props as Props;
---

<section class="course-promo" data-course-promo>
  <header class="course-promo__header">
    <div class="course-promo__meta">
      <span>[ courses ]</span>
      <span>/ подборка</span>
    </div>

    <div class="course-promo__title-row">
      <h3>{title}</h3>

      {courses.length > 1 && (
        <div class="course-promo__controls" aria-label="Навигация по курсам">
          <button type="button" class="course-promo__control" data-course-prev aria-label="Предыдущие курсы">←</button>
          <button type="button" class="course-promo__control" data-course-next aria-label="Следующие курсы">→</button>
        </div>
      )}
    </div>

    {description && <p>{description}</p>}
  </header>

  <div class="course-promo__viewport">
    <div class="course-promo__track" data-course-track>
      {courses.map((course, index) => (
        <article class="course-card">
          <a class="course-card__media" href={course.link} aria-label={course.title}>
            <img class="course-card__image" src={course.image} alt="" loading="lazy" decoding="async" />
            <span class="course-card__index">{String(index + 1).padStart(2, "0")}</span>

            {course.pins && course.pins.length > 0 && (
              <span class="course-card__pins">
                {course.pins.map((pin) => <span>{pin}</span>)}
              </span>
            )}
          </a>

          <div class="course-card__body">
            <div class="course-card__meta">
              {course.pins && course.pins.length > 0 && <span>{course.pins[0]}</span>}
              <span>курс</span>
            </div>

            <h4>{course.title}</h4>

            <p>{course.description || course.features.join(" · ")}</p>

            <ul aria-label="Особенности курса">
              {course.features.map((feature) => (
                <li>{feature}</li>
              ))}
            </ul>
          </div>

          <footer class="course-card__footer">
            <div class="course-card__price">
              {(course.oldPrice || course.discount) && (
                <div class="course-card__deal">
                  {course.oldPrice && <span class="course-card__old-price">{course.oldPrice}</span>}
                  {course.discount && <span class="course-card__discount">{course.discount}</span>}
                </div>
              )}
              <strong>{course.price}</strong>
            </div>

            <a class="course-card__button" href={course.link}>
              <span>{course.buttonText || "Подробнее"}</span>
              <span aria-hidden="true">↗</span>
            </a>
          </footer>
        </article>
      ))}
    </div>
  </div>
</section>

<script is:inline>
  function initCoursePromo() {
    document.querySelectorAll("[data-course-promo]").forEach((promo) => {
      if (promo.dataset.coursePromoReady === "true") return;
      promo.dataset.coursePromoReady = "true";

      const track = promo.querySelector("[data-course-track]");
      const prev = promo.querySelector("[data-course-prev]");
      const next = promo.querySelector("[data-course-next]");

      promo.querySelectorAll(".course-card__image").forEach((image) => {
        image.addEventListener("error", () => {
          image.hidden = true;
          image.closest(".course-card__media")?.classList.add("course-card__media--empty");
        });
      });

      if (!track || !prev || !next) return;

      const scroll = (direction) => {
        const card = track.querySelector(".course-card");
        const amount = card ? card.getBoundingClientRect().width + 1 : track.clientWidth * 0.8;
        track.scrollBy({ left: amount * direction, behavior: "smooth" });
      };

      prev.addEventListener("click", () => scroll(-1));
      next.addEventListener("click", () => scroll(1));
    });
  }

  initCoursePromo();
  document.addEventListener("astro:page-load", initCoursePromo);
</script>

<style>
  .course-promo {
    width: 100%;
    margin: clamp(32px, 5vw, 56px) 0;
    border: 1px solid var(--ink);
    background: var(--paper);
    color: var(--ink);
  }

  .course-promo__header {
    display: grid;
    gap: 14px;
    padding: clamp(18px, 3vw, 28px);
    border-bottom: 1px solid var(--ink);
    background:
      linear-gradient(90deg, color-mix(in oklab, var(--rust) 8%, transparent) 1px, transparent 1px),
      linear-gradient(180deg, var(--milk), var(--paper));
    background-size: 28px 100%, 100% 100%;
  }

  .course-promo__meta {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
    color: var(--rust);
    font-family: var(--academy-font-mono);
    font-size: var(--academy-caption);
    font-weight: 700;
    letter-spacing: 0.16em;
    line-height: 1.2;
    text-transform: uppercase;
  }

  .course-promo__title-row {
    display: grid;
    grid-template-columns: minmax(0, 1fr) auto;
    gap: 18px;
    align-items: end;
  }

  .course-promo__title-row h3 {
    margin: 0;
    max-width: 900px;
    color: var(--ink);
    font-family: var(--academy-font-display);
    font-size: clamp(28px, 4vw, 48px);
    font-weight: 900;
    letter-spacing: 0;
    line-height: 0.96;
  }

  .course-promo__header p {
    max-width: 760px;
    margin: 0;
    color: var(--inkSoft);
    font-family: var(--academy-font-body);
    font-size: var(--academy-prose);
    line-height: 1.55;
  }

  .course-promo__controls {
    display: flex;
    border: 1px solid var(--ink);
    background: var(--ink);
    gap: 1px;
  }

  .course-promo__control {
    width: 42px;
    height: 42px;
    border: 0;
    border-radius: 0;
    background: var(--paper);
    color: var(--ink);
    cursor: pointer;
    font-family: var(--academy-font-mono);
    font-size: 18px;
    line-height: 1;
    transition: background 140ms ease, color 140ms ease;
  }

  .course-promo__control:hover,
  .course-promo__control:focus-visible {
    background: var(--ink);
    color: var(--paper);
    outline: none;
  }

  .course-promo__viewport {
    background: var(--line);
  }

  .course-promo__track {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(min(100%, 320px), 1fr));
    gap: 1px;
    background: var(--line);
  }

  .course-card {
    display: grid;
    min-width: 0;
    grid-template-rows: auto 1fr auto;
    background: var(--paper);
  }

  .course-card__media {
    position: relative;
    display: block;
    aspect-ratio: 16 / 9;
    overflow: hidden;
    background:
      repeating-linear-gradient(
        -45deg,
        color-mix(in oklab, var(--rust) 14%, transparent) 0 1px,
        transparent 1px 9px
      ),
      var(--milk);
    color: var(--ink);
    text-decoration: none;
  }

  .course-card__media::after {
    content: "";
    position: absolute;
    inset: 0;
    border-bottom: 1px solid var(--line);
    pointer-events: none;
  }

  .course-card__media--empty::before {
    content: "image / course";
    position: absolute;
    right: 14px;
    bottom: 12px;
    z-index: 2;
    color: var(--inkSoft);
    font-family: var(--academy-font-mono);
    font-size: 11px;
    font-weight: 700;
    letter-spacing: 0.14em;
    text-transform: uppercase;
  }

  .course-card__image {
    width: 100%;
    height: 100%;
    margin: 0;
    display: block;
    object-fit: cover;
    filter: saturate(0.92) contrast(1.03);
    transition: transform 180ms ease, filter 180ms ease;
  }

  .course-card:hover .course-card__image {
    transform: scale(1.025);
    filter: saturate(1) contrast(1.06);
  }

  .course-card__index {
    position: absolute;
    top: 10px;
    left: 10px;
    z-index: 2;
    display: inline-flex;
    min-width: 38px;
    min-height: 32px;
    align-items: center;
    justify-content: center;
    border: 1px solid var(--ink);
    background: var(--paper);
    color: var(--ink);
    font-family: var(--academy-font-mono);
    font-size: 12px;
    font-weight: 800;
    letter-spacing: 0.08em;
  }

  .course-card__pins {
    position: absolute;
    top: 10px;
    right: 10px;
    z-index: 2;
    display: flex;
    max-width: calc(100% - 64px);
    flex-wrap: wrap;
    justify-content: flex-end;
    gap: 6px;
  }

  .course-card__pins span,
  .course-card__discount {
    display: inline-flex;
    min-height: 26px;
    align-items: center;
    border: 1px solid var(--ink);
    background: var(--ink);
    color: var(--paper);
    font-family: var(--academy-font-mono);
    font-size: 11px;
    font-weight: 800;
    letter-spacing: 0.1em;
    line-height: 1;
    padding: 0 8px;
    text-transform: uppercase;
  }

  .course-card__body {
    display: grid;
    align-content: start;
    gap: 14px;
    padding: 22px 20px 24px;
  }

  .course-card__meta {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
    align-items: center;
    color: var(--rust);
    font-family: var(--academy-font-mono);
    font-size: 11px;
    font-weight: 800;
    letter-spacing: 0.14em;
    line-height: 1.1;
    text-transform: uppercase;
  }

  .course-card__body h4 {
    margin: 0;
    color: var(--ink);
    font-family: var(--academy-font-display);
    font-size: clamp(26px, 3vw, 38px);
    font-weight: 900;
    letter-spacing: 0;
    line-height: 1;
  }

  .course-card__body p {
    margin: 0;
    max-width: 42rem;
    color: var(--inkSoft);
    font-family: var(--academy-font-body);
    font-size: clamp(15px, 1.8vw, 17px);
    line-height: 1.45;
  }

  .course-card__body ul {
    display: flex;
    flex-wrap: wrap;
    gap: 1px;
    margin: 0;
    padding: 0;
    list-style: none;
    background: transparent;
  }

  .course-card__body li {
    display: inline-flex;
    min-height: 30px;
    align-items: center;
    border: 1px solid var(--line);
    background: var(--milk);
    color: var(--ink);
    font-family: var(--academy-font-mono);
    font-size: 11px;
    font-weight: 800;
    letter-spacing: 0.08em;
    line-height: 1.1;
    padding: 0 9px;
    text-transform: uppercase;
  }

  .course-card__footer {
    display: grid;
    gap: 1px;
    border-top: 1px solid var(--line);
    background: var(--line);
  }

  .course-card__price {
    display: grid;
    gap: 8px;
    padding: 18px 20px;
    background: var(--milk);
  }

  .course-card__deal {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
    align-items: center;
  }

  .course-card__old-price {
    color: var(--inkSoft);
    font-family: var(--academy-font-mono);
    font-size: 12px;
    font-weight: 700;
    text-decoration: line-through;
  }

  .course-card__price strong {
    color: var(--ink);
    font-family: var(--academy-font-display);
    font-size: clamp(26px, 3vw, 36px);
    font-weight: 900;
    letter-spacing: 0;
    line-height: 0.95;
  }

  .course-card__button {
    display: flex;
    min-height: 54px;
    align-items: center;
    justify-content: space-between;
    gap: 18px;
    padding: 0 20px;
    border: 0;
    background: var(--ink);
    color: var(--paper);
    font-family: var(--academy-font-mono);
    font-size: 12px;
    font-weight: 800;
    letter-spacing: 0.14em;
    line-height: 1.2;
    text-decoration: none;
    text-transform: uppercase;
    transition: background 140ms ease, color 140ms ease;
  }

  .course-card__button:hover,
  .course-card__button:focus-visible {
    background: var(--rust);
    color: var(--paper);
    outline: none;
  }

  @media (max-width: 760px) {
    .course-promo__title-row {
      grid-template-columns: 1fr;
      align-items: start;
    }

    .course-promo__controls {
      justify-self: start;
    }

    .course-promo__track {
      grid-auto-columns: minmax(260px, 86%);
      grid-auto-flow: column;
      grid-template-columns: none;
      overflow-x: auto;
      scroll-snap-type: x mandatory;
      scrollbar-color: var(--rust) var(--paper);
      scrollbar-width: thin;
    }

    .course-promo__track::-webkit-scrollbar {
      height: 10px;
    }

    .course-promo__track::-webkit-scrollbar-track {
      background: var(--paper);
      border-top: 1px solid var(--ink);
    }

    .course-promo__track::-webkit-scrollbar-thumb {
      background: var(--rust);
      border: 2px solid var(--paper);
    }

    .course-card {
      scroll-snap-align: start;
    }
  }
</style>
