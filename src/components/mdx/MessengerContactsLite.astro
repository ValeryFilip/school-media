---
interface Messenger {
  href: string;
  label: string;
  icon: string;
  size?: number;
}

interface Props {
  title?: string;
  subtitle?: string;
  messengers?: Messenger[];
}

const {
  title = "Свяжитесь со мной в мессенджерах",
  subtitle = "Задайте свой вопрос любым удобным способом",
  messengers = [
    {
      href: "https://t.me/valery_chemistry",
      label: "Telegram",
      icon: "/images/technical/telegram.webp",
      size: 56,
    },
    {
      href: "https://wa.me/79818364992?text=%D0%9F%D1%80%D0%B8%D0%B2%D0%B5%D1%82!%20",
      label: "WhatsApp",
      icon: "/images/technical/whatsapp.webp",
      size: 56,
    },
    {
      href: "https://vk.me/valeryfilip",
      label: "VK",
      icon: "/images/technical/vk.webp",
      size: 56,
    },
  ],
} = Astro.props as Props;
---

<section class="messenger-lite">
  <div class="messenger-lite__inner">
    <h3 class="messenger-lite__title">{title}</h3>
    <p class="messenger-lite__subtitle">{subtitle}</p>

    <div class="messenger-lite__list">
      {messengers.map((item) => (
        <a
          class="messenger-lite__link"
          href={item.href}
          target="_blank"
          rel="noopener noreferrer"
          aria-label={`Написать мне в ${item.label}`}
          title={item.label}
        >
          <img
            src={item.icon}
            alt={item.label}
            width={item.size ?? 72}
            height={item.size ?? 72}
            loading="lazy"
            decoding="async"
          />
        </a>
      ))}
    </div>
  </div>
</section>

<style>
  .messenger-lite {
    margin: 28px 0;
  }

  .messenger-lite__inner {
    padding: 34px 28px;
    border-radius: 28px;
    background: linear-gradient(180deg, #f7f8fb 0%, #f2f4f8 100%);
    box-shadow: inset 0 1px 0 rgba(255, 255, 255, 0.7);
    text-align: center;
  }

  .messenger-lite__title {
    margin: 0;
    font-size: clamp(22px, 3vw, 32px);
    line-height: 1.12;
    font-weight: 800;
    letter-spacing: -0.02em;
    color: #1a2230;
  }

  .messenger-lite__subtitle {
    margin: 14px auto 0;
    max-width: 42ch;
    font-size: clamp(15px, 1.9vw, 20px);
    line-height: 1.4;
    color: #4d5b72;
  }

  .messenger-lite__list {
    display: flex;
    justify-content: center;
    gap: 18px;
    margin-top: 30px;
    flex-wrap: wrap;
  }

  .messenger-lite__link {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 72px;
    height: 72px;
    border-radius: 20px;
    background: #fff;
    box-shadow: 0 10px 24px rgba(28, 44, 76, 0.08);
    transition: transform 0.18s ease, box-shadow 0.18s ease;
  }

  .messenger-lite__link:hover {
    transform: translateY(-2px);
    box-shadow: 0 16px 30px rgba(28, 44, 76, 0.12);
  }

  .messenger-lite__link img {
    display: block;
    width: 56px;
    height: 56px;
    margin: 0;
    border-radius: 14px;
  }

  @media (max-width: 640px) {
    .messenger-lite__inner {
      padding: 26px 18px;
      border-radius: 22px;
    }

    .messenger-lite__subtitle {
      font-size: 16px;
    }

    .messenger-lite__link {
      width: 64px;
      height: 64px;
      border-radius: 18px;
    }

    .messenger-lite__link img {
      width: 48px;
      height: 48px;
      border-radius: 12px;
    }
  }
</style>
