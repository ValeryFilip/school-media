---
interface Messenger {
  href: string;
  label: string;
  icon: string;
  size?: number;
}

interface Props {
  title?: string;
  subtitle?: string;
  messengers?: Messenger[];
}

const {
  title = "Свяжитесь со мной в мессенджерах",
  subtitle = "Задайте свой вопрос любым удобным способом",
  messengers = [
    {
      href: "https://t.me/valery_chemistry",
      label: "Telegram",
      icon: "/images/technical/telegram.webp",
      size: 56,
    },
    {
      href: "https://wa.me/79818364992?text=%D0%9F%D1%80%D0%B8%D0%B2%D0%B5%D1%82!%20",
      label: "WhatsApp",
      icon: "/images/technical/whatsapp.webp",
      size: 56,
    },
    {
      href: "https://vk.me/valeryfilip",
      label: "VK",
      icon: "/images/technical/vk.webp",
      size: 56,
    },
  ],
} = Astro.props as Props;
---

<section class="messenger-lite">
  <div class="messenger-lite__head">
    <span>// связь</span>
    <span>[ {messengers.length} канала ]</span>
  </div>
  <div class="messenger-lite__intro">
    <h3 class="messenger-lite__title">{title}</h3>
    <p class="messenger-lite__subtitle">{subtitle}</p>
  </div>

  <div class="messenger-lite__list">
    {messengers.map((item) => (
      <a
        class="messenger-lite__link"
        href={item.href}
        target="_blank"
        rel="noopener noreferrer"
        aria-label={`Написать мне в ${item.label}`}
        title={item.label}
      >
        <span class="messenger-lite__icon">
          <img
            src={item.icon}
            alt=""
            width={item.size ?? 72}
            height={item.size ?? 72}
            loading="lazy"
            decoding="async"
          />
        </span>
        <span class="messenger-lite__label">{item.label}</span>
        <span class="messenger-lite__arrow" aria-hidden="true">→</span>
      </a>
    ))}
  </div>
</section>

<style>
  .messenger-lite {
    margin: 28px 0;
    border: 1px solid #1a1410;
    background: #efe9da;
  }

  .messenger-lite__head {
    display: flex;
    justify-content: space-between;
    gap: 16px;
    min-height: 40px;
    padding: 0 14px;
    align-items: center;
    border-bottom: 1px solid #1a1410;
    background: #1a1410;
    color: #efe9da;
    font-family: "JetBrains Mono", ui-monospace, monospace;
    font-size: 11px;
    font-weight: 700;
    letter-spacing: 0.12em;
    text-transform: uppercase;
  }

  .messenger-lite__intro {
    padding: clamp(18px, 2.5vw, 28px);
    border-bottom: 1px solid #c9bfac;
  }

  .messenger-lite__title {
    margin: 0;
    font-family: "Space Grotesk", system-ui, sans-serif;
    font-size: clamp(22px, 3vw, 34px);
    line-height: 1.05;
    font-weight: 700;
    letter-spacing: -0.02em;
    color: #1a1410;
  }

  .messenger-lite__subtitle {
    margin: 12px 0 0;
    max-width: 48ch;
    font-size: clamp(15px, 1.7vw, 18px);
    line-height: 1.45;
    color: #2e2620;
  }

  .messenger-lite__list {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 1px;
    background: #c9bfac;
  }

  .messenger-lite__link {
    position: relative;
    display: grid;
    gap: 10px;
    justify-items: start;
    min-height: 132px;
    padding: 16px;
    background: #f7f2e4;
    color: #1a1410;
    text-decoration: none;
    transition: background 0.16s ease, color 0.16s ease;
  }

  .messenger-lite__link:hover {
    background: #1a1410;
    color: #efe9da;
    text-decoration: none;
  }

  .messenger-lite__icon {
    display: grid;
    place-items: center;
    width: 48px;
    height: 48px;
  }

  .messenger-lite__icon img {
    display: block;
    width: 48px;
    height: 48px;
    margin: 0;
    object-fit: contain;
  }

  .messenger-lite__label {
    font-family: "JetBrains Mono", ui-monospace, monospace;
    font-size: 12px;
    font-weight: 700;
    letter-spacing: 0.1em;
    text-transform: uppercase;
  }

  .messenger-lite__arrow {
    position: absolute;
    right: 14px;
    top: 12px;
    color: #b23a14;
    font-family: "JetBrains Mono", ui-monospace, monospace;
    font-size: 20px;
  }

  .messenger-lite__link:hover .messenger-lite__arrow {
    color: currentColor;
  }

  @media (max-width: 640px) {
    .messenger-lite__list {
      grid-template-columns: 1fr;
    }

    .messenger-lite__link {
      min-height: 96px;
      grid-template-columns: auto 1fr;
      align-items: center;
    }
  }
</style>
