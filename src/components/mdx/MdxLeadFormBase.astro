---
interface Field {
  name: string;
  label: string;
  type?: "text" | "tel" | "email" | "textarea";
  placeholder?: string;
  autocomplete?: string;
  required?: boolean;
  inputmode?: string;
  pattern?: string;
  title?: string;
  rows?: number;
}

interface Consent {
  html: string;
  required?: boolean;
  fieldName?: string;
}

interface Props {
  id?: string;
  title: string;
  subtitle?: string;
  mode?: "form" | "button";
  imageSrc?: string;
  imageAlt?: string;
  imageSide?: "left" | "right";
  imageFit?: "cover" | "contain";
  fields?: Field[];
  buttonText?: string;
  submitText?: string;
  action?: string;
  formType?: string;
  successMessage?: string;
  successRedirect?: string;
  successDelay?: number;
  requiredAny?: string[];
  requiredAll?: string[];
  consents?: Consent[];
  popupId?: string;
  popupSource?: string;
  popupVariant?: string;
  popupCampaign?: string;
  theme?: "blue" | "light";
}

const defaultConsents: Consent[] = [
  {
    html: 'Согласен с <a href="/docs/privacy/" target="_blank" rel="noopener">политикой конфиденциальности</a>',
    required: true,
    fieldName: "consent_privacy",
  },
  {
    html: 'Согласен на <a href="/docs/agreement/" target="_blank" rel="noopener">обработку персональных данных</a>',
    required: true,
    fieldName: "consent_personal_data",
  },
  {
    html: 'Согласен на <a href="/docs/marketing-consent/" target="_blank" rel="noopener">рекламную рассылку</a>',
    required: true,
    fieldName: "consent_marketing",
  },
];

const {
  id = `mdx-lead-${Math.random().toString(36).slice(2, 8)}`,
  title,
  subtitle,
  mode = "form",
  imageSrc,
  imageAlt = "",
  imageSide = "right",
  imageFit = "cover",
  fields = [],
  buttonText = "Записаться",
  submitText = "Отправить заявку",
  action = "/api/lead.php",
  formType = "mdx-inline",
  successMessage = "Заявка отправлена!",
  successRedirect = "/thank-you",
  successDelay = 1500,
  requiredAny = fields
    .filter((field) => ["phone", "telegram", "email"].includes(field.name))
    .map((field) => field.name),
  requiredAll = fields.filter((field) => field.required).map((field) => field.name),
  consents = defaultConsents,
  popupId = "lead-popup",
  popupSource = "mdx-banner",
  popupVariant = "inline",
  popupCampaign = "mdx-banner",
  theme = "blue",
} = Astro.props as Props;

const hasImage = Boolean(imageSrc);
const sectionClass = [
  "mdx-lead",
  `mdx-lead--${theme}`,
  hasImage ? "mdx-lead--with-image" : "mdx-lead--no-image",
  hasImage && imageSide === "left" ? "mdx-lead--image-left" : "",
].filter(Boolean).join(" ");
---

<section class={sectionClass} style={`--mdx-image-fit:${imageFit}`}>
  {hasImage && (
    <div class="mdx-lead__media">
      <img src={imageSrc} alt={imageAlt} loading="lazy" decoding="async" />
    </div>
  )}

  <div class="mdx-lead__body">
    <div class="mdx-lead__head">
      <span class="mdx-lead__eyebrow">[ форма ] / 40 секунд</span>
      <h3 class="mdx-lead__title">{title}</h3>
      {subtitle && <p class="mdx-lead__subtitle">{subtitle}</p>}
    </div>

    {mode === "form" ? (
      <form
        class="mdx-lead__form"
        data-endpoint={action}
        data-form
        data-form-type={formType}
        data-form-id={id}
        data-success-message={successMessage}
        data-success-redirect={successRedirect}
        data-success-delay={String(successDelay)}
        data-required-any={requiredAny.join(",")}
        data-required-all={requiredAll.join(",")}
        novalidate
      >
        <div class={`mdx-lead__fields ${fields.length <= 2 ? "mdx-lead__fields--compact" : ""}`}>
          {fields.map((field, index) => (
            <label class={`mdx-lead__field ${field.type === "textarea" ? "mdx-lead__field--full" : ""}`}>
              <span class="mdx-lead__label">[{String(index + 1).padStart(2, "0")}] {field.label}</span>
              {field.type === "textarea" ? (
                <textarea
                  class="mdx-lead__input mdx-lead__textarea"
                  name={field.name}
                  placeholder={field.placeholder}
                  rows={field.rows ?? 4}
                  required={field.required ?? false}
                />
              ) : (
                <input
                  class="mdx-lead__input"
                  type={field.type ?? "text"}
                  name={field.name}
                  placeholder={field.placeholder}
                  autocomplete={field.autocomplete}
                  required={field.required ?? false}
                  inputmode={field.inputmode as "text" | "tel" | "email" | "url" | "search" | "none" | "numeric" | "decimal" | undefined}
                  pattern={field.pattern}
                  title={field.title}
                />
              )}
            </label>
          ))}
        </div>

        <div class="mdx-lead__consents">
          {consents.map((consent, index) => (
            <label class="mdx-lead__consent" for={`${id}-consent-${index}`}>
              <input
                id={`${id}-consent-${index}`}
                class="mdx-lead__checkbox"
                type="checkbox"
                name={consent.fieldName}
                value="true"
                required={consent.required ?? false}
              />
              <span set:html={consent.html} />
            </label>
          ))}
        </div>

        <div class="mdx-lead__actions">
          <button class="mdx-lead__submit" type="submit">{submitText}<span aria-hidden="true"> -></span></button>
          <div class="mdx-lead__status" data-form-status hidden></div>
          <pre class="mdx-lead__debug" data-form-debug hidden></pre>
        </div>
      </form>
    ) : (
      <div class="mdx-lead__actions mdx-lead__actions--button-only">
        <button
          type="button"
          class="mdx-lead__submit popup-btn"
          data-popup-id={popupId}
          data-source={popupSource}
          data-variant={popupVariant}
          data-campaign={popupCampaign}
        >
          {buttonText}<span aria-hidden="true"> -></span>
        </button>
      </div>
    )}
  </div>
</section>

<style>
  .mdx-lead {
    --mdx-lead-bg: var(--ink);
    --mdx-lead-card: color-mix(in oklab, var(--paper) 8%, transparent);
    --mdx-lead-border: color-mix(in oklab, var(--paper) 24%, transparent);
    --mdx-lead-text: var(--paper);
    --mdx-lead-muted: color-mix(in oklab, var(--paper) 72%, transparent);
    --mdx-lead-input-bg: var(--paper);
    --mdx-lead-input-text: var(--ink);
    --mdx-lead-button-bg: var(--rust);
    --mdx-lead-button-text: var(--paper);
    display: grid;
    grid-template-columns: minmax(0, 0.9fr) minmax(0, 1.1fr);
    width: 100%;
    max-width: 100%;
    box-sizing: border-box;
    margin: 28px 0;
    border: 1px solid var(--mdx-lead-border);
    background: var(--mdx-lead-bg);
    color: var(--mdx-lead-text);
    overflow: hidden;
  }

  .mdx-lead--light {
    --mdx-lead-bg: var(--milk);
    --mdx-lead-card: var(--paper);
    --mdx-lead-border: var(--line);
    --mdx-lead-text: var(--ink);
    --mdx-lead-muted: var(--dim);
    --mdx-lead-input-bg: var(--paper);
    --mdx-lead-input-text: var(--ink);
    --mdx-lead-button-bg: var(--ink);
    --mdx-lead-button-text: var(--paper);
  }

  .mdx-lead--no-image {
    grid-template-columns: 1fr;
  }

  .mdx-lead--image-left .mdx-lead__media {
    order: -1;
  }

  .mdx-lead__media {
    min-height: 100%;
    border-right: 1px solid var(--mdx-lead-border);
    background: var(--mdx-lead-card);
    overflow: hidden;
  }

  .mdx-lead--image-left .mdx-lead__media {
    border-right: 0;
    border-left: 1px solid var(--mdx-lead-border);
  }

  .mdx-lead__media img {
    display: block;
    width: 100%;
    height: 100%;
    min-height: 320px;
    object-fit: var(--mdx-image-fit, cover);
  }

  .mdx-lead__body {
    display: grid;
    align-content: center;
    gap: 20px;
    min-width: 0;
    padding: clamp(22px, 4vw, 38px);
  }

  .mdx-lead__head {
    display: grid;
    gap: 12px;
  }

  .mdx-lead__eyebrow,
  .mdx-lead__label {
    font-family: var(--academy-font-mono);
    font-size: var(--academy-caption);
    line-height: 1.2;
    letter-spacing: 0.16em;
    text-transform: uppercase;
  }

  .mdx-lead__eyebrow {
    color: var(--mdx-lead-muted);
  }

  .mdx-lead__title {
    margin: 0;
    color: var(--mdx-lead-text);
    font-family: var(--academy-font-display);
    font-size: var(--academy-card-title);
    font-weight: 700;
    line-height: 1.05;
    letter-spacing: 0;
  }

  .mdx-lead__subtitle {
    max-width: 62ch;
    margin: 0;
    color: var(--mdx-lead-muted);
    font-family: var(--academy-font-body);
    font-size: var(--academy-prose);
    line-height: 1.55;
  }

  .mdx-lead__form,
  .mdx-lead__fields,
  .mdx-lead__field,
  .mdx-lead__consents,
  .mdx-lead__actions {
    display: grid;
  }

  .mdx-lead__form {
    gap: 14px;
  }

  .mdx-lead__fields {
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 1px;
    background: var(--mdx-lead-border);
    border: 1px solid var(--mdx-lead-border);
  }

  .mdx-lead__field {
    gap: 8px;
    min-width: 0;
    padding: 14px;
    background: var(--mdx-lead-bg);
  }

  .mdx-lead--light .mdx-lead__field {
    background: var(--milk);
  }

  .mdx-lead__field--full {
    grid-column: 1 / -1;
  }

  .mdx-lead__label {
    color: var(--mdx-lead-muted);
  }

  .mdx-lead__input {
    width: 100%;
    min-height: 52px;
    box-sizing: border-box;
    border: 1px solid var(--mdx-lead-border);
    border-radius: 0;
    background: var(--mdx-lead-input-bg);
    color: var(--mdx-lead-input-text);
    padding: 14px 16px;
    font-family: var(--academy-font-display);
    font-size: var(--academy-action);
    line-height: 1.25;
  }

  .mdx-lead__input:focus {
    outline: 2px solid var(--rust);
    outline-offset: 2px;
  }

  .mdx-lead__input::placeholder {
    color: var(--dim);
  }

  .mdx-lead__textarea {
    min-height: 120px;
    resize: vertical;
    font-family: var(--academy-font-body);
  }

  .mdx-lead__consents {
    gap: 10px;
    border: 1px solid var(--mdx-lead-border);
    background: var(--mdx-lead-card);
    padding: 14px 16px;
  }

  .mdx-lead__consent {
    display: grid;
    grid-template-columns: 18px minmax(0, 1fr);
    align-items: start;
    gap: 10px;
    color: var(--mdx-lead-muted);
    font-family: var(--academy-font-mono);
    font-size: var(--academy-caption);
    line-height: 1.45;
  }

  .mdx-lead__checkbox {
    width: 16px;
    height: 16px;
    margin: 1px 0 0;
    accent-color: var(--rust);
  }

  .mdx-lead__consent :global(a) {
    color: inherit;
    text-decoration: underline;
    text-underline-offset: 3px;
  }

  .mdx-lead__actions {
    gap: 10px;
    align-items: start;
  }

  .mdx-lead__actions--button-only {
    justify-content: start;
  }

  .mdx-lead__submit {
    appearance: none;
    width: fit-content;
    max-width: 100%;
    min-height: 54px;
    border: 1px solid var(--mdx-lead-button-bg);
    border-radius: 0;
    background: var(--mdx-lead-button-bg);
    color: var(--mdx-lead-button-text);
    padding: 0 24px;
    cursor: pointer;
    font-family: var(--academy-font-mono);
    font-size: var(--academy-control);
    font-weight: 700;
    letter-spacing: 0.08em;
    line-height: 1.15;
    text-transform: uppercase;
  }

  .mdx-lead__submit:hover {
    background: var(--mdx-lead-button-text);
    color: var(--mdx-lead-button-bg);
  }

  .mdx-lead__submit:disabled {
    opacity: 0.65;
    cursor: not-allowed;
  }

  .mdx-lead__status {
    font-family: var(--academy-font-mono);
    font-size: var(--academy-control);
    font-weight: 700;
  }

  .mdx-lead__status.ok,
  .mdx-lead--light .mdx-lead__status.ok {
    color: var(--ochre);
  }

  .mdx-lead__status.err,
  .mdx-lead--light .mdx-lead__status.err {
    color: var(--rust);
  }

  .mdx-lead__debug {
    max-width: 100%;
    margin: 0;
    overflow: auto;
    border: 1px solid var(--mdx-lead-border);
    background: var(--ink);
    color: var(--paper);
    padding: 12px;
    font-family: var(--academy-font-mono);
    font-size: var(--academy-caption);
    line-height: 1.45;
  }

  @media (max-width: 900px) {
    .mdx-lead,
    .mdx-lead--with-image {
      grid-template-columns: 1fr;
    }

    .mdx-lead__media,
    .mdx-lead--image-left .mdx-lead__media {
      border-right: 0;
      border-left: 0;
      border-bottom: 1px solid var(--mdx-lead-border);
    }

    .mdx-lead__media img {
      min-height: 240px;
    }
  }

  @media (max-width: 640px) {
    .mdx-lead {
      margin: 22px 0;
    }

    .mdx-lead__body {
      padding: 20px;
    }

    .mdx-lead__fields {
      grid-template-columns: 1fr;
    }

    .mdx-lead__submit {
      width: 100%;
    }
  }
</style>
