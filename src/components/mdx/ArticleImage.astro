---
interface Props {
  src: string;
  alt: string;
  caption?: string;
  position?: "center" | "full" | "left" | "right";
}

const { src, alt, caption, position = "center" } = Astro.props as Props;
const modalId = `modal-${Math.random().toString(36).slice(2, 9)}`;
---

<figure class={`article-image position-${position}`}>
  <img
    src={src}
    alt={alt}
    loading="lazy"
    decoding="async"
    class="zoomable-image"
    data-modal-target={modalId}
  />
  {caption && <figcaption class="image-caption">[ image ] / {caption}</figcaption>}
</figure>

<dialog id={modalId} class="image-modal">
  <div class="modal-content">
    <button class="close-modal" aria-label="Закрыть изображение">×</button>
    <img src={src} alt={alt} class="modal-image" loading="lazy" />
    {caption && <p class="modal-caption">{caption}</p>}
  </div>
</dialog>

<!-- is:inline + plain JS — без TS-аннотаций (as HTMLElement и т.д.) -->
<script is:inline>
  var setupModals = function () {
    var triggers = document.querySelectorAll(".zoomable-image");

    triggers.forEach(function (trigger) {
      trigger.addEventListener("click", function (e) {
        var targetId = e.currentTarget.dataset.modalTarget;
        if (!targetId) return;

        var modal = document.getElementById(targetId);
        if (modal) {
          modal.showModal();
          document.body.style.overflow = "hidden";
        }
      });
    });

    var modals = document.querySelectorAll(".image-modal");
    modals.forEach(function (modal) {
      var closeBtn = modal.querySelector(".close-modal");

      if (closeBtn) {
        closeBtn.addEventListener("click", function () {
          modal.close();
          document.body.style.overflow = "";
        });
      }

      modal.addEventListener("click", function (e) {
        var target = e.target;
        if (target === modal || target.classList.contains("modal-content")) {
          modal.close();
          document.body.style.overflow = "";
        }
      });
    });
  };

  setupModals();
  document.addEventListener("astro:page-load", setupModals);
</script>

<style>
  .article-image {
    width: 100%;
    max-width: 100%;
    box-sizing: border-box;
    margin: clamp(1.5rem, 4vw, 2.5rem) 0;
    padding: 0;
  }

  .zoomable-image {
    display: block;
    width: 100%;
    max-width: 100%;
    height: auto;
    border: 1px solid var(--line);
    border-radius: 0;
    object-fit: cover;
    cursor: zoom-in;
    transition: border-color 0.2s ease;
  }

  .zoomable-image:hover {
    border-color: var(--ink);
  }

  .image-caption {
    margin: 0;
    border: 1px solid var(--line);
    border-top: 0;
    background: var(--paper);
    color: var(--dim);
    padding: 10px 12px;
    font-family: var(--academy-font-mono);
    font-size: var(--academy-caption);
    font-style: normal;
    line-height: 1.45;
    letter-spacing: 0.08em;
    text-align: left;
    text-transform: uppercase;
  }

  .position-center {
    display: flex;
    flex-direction: column;
    align-items: stretch;
  }

  .position-center img,
  .position-full img {
    width: 100%;
    max-width: 100%;
  }

  .position-full {
    width: 100%;
  }

  .position-left {
    float: left;
    max-width: 45%;
    margin: 0.75rem 1.5rem 1rem 0;
  }

  .position-right {
    float: right;
    max-width: 45%;
    margin: 0.75rem 0 1rem 1.5rem;
  }

  .image-modal {
    position: fixed;
    inset: 0;
    width: 100vw;
    height: 100vh;
    max-width: 100vw;
    max-height: 100vh;
    margin: 0;
    padding: 0;
    border: 0;
    background: color-mix(in oklab, var(--ink) 88%, transparent);
    outline: none;
    cursor: zoom-out;
    z-index: 9999;
    backdrop-filter: blur(4px);
  }

  .image-modal::backdrop {
    background: transparent;
  }

  .modal-content {
    position: relative;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    width: 100%;
    height: 100%;
    box-sizing: border-box;
    padding: clamp(16px, 3vw, 40px);
    cursor: default;
  }

  .modal-image {
    max-width: 100%;
    max-height: 85vh;
    border: 1px solid var(--paper);
    border-radius: 0;
    object-fit: contain;
  }

  .modal-caption {
    max-width: 800px;
    margin: 16px 0 0;
    color: var(--paper);
    font-family: var(--academy-font-mono);
    font-size: var(--academy-control);
    line-height: 1.45;
    text-align: center;
  }

  .close-modal {
    position: absolute;
    top: max(20px, env(safe-area-inset-top, 20px));
    right: max(20px, env(safe-area-inset-right, 20px));
    z-index: 2;
    display: flex;
    align-items: center;
    justify-content: center;
    width: 44px;
    height: 44px;
    border: 1px solid var(--paper);
    border-radius: 0;
    background: var(--paper);
    color: var(--ink);
    cursor: pointer;
    font-size: 30px;
    line-height: 1;
  }

  .close-modal:hover {
    background: var(--ink);
    color: var(--paper);
  }

  @media (max-width: 768px) {
    .position-left,
    .position-right {
      float: none;
      display: flex;
      flex-direction: column;
      align-items: stretch;
      max-width: 100%;
      margin: 1.5rem 0;
    }

    .close-modal {
      top: 10px;
      right: 10px;
      width: 36px;
      height: 36px;
      font-size: 26px;
    }

    .modal-image {
      max-height: 80vh;
    }
  }
</style>
