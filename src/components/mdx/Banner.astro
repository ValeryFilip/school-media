---
interface Props {
  type?: "info" | "warning" | "success" | "danger";
  title?: string;
}

const { type = "info", title } = Astro.props;

const config = {
  info: { icon: "i", label: "INFO", color: "#1a3556" },
  warning: { icon: "!", label: "ВАЖНО", color: "#c9882b" },
  success: { icon: "✓", label: "ВЫВОД", color: "#2f7d5b" },
  danger: { icon: "×", label: "СТОП", color: "#b23a14" },
};

const { icon, label, color } = config[type];
const bannerTitleId = title
  ? `banner-title-${type}-${Math.random().toString(36).slice(2, 10)}`
  : null;
---

<div
  class="banner"
  style={`--banner-color: ${color};`}
  role="alert"
  {...bannerTitleId ? { "aria-labelledby": bannerTitleId } : {}}
>
  <div class="banner-head">
    <span class="banner-icon" aria-hidden="true">{icon}</span>
    <span class="banner-kicker">[ {label} ]</span>
    {
      title && bannerTitleId && (
        <div id={bannerTitleId} class="banner-title">
          {title}
        </div>
      )
    }
  </div>
  <div class="banner-text">
    <slot />
  </div>
</div>

<style>
  .banner {
    margin: clamp(1rem, 2vw, 1.5rem) 0;
    border: 1px solid var(--banner-color);
    border-radius: 0;
    background: #efe9da;
    color: #1a1410;
    overflow: hidden;
  }

  .banner-head {
    display: grid;
    grid-template-columns: auto auto 1fr;
    align-items: center;
    gap: 10px;
    min-height: 42px;
    padding: 0 14px;
    border-bottom: 1px solid #1a1410;
    background: var(--banner-color);
    color: #efe9da;
    font-family: "JetBrains Mono", ui-monospace, monospace;
    text-transform: uppercase;
    letter-spacing: 0.08em;
  }

  .banner-icon {
    display: grid;
    place-items: center;
    width: 24px;
    height: 24px;
    border: 1px solid currentColor;
    font-size: 14px;
    font-weight: 700;
    line-height: 1;
  }

  .banner-kicker,
  .banner-title {
    font-size: 11px;
    font-weight: 700;
  }

  .banner-title {
    color: inherit;
    text-align: right;
  }

  .banner-text {
    padding: clamp(14px, 1.8vw, 18px) clamp(16px, 2vw, 22px);
    color: #1a1410;
    line-height: 1.6;
    font-size: clamp(14px, 1.5vw, 15px);
  }

  .banner-text :global(p:first-child) {
    margin-top: 0;
  }

  .banner-text :global(p:last-child) {
    margin-bottom: 0;
  }

  .banner-text :global(a) {
    color: var(--banner-color);
    text-decoration: underline;
    text-decoration-thickness: 1px;
  }

  @media (max-width: 600px) {
    .banner-head {
      grid-template-columns: auto 1fr;
      padding: 0 12px;
    }

    .banner-title {
      grid-column: 1 / -1;
      padding-bottom: 10px;
      text-align: left;
    }

    .banner-text {
      padding: 14px;
      font-size: 14px;
    }
  }
</style>
