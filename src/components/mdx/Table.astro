---
/**
 * Таблица для статей (жёсткий перенос «по буквам»).
 * threshold — минимальный тестовый балл (по Рособрнадзору): все строки, где значение во 2-й колонке < threshold, подсвечиваются светло-красным.
 */
interface Props {
  striped?: boolean;
  bordered?: boolean;
  /** Минимальный тестовый балл для поступления: строки ниже подсвечиваются */
  threshold?: number;
}

const { striped = true, bordered = true, threshold } = Astro.props;
---

<div
  class={`table-wrapper ${striped ? "striped" : ""} ${bordered ? "bordered" : ""}`}
  role="region"
  aria-label="Таблица"
  {...(threshold != null ? { "data-threshold": threshold } : {})}
>
  <slot />
</div>

{threshold != null && (
  <script>
    (function () {
      function applyThresholds() {
        document.querySelectorAll(".table-wrapper[data-threshold]").forEach((wrapper) => {
          const threshold = parseInt(wrapper.getAttribute("data-threshold") || "0", 10);
          const table = wrapper.querySelector("table");
          if (!table) return;
          const rows = table.querySelectorAll("tbody tr");
          rows.forEach((tr) => {
            const cells = tr.querySelectorAll("td");
            if (cells.length < 2) return;
            const testScore = parseInt(cells[1].textContent?.trim() || "", 10);
            if (!Number.isNaN(testScore) && testScore < threshold) {
              tr.classList.add("below-threshold");
            }
          });
        });
      }
      if (document.readyState === "loading") {
        document.addEventListener("DOMContentLoaded", applyThresholds);
      } else {
        applyThresholds();
      }
    })();
  </script>
)}

<style>
  .table-wrapper {
    overflow-x: auto;
    margin: clamp(1rem, 3vw, 2rem) 0;
    border-radius: clamp(6px, 0.8vw, 8px);
    box-shadow: 0 2px 8px rgba(0, 0, 0, 0.05);
    background: var(--white);
  }

  /* Буквенные переносы: фиксируем раскладку колонок и ломаем последовательности где угодно */
  .table-wrapper :global(table) {
    width: 100%;
    border-collapse: collapse;
    table-layout: fixed; /* критично для равномерных колонок и переносов */
    background: var(--white);
  }

  .table-wrapper :global(th),
  .table-wrapper :global(td) {
    padding: clamp(8px, 1.2vw, 12px) clamp(12px, 1.6vw, 16px);
    text-align: left;

    white-space: normal; /* разрешаем переносы */
    word-break: break-all; /* ломаем слова по буквам */
    overflow-wrap: anywhere; /* можно рвать где угодно */
    line-break: anywhere; /* доп. агрессивный перенос (если поддерживается) */
  }

  .table-wrapper :global(th) {
    background: #f5f5f5;
    font-weight: 600;
    color: var(--black);
    border-bottom: 2px solid var(--border);
  }

  /* Зебра */
  .table-wrapper.striped :global(tbody tr:nth-child(even)) {
    background: #f9f9f9;
  }

  /* Границы */
  .table-wrapper.bordered :global(td),
  .table-wrapper.bordered :global(th) {
    border: 1px solid var(--border);
  }

  /* Hover строки */
  .table-wrapper :global(tbody tr:hover) {
    background: #f0f7ff;
  }

  /* Строки ниже порога — один светло-красный тон для всех */
  .table-wrapper :global(tbody tr.below-threshold td) {
    background: #ffebee !important;
  }
  .table-wrapper :global(tbody tr.below-threshold:hover td) {
    background: #ffcdd2 !important;
  }

  /* Насильно переносим и внутри ссылок / кодовых элементов */
  .table-wrapper :global(td a),
  .table-wrapper :global(th a),
  .table-wrapper :global(td code),
  .table-wrapper :global(th code),
  .table-wrapper :global(td kbd),
  .table-wrapper :global(th kbd) {
    white-space: normal;
    word-break: break-all;
    overflow-wrap: anywhere;
    line-break: anywhere;
  }

  @media (max-width: 600px) {
    .table-wrapper :global(th),
    .table-wrapper :global(td) {
      padding: 8px 10px;
      font-size: 10px;
    }
    .table-wrapper :global(th) {
      font-size: 10px;
    }
  }
</style>
