---
/**
 * Таблица для статей.
 * scroll — широкие таблицы: не сжимает текст, уходит в горизонтальный скролл.
 * fit (по умолчанию) — адаптивные таблицы: шрифт уменьшается под экран.
 * threshold — строки, где значение во 2-й колонке < threshold, подсвечиваются светло-красным.
 */
interface Props {
  striped?: boolean;
  bordered?: boolean;
  layout?: "fit" | "scroll";
  /** Минимальный тестовый балл для поступления: строки ниже подсвечиваются */
  threshold?: number;
}

const { striped = true, bordered = true, layout = "fit", threshold } = Astro.props;
---

<div
  class={`table-wrapper layout-${layout} ${striped ? "striped" : ""} ${bordered ? "bordered" : ""}`}
  role="region"
  aria-label="Таблица"
  {...(threshold != null ? { "data-threshold": threshold } : {})}
>
  <slot />
</div>

{threshold != null && (
  <script>
    (function () {
      function applyThresholds() {
        document.querySelectorAll(".table-wrapper[data-threshold]").forEach((wrapper) => {
          const threshold = parseInt(wrapper.getAttribute("data-threshold") || "0", 10);
          const table = wrapper.querySelector("table");
          if (!table) return;
          const rows = table.querySelectorAll("tbody tr");
          rows.forEach((tr) => {
            const cells = tr.querySelectorAll("td");
            if (cells.length < 2) return;
            const testScore = parseInt(cells[1].textContent?.trim() || "", 10);
            if (!Number.isNaN(testScore) && testScore < threshold) {
              tr.classList.add("below-threshold");
            }
          });
        });
      }
      if (document.readyState === "loading") {
        document.addEventListener("DOMContentLoaded", applyThresholds);
      } else {
        applyThresholds();
      }
    })();
  </script>
)}

<style>
  /* ── Общее ── */
  .table-wrapper {
    overflow-x: auto;
    margin: clamp(1rem, 3vw, 2rem) 0;
    border-radius: clamp(6px, 0.8vw, 8px);
    box-shadow: 0 2px 8px rgba(0, 0, 0, 0.05);
    background: var(--white);
  }

  .table-wrapper :global(table) {
    border-collapse: collapse;
    background: var(--white);
  }

  .table-wrapper :global(th),
  .table-wrapper :global(td) {
    padding: clamp(8px, 1.2vw, 12px) clamp(12px, 1.6vw, 16px);
    text-align: left;
    white-space: normal;
    word-break: break-word;
    overflow-wrap: break-word;
  }

  .table-wrapper :global(th) {
    background: #f5f5f5;
    font-weight: 600;
    color: var(--black);
    border-bottom: 2px solid var(--border);
  }

  /* Зебра */
  .table-wrapper.striped :global(tbody tr:nth-child(even)) {
    background: #f9f9f9;
  }

  /* Границы */
  .table-wrapper.bordered :global(td),
  .table-wrapper.bordered :global(th) {
    border: 1px solid var(--border);
  }

  /* Hover */
  .table-wrapper :global(tbody tr:hover) {
    background: #f0f7ff;
  }

  /* Threshold */
  .table-wrapper :global(tbody tr.below-threshold td) {
    background: #ffebee !important;
  }
  .table-wrapper :global(tbody tr.below-threshold:hover td) {
    background: #ffcdd2 !important;
  }

  /* ── fit: таблица растягивается на всю ширину, шрифт уменьшается ── */
  .table-wrapper.layout-fit :global(table) {
    width: 100%;
    table-layout: auto;
  }

  .table-wrapper.layout-fit :global(th),
  .table-wrapper.layout-fit :global(td) {
    font-size: clamp(11px, 1.4vw, 15px);
  }

  @media (max-width: 600px) {
    .table-wrapper.layout-fit :global(th),
    .table-wrapper.layout-fit :global(td) {
      padding: 6px 8px;
      font-size: clamp(9px, 2.8vw, 12px);
    }
  }

  /* ── scroll: таблица естественной ширины, wrapper скроллит внутри себя ── */
  .table-wrapper.layout-scroll {
    max-width: 100%;
  }

  .table-wrapper.layout-scroll :global(table) {
    width: max-content;
    min-width: 100%;
    table-layout: auto;
    font-size: clamp(12px, 1.4vw, 15px);
  }

  .table-wrapper.layout-scroll :global(th),
  .table-wrapper.layout-scroll :global(td) {
    white-space: nowrap;
  }
</style>
