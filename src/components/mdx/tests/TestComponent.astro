---
interface Question {
  type: "radio" | "checkbox" | "text";
  mode?: "alone" | "slider";
  title?: string;
  text: string;
  items?: {
    text: string;
    correct: boolean;
  }[];
  correctTextAnswer?: string;
  helpText: string;
  explanationText: string;
}

interface Props {
  questions: Question[];
}

const questionId = `q-${Math.random().toString(36).slice(2, 8)}`;
const { questions } = Astro.props as Props;
const question = questions[0];
---

<div
  class="section test-section"
  data-type={question.type}
  data-correcttext={question.correctTextAnswer}
  data-mode={question.mode ?? "alone"}
>
  <div class="test__wrapper">
    <div class="test__head">
      <span class="test__eyebrow">[ test ] / вопрос</span>
      {question.title && <h3 class="test__title">{question.title}</h3>}
    </div>

    <div class="test__content">
      <div class="test__question">
        <p class="test__question-text">{question.text}</p>

        {question.type !== "text" && (
          <div class="test__question-items">
            {question.items?.map((item, i) => (
              <div class="test__question-item">
                <input
                  class="test__question-input"
                  type={question.type === "radio" ? "radio" : "checkbox"}
                  name={questionId}
                  id={`${questionId}-${i}`}
                  data-correct={String(item.correct)}
                />
                <label for={`${questionId}-${i}`}>
                  <span class="test__option-index">{String(i + 1).padStart(2, "0")}</span>
                  <span>{item.text}</span>
                </label>
              </div>
            ))}
          </div>
        )}

        {question.type === "text" && (
          <div class="test__question-text-input">
            <input
              class="test__text-input"
              type="text"
              placeholder="Введите ответ"
              name={questionId}
              id={questionId}
            />
          </div>
        )}

        <div class="test__answer-buttons">
          <button class="test__answer-button-text" type="button">Проверить <span aria-hidden="true">-></span></button>
          <button class="test__next-button" type="button" data-next hidden>Далее <span aria-hidden="true">-></span></button>
        </div>
      </div>

      <div class="test__answer-result" hidden>
        <p class="test__answer-result-text">Ответ</p>
      </div>

      <div class="test__answer-text" hidden>
        <p class="test__answer-explanation">{question.explanationText}</p>
        <p class="test__answer-hint">{question.helpText}</p>
      </div>
    </div>
  </div>
</div>

<style>
  .test-section {
    width: 100%;
    max-width: 100%;
    margin: 28px 0;
  }

  .test__wrapper {
    width: 100%;
    box-sizing: border-box;
    border: 1px solid var(--ink);
    background: var(--paper);
    color: var(--ink);
  }

  .test__head {
    display: grid;
    gap: 10px;
    border-bottom: 1px solid var(--ink);
    background: var(--ink);
    color: var(--paper);
    padding: 14px 16px;
  }

  .test__eyebrow,
  .test__option-index {
    font-family: var(--academy-font-mono);
    font-size: var(--academy-caption);
    letter-spacing: 0.16em;
    line-height: 1.2;
    text-transform: uppercase;
  }

  .test__title {
    margin: 0;
    color: inherit;
    font-family: var(--academy-font-display);
    font-size: var(--academy-small-title);
    line-height: 1.1;
  }

  .test__content {
    display: grid;
    gap: 1px;
    background: var(--line);
  }

  .test__question,
  .test__answer-result,
  .test__answer-text {
    background: var(--milk);
    padding: clamp(18px, 3vw, 28px);
  }

  .test__question {
    display: grid;
    gap: 18px;
  }

  .test__question-text {
    margin: 0;
    color: var(--ink);
    font-family: var(--academy-font-display);
    font-size: var(--academy-faq-title);
    font-weight: 700;
    line-height: 1.25;
  }

  .test__question-items {
    display: grid;
    gap: 1px;
    border: 1px solid var(--line);
    background: var(--line);
  }

  .test__question-item {
    position: relative;
    display: grid;
    grid-template-columns: 22px minmax(0, 1fr);
    align-items: stretch;
    gap: 12px;
    min-width: 0;
    background: var(--paper);
    cursor: pointer;
  }

  .test__question-item:hover {
    background: var(--milk);
  }

  .test__question-item:has(input:checked) {
    background: var(--ink);
    color: var(--paper);
  }

  .test__question-input {
    align-self: start;
    width: 16px;
    height: 16px;
    margin: 18px 0 0 16px;
    accent-color: var(--rust);
    cursor: pointer;
  }

  .test__question-item label {
    display: grid;
    grid-template-columns: auto minmax(0, 1fr);
    gap: 14px;
    min-width: 0;
    padding: 14px 16px 14px 4px;
    color: inherit;
    cursor: pointer;
    font-family: var(--academy-font-body);
    font-size: var(--academy-prose);
    line-height: 1.45;
    user-select: none;
  }

  .test__option-index {
    color: var(--rust);
  }

  .test__question-item:has(input:checked) .test__option-index {
    color: var(--ochre);
  }

  .test__question-text-input {
    display: grid;
  }

  .test__text-input {
    width: 100%;
    min-height: 56px;
    box-sizing: border-box;
    border: 1px solid var(--line);
    border-radius: 0;
    background: var(--paper);
    color: var(--ink);
    padding: 14px 16px;
    font-family: var(--academy-font-display);
    font-size: var(--academy-action);
    line-height: 1.25;
    outline: none;
  }

  .test__text-input:focus {
    border-color: var(--ink);
    outline: 2px solid var(--rust);
    outline-offset: 2px;
  }

  .test__text-input::placeholder {
    color: var(--dim);
  }

  .test__answer-buttons {
    display: flex;
    flex-wrap: wrap;
    gap: 10px;
  }

  .test__answer-button-text,
  .test__next-button {
    min-height: 52px;
    border: 1px solid var(--ink);
    border-radius: 0;
    background: var(--ink);
    color: var(--paper);
    padding: 0 22px;
    cursor: pointer;
    font-family: var(--academy-font-mono);
    font-size: var(--academy-control);
    font-weight: 700;
    letter-spacing: 0.08em;
    line-height: 1.15;
    text-transform: uppercase;
  }

  .test__next-button {
    background: var(--rust);
    border-color: var(--rust);
  }

  .test__answer-button-text:hover,
  .test__next-button:hover {
    background: var(--paper);
    color: var(--ink);
  }

  .test__answer-result {
    border-left: 4px solid var(--rust);
  }

  .test__answer-result-text {
    margin: 0;
    color: var(--ink);
    font-family: var(--academy-font-mono);
    font-size: var(--academy-control);
    font-weight: 700;
    letter-spacing: 0.08em;
    line-height: 1.35;
    text-transform: uppercase;
  }

  .test__answer-text {
    display: grid;
    gap: 10px;
    border-left: 4px solid var(--inkBlue);
  }

  .test__answer-explanation,
  .test__answer-hint {
    margin: 0;
    color: var(--inkSoft);
    font-family: var(--academy-font-body);
    font-size: var(--academy-prose);
    line-height: 1.55;
  }

  .test__answer-result[data-result="correct"] {
    border-left-color: var(--ochre);
  }

  .test__answer-result[data-result="correct"] .test__answer-result-text {
    color: var(--ochre);
  }

  .test__answer-result[data-result="incorrect"] {
    border-left-color: var(--rust);
  }

  .test__answer-result[data-result="incorrect"] .test__answer-result-text {
    color: var(--rust);
  }

  .test__answer-result[hidden],
  .test__answer-text[hidden],
  .test__answer-explanation[hidden],
  .test__answer-hint[hidden],
  .test__next-button[hidden] {
    display: none !important;
  }

  @media (max-width: 600px) {
    .test__question,
    .test__answer-result,
    .test__answer-text {
      padding: 18px;
    }

    .test__answer-button-text,
    .test__next-button {
      width: 100%;
    }
  }
</style>

<script is:inline>
  document.querySelectorAll(".test-section").forEach((test) => {
    const questionInputs = test.querySelectorAll(".test__question-input");
    const answerButton = test.querySelector(".test__answer-button-text");
    const nextButton = test.querySelector(".test__next-button");
    const resultContainer = test.querySelector(".test__answer-result");
    const resultText = test.querySelector(".test__answer-result-text");
    const helpContainer = test.querySelector(".test__answer-text");
    const explanationText = test.querySelector(".test__answer-explanation");
    const hintText = test.querySelector(".test__answer-hint");
    const textInput = test.querySelector(".test__text-input");

    if (!answerButton || !resultContainer || !resultText || !helpContainer || !explanationText || !hintText) return;

    function resetUI() {
      resultContainer.hidden = true;
      helpContainer.hidden = true;
      explanationText.hidden = true;
      hintText.hidden = true;
      resultContainer.removeAttribute("data-result");
      if (test.dataset.mode === "slider" && nextButton) {
        nextButton.hidden = true;
      }
    }

    function showEmpty() {
      resultContainer.hidden = false;
      resultText.textContent = "Выберите ответ";
      helpContainer.hidden = true;
      explanationText.hidden = true;
      hintText.hidden = true;
    }

    function showCorrect() {
      resultContainer.hidden = false;
      resultContainer.dataset.result = "correct";
      resultText.textContent = "Ответ верный";
      helpContainer.hidden = false;
      explanationText.hidden = false;
      hintText.hidden = true;
      if (test.dataset.mode === "slider" && nextButton) {
        nextButton.hidden = false;
      }
    }

    function showIncorrect() {
      resultContainer.hidden = false;
      resultContainer.dataset.result = "incorrect";
      resultText.textContent = "Ответ неверный";
      helpContainer.hidden = false;
      explanationText.hidden = true;
      hintText.hidden = false;
      if (test.dataset.mode === "slider" && nextButton) {
        nextButton.hidden = true;
      }
    }

    function normalizeAnswer(value) {
      const raw = value.trim().toLowerCase();
      const numeric = raw.replace(/\s+/g, "").replace(/%$/, "").replace(",", ".");
      return /^-?\d+(\.\d+)?$/.test(numeric) ? numeric : raw;
    }

    answerButton.addEventListener("click", () => {
      resetUI();
      const questionType = test.dataset.type;

      if (questionType === "text") {
        const writtenAnswer = textInput?.value.trim();
        if (!writtenAnswer) {
          showEmpty();
          return;
        }

        const correctAnswer = test.dataset.correcttext?.trim();
        if (!correctAnswer) {
          showIncorrect();
          return;
        }

        normalizeAnswer(writtenAnswer) === normalizeAnswer(correctAnswer) ? showCorrect() : showIncorrect();
        return;
      }

      const checkedInputs = Array.from(questionInputs).filter((input) => input.checked);
      const correctAnswers = Array.from(questionInputs).filter((input) => input.dataset.correct === "true");

      if (checkedInputs.length === 0) {
        showEmpty();
        return;
      }

      if (questionType === "checkbox") {
        if (checkedInputs.length !== correctAnswers.length) {
          showIncorrect();
          return;
        }

        const allCorrect = correctAnswers.every((answer) => checkedInputs.includes(answer));
        allCorrect ? showCorrect() : showIncorrect();
        return;
      }

      if (questionType === "radio") {
        checkedInputs[0].dataset.correct === "true" ? showCorrect() : showIncorrect();
      }
    });

    nextButton?.addEventListener("click", () => {
      test.dispatchEvent(new CustomEvent("test:next", { bubbles: true }));
    });
  });
</script>
