---
import TestComponent from "./TestComponent.astro";

interface Question {
  title: string;
  text: string;
  items: {
    text: string;
    correct: boolean;
  }[];
  explanationText: string;
  helpText: string;
}

interface Props {
  questions: Question[];
}

const { questions } = Astro.props as Props;
const question = questions[0];
---

<TestComponent
  questions={[
    {
      ...question,
      type: "radio",
      mode: "alone",
    },
  ]}
/>
