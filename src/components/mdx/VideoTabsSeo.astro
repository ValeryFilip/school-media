---
interface Props {
  youtubeHref?: string;
  vkHref?: string;
  rutubeHref?: string;
}

const { youtubeHref: youtubeRaw, vkHref, rutubeHref } = Astro.props as Props;

// youtube.com → youtube-nocookie.com: YouTube не ставит маркетинговые
// cookies, пока пользователь не нажал play. PageSpeed/Cookie audit
// перестаёт ругаться на 4 сторонних cookie от YouTube.
const youtubeHref = youtubeRaw?.replace(
  /\/\/(www\.)?youtube\.com\//,
  "//www.youtube-nocookie.com/",
);

const videoSources = [
  {
    id: "youtube",
    label: "YouTube",
    href: youtubeHref,
    title: "YouTube video player",
    width: "560",
    height: "315",
    allow:
      "accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture; web-share",
    referrerPolicy: "strict-origin-when-cross-origin",
  },
  {
    id: "vk",
    label: "VK Video",
    href: vkHref,
    title: "VK video player",
    width: "560",
    height: "315",
    allow:
      "autoplay; encrypted-media; fullscreen; picture-in-picture; screen-wake-lock;",
  },
  {
    id: "rutube",
    label: "Rutube",
    href: rutubeHref,
    title: "Rutube video player",
    width: "720",
    height: "405",
    allow: "clipboard-write; autoplay",
    style: "border: none",
  },
].filter((source) => source.href);
---

{videoSources.length > 0 && (
  <section class="tabs" aria-label="Видео: выбор источника">
    <div class="tabs__head">
      <span class="tabs__eyebrow">[ video ] / source</span>
      <div class="tab-headers" role="tablist" aria-label="Источник видео">
        {videoSources.map((source, index) => (
          <button
            class={`tab-header ${index === 0 ? "active" : ""}`}
            type="button"
            role="tab"
            id={`tab-${source.id}`}
            aria-selected={index === 0 ? "true" : "false"}
            aria-controls={`panel-${source.id}`}
            tabindex={index === 0 ? "0" : "-1"}
            data-tab={source.id}
          >
            {source.label}
          </button>
        ))}
      </div>
    </div>
    <div class="tab-contents">
      {videoSources.map((source, index) => (
        <div
          class="tab-content"
          role="tabpanel"
          id={`panel-${source.id}`}
          aria-labelledby={`tab-${source.id}`}
          aria-hidden={index === 0 ? "false" : "true"}
          data-tab={source.id}
          hidden={index !== 0}
        >
          <iframe
            width={source.width}
            height={source.height}
            src={index === 0 ? source.href : undefined}
            data-src={index === 0 ? undefined : source.href}
            title={source.title}
            allow={source.allow}
            referrerpolicy={source.referrerPolicy}
            style={source.style}
            allowfullscreen
            loading={index === 0 ? "eager" : "lazy"}></iframe>
        </div>
      ))}
    </div>
  </section>
)}

<style>
  .tabs {
    width: 100%;
    max-width: 100%;
    box-sizing: border-box;
    margin: 32px 0;
    border: 1px solid var(--ink);
    background: var(--paper);
  }

  .tabs__head {
    display: grid;
    gap: 12px;
    border-bottom: 1px solid var(--ink);
    background: var(--ink);
    color: var(--paper);
    padding: 14px 16px 0;
  }

  .tabs__eyebrow {
    font-family: var(--academy-font-mono);
    font-size: var(--academy-caption);
    letter-spacing: 0.16em;
    line-height: 1.2;
    text-transform: uppercase;
  }

  .tab-headers {
    display: flex;
    flex-wrap: wrap;
    gap: 0;
  }

  .tab-header {
    min-height: 42px;
    border: 1px solid var(--paper);
    border-bottom: 0;
    border-radius: 0;
    background: transparent;
    color: var(--paper);
    padding: 0 18px;
    cursor: pointer;
    font-family: var(--academy-font-mono);
    font-size: var(--academy-caption);
    font-weight: 700;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }

  .tab-header.active,
  .tab-header:hover {
    background: var(--paper);
    color: var(--ink);
  }

  .tab-contents {
    background: var(--line);
  }

  .tab-content {
    position: relative;
    padding: clamp(12px, 2vw, 20px);
    background: var(--milk);
  }

  .tab-content[hidden] {
    display: none;
  }

  iframe {
    display: block;
    width: 100%;
    max-width: 100%;
    height: auto;
    aspect-ratio: 16 / 9;
    border: 1px solid var(--line);
    border-radius: 0;
    background: var(--ink);
  }

  @media (max-width: 600px) {
    .tabs__head {
      padding: 14px 14px 0;
    }

    .tab-headers,
    .tab-header {
      width: 100%;
    }
  }
</style>

<script is:inline>
  (function () {
    function loadVisibleIframe(tabContent) {
      if (!tabContent || tabContent.hidden) return;
      const iframe = tabContent.querySelector("iframe[data-src]");
      if (iframe && iframe.dataset.src && !iframe.src) {
        iframe.src = iframe.dataset.src;
      }
    }

    document.querySelectorAll(".tabs").forEach(function (section) {
      const tabButtons = section.querySelectorAll(".tab-header");
      const tabContents = section.querySelectorAll(".tab-content");

      tabButtons.forEach(function (tabButton) {
        tabButton.addEventListener("click", function () {
          const tabButtonType = tabButton.dataset.tab;
          const tabContent = section.querySelector(".tab-content[data-tab=\"" + tabButtonType + "\"]");
          if (!tabContent) return;

          tabContent.hidden = false;
          tabContent.setAttribute("aria-hidden", "false");

          tabContents.forEach(function (other) {
            if (other !== tabContent) {
              other.hidden = true;
              other.setAttribute("aria-hidden", "true");
            }
          });

          tabButton.classList.add("active");
          tabButton.setAttribute("aria-selected", "true");
          tabButton.setAttribute("tabindex", "0");

          tabButtons.forEach(function (other) {
            if (other !== tabButton) {
              other.classList.remove("active");
              other.setAttribute("aria-selected", "false");
              other.setAttribute("tabindex", "-1");
            }
          });

          loadVisibleIframe(tabContent);
        });
      });
    });
  })();
</script>
