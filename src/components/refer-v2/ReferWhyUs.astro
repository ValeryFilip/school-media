---
import { referWhyUs } from "../../data/referLanding";
import EgeH2 from "../ege/EgeH2.astro";

const d = referWhyUs;

const barColor = (c: "line" | "acid" | "fuchsia2") =>
  c === "acid"
    ? "bg-acid"
    : c === "fuchsia2"
      ? "bg-fuchsia2"
      : "bg-line";
---

<section class="section relative" id="why">
  <div class="gutter py-24 md:py-32">
    <div class="grid grid-cols-12 gap-6 mb-14">
      <div class="col-span-12 md:col-span-3">
        <div class="sec-num">{d.secNum}</div>
      </div>
      <div class="col-span-12 md:col-span-9">
        <EgeH2 text={d.title.text} marks={d.title.marks} />
      </div>
    </div>

    <div
      class="grid grid-cols-1 md:grid-cols-3 gap-px bg-line border border-line"
    >
      {
        d.features.map((f, i) => (
          <div class="feat-cell">
            <div class="font-mono text-[10px] text-acid uppercase tracking-widest mb-6">
              {f.kicker}
            </div>

            {f.kind === "number" && (
              <div
                class={`font-display font-bold text-[clamp(56px,8vw,96px)] leading-none tracking-tight mb-4 ${f.visualClass ?? ""}`}
                set:html={f.visual!.html}
              />
            )}

            {f.kind === "chart" && (
              <div class="mb-4 grid grid-cols-7 gap-1">
                {f.bars!.map((b) => (
                  <div
                    class={`h-12 ${barColor(b.c)}`}
                    style={`height: ${b.h}px;`}
                  />
                ))}
              </div>
            )}

            {f.kind === "schedule" && (
              <div class="mb-4 flex items-end gap-1">
                <div class="font-display font-bold text-[64px] leading-none tracking-tight">
                  {f.scheduleBig}
                </div>
                <div class="font-mono text-[10px] text-dim mb-2 ml-2">
                  {f.scheduleSmall}
                </div>
              </div>
            )}

            <div class="font-display font-bold text-2xl md:text-3xl leading-tight mb-3">
              {f.title}
            </div>
            <p class="font-mono text-[12px] text-paper/70 leading-relaxed">
              {f.text}
            </p>
          </div>
        ))
      }
    </div>
  </div>
</section>
