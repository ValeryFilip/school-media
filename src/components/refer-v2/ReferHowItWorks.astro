---
import { referHowItWorks } from "../../data/referLanding";
import EgeH2 from "../ege/EgeH2.astro";

const d = referHowItWorks;
---

<section class="section relative" id="how">
  <div class="gutter py-24 md:py-32">
    <div class="grid grid-cols-12 gap-6 mb-14">
      <div class="col-span-12 md:col-span-3">
        <div class="sec-num">{d.secNum}</div>
      </div>
      <div class="col-span-12 md:col-span-9">
        <EgeH2 text={d.title.text} marks={d.title.marks} />
      </div>
    </div>

    <div
      class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-px bg-line border border-line"
    >
      {
        d.steps.map((s) => (
          <div
            class="step-card"
            style={
              s.isAccent
                ? "background: rgba(255,46,136,0.06); border-color: var(--fuchsia2);"
                : undefined
            }
          >
            <div
              class="step-num"
              style={s.isAccent ? "color: var(--fuchsia2);" : undefined}
            >
              // шаг {s.idx}
            </div>
            <div
              class={`font-display font-bold text-[80px] leading-none tracking-tight ${s.isAccent ? "text-fuchsia2" : s.idx === "01" ? "text-acid" : ""}`}
            >
              {s.idx}
            </div>
            <div class="font-display font-bold text-2xl md:text-3xl mt-6 mb-3">
              {s.title}
            </div>
            <p class="font-mono text-[12px] text-paper/70 leading-relaxed">
              {s.text}
            </p>
            <div
              class="mt-6 font-mono text-[10px] uppercase tracking-wider"
              style={
                s.isAccent ? "color: var(--fuchsia2);" : "color: var(--dim);"
              }
            >
              {s.footer}
            </div>
          </div>
        ))
      }
    </div>
  </div>
</section>
