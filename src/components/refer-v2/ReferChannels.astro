---
import { referChannels } from "../../data/referLanding";
import EgeH2 from "../ege/EgeH2.astro";

const d = referChannels;
---

<section class="section relative" id="channels">
  <div class="gutter py-24 md:py-32">
    <div class="grid grid-cols-12 gap-6 mb-14">
      <div class="col-span-12 md:col-span-3">
        <div class="sec-num">{d.secNum}</div>
      </div>
      <div class="col-span-12 md:col-span-9">
        <EgeH2 text={d.title.text} marks={d.title.marks} />
        <p class="mt-6 max-w-2xl text-lg leading-snug text-paper/80">
          {d.lead}
        </p>
      </div>
    </div>

    <div
      class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-px bg-line border border-line"
    >
      {
        d.channels.map((c) => (
          <div class={`chan-tile ${c.isRec ? "is-rec" : ""}`}>
            {c.pill && (
              <span class="pill absolute top-5 right-5 text-acid">{c.pill}</span>
            )}
            <div class="font-mono text-[10px] text-acid uppercase tracking-widest mb-6">
              // канал · {c.idx}
            </div>
            <div class="font-display font-bold text-[clamp(40px,5vw,64px)] leading-none tracking-tight">
              {c.code}
            </div>
            <div class="font-display font-bold text-2xl md:text-3xl mt-6 mb-3">
              {c.title}
            </div>
            <p class="font-mono text-[12px] text-paper/70 leading-relaxed">
              {c.text}
            </p>
            <div
              class={`mt-6 font-mono text-[10px] uppercase tracking-wider ${c.footerClass}`}
            >
              {c.footer}
            </div>
          </div>
        ))
      }
    </div>

    <!-- Help with templates -->
    <div
      class="mt-12 border border-line bg-coal p-8 md:p-10 grid grid-cols-12 gap-6 items-center"
    >
      <div class="col-span-12 md:col-span-8">
        <div
          class="font-mono text-[11px] text-fuchsia2 uppercase tracking-widest mb-3"
        >
          {d.help.kicker}
        </div>
        <div
          class="font-display font-bold text-[clamp(28px,3.5vw,44px)] leading-tight tracking-[-0.01em]"
        >
          {d.help.title}
        </div>
      </div>
      <div class="col-span-12 md:col-span-4 md:text-right">
        <a
          href={d.help.cta.href}
          class="inline-flex items-center gap-3 border border-paper px-6 py-4 font-mono text-[12px] uppercase tracking-widest hover:bg-paper hover:text-ink transition"
        >
          {d.help.cta.label} <span>→</span>
        </a>
      </div>
    </div>

    <div class="mt-4 font-mono text-[10px] text-dim">
      {d.warning}
    </div>
  </div>
</section>
