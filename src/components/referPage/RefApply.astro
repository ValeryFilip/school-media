---
interface Props {
  formAction?: string;
}
const { formAction = "/api/referral/apply" } = Astro.props as Props;
---

<section id="apply" class="p3 apply" aria-label="Apply form">
  <div class="wrap">
    <div class="grid">
      <div class="copy">
        <h2>Подай заявку — подключим после модерации</h2>
        <p class="lead">
          Мы проверим площадку и формат продвижения, затем выдадим
          ссылку/промокод и материалы.
        </p>

        <div class="list">
          <div class="li">
            <span class="n">01</span> Проверка заявки (24–48ч)
          </div>
          <div class="li">
            <span class="n">02</span> Выдача ссылки/промокода
          </div>
          <div class="li">
            <span class="n">03</span> Материалы + рекомендации по связкам
          </div>
        </div>

        <div class="chips">
          <span class="pill">✅ честная атрибуция</span>
          <span class="pill">✅ без спама</span>
          <span class="pill">✅ поддержка</span>
        </div>
      </div>

      <div class="panel">
        <div class="title">Расширенная заявка</div>

        <form class="form" method="post" action={formAction}>
          <div class="row">
            <label class="field">
              <span>Имя</span>
              <input name="name" placeholder="Валерий" />
            </label>
            <label class="field">
              <span>TG ник *</span>
              <input name="tg" placeholder="@username" required />
            </label>
          </div>

          <label class="field">
            <span>Ссылка на площадку *</span>
            <input name="link" placeholder="t.me/канал / VK / сайт" required />
          </label>

          <div class="row">
            <label class="field">
              <span>Гео аудитории</span>
              <select name="geo">
                <option>Россия</option>
                <option>СНГ</option>
                <option selected>Смешанное</option>
                <option>Другое</option>
              </select>
            </label>
            <label class="field">
              <span>Охваты/активность</span>
              <select name="reach">
                <option>до 300</option>
                <option>300–1 000</option>
                <option selected>1 000–5 000</option>
                <option>5 000+</option>
              </select>
            </label>
          </div>

          <fieldset class="checks">
            <legend>Как планируете продвигать?</legend>
            <label
              ><input type="checkbox" name="promo" value="post" /> Пост</label
            >
            <label
              ><input type="checkbox" name="promo" value="stories" /> Сторис/короткие
              видео</label
            >
            <label
              ><input type="checkbox" name="promo" value="pin" /> Закреп/профиль</label
            >
            <label
              ><input type="checkbox" name="promo" value="consult" /> Личная рекомендация</label
            >
          </fieldset>

          <label class="field">
            <span>Комментарий</span>
            <textarea
              name="note"
              rows="4"
              placeholder="Коротко про аудиторию и формат..."></textarea>
          </label>

          <button class="btn" type="submit">Отправить заявку</button>
          <div class="fine">
            Ответим за 24–48 часов. Если ник меняется — лучше укажи ссылку на
            профиль.
          </div>
        </form>
      </div>
    </div>
  </div>
</section>

<style>
  .p3.apply {
    margin: 20px;
    border-radius: 28px;
    background: #070a12;
    color: #eef2ff;
    padding: clamp(26px, 5vw, 56px) 0;
    position: relative;
    overflow: hidden;
  }
  .p3.apply::before {
    content: "";
    position: absolute;
    inset: -2px;
    background:
      radial-gradient(
        520px 260px at 20% 20%,
        rgba(34, 197, 94, 0.14),
        transparent 60%
      ),
      radial-gradient(
        520px 260px at 80% 60%,
        rgba(167, 139, 250, 0.18),
        transparent 60%
      );
    pointer-events: none;
  }
  .wrap {
    position: relative;
    z-index: 2;
    max-width: 1240px;
    margin: 0 auto;
    padding: 0 clamp(16px, 3vw, 28px);
  }
  .grid {
    display: grid;
    grid-template-columns: 1.05fr 0.95fr;
    gap: 12px;
    align-items: start;
  }

  h2 {
    margin: 0 0 10px;
    font-size: clamp(24px, 3.6vw, 40px);
    letter-spacing: -0.02em;
    line-height: 1.1;
    font-weight: 950;
  }
  .lead {
    margin: 0 0 14px;
    color: rgba(238, 242, 255, 0.8);
    line-height: 1.65;
    font-weight: 650;
    font-size: 16px;
  }

  .copy {
    border-radius: 20px;
    background: rgba(255, 255, 255, 0.06);
    border: 1px solid rgba(255, 255, 255, 0.12);
    backdrop-filter: blur(14px);
    padding: 14px;
  }

  .list {
    display: grid;
    gap: 10px;
    margin: 14px 0;
  }
  .li {
    display: flex;
    align-items: center;
    gap: 10px;
    padding: 10px 12px;
    border-radius: 14px;
    background: rgba(255, 255, 255, 0.05);
    border: 1px solid rgba(255, 255, 255, 0.1);
    font-weight: 850;
    color: rgba(238, 242, 255, 0.86);
  }
  .n {
    width: 28px;
    height: 28px;
    border-radius: 10px;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    background: rgba(96, 165, 250, 0.2);
    border: 1px solid rgba(255, 255, 255, 0.12);
    font-weight: 950;
    color: rgba(238, 242, 255, 0.92);
    flex: 0 0 auto;
  }

  .chips {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
  }
  .pill {
    padding: 7px 10px;
    border-radius: 999px;
    background: rgba(255, 255, 255, 0.08);
    border: 1px solid rgba(255, 255, 255, 0.12);
    font-size: 12px;
    font-weight: 850;
    color: rgba(238, 242, 255, 0.86);
  }

  .panel {
    border-radius: 20px;
    background: rgba(255, 255, 255, 0.06);
    border: 1px solid rgba(255, 255, 255, 0.12);
    backdrop-filter: blur(14px);
    padding: 14px;
  }
  .title {
    font-weight: 950;
    font-size: 18px;
    margin-bottom: 10px;
  }

  .form {
    display: grid;
    gap: 12px;
  }
  .row {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 12px;
  }

  .field {
    display: grid;
    gap: 8px;
  }
  .field span {
    font-size: 12px;
    font-weight: 900;
    color: rgba(238, 242, 255, 0.78);
    letter-spacing: 0.02em;
  }
  input,
  select,
  textarea {
    background: rgba(9, 12, 22, 0.55);
    color: #eef2ff;
    border: 1px solid rgba(255, 255, 255, 0.16);
    border-radius: 14px;
    padding: 12px 12px;
    outline: none;
    font: inherit;
  }
  input:focus,
  select:focus,
  textarea:focus {
    box-shadow: 0 0 0 4px rgba(96, 165, 250, 0.18);
    border-color: rgba(96, 165, 250, 0.35);
  }

  .checks {
    border-radius: 16px;
    background: rgba(255, 255, 255, 0.04);
    border: 1px solid rgba(255, 255, 255, 0.1);
    padding: 12px;
    display: grid;
    gap: 10px;
  }
  .checks legend {
    font-size: 12px;
    font-weight: 900;
    color: rgba(238, 242, 255, 0.78);
    letter-spacing: 0.02em;
    padding: 0 0 8px;
  }
  .checks label {
    display: flex;
    gap: 10px;
    align-items: flex-start;
    font-weight: 750;
    color: rgba(238, 242, 255, 0.84);
  }

  .btn {
    text-decoration: none;
    display: inline-flex;
    justify-content: center;
    align-items: center;
    padding: 12px 16px;
    border-radius: 14px;
    font-weight: 950;
    color: #0b0f19;
    background: linear-gradient(135deg, #f97316, #fb7185);
    box-shadow: 0 12px 40px rgba(249, 115, 22, 0.2);
    border: 0;
    cursor: pointer;
  }
  .fine {
    color: rgba(238, 242, 255, 0.65);
    font-size: 12px;
    line-height: 1.45;
    font-weight: 650;
  }

  @media (max-width: 980px) {
    .grid {
      grid-template-columns: 1fr;
    }
    .row {
      grid-template-columns: 1fr;
    }
  }
  @media (max-width: 560px) {
    .p3.apply {
      margin: 12px;
      border-radius: 22px;
    }
  }
</style>
