<section id="calc" class="p3 calc" aria-label="Калькулятор">
  <div class="wrap">
    <header class="head">
      <h2>Калькулятор дохода</h2>
      <p>Учитываем бонус за приведённых учеников + 15% с продаж на Stepik.</p>
    </header>

    <div class="panel">
      <div class="panel__grid">
        <!-- left -->
        <div class="controls">
          <div class="rowTop">
            <span class="pill">🎛️ параметры</span>
            <span class="pill pill--soft">быстрый расчёт</span>
          </div>

          <div class="field">
            <div class="label">
              <span>Количество учеников</span>
              <b id="studentsOut">5</b>
            </div>
            <input
              id="students"
              class="range"
              type="range"
              min="0"
              max="40"
              value="5"
            />
            <div class="meta">
              <span>0</span><span>40</span>
            </div>
            <div class="hintLine" id="tierHint">Тариф: 1–5 → 3000 ₽/ученик</div>
          </div>

          <label class="field">
            <span class="label2">Сумма продаж на Stepik (₽)</span>
            <input
              id="stepikSales"
              class="input"
              type="number"
              min="0"
              step="100"
              value="0"
            />
          </label>

          <div class="hint">
            <div class="hint__t">💡 Важно</div>
            <div class="hint__d">
              Это ориентир. Финальные условия и выдача ссылки — после модерации.
            </div>
          </div>
        </div>

        <!-- right -->
        <aside class="summary">
          <div class="sumTop">
            <div class="sumLabel">Итого</div>
            <div class="sumValue" id="total">≈ 15 000 ₽</div>
          </div>

          <div class="line">
            <span>Продажи Stepik</span>
            <b id="salesOut">0 ₽</b>
          </div>

          <div class="line">
            <span>Ученики</span>
            <b id="studentsOut2">5</b>
          </div>

          <a class="cta" href="#apply">Подать заявку</a>
          <div class="fine">Подключим после модерации (24–48ч).</div>
        </aside>
      </div>
    </div>
  </div>

  <script is:inline>
    const fmt = (n) => new Intl.NumberFormat("ru-RU").format(Math.round(n));

    const students = document.getElementById("students");
    const studentsOut = document.getElementById("studentsOut");
    const studentsOut2 = document.getElementById("studentsOut2");
    const stepikSales = document.getElementById("stepikSales");

    const tierHint = document.getElementById("tierHint");
    const total = document.getElementById("total");
    const salesOut = document.getElementById("salesOut");

    function perStudentRate(count) {
      if (count <= 0) return 0;
      if (count <= 5) return 3000;
      if (count <= 10) return 3500;
      return 4000;
    }

    function tierText(count) {
      if (count <= 0) return "Тариф: —";
      if (count <= 5) return "Тариф: 1–5 → 3000 ₽/ученик";
      if (count <= 10) return "Тариф: 6–10 → 3500 ₽/ученик";
      return "Тариф: 10+ → 4000 ₽/ученик";
    }

    function recalc() {
      const s = Number(students.value);
      const sales = Math.max(0, Number(stepikSales.value || 0));

      const rate = perStudentRate(s);
      const studentsBonus = s * rate;
      const stepikCommission = sales * 0.15;

      const sum = studentsBonus + stepikCommission;

      studentsOut.textContent = s;
      studentsOut2.textContent = s;
      tierHint.textContent = tierText(s);

      salesOut.textContent = fmt(sales) + " ₽";
      total.textContent = "≈ " + fmt(sum) + " ₽";
    }

    [students, stepikSales].forEach((el) =>
      el.addEventListener("input", recalc),
    );
    recalc();
  </script>
</section>

