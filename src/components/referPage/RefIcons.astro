---
type IconName =
  | "check"
  | "spark"
  | "chart"
  | "clock"
  | "shield"
  | "link"
  | "gift"
  | "stats"
  | "money"
  | "users";

const {
  name,
  class: className = "ref-icon",
  title,
} = Astro.props as {
  name: IconName;
  class?: string;
  title?: string;
};
const t = title ?? name;
---

<span
  class={className}
  aria-hidden={title ? "false" : "true"}
  role={title ? "img" : undefined}
  aria-label={title ? t : undefined}
>
  {
    name === "check" && (
      <svg viewBox="0 0 24 24" width="18" height="18" fill="none">
        <path
          d="M20 6L9 17l-5-5"
          stroke="currentColor"
          stroke-width="2.2"
          stroke-linecap="round"
          stroke-linejoin="round"
        />
      </svg>
    )
  }
  {
    name === "spark" && (
      <svg viewBox="0 0 24 24" width="18" height="18" fill="none">
        <path
          d="M12 2l1.6 5.2L19 9l-5.4 1.8L12 16l-1.6-5.2L5 9l5.4-1.8L12 2Z"
          stroke="currentColor"
          stroke-width="2"
          stroke-linejoin="round"
        />
        <path d="M4 18l.8 2.6L7.5 22l-2.7.9L4 25" opacity=".0" />
        <path
          d="M18.2 14.3l.9 2.8 2.9 1-2.9 1-.9 2.8-.9-2.8-2.9-1 2.9-1 .9-2.8Z"
          stroke="currentColor"
          stroke-width="2"
          stroke-linejoin="round"
        />
      </svg>
    )
  }
  {
    name === "chart" && (
      <svg viewBox="0 0 24 24" width="18" height="18" fill="none">
        <path
          d="M4 19V5"
          stroke="currentColor"
          stroke-width="2"
          stroke-linecap="round"
        />
        <path
          d="M4 19h16"
          stroke="currentColor"
          stroke-width="2"
          stroke-linecap="round"
        />
        <path
          d="M7 16l4-5 4 3 4-7"
          stroke="currentColor"
          stroke-width="2"
          stroke-linecap="round"
          stroke-linejoin="round"
        />
        <path
          d="M7 16h0"
          stroke="currentColor"
          stroke-width="6"
          stroke-linecap="round"
        />
        <path
          d="M11 11h0"
          stroke="currentColor"
          stroke-width="6"
          stroke-linecap="round"
        />
        <path
          d="M15 14h0"
          stroke="currentColor"
          stroke-width="6"
          stroke-linecap="round"
        />
        <path
          d="M19 7h0"
          stroke="currentColor"
          stroke-width="6"
          stroke-linecap="round"
        />
      </svg>
    )
  }
  {
    name === "clock" && (
      <svg viewBox="0 0 24 24" width="18" height="18" fill="none">
        <path
          d="M12 7v6l4 2"
          stroke="currentColor"
          stroke-width="2.2"
          stroke-linecap="round"
          stroke-linejoin="round"
        />
        <path
          d="M21 12a9 9 0 1 1-18 0 9 9 0 0 1 18 0Z"
          stroke="currentColor"
          stroke-width="2"
        />
      </svg>
    )
  }
  {
    name === "shield" && (
      <svg viewBox="0 0 24 24" width="18" height="18" fill="none">
        <path
          d="M12 2l8 4v6c0 5-3.4 9.4-8 10-4.6-.6-8-5-8-10V6l8-4Z"
          stroke="currentColor"
          stroke-width="2"
          stroke-linejoin="round"
        />
        <path
          d="M9 12l2 2 4-5"
          stroke="currentColor"
          stroke-width="2.2"
          stroke-linecap="round"
          stroke-linejoin="round"
        />
      </svg>
    )
  }
  {
    name === "link" && (
      <svg viewBox="0 0 24 24" width="18" height="18" fill="none">
        <path
          d="M10 13a5 5 0 0 1 0-7l1-1a5 5 0 0 1 7 7l-1 1"
          stroke="currentColor"
          stroke-width="2"
          stroke-linecap="round"
        />
        <path
          d="M14 11a5 5 0 0 1 0 7l-1 1a5 5 0 0 1-7-7l1-1"
          stroke="currentColor"
          stroke-width="2"
          stroke-linecap="round"
        />
      </svg>
    )
  }
  {
    name === "gift" && (
      <svg viewBox="0 0 24 24" width="18" height="18" fill="none">
        <path
          d="M20 12v10H4V12"
          stroke="currentColor"
          stroke-width="2"
          stroke-linejoin="round"
        />
        <path
          d="M2 7h20v5H2V7Z"
          stroke="currentColor"
          stroke-width="2"
          stroke-linejoin="round"
        />
        <path
          d="M12 7v15"
          stroke="currentColor"
          stroke-width="2"
          stroke-linecap="round"
        />
        <path
          d="M12 7c-2.5 0-4-1.2-4-3a2 2 0 0 1 4 0"
          stroke="currentColor"
          stroke-width="2"
          stroke-linecap="round"
        />
        <path
          d="M12 7c2.5 0 4-1.2 4-3a2 2 0 0 0-4 0"
          stroke="currentColor"
          stroke-width="2"
          stroke-linecap="round"
        />
      </svg>
    )
  }
  {
    name === "stats" && (
      <svg viewBox="0 0 24 24" width="18" height="18" fill="none">
        <path
          d="M6 20V10"
          stroke="currentColor"
          stroke-width="2"
          stroke-linecap="round"
        />
        <path
          d="M12 20V4"
          stroke="currentColor"
          stroke-width="2"
          stroke-linecap="round"
        />
        <path
          d="M18 20v-7"
          stroke="currentColor"
          stroke-width="2"
          stroke-linecap="round"
        />
      </svg>
    )
  }
  {
    name === "money" && (
      <svg viewBox="0 0 24 24" width="18" height="18" fill="none">
        <path
          d="M4 7h16v10H4V7Z"
          stroke="currentColor"
          stroke-width="2"
          stroke-linejoin="round"
        />
        <path
          d="M12 10a2 2 0 1 0 0 4 2 2 0 0 0 0-4Z"
          stroke="currentColor"
          stroke-width="2"
        />
        <path
          d="M7 10h0"
          stroke="currentColor"
          stroke-width="3"
          stroke-linecap="round"
        />
        <path
          d="M17 14h0"
          stroke="currentColor"
          stroke-width="3"
          stroke-linecap="round"
        />
      </svg>
    )
  }
  {
    name === "users" && (
      <svg viewBox="0 0 24 24" width="18" height="18" fill="none">
        <path
          d="M16 11a4 4 0 1 1-8 0 4 4 0 0 1 8 0Z"
          stroke="currentColor"
          stroke-width="2"
        />
        <path
          d="M4 21a8 8 0 0 1 16 0"
          stroke="currentColor"
          stroke-width="2"
          stroke-linecap="round"
        />
      </svg>
    )
  }
</span>
