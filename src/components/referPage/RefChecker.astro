---
interface Props {
  endpoint?: string; // /api/referral/check
}
const { endpoint = "/api/referral/check" } = Astro.props as Props;
---

<section class="p3 checker" aria-label="Earnings checker">
  <div class="wrap">
    <header class="head">
      <h2>Чекер доходности партнёра</h2>
      <p>
        Для одобренных партнёров. Введите TG-ник и посмотрите начисления. Если
        ник не найден — подайте заявку.
      </p>
    </header>

    <div class="panel">
      <div class="grid">
        <div class="left">
          <label class="field">
            <span>Telegram ник</span>
            <input id="u" placeholder="@username" />
          </label>
          <button id="go" class="btn" type="button">Показать доход</button>
          <div class="fine">
            Показываем агрегированные данные без персональных сведений учеников.
          </div>
        </div>

        <div class="right" id="out">
          <div class="state">
            <div class="t">Введите ваш TG-ник</div>
            <div class="d">Например: <b>@egehim_partner</b></div>
          </div>
        </div>
      </div>
    </div>
  </div>

  <script is:inline define:vars={{ endpoint }}>
    const u = document.getElementById("u");
    const go = document.getElementById("go");
    const out = document.getElementById("out");

    const esc = (s) =>
      (s || "").replace(
        /[&<>"']/g,
        (m) =>
          ({
            "&": "&amp;",
            "<": "&lt;",
            ">": "&gt;",
            '"': "&quot;",
            "'": "&#39;",
          })[m],
      );

    function renderNotFound() {
      out.innerHTML = `
        <div class="state">
          <div class="t">Ник не найден</div>
          <div class="d">Похоже, вы ещё не в программе или заявка не одобрена.</div>
          <a class="cta" href="#apply">Подать заявку</a>
        </div>
      `;
    }

    function renderError(msg) {
      out.innerHTML = `
        <div class="state">
          <div class="t">Ошибка</div>
          <div class="d">${esc(msg || "Попробуйте позже.")}</div>
        </div>
      `;
    }

    function renderFound(d) {
      out.innerHTML = `
        <div class="cards">
          <div class="c">
            <div class="k">Заработано всего</div>
            <div class="v">${esc(d.total)} ₽</div>
          </div>
          <div class="c">
            <div class="k">За текущий месяц</div>
            <div class="v">${esc(d.month)} ₽</div>
          </div>
          <div class="c">
            <div class="k">Начислено</div>
            <div class="v">${esc(d.accrued)} ₽</div>
          </div>
          <div class="c">
            <div class="k">Выплачено</div>
            <div class="v">${esc(d.paid)} ₽</div>
          </div>
          <div class="c">
            <div class="k">Оплат</div>
            <div class="v">${esc(d.pays)}</div>
          </div>
          <div class="c">
            <div class="k">Следующая выплата</div>
            <div class="v">${esc(d.nextPayout)}</div>
          </div>
        </div>
      `;
    }

    async function run() {
      const val = (u.value || "").trim();
      if (!val) return;

      out.innerHTML = `<div class="state"><div class="t">Загружаю...</div></div>`;

      try {
        const url = new URL(endpoint, window.location.origin);
        url.searchParams.set("username", val.startsWith("@") ? val : "@" + val);

        const r = await fetch(url.toString(), {
          headers: { Accept: "application/json" },
        });
        if (r.status === 404) return renderNotFound();
        if (!r.ok) return renderError("Статус сервера: " + r.status);

        const data = await r.json();
        if (!data || data.found === false) return renderNotFound();
        return renderFound(data);
      } catch (e) {
        return renderError("Сетевая ошибка.");
      }
    }

    go.addEventListener("click", run);
    u.addEventListener("keydown", (e) => {
      if (e.key === "Enter") run();
    });
  </script>
</section>

<style>
  .p3.checker {
    margin: 20px;
    border-radius: 28px;
    background: #070a12;
    color: #eef2ff;
    padding: clamp(26px, 5vw, 56px) 0;
    position: relative;
    overflow: hidden;
  }
  .p3.checker::before {
    content: "";
    position: absolute;
    inset: -2px;
    background:
      radial-gradient(
        520px 260px at 20% 20%,
        rgba(96, 165, 250, 0.16),
        transparent 60%
      ),
      radial-gradient(
        520px 260px at 80% 70%,
        rgba(249, 115, 22, 0.14),
        transparent 60%
      );
    pointer-events: none;
  }
  .wrap {
    position: relative;
    z-index: 2;
    max-width: 1240px;
    margin: 0 auto;
    padding: 0 clamp(16px, 3vw, 28px);
  }
  .head {
    max-width: 72ch;
    margin-bottom: 18px;
  }
  h2 {
    margin: 0 0 10px;
    font-size: clamp(24px, 3.6vw, 40px);
    letter-spacing: -0.02em;
    line-height: 1.1;
    font-weight: 950;
  }
  .head p {
    margin: 0;
    color: rgba(238, 242, 255, 0.8);
    line-height: 1.65;
    font-weight: 650;
    font-size: 16px;
  }

  .panel {
    border-radius: 20px;
    background: rgba(255, 255, 255, 0.06);
    border: 1px solid rgba(255, 255, 255, 0.12);
    backdrop-filter: blur(14px);
    padding: 14px;
  }
  .grid {
    display: grid;
    grid-template-columns: 0.9fr 1.1fr;
    gap: 12px;
    align-items: start;
  }

  .left {
    border-radius: 18px;
    background: rgba(255, 255, 255, 0.05);
    border: 1px solid rgba(255, 255, 255, 0.1);
    padding: 14px;
    display: grid;
    gap: 12px;
  }
  .field {
    display: grid;
    gap: 8px;
  }
  .field span {
    font-size: 12px;
    font-weight: 900;
    color: rgba(238, 242, 255, 0.78);
    letter-spacing: 0.02em;
  }
  input {
    background: rgba(9, 12, 22, 0.55);
    color: #eef2ff;
    border: 1px solid rgba(255, 255, 255, 0.16);
    border-radius: 14px;
    padding: 12px 12px;
    outline: none;
    font: inherit;
  }
  input:focus {
    box-shadow: 0 0 0 4px rgba(96, 165, 250, 0.18);
    border-color: rgba(96, 165, 250, 0.35);
  }

  .btn {
    border: 0;
    cursor: pointer;
    padding: 12px 16px;
    border-radius: 14px;
    font-weight: 950;
    color: #0b0f19;
    background: linear-gradient(135deg, #60a5fa, #a78bfa);
    box-shadow: 0 12px 40px rgba(96, 165, 250, 0.18);
  }
  .fine {
    color: rgba(238, 242, 255, 0.65);
    font-size: 12px;
    line-height: 1.45;
    font-weight: 650;
  }

  .right {
    border-radius: 18px;
    background: rgba(255, 255, 255, 0.05);
    border: 1px solid rgba(255, 255, 255, 0.1);
    padding: 14px;
    min-height: 220px;
  }
  .state .t {
    font-weight: 950;
    font-size: 18px;
    margin-bottom: 8px;
  }
  .state .d {
    color: rgba(238, 242, 255, 0.78);
    font-weight: 650;
    line-height: 1.55;
  }

  .cta {
    margin-top: 12px;
    text-decoration: none;
    display: inline-flex;
    justify-content: center;
    align-items: center;
    padding: 12px 16px;
    border-radius: 14px;
    font-weight: 950;
    color: #0b0f19;
    background: linear-gradient(135deg, #f97316, #fb7185);
    box-shadow: 0 12px 40px rgba(249, 115, 22, 0.18);
  }

  .cards {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 12px;
  }
  .c {
    border-radius: 16px;
    background: rgba(255, 255, 255, 0.06);
    border: 1px solid rgba(255, 255, 255, 0.12);
    padding: 12px;
  }
  .k {
    color: rgba(238, 242, 255, 0.72);
    font-weight: 850;
    margin-bottom: 6px;
  }
  .v {
    font-weight: 950;
    font-size: 20px;
    letter-spacing: -0.02em;
  }

  @media (max-width: 980px) {
    .grid {
      grid-template-columns: 1fr;
    }
    .cards {
      grid-template-columns: 1fr;
    }
  }
  @media (max-width: 560px) {
    .p3.checker {
      margin: 12px;
      border-radius: 22px;
    }
  }
</style>
