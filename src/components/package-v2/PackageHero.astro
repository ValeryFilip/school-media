---
import type { PackageData } from "../../data/packageLanding";
import EgeAcidButton from "../ege/EgeAcidButton.astro";

interface Props {
  data: PackageData["hero"];
}

const { data: d } = Astro.props;
const b = d.bundle;
---

<section class="relative pt-14 overflow-hidden">
  <div
    class="absolute inset-0 pt-grid opacity-[0.35] pointer-events-none"
    id="ptBg"
    aria-hidden="true"
  >
  </div>

  <div class="relative gutter pt-16 md:pt-20 pb-16">
    <div class="flex items-center gap-3 mb-6">
      <span class="w-2 h-2 bg-acid"></span>
      <span class="label">{d.secNum}</span>
    </div>

    <div class="grid grid-cols-12 gap-6 lg:gap-10 items-start">
      <!-- LEFT: title + lead + CTA -->
      <div class="col-span-12 lg:col-span-7">
        <div
          class="font-mono text-[12px] text-fuchsia2 uppercase tracking-widest mb-5"
        >
          {d.microKicker}
        </div>

        <h1
          class="font-display font-bold tracking-[-0.035em] leading-[0.92] sm:leading-[0.88] text-[clamp(34px,11vw,132px)] sm:text-[clamp(40px,8vw,132px)] break-words"
          set:html={d.headline.html}
        />

        <p
          class="mt-6 sm:mt-8 max-w-2xl text-paper/80 text-base sm:text-lg md:text-xl leading-snug"
          set:html={d.lead.html}
        />

        <div class="mt-8 sm:mt-10 flex flex-wrap items-center gap-3 sm:gap-4">
          <EgeAcidButton
            href={d.ctaPrimary.href}
            label={d.ctaPrimary.label}
            arrow="→"
            class="w-full sm:w-auto px-5 sm:px-7 py-4 sm:py-5 text-[14px] sm:text-[16px]"
          />
          <a
            href={d.ctaSecondary.href}
            class="font-mono text-[12px] uppercase tracking-wider text-paper/80 hover:text-acid transition px-4 py-3 sm:py-5"
          >
            {d.ctaSecondary.label}
          </a>
        </div>

        <div
          class="mt-8 flex flex-wrap items-center gap-x-6 gap-y-2 font-mono text-[12px] text-dim"
        >
          {
            d.microSpecs.map((s) => (
              <span class="flex items-center gap-2">
                <span class="text-acid">✓</span> {s}
              </span>
            ))
          }
        </div>
      </div>

      <!-- RIGHT: bundle manifest -->
      <div class="col-span-12 lg:col-span-5">
        <div class="border border-line bg-coal p-5">
          <div class="flex items-center justify-between mb-4">
            <span class="font-mono text-[10px] text-dim">{b.kicker}</span>
            <span class="font-mono text-[10px] text-acid">{b.indicator}</span>
          </div>

          <div class="space-y-2.5">
            {
              b.layers.map((l) => {
                const Tag = l.href ? "a" : "div";
                const isExternal = Boolean(l.href?.startsWith("http"));
                const linkAttrs = l.href
                  ? {
                      href: l.href,
                      target: isExternal ? "_blank" : undefined,
                      rel: isExternal ? "noopener noreferrer" : undefined,
                    }
                  : {};
                return (
                  <Tag
                    {...linkAttrs}
                    class:list={[
                      "bundle-layer block",
                      l.href && "bundle-layer--link hover:bg-ink/40 transition",
                    ]}
                  >
                    <div class="flex flex-wrap items-baseline justify-between gap-x-3 gap-y-1 mb-1">
                      <span class="font-display font-bold text-base sm:text-lg">
                        {l.idx} · {l.name}
                        {l.href && (
                          <span class="font-mono text-acid text-[11px] ml-1 opacity-60">↗</span>
                        )}
                      </span>
                      <span class="font-mono text-[11px] text-acid whitespace-nowrap">
                        {l.share}
                      </span>
                    </div>
                    <div class="font-mono text-[11px] text-dim leading-snug">
                      {l.meta}
                    </div>
                  </Tag>
                );
              })
            }
          </div>

          <div class="grid grid-cols-3 gap-px bg-line border border-line mt-3">
            {
              b.miniStats.map((m) => (
                <div class="bg-coal p-3">
                  <div
                    class={`font-display font-bold text-xl ${m.valueClass ?? ""}`}
                    set:html={m.value.html}
                  />
                  <div class="font-mono text-[9px] text-dim mt-1 uppercase tracking-wider">
                    {m.label}
                  </div>
                </div>
              ))
            }
          </div>

          <div
            class="mt-3 flex flex-wrap items-start sm:items-baseline justify-between gap-3 border border-fuchsia2 px-4 py-3"
          >
            <div class="min-w-0">
              <div class="font-mono text-[10px] text-dim line-through">
                {b.price.old}
              </div>
              <div
                class="font-display font-bold text-xl sm:text-2xl text-acid break-words"
                set:html={b.price.current.html}
              />
            </div>
            <span
              class="font-mono text-[10px] bg-fuchsia2 text-ink px-2 py-1 font-bold tracking-widest whitespace-nowrap self-start"
            >
              {b.price.savingBadge}
            </span>
          </div>
        </div>
      </div>
    </div>

    <!-- Stat strip -->
    <div
      class="mt-10 md:mt-16 grid grid-cols-2 md:grid-cols-4 gap-px bg-line border border-line"
    >
      {
        d.stats.map((s) => (
          <div class="bg-ink p-4 sm:p-6">
            <div
              class={`font-display font-bold text-3xl sm:text-4xl md:text-5xl break-words ${s.valueClass ?? ""}`}
              set:html={s.value.html}
            />
            <div class="label mt-2">{s.label}</div>
          </div>
        ))
      }
    </div>
  </div>
</section>

<script>
  /* PT-grid фон */
  (function () {
    const g = document.getElementById("ptBg");
    if (!g || g.childElementCount) return;
    for (let i = 0; i < 18 * 5; i++)
      g.appendChild(document.createElement("div"));
  })();
</script>
