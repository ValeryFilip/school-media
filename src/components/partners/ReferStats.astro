---
/* src/components/partners/ReferStats.astro */
import H2Zag from "../text/h2zag.astro";

const stats = [
  {
    icon: "percent",
    label: "Комиссия",
    value: "15%",
    note: "От суммы оплат на stepik",
    color: "var(--color-accent)",
  },
  {
    icon: "group",
    label: "ученики",
    value: "до 5000 руб",
    note: "За друга на годовом курсе",
    color: "var(--color-brand)",
  },
  {
    icon: "calendar_month",
    label: "Выплаты",
    value: "Раз в месяц",
    note: "Гарантированно",
    color: "var(--color-success)",
  },
  {
    icon: "headset_mic",
    label: "Поддержка",
    value: "24/7",
    note: "На связи",
    color: "var(--color-brand)",
  },
];
---

<section class="section partner-section partner-stats">
  <div class="container">
    <div class="partner-grid-auto partner-stats__grid">
      {
        stats.map((stat) => (
          <article class="card partner-card partner-card--interactive stat-card">
            <div
              class="partner-icon-chip stat-card__icon"
              style={`--stat-color: ${stat.color}`}
            >
              <span class="material-symbols-outlined">{stat.icon}</span>
            </div>
            <div class="stat-card__content">
              <span class="stat-card__label">{stat.label}</span>
              <p class="stat-card__value">{stat.value}</p>
              <span class="stat-card__note">{stat.note}</span>
            </div>
          </article>
        ))
      }
    </div>
  </div>
</section>

<link
  href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&display=swap"
  rel="stylesheet"
/>

<style>
  .partner-stats__grid {
    align-items: stretch;
  }

  .stat-card {
    min-height: 100%;
  }

  .stat-card__icon {
    background: color-mix(in oklab, var(--stat-color) 10%, white);
    color: var(--stat-color);
  }

  .stat-card__icon .material-symbols-outlined {
    font-size: 1.75rem;
  }

  .stat-card__label {
    display: block;
    margin-bottom: 4px;
    color: var(--color-text-muted);
    font-family: var(--overline-font-family);
    font-size: var(--overline-font-size);
    font-weight: var(--overline-font-weight);
    line-height: var(--overline-line-height);
    letter-spacing: var(--overline-letter-spacing);
    text-transform: uppercase;
  }

  .stat-card__value {
    font-size: clamp(1.75rem, 3vw, 2.25rem);
    font-weight: var(--fw-bold);
    color: var(--color-text);
    margin: 0;
    line-height: 1.1;
  }

  .stat-card__note {
    display: block;
    margin-top: 8px;
    color: var(--stat-color);
    font-family: var(--label-font-family);
    font-size: var(--label-font-size);
    font-weight: var(--label-font-weight);
    line-height: var(--label-line-height);
  }
</style>
