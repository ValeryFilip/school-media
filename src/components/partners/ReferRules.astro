---
/* src/components/partners/ReferRules.astro */
import H2Zag from "../text/h2zag.astro";

const quickRules = [
  {
    icon: "account_balance_wallet",
    title: "Минимальная выплата",
    value: "500 Рублей",
    color: "var(--color-brand)",
  },
  {
    icon: "cookie",
    title: "Срок сохранения ссылки",
    value: "Бессрочно",
    color: "var(--color-brand)",
  },
  {
    icon: "block",
    title: "Запрещенные методы",
    value: "Спам, реклама на бренд. Подробнее ниже.",
    color: "var(--color-danger)",
  },
  {
    icon: "calendar_month",
    title: "Расписание выплат",
    value: "Ежемесячно",
    color: "var(--color-brand)",
  },
];

const detailedRules = [
  {
    icon: "task_alt",
    title: "Регистрация и модерация",
    text: "Все участники проходят ручную модерацию. Мы внимательно проверяем источники трафика и рефераллов. Регистрация доступна любым людям. В приоритете ученики школ, преподаватели.",
    color: "var(--color-brand)",
  },
  {
    icon: "monetization_on",
    title: "Начисление комиссии",
    text: "Вы зарабатываете комиссию с каждой успешной оплаты курсов, совершенной приглашёнными друзьями. Вот как это работает:",
    list: [
      "Вы получаете 15% комиссии с суммы успешных оплат наших курсов на платформе степик приведенным другом. Комиссия рассчитывается от чистой оплаченной суммы (сумма после вычета любых скидок ученика).",
      "Вы получаете до 5000 рублей за каждого друга, оплатившего годовой курс (в формате минигрупп или индивидуально). Комиссия выплачивается только за первую покупку годового курса. Если ученик оплатил несколько продуктов внутри годового курса, то комиссия начисляется только за первый оплаченный курс.",
      "Выплаты за покупки курсов на степик или годового курса (в формате минигрупп или индивидуально) СУММИРУЮТСЯ!",
    ],
    color: "var(--color-brand)",
  },
  {
    icon: "warning",
    title: "Ограничения продвижения",
    text: "Запрещенные действия влекут бан аккаунта и блокировку выплат:",
    list: [
      "Покупка рекламы по брендовым запросам (например: Валерий Филипенко, ЕГЭХИМ).",
      "Массовая отправка нежелательных сообщений (Спам).",
      "Создание групп, маскирующихся под официальные ресурсы школы.",
      "Использование ботов для накрутки регистраций и оплат.",
      "Использование черных методов продвижения, таких как кликфрод, фрод с регистрациями и оплатами, использование украденных платежных данных и т.д.",
    ],
    color: "var(--color-danger)",
  },
  {
    icon: "payments",
    title: "Способы вывода средств",
    text: "Доступен вывод средств прямо на Российские банковские карты, кошельки ЮMoney, а также переводом для ИП и самозанятых. Комиссии за перевод оплачивает партнер.",
    color: "var(--color-brand)",
  },
];
---

<section class="section partner-section partner-rules">
  <div class="container">
    <div class="partner-section__head">
      <H2Zag
        title="Правила программы"
        subtitle="Основные правила партнёрской организации. Мы верим в открытость и честное сотрудничество."
      />
    </div>

    <div class="partner-rules__quick">
      {
        quickRules.map((rule) => (
          <article class="rule-mini card partner-card partner-card--interactive">
            <div
              class="partner-icon-chip rule-mini__icon"
              style={`--rule-color: ${rule.color}`}
            >
              <span class="material-symbols-outlined">{rule.icon}</span>
            </div>
            <div class="rule-mini__content">
              <h4 class="rule-mini__title">{rule.title}</h4>
              <p class="rule-mini__value">{rule.value}</p>
            </div>
          </article>
        ))
      }
    </div>

    <div class="partner-rules__detailed card partner-surface">
      <h3 class="detailed-title">Подробные условия участия</h3>
      <div class="detailed-list">
        {
          detailedRules.map((item) => (
            <div class="detailed-item">
              <div class="detailed-item__icon" style={`color: ${item.color}`}>
                <span class="material-symbols-outlined">{item.icon}</span>
              </div>
              <div class="detailed-item__content">
                <h4 class="detailed-item__title">{item.title}</h4>
                <p class="detailed-item__text">{item.text}</p>
                {item.list && (
                  <ul class="detailed-item__bullets">
                    {item.list.map((bullet) => (
                      <li>{bullet}</li>
                    ))}
                  </ul>
                )}
              </div>
            </div>
          ))
        }
      </div>
    </div>
  </div>
</section>

<style>
  .partner-rules__quick {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(240px, 1fr));
    gap: var(--space-16);
    margin-bottom: var(--space-50);
  }

  .rule-mini {
    display: flex;
    flex-direction: column;
    gap: var(--space-16);
    background: color-mix(in srgb, var(--color-bg) 8%, transparent);
    border-color: color-mix(
      in srgb,
      var(--color-text-inverse) 14%,
      transparent
    );
    box-shadow: none;
    backdrop-filter: blur(8px);
  }

  .rule-mini__icon {
    background: color-mix(in srgb, var(--rule-color) 18%, transparent);
    color: color-mix(in srgb, var(--rule-color) 84%, white);
  }

  .rule-mini__title {
    margin: 0 0 4px;
    color: var(--color-text-inverse);
  }

  .rule-mini__value {
    color: color-mix(in srgb, var(--color-text-inverse) 84%, transparent);
    margin: 0;
  }

  .partner-rules__detailed {
    padding: var(--space-50);
    text-align: left;
    background: color-mix(in srgb, var(--color-bg) 7%, transparent);
    border-color: color-mix(
      in srgb,
      var(--color-text-inverse) 14%,
      transparent
    );
    box-shadow: none;
    backdrop-filter: blur(10px);
  }

  .detailed-title {
    margin: 0 0 var(--space-40);
    color: var(--color-text-inverse);
  }

  .detailed-list {
    display: grid;
    gap: var(--space-20);
  }

  .detailed-item {
    display: flex;
    gap: var(--space-24);
    padding: var(--space-24);
    border-radius: var(--radius-lg);
    background: color-mix(in srgb, var(--color-bg) 10%, transparent);
    border: 1px solid
      color-mix(in srgb, var(--color-text-inverse) 12%, transparent);
    backdrop-filter: blur(8px);
  }

  .detailed-item__icon {
    flex-shrink: 0;
    width: 48px;
    height: 48px;
    border-radius: 14px;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    background: color-mix(in srgb, currentColor 16%, transparent);
  }

  .detailed-item__icon .material-symbols-outlined {
    font-size: 32px;
  }

  .detailed-item__title {
    margin: 0 0 8px;
    color: var(--color-text-inverse);
  }

  .detailed-item__text {
    color: color-mix(in srgb, var(--color-text-inverse) 82%, transparent);
    margin: 0;
    max-width: 800px;
  }

  .detailed-item__bullets {
    margin: 16px 0 0 24px;
    padding: 0;
    list-style-type: disc;
    color: color-mix(in srgb, var(--color-text-inverse) 82%, transparent);
    display: grid;
    gap: 8px;
  }

  @media (max-width: 800px) {
    .partner-rules__detailed {
      padding: var(--space-24);
    }

    .detailed-item {
      flex-direction: column;
      gap: 12px;
    }

    .detailed-item__text {
      font-size: 15px;
    }
  }
</style>
