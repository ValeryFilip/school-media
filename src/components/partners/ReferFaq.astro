---
/* src/components/partners/ReferFaq.astro */
import H2Zag from "../text/h2zag.astro";

const faqs = [
  {
    q: "Где отслеживать статистику оплат?",
    a: "За прогрессом, количеством кликов и регистраций можно наблюдать в режиме реального времени в личном кабинете партнера. Информация обновляется раз в несколько дней. Выше есть форма для проверки по нику в телегам.",
  },
  {
    q: "Кого можно приглашать в программу?",
    a: "Любого человека, который готовится к ЕГЭ по химии и ещё ни разу не регистрировался на платформе нашей школы. Это могут быть ваши одноклассники, друзья из секций, подписчики или просто знакомые.",
  },
  {
    q: "Что получит мой друг за регистрацию?",
    a: "Это выгодно вам обоим: вы получаете фиксированную комиссию, а ваш друг получает бесплатное занятие или скидку в 5% на покупку курса. Это отличный способ помочь друзьям с подготовкой к ЕГЭ по химии и одновременно заработать.",
  },
  {
    q: "А точно выплатите деньги?",
    a: "Да, мы гарантируем выплаты. Комиссия начисляется за каждую успешную оплату курсов, совершенную приглашёнными друзьями. Выплаты производятся ежемесячно, и вы можете быть уверены, что получите заслуженное вознаграждение за свои усилия.",
  },
  {
    q: "А если не засчитается оплата другом?",
    a: " Если оплата не засчитывается, пожалуйста, свяжитесь с нашей поддержкой. Мы всегда готовы помочь разобраться в ситуации и обеспечить правильное начисление комиссии. Важно сохранять все подтверждающие документы и информацию о транзакции для ускорения процесса решения вопроса. Все запросы рассматриваются индивидуально и человеком.",
  },
  {
    q: "Что такое реферальноая ссылка и как она работает?",
    a: " Реферальная ссылка — это уникальная URL-адрес, который вы получаете после регистрации в нашей партнерской программе. Она содержит специальный код, который позволяет системе отслеживать, что новый пользователь пришёл именно от вас. Когда кто-то кликает на вашу реферальную ссылку и регистрируется на нашей платформе, система автоматически связывает этого нового пользователя с вашим аккаунтом. Это позволяет вам зарабатывать комиссию с каждой успешной оплаты курсов, совершенной приглашёнными друзьями.",
  },
];
---

<section class="section partner-section partner-faq" id="partner-faq">
  <div class="container max-w-4xl">
    <div class="partner-section__head">
      <H2Zag
        title="База знаний"
        subtitle="Всё, что вам нужно знать о получении вознаграждений за приглашения в нашу онлайн-школу химии."
      />
    </div>

    <div class="partner-faq__list">
      {
        faqs.map((faq, idx) => (
          <details
            class="faq-item card partner-card--interactive"
            open={idx === 0}
          >
            <summary class="faq-item__summary">
              <h4 class="faq-item__question">{faq.q}</h4>
              <div class="faq-item__toggle">
                <span class="material-symbols-outlined">add</span>
              </div>
            </summary>
            <div class="faq-item__content">
              <div class="faq-item__box">
                <p class="faq-item__text">{faq.a}</p>
              </div>
            </div>
          </details>
        ))
      }
    </div>
  </div>
</section>

<style>
  .partner-faq__list {
    display: grid;
    gap: 16px;
  }

  .faq-item {
    overflow: hidden;
    transition:
      box-shadow var(--dur-1) var(--ease),
      border-color var(--dur-1) var(--ease),
      transform var(--dur-1) var(--ease);
  }

  .faq-item[open] {
    box-shadow: var(--shadow-2);
    border-color: var(--brand-200);
  }

  .faq-item__summary {
    list-style: none;
    padding: var(--space-24) var(--space-32);
    display: flex;
    justify-content: space-between;
    align-items: center;
    cursor: pointer;
    user-select: none;
    gap: var(--space-16);
  }

  .faq-item__summary::-webkit-details-marker {
    display: none;
  }

  .faq-item__question {
    margin: 0;
    transition: color var(--dur-1) var(--ease);
  }

  .faq-item[open] .faq-item__question {
    color: var(--color-brand);
  }

  .faq-item__toggle {
    width: 36px;
    height: 36px;
    border-radius: 50%;
    background: var(--gray-100);
    display: flex;
    align-items: center;
    justify-content: center;
    transition: all var(--dur-1) var(--ease);
    flex: 0 0 auto;
  }

  .faq-item[open] .faq-item__toggle {
    background: var(--color-accent);
    color: var(--color-text-inverse);
    transform: rotate(135deg);
  }

  .faq-item__content {
    padding: 0 var(--space-32) var(--space-32);
  }

  .faq-item__box {
    padding: var(--space-20);
    background: var(--gray-50);
    border-radius: var(--radius-md);
    border-left: 4px solid var(--color-brand);
  }

  .faq-item__text {
    color: var(--color-text-secondary);
    margin: 0;
  }

  @media (max-width: 600px) {
    .faq-item__summary {
      padding: var(--space-20);
    }

    .faq-item__question {
      font-size: 16px;
    }

    .faq-item__content {
      padding: 0 var(--space-20) var(--space-20);
    }
  }
</style>
