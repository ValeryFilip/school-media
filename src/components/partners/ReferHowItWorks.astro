---
/* src/components/partners/ReferHowItWorks.astro */
import H2Zag from "../text/h2zag.astro";

const steps = [
  {
    number: "1",
    icon: "person_add",
    title: "Регистрация",
    desc: "Создайте партнерский аккаунт в несколько кликов. Это займет меньше 2 минут.",
  },
  {
    number: "2",
    icon: "link",
    title: "Личная ссылка",
    desc: "Получите уникальную ссылку для автоматического учета всех приглашений.",
  },
  {
    number: "3",
    icon: "share",
    title: "Приглашение",
    desc: "Рассылайте ссылку в соцсетях, мессенджерах или напрямую друзьям.",
  },
  {
    number: "4",
    icon: "payments",
    title: "Выплаты",
    desc: "Получите 15% за курсы и до 5000р за ученика на годовом курсе.",
  },
];
---

<section class="section partner-section partner-how">
  <div class="container">
    <div class="partner-section__head">
      <H2Zag
        title="Как это работает"
        subtitle="Простой и понятный процесс позволит вам начать зарабатывать буквально за четыре шага."
      />
    </div>

    <div class="partner-how__steps">
      <div class="steps-line"></div>
      {
        steps.map((step) => (
          <div class="step-card card partner-card partner-card--interactive">
            <div class="step-card__num-box">
              <div class="step-card__circle">
                <span class="step-card__number">{step.number}</span>
              </div>
              <div class="step-card__icon">
                <span class="material-symbols-outlined">{step.icon}</span>
              </div>
            </div>
            <h4 class="step-card__title">{step.title}</h4>
            <p class="step-card__text">{step.desc}</p>
          </div>
        ))
      }
    </div>
  </div>
</section>

<style>
  .partner-how > .container {
    position: relative;
    z-index: 1;
  }

  .partner-how__steps {
    position: relative;
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: var(--space-32);
  }

  .steps-line {
    position: absolute;
    top: 48px;
    left: 10%;
    right: 10%;
    height: 2px;
    background: var(--color-border);
    z-index: 1;
  }

  .step-card {
    position: relative;
    z-index: 2;
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
  }

  .step-card__num-box {
    position: relative;
    margin-bottom: var(--space-24);
  }

  .step-card__circle {
    width: 96px;
    height: 96px;
    border-radius: 50%;
    background: var(--color-surface);
    border: 4px solid var(--gray-100);
    display: flex;
    align-items: center;
    justify-content: center;
    box-shadow: 0 10px 25px -5px rgba(0, 0, 0, 0.05);
    transition: border-color var(--dur-1) var(--ease);
  }

  .step-card:hover .step-card__circle {
    border-color: var(--brand-200);
  }

  .step-card__number {
    font-size: 40px;
    font-weight: 900;
    color: var(--color-accent);
  }

  .step-card__icon {
    position: absolute;
    bottom: -8px;
    right: -8px;
    width: 40px;
    height: 40px;
    border-radius: 10px;
    background: var(--color-brand);
    color: var(--color-text-inverse);
    display: flex;
    align-items: center;
    justify-content: center;
    box-shadow: 0 4px 12px rgba(54, 110, 240, 0.3);
  }

  .step-card__icon .material-symbols-outlined {
    font-size: 20px;
  }

  .step-card__title {
    margin: 0 0 12px;
    color: var(--color-text);
  }

  .step-card__text {
    color: var(--color-text-secondary);
    margin: 0;
  }

  @media (max-width: 1000px) {
    .partner-how__scribble svg {
      left: -12%;
      top: 14%;
      width: 126%;
      height: 220px;
      transform: rotate(-8deg);
    }

    .partner-how__steps {
      grid-template-columns: repeat(2, 1fr);
      gap: var(--space-40) var(--space-24);
    }

    .steps-line {
      display: none;
    }
  }

  @media (max-width: 600px) {
    .partner-how {
      padding: 28px 20px;
    }

    .partner-how__scribble svg {
      left: -22%;
      top: 88px;
      width: 152%;
      height: 190px;
      transform: rotate(-10deg);
    }

    .partner-how__steps {
      grid-template-columns: 1fr;
    }
  }
</style>
