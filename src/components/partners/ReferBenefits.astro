---
/* src/components/partners/ReferBenefits.astro */
import H2Zag from "../text/h2zag.astro";

const benefits = [
  {
    icon: "currency_ruble",
    title: "Высокие ставки комиссий",
    desc: "Лучшая на рынке выплата в размере 15% за каждое приглашение, без ограничений по доходу.",
  },
  {
    icon: "query_stats",
    title: "Аналитика в реальном времени",
    desc: "Отслеживайте клики, регистрации и ваши заработки в удобном личном кабинете.",
  },
  {
    icon: "schedule",
    title: "Автоматические выплаты",
    desc: "Не нужно подавать ручные заявки. Мы отправляем выплаты регулярными переводами.",
  },
];
---

<section class="section partner-section partner-benefits">
  <div class="container">
    <div class="partner-section__head">
      <H2Zag
        title="Почему выбирают нас?"
        subtitle="Мы предоставляем все передовые инструменты для вашего успеха. Наша программа построена на прозрачности и щедром награждении."
      />
    </div>

    <div class="partner-benefits__grid">
      <div class="partner-benefits__list">
        {
          benefits.map((item) => (
            <article class="card partner-card partner-card--interactive benefit-item">
              <div class="partner-icon-chip benefit-item__icon">
                <span class="material-symbols-outlined">{item.icon}</span>
              </div>
              <div class="benefit-item__content">
                <h4 class="benefit-item__title">{item.title}</h4>
                <p class="benefit-item__desc">{item.desc}</p>
              </div>
            </article>
          ))
        }
      </div>

      <div class="partner-benefits__visual">
        <div class="revenue-widget card partner-surface">
          <div class="revenue-widget__header">
            <span class="revenue-widget__label">Сводка доходов</span>
            <span class="material-symbols-outlined">more_horiz</span>
          </div>

          <div class="revenue-widget__main">
            <div class="revenue-widget__total text-center">
              <span class="total-label">Всего заработано</span>
              <p class="total-value">42 500 ₽</p>
              <span class="total-badge">+12%</span>
            </div>

            <div class="revenue-widget__chart">
              <div class="bar" style="height: 40%"></div>
              <div class="bar" style="height: 65%"></div>
              <div class="bar" style="height: 45%"></div>
              <div class="bar active" style="height: 90%"></div>
              <div class="bar" style="height: 55%"></div>
              <div class="bar active" style="height: 100%"></div>
              <div class="bar" style="height: 70%"></div>
            </div>

            <button
              class="btn btn--blue"
              style="width: 100%; border-radius: 12px; padding: 12px"
              >Вывести средства</button
            >
          </div>
        </div>

        <div class="blob blob-1"></div>
        <div class="blob blob-2"></div>
      </div>
    </div>
  </div>
</section>

<style>
  .partner-benefits__grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: var(--space-50);
    align-items: center;
  }

  .partner-benefits__list {
    display: grid;
    gap: var(--space-20);
  }

  .benefit-item {
    display: flex;
    gap: var(--space-20);
    align-items: flex-start;
  }

  .benefit-item__icon {
    flex-shrink: 0;
  }

  .benefit-item__icon .material-symbols-outlined {
    font-size: 1.75rem;
  }

  .benefit-item__title {
    margin: 0 0 8px;
    color: var(--color-text);
  }

  .benefit-item__desc {
    margin: 0;
    color: var(--color-text-secondary);
  }

  .partner-benefits__visual {
    position: relative;
    display: flex;
    justify-content: center;
  }

  .revenue-widget {
    position: relative;
    z-index: 2;
    width: 100%;
    max-width: 400px;
    padding: var(--space-32);
    transform: rotate(2deg);
    transition: transform 0.5s var(--ease);
  }

  .revenue-widget:hover {
    transform: rotate(0deg);
  }

  .revenue-widget__header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: var(--space-32);
    color: var(--color-text-muted);
  }

  .revenue-widget__label {
    font-weight: 700;
    font-size: 14px;
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }

  .revenue-widget__total {
    margin-bottom: var(--space-32);
  }

  .total-label {
    display: block;
    color: var(--color-text-muted);
    margin-bottom: 4px;
  }

  .total-value {
    font-size: 32px;
    font-weight: 800;
    color: var(--color-text);
    margin: 0 0 8px;
  }

  .total-badge {
    display: inline-block;
    padding: 2px 8px;
    background: var(--success-50);
    color: var(--color-success);
    border-radius: 6px;
    font-size: 12px;
    font-weight: 700;
  }

  .revenue-widget__chart {
    display: flex;
    align-items: flex-end;
    gap: 8px;
    height: 120px;
    margin-bottom: var(--space-32);
  }

  .bar {
    flex: 1;
    background: var(--brand-100);
    border-radius: 4px 4px 0 0;
    transition: height 1s ease;
  }

  .bar.active {
    background: var(--color-brand);
  }

  .blob {
    position: absolute;
    border-radius: 50%;
    filter: blur(40px);
    opacity: 0.4;
    z-index: 1;
  }

  .blob-1 {
    width: 200px;
    height: 200px;
    background: var(--color-brand);
    top: -30px;
    right: -30px;
  }

  .blob-2 {
    width: 250px;
    height: 250px;
    background: var(--color-accent);
    bottom: -50px;
    left: -50px;
  }

  @media (max-width: 1100px) {
    .partner-benefits__grid {
      grid-template-columns: 1fr;
      gap: var(--space-40);
    }

    .partner-benefits__visual {
      order: -1;
    }
  }
</style>
