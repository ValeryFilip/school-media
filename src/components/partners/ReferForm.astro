---
/* src/components/partners/ReferForm.astro */
---

<section class="section partner-form" id="apply">
  <div class="container">
    <div class="partner-form__grid">
      <div class="partner-form__info">
        <div class="partner-hero__badge" style="margin-bottom: var(--space-16)">
          Заявка
        </div>
        <h2 class="h2">Стать партнером школы</h2>
        <p class="partner-form__desc">
          Заполните небольшую анкету. Наш менеджер свяжется с вами в течение
          часа для активации партнерского аккаунта.
        </p>
      </div>

      <div
        class="form-card card"
        style="max-width: 600px; margin: 0 auto; position: relative; z-index: 2;"
      >
        <form class="actual-form">
          <div class="form-grid">
            <div class="form-group">
              <label class="form-label">Имя и Фамилия</label>
              <input
                type="text"
                class="form-input"
                placeholder="Иван Иванов"
                required
              />
            </div>
            <div class="form-group">
              <label class="form-label">Telegram / Телефон</label>
              <input
                type="text"
                class="form-input"
                placeholder="@username или +7..."
                required
              />
            </div>
          </div>

          <div class="form-group">
            <label class="form-label">Email</label>
            <input
              type="email"
              class="form-input"
              placeholder="ivan@example.com"
              required
            />
          </div>

          <div class="form-group">
            <label class="form-label">Где планируете размещать ссылку?</label>
            <div class="select-wrapper">
              <select class="form-select" required>
                <option value="" disabled selected>Выберите вариант</option>
                <option value="school">Школьные чаты и друзья</option>
                <option value="vk">Личная страница ВКонтакте</option>
                <option value="tg">Telegram канал/чат</option>
                <option value="youtube">YouTube или TikTok</option>
                <option value="other">Другое</option>
              </select>
              <span class="material-symbols-outlined select-icon"
                >expand_more</span
              >
            </div>
          </div>

          <button
            type="submit"
            class="btn btn--blue"
            style="width: 100%; height: 60px; font-size: 18px;"
            >Отправить заявку</button
          >
        </form>
      </div>
    </div>
  </div>

  <style>
    .partner-form {
      padding: clamp(60px, 8vw, 100px) 0;
      background: var(--white);
    }

    .partner-form__grid {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: var(--space-50);
      align-items: center;
    }

    .partner-form__desc {
      font-size: var(--text);
      color: var(--gray);
      max-width: 60ch;
      margin: 0;
    }

    .form-card {
      width: 100%;
      margin: 0;
      padding: var(--space-50);
      position: relative;
      overflow: hidden;
      background: #f8fafc;
    }

    .actual-form {
      position: relative;
      z-index: 2;
      display: grid;
      gap: 24px;
      text-align: left;
    }

    .form-grid {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 24px;
    }

    .form-group {
      display: grid;
      gap: 8px;
    }

    .form-label {
      font-size: 14px;
      font-weight: 700;
      color: var(--black);
    }

    .form-input,
    .form-select {
      width: 100%;
      height: 52px;
      padding: 0 16px;
      border-radius: 12px;
      border: 1px solid var(--border);
      background: var(--white);
      font-size: 16px;
      color: var(--black);
      outline: none;
      transition: all 0.3s;
    }

    .form-input:focus,
    .form-select:focus {
      border-color: var(--blue);
      box-shadow: 0 0 0 4px rgba(54, 110, 240, 0.1);
    }

    .select-wrapper {
      position: relative;
    }

    .form-select {
      appearance: none;
      cursor: pointer;
    }

    .select-icon {
      position: absolute;
      right: 16px;
      top: 50%;
      transform: translateY(-50%);
      pointer-events: none;
      color: var(--gray);
    }

    /* Декор */
    .form-decor {
      position: absolute;
      width: 150px;
      height: 150px;
      border-radius: 50%;
      filter: blur(50px);
      opacity: 0.08;
      z-index: 1;
    }

    .blob-1 {
      background: var(--orange);
      top: -20px;
      right: -20px;
    }
    .blob-2 {
      background: var(--blue);
      bottom: -20px;
      left: -20px;
    }

    @media (max-width: 700px) {
      .form-card {
        padding: var(--space-24);
      }
      .form-grid {
        grid-template-columns: 1fr;
      }
    }

    @media (max-width: 1100px) {
      .partner-form__grid {
        grid-template-columns: 1fr;
        gap: var(--space-40);
      }
    }

    /* Badge helper */
    .partner-hero__badge {
      display: inline-block;
      padding: 6px 16px;
      background: rgba(54, 110, 240, 0.1);
      color: var(--blue);
      border-radius: 999px;
      font-size: 14px;
      font-weight: 700;
      text-transform: uppercase;
      letter-spacing: 0.05em;
    }
  </style>
</section>
