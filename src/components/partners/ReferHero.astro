---
/* src/components/partners/ReferHero.astro */

interface Props {
  id?: string;
  badge?: string;
  title?: string;
  highlight?: string;
  description?: string;
  ctaPrimary?: { text: string; href: string };
  ctaSecondary?: { text: string; href: string };
}

const {
  id = "partner-hero",
  badge = "Партнерство",
  title = "Помогай друзьям сдать ЕГЭ",
  highlight = "получай бонусы",
  description = "Присоединяйся к партнерской программе нашей школы химии. Делись качественными материалами для подготовки с одноклассниками и зарабатывай на каждой их регистрации.",
  ctaPrimary = { text: "Стать партнером", href: "#" },
  ctaSecondary = { text: "Узнать больше", href: "#" },
} = Astro.props;
---

<section id={id} class="section partner-hero">
  <div class="container text-center">
    <div class="partner-hero__badge">
      {badge}
    </div>

    <h1 id={`${id}-title`} class="partner-hero__title">
      {title} и <span class="partner-hero__highlight">{highlight}</span>
    </h1>

    <p class="partner-hero__lead">
      {description}
    </p>

    <div class="partner-hero__actions">
      <a href={ctaPrimary.href} class="btn btn--blue">{ctaPrimary.text}</a>
      <a href={ctaSecondary.href} class="btn btn--ghost">{ctaSecondary.text}</a>
    </div>
  </div>
</section>

<style>
  .partner-hero {
    padding: 0;
    display: flex;
    justify-content: center;
    align-items: center;
  }

  .partner-hero__badge {
    display: block;
    width: max-content;
    margin: 0 auto var(--space-24);
    padding: 6px 16px;
    background: rgba(54, 110, 240, 0.1);
    color: var(--blue);
    border-radius: 999px;
    font-size: 14px;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }

  .partner-hero__title {
    font-size: var(--h1);
    line-height: 1.1;
    font-weight: 800;
    margin: 0 auto var(--space-24);
    max-width: 800px;
    color: var(--black);
    letter-spacing: -0.02em;
    text-align: center;
  }

  .partner-hero__highlight {
    color: var(--blue);
  }

  .partner-hero__lead {
    font-size: var(--lead);
    line-height: 1.6;
    color: var(--gray);
    max-width: 800px;
    margin: 0 auto var(--space-40);
    text-align: center;
  }

  .partner-hero__actions {
    display: flex;
    justify-content: center;
    gap: var(--space-16);
    flex-wrap: wrap;
  }

  .partner-hero__actions .btn {
    min-width: 200px;
    padding: 18px 32px;
    border-radius: 16px;
    font-size: 18px;
  }

  @media (max-width: 600px) {
    .partner-hero__actions .btn {
      width: 100%;
    }
  }
</style>
