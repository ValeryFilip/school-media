---
/* src/components/partners/ReferPlacement.astro */
import H2Zag from "../text/h2zag.astro";

const channels = [
  {
    icon: "send",
    title: "Telegram и школьные чаты",
    desc: "Отправьте личную рекомендацию с вашей ссылкой в чат класса или группы подготовки по химии.",
    badge: "Рекомендовано",
  },
  {
    icon: "share",
    title: "ВКонтакте",
    desc: "Опубликуйте историю с рассказом о своих успехах в химии или сделайте пост на своей стене с рекомендацией школы.",
  },
  {
    icon: "chat",
    title: "Личные сообщения",
    desc: "Напишите напрямую друзьям в WhatsApp или VK, которые тоже планируют сдавать профильную химию.",
  },
  {
    icon: "smart_display",
    title: "YouTube / Reels / Shorts",
    desc: "Добавьте ссылку в описание вашего профиля, сделайте короткое видео-историю или оставьте комментарий.",
  },
];
---

<section class="section partner-section partner-placement">
  <div class="container">
    <div class="partner-section__head">
      <H2Zag
        title="Лучшие каналы связи"
        subtitle="Используйте эти проверенные форматы, чтобы помочь большему количеству школьников подготовиться к ЕГЭ бесплатно и качественно."
      />
    </div>

    <div class="partner-placement__grid">
      {
        channels.map((item) => (
          <article class="channel-card card partner-card partner-card--interactive">
            <div class="channel-card__top">
              <div class="partner-icon-chip channel-card__icon">
                <span class="material-symbols-outlined">{item.icon}</span>
              </div>
              {item.badge && (
                <span class="partner-pill badge-mini">{item.badge}</span>
              )}
            </div>
            <div class="channel-card__content">
              <h4 class="channel-card__title">{item.title}</h4>
              <p class="channel-card__text">{item.desc}</p>
            </div>
          </article>
        ))
      }
    </div>

    <div class="placement-cta card card--brand-dark">
      <div class="placement-cta__content">
        <h3 class="placement-cta__title">
          <span class="material-symbols-outlined">auto_awesome</span>
          Нужна помощь с написанием текста?
        </h3>
        <p class="placement-cta__text">
          Мы подготовили готовые шаблоны сообщений и яркие картинки, чтобы вам
          было проще приглашать друзей.
        </p>
      </div>
      <a
        href="https://t.me/valery_chemistry"
        class="btn btn--ghost placement-cta__btn"
      >
        <span class="material-symbols-outlined">download_for_offline</span>
        Узнать про материалы
      </a>
    </div>
  </div>
</section>

<style>
  .partner-section__head {
    display: flex;
  }
  .partner-placement__grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: var(--space-24);
    margin-bottom: var(--space-50);
  }

  .channel-card {
    display: flex;
    flex-direction: column;
    gap: var(--space-20);
  }

  .channel-card__top {
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: var(--space-12);
  }

  .channel-card__icon {
    width: 56px;
    height: 56px;
  }

  .channel-card__icon .material-symbols-outlined {
    font-size: 30px;
  }

  .badge-mini {
    background: var(--accent-50);
    color: var(--color-accent);
  }

  .channel-card__title {
    margin: 0 0 8px;
    color: var(--color-text);
  }

  .channel-card__text {
    margin: 0;
    color: var(--color-text-secondary);
  }

  .placement-cta {
    padding: var(--space-40) var(--space-50);
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: var(--space-24);
    background-color: var(--color-brand);
  }

  .placement-cta__title {
    margin: 0 0 12px;
    display: flex;
    align-items: center;
    gap: 12px;
    color: inherit;
  }

  .placement-cta__title .material-symbols-outlined {
    font-size: 32px;
    color: color-mix(in srgb, currentColor 70%, transparent);
  }

  .placement-cta__text {
    max-width: 500px;
    margin: 0;
    color: color-mix(in srgb, currentColor 84%, transparent);
  }

  .placement-cta__btn {
    background: rgba(255, 255, 255, 0.96);
    border-color: rgba(255, 255, 255, 0.28);
    color: var(--color-brand);
  }

  @media (max-width: 1100px) {
    .placement-cta {
      flex-direction: column;
      text-align: center;
      padding: var(--space-32);
    }

    .placement-cta__title {
      justify-content: center;
    }
  }

  @media (max-width: 800px) {
    .partner-placement__grid {
      grid-template-columns: 1fr;
    }
  }
</style>
