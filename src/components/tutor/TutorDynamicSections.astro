---
import EgeReviews from "../ege/EgeReviews.astro";
import { realReviews } from "../../data/realReviews";
import { tutorIncludes, tutorMethods, tutorServices } from "../../data/tutorContent";
---

<section class="section relative" id="method">
  <div class="gutter py-24 md:py-32">
    <div class="grid grid-cols-12 gap-6 mb-14">
      <div class="col-span-12 md:col-span-3">
        <div class="sec-num">[04] / МЕТОДИКА</div>
      </div>
      <div class="col-span-12 md:col-span-9">
        <h2 class="font-display font-bold text-[clamp(36px,5.5vw,84px)] leading-[0.95] tracking-[-0.02em] titrate">
          Четыре принципа, на&nbsp;которых строится <span class="ul">любой мой ученик</span>.
        </h2>
      </div>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 gap-px bg-line border border-line" id="methodGrid">
      {tutorMethods.map((item) => (
        <article class="bg-ink p-7 md:p-10">
          <div class="flex items-start gap-6">
            <div class="w-20 h-20 border border-paper grid place-items-center font-mono font-bold text-2xl relative shrink-0">
              {item.symbol}
              <span class="absolute top-1 left-1.5 font-mono text-[10px] text-dim font-normal">{item.num}</span>
            </div>
            <div>
              <div class="font-mono text-[11px] text-acid mb-2">// ПРИНЦИП {item.num}</div>
              <h3 class="font-display font-bold text-2xl md:text-3xl leading-tight mb-3">{item.title}</h3>
              <p class="text-paper/80 text-sm leading-snug">{item.text}</p>
            </div>
          </div>
        </article>
      ))}
    </div>
  </div>
</section>

<section class="section relative" id="services">
  <div class="gutter py-24 md:py-32">
    <div class="grid grid-cols-12 gap-6 mb-14">
      <div class="col-span-12 md:col-span-3">
        <div class="sec-num">[05] / УСЛУГИ</div>
      </div>
      <div class="col-span-12 md:col-span-9">
        <h2 class="font-display font-bold text-[clamp(34px,4.8vw,72px)] leading-[0.95] tracking-[-0.02em] titrate">
          С&nbsp;чем работаю. <span class="text-dim">От&nbsp;8&nbsp;класса до&nbsp;<span class="ul">диссертации</span>.</span>
        </h2>
      </div>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-px bg-line border border-line" id="servicesGrid">
      {tutorServices.map((service) => (
        <button type="button" class="svc-card popup-btn text-left block bg-ink p-7 md:p-8 border-line border" data-popup-id="lead-popup" data-source="tutor-services" data-variant={service.name}>
          <div class="flex items-start justify-between mb-6">
            <span class="font-mono text-[11px] text-dim">№ {service.num}</span>
            <span class="font-mono text-[11px] text-fuchsia2">{service.meta}</span>
          </div>
          <div class="font-display font-bold text-[64px] leading-none mb-4">{service.symbol}</div>
          <h3 class="font-display font-bold text-2xl leading-tight mb-2">{service.name}</h3>
          <p class="font-mono text-[12px] text-dim leading-snug mb-7">{service.description}</p>
          <div class="flex items-end justify-between pt-5 border-t border-line">
            <div>
              <div class="font-mono text-[10px] text-dim uppercase tracking-wider">стоимость</div>
              <div class="flex items-baseline gap-2 mt-1">
                <span class="font-display font-bold text-2xl">{service.price}</span>
                <span class="font-mono text-[11px] text-dim">{service.unit}</span>
              </div>
            </div>
            <span class="font-mono text-xl">→</span>
          </div>
        </button>
      ))}
    </div>

    <div class="mt-6 font-mono text-xs text-dim flex flex-wrap gap-x-6 gap-y-2">
      <div>· Цены — стартовые, конечная зависит от&nbsp;цели и&nbsp;нагрузки</div>
      <div>· Первое занятие — 60&nbsp;мин — бесплатно</div>
      <div>· Только онлайн</div>
    </div>
  </div>
</section>

<section class="section relative" id="individual-includes">
  <div class="gutter py-24 md:py-32">
    <div class="grid grid-cols-12 gap-6 mb-14">
      <div class="col-span-12 md:col-span-3">
        <div class="sec-num">[06] / ЧТО ВХОДИТ</div>
      </div>
      <div class="col-span-12 md:col-span-9">
        <h2 class="font-display font-bold text-[clamp(34px,4.8vw,72px)] leading-[0.95] tracking-[-0.02em] titrate">
          Не&nbsp;просто созвон. <span class="text-dim">Полный цикл <span class="ul">индивидуальной работы</span>.</span>
        </h2>
      </div>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-px bg-line border border-line">
      {tutorIncludes.map((item) => (
        <article class="bg-ink p-7 md:p-8 min-h-56 flex flex-col">
          <div class="font-mono text-[11px] text-acid mb-8">// ВКЛЮЧЕНО · {item.num}</div>
          <h3 class="font-display font-bold text-2xl leading-tight mb-3">{item.title}</h3>
          <p class="text-paper/80 text-sm leading-snug">{item.text}</p>
        </article>
      ))}
    </div>
  </div>
</section>

<EgeReviews
  id="reviews"
  cases={realReviews}
  section="[07] / ОТЗЫВЫ"
  title="Отзывы."
  mutedTitle={'Результаты <span class="ul">в&nbsp;баллах</span>.'}
/>
