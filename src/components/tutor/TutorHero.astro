---
import EgeAcidButton from "../ege/EgeAcidButton.astro";

const marqueeItems = [
  "ЕГЭ · химия",
  "поступление мед / хим вузы",
  "олимпиады · Менделеевская, ВОШ",
  "пересдача ЕГЭ",
  "помощь студентам · общая, орг, аналитическая",
  "консультации преподавателям",
];
---

<section class="relative pt-14 overflow-hidden">
  <div class="absolute inset-0 pt-grid opacity-[0.35]" id="ptBg" aria-hidden="true"></div>
  <div class="absolute inset-0 pointer-events-none" id="formulaField" aria-hidden="true"></div>

  <div class="relative gutter pt-20 pb-20 md:pt-24 md:pb-28">
    <div class="grid grid-cols-12 gap-6 items-start">
      <div class="col-span-12 lg:col-span-8">
        <div class="flex items-center gap-3 mb-6">
          <span class="w-2 h-2 bg-acid"></span>
          <span class="label">[01] / Hero · открыто 4 окна в&nbsp;неделю</span>
        </div>

        <h1 class="font-display font-bold tracking-[-0.035em] leading-[0.88] text-[clamp(48px,10vw,168px)]">
          Валерий<br />
          <span class="text-dim">Филипенко</span><span class="text-fuchsia2">.</span><br />
          <span class="inline-block relative"><span class="ul">Репетитор</span></span><br />
          по&nbsp;химии<span class="text-acid">_</span>
        </h1>

        <p class="mt-8 max-w-xl text-paper/80 text-lg md:text-xl leading-snug">
          Готовлю к&nbsp;ЕГЭ, поступлению в&nbsp;мед/хим вузы и&nbsp;олимпиадам.
          Веду студентов и&nbsp;помогаю преподавателям с&nbsp;методикой.
          <span class="text-paper">Без&nbsp;«зубри таблицу»</span>.
        </p>

        <div class="mt-10 flex flex-wrap items-center gap-4">
          <EgeAcidButton
            as="button"
            type="button"
            label="Записаться на пробное"
            arrow="→"
            popupId="lead-popup"
            source="tutor-hero"
            variant="primary"
            campaign="tutor"
            class="text-[17px] px-7 py-5"
          />
          <a href="https://t.me/valery_chemistry" class="inline-flex items-center gap-3 border border-paper text-paper hover:bg-paper hover:text-ink transition font-mono text-sm uppercase tracking-wider px-6 py-5">
            Написать в&nbsp;Telegram
            <span class="font-mono">↗</span>
          </a>
        </div>

        <div class="mt-10 flex flex-wrap items-center gap-x-8 gap-y-3 font-mono text-xs text-dim">
          <div class="flex items-center gap-2"><span class="w-1.5 h-1.5 bg-acid"></span>СПбГТИ(ТУ) · хим.фак</div>
          <div class="flex items-center gap-2"><span class="w-1.5 h-1.5 bg-acid"></span>10 лет в&nbsp;подготовке</div>
          <div class="flex items-center gap-2"><span class="w-1.5 h-1.5 bg-acid"></span>2000+ учеников</div>
          <div class="flex items-center gap-2"><span class="w-1.5 h-1.5 bg-fuchsia2"></span>2&nbsp;стобалльника</div>
        </div>
      </div>

      <div class="col-span-12 lg:col-span-4 lg:pl-4">
        <div class="photo-frame photo-frame--clean aspect-[4/5]">
          <div class="ph-meta corner-tl">ID · 0001</div>
          <div class="ph-meta corner-tr">● REC</div>
          <img
            src="/images/valerii-filipenko.webp"
            alt="Валерий Филипенко — репетитор по химии"
            class="absolute inset-0 h-full w-full object-cover"
            width="800"
            height="1200"
            loading="eager"
            decoding="async"
          />
          <div class="absolute inset-0 bg-gradient-to-t from-ink/45 via-transparent to-transparent" aria-hidden="true"></div>
          <div class="ph-meta corner-bl">online · chemistry</div>
          <div class="ph-meta corner-br">35мм · SPBGTI.2016</div>
        </div>
        <div class="mt-3 grid grid-cols-2 gap-2 font-mono text-[10px] text-dim">
          <div>В&nbsp;кадре: Валерий Филипенко</div>
          <div class="text-right">aspect 4:5</div>
        </div>
      </div>
    </div>
  </div>

  <div class="relative border-t border-line py-4 overflow-hidden">
    <div class="marquee font-mono text-sm text-dim whitespace-nowrap">
      {[0, 1].map(() => (
        <div class="flex items-center gap-12" aria-hidden={undefined}>
          {marqueeItems.map((item, index) => (
            <>
              <span>{item}</span>
              <span class={index % 2 === 0 ? "text-acid" : "text-fuchsia2"}>●</span>
            </>
          ))}
        </div>
      ))}
    </div>
  </div>
</section>

<style>
  .photo-frame--clean::before {
    display: none;
  }
</style>
