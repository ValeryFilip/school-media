---

<div class="exam-results">
  <!-- Уровень 1: чипы месяцев -->
  <div class="month-chips" role="group" aria-label="Выбор месяца">
    {
      months.map((month, i) => (
        <button
          class={`month-chip${i === 0 ? " is-active" : ""}`}
          data-month={month.id}
        >
          {month.label}
          <span class="chip-count">{month.exams.length}</span>
        </button>
      ))
    }
  </div>

  <!-- Уровень 2: чипы пробников (меняются при смене месяца) -->
  {
    months.map((month, mi) => (
      <div
        class={`exam-chips${mi === 0 ? " is-active" : ""}`}
        data-month-panel={month.id}
        role="group"
        aria-label="Выбор пробника"
      >
        {month.exams.map((exam, ei) => (
          <button
            class={`exam-chip${ei === 0 && mi === 0 ? " is-active" : ""}`}
            data-exam={exam.id}
            data-month={month.id}
          >
            <span class="exam-chip-label">{exam.label}</span>
            <span class="exam-chip-date">{exam.date}</span>
          </button>
        ))}
      </div>
    ))
  }

  <!-- Уровень 3: панели с учениками -->
  {
    months.map((month, mi) =>
      month.exams.map((exam, ei) => (
        <div
          class={`exam-panel${mi === 0 && ei === 0 ? " is-active" : ""}`}
          data-exam-panel={exam.id}
        >
          <div class="students-grid">
            {exam.students.map((student) => (
              <div class="student-block">
                <button
                  class="student-header"
                  data-toggle={student.id}
                  aria-expanded="false"
                >
                  <div class="student-meta">
                    <span class="student-name">{student.name}</span>
                    <span class="student-scores">
                      <span class="score-pill score-primary">
                        {student.primaryScore}/{student.primaryMax}
                      </span>
                      <span class="score-pill score-test">
                        {student.testScore} б.
                      </span>
                      <span
                        class={`score-pill score-grade ${student.testScore >= 80 ? "grade-5" : student.testScore >= 60 ? "grade-4" : "grade-3"}`}
                      >
                        {student.grade}
                      </span>
                    </span>
                  </div>
                  <span class="toggle-icon" aria-hidden="true">
                    <svg width="16" height="16" viewBox="0 0 16 16" fill="none">
                      <path
                        d="M4 6l4 4 4-4"
                        stroke="currentColor"
                        stroke-width="1.5"
                        stroke-linecap="round"
                        stroke-linejoin="round"
                      />
                    </svg>
                  </span>
                </button>

                <div
                  class="student-results"
                  id={`results-${student.id}`}
                  hidden
                >
                  <div class="summary-row">
                    <div class="summary-stat">
                      <span class="stat-value">
                        {student.primaryScore} / {student.primaryMax}
                      </span>
                      <span class="stat-label">Первичный балл</span>
                    </div>
                    <div class="summary-stat">
                      <span class="stat-value stat-test">
                        {student.testScore} / {student.testMax}
                      </span>
                      <span class="stat-label">Тестовый балл</span>
                    </div>
                    <div class="summary-stat">
                      <span class="stat-value stat-p1">
                        {student.part1.reduce((s, r) => s + r.score, 0)} / {student.part1.reduce((s, r) => s + r.maxScore, 0)}
                      </span>
                      <span class="stat-label">Часть 1</span>
                    </div>
                    <div class="summary-stat">
                      <span class="stat-value stat-p2">
                        {student.part2.reduce((s, r) => s + r.score, 0)} / {student.part2.reduce((s, r) => s + r.maxScore, 0)}
                      </span>
                      <span class="stat-label">Часть 2</span>
                    </div>
                  </div>

                  <h4 class="section-title">Часть 1 — Краткие ответы</h4>
                  <div class="table-wrap">
                    <table>
                      <thead>
                        <tr>
                          <th>№</th>
                          <th>Ответ</th>
                          <th>Верный</th>
                          <th>Балл</th>
                          <th>Комментарий</th>
                        </tr>
                      </thead>
                      <tbody>
                        {student.part1.map((row) => (
                          <tr>
                            <td class="cell-num">{row.num}</td>
                            <td>{row.student}</td>
                            <td>{row.correct}</td>
                            <td>
                              <span
                                class={`score-badge ${row.score === row.maxScore ? "badge-max" : row.score === 0 ? "badge-zero" : "badge-partial"}`}
                              >
                                {row.score}/{row.maxScore}
                              </span>
                            </td>
                            <td class="cell-comment">{row.comment}</td>
                          </tr>
                        ))}
                      </tbody>
                    </table>
                  </div>

                  <h4 class="section-title">Часть 2 — Развёрнутые ответы</h4>
                  <div class="table-wrap">
                    <table>
                      <thead>
                        <tr>
                          <th>№</th>
                          <th>Статус</th>
                          <th>Балл</th>
                          <th>Комментарий</th>
                        </tr>
                      </thead>
                      <tbody>
                        {student.part2.map((row) => (
                          <tr>
                            <td class="cell-num">{row.num}</td>
                            <td>
                              <span
                                class={`status-tag ${row.score === row.maxScore ? "status-full" : row.score === 0 ? "status-none" : "status-partial"}`}
                              >
                                {row.status}
                              </span>
                            </td>
                            <td>
                              <span
                                class={`score-badge ${row.score === row.maxScore ? "badge-max" : row.score === 0 ? "badge-zero" : "badge-partial"}`}
                              >
                                {row.score}/{row.maxScore}
                              </span>
                            </td>
                            <td class="cell-comment">{row.comment}</td>
                          </tr>
                        ))}
                      </tbody>
                    </table>
                  </div>
                </div>
              </div>
            ))}
          </div>
        </div>
      )),
    )
  }
</div>

<style>
  .exam-results {
    color: var(--color-text);
  }

  .exam-results button {
    font: inherit;
  }

  /* ── Уровень 1: месяцы ── */
  .month-chips {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
    margin-bottom: 12px;
  }

  .month-chip {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    padding: 8px 16px;
    border-radius: 100px;
    border: 1.5px solid var(--color-border);
    background: white;
    color: var(--color-text-secondary);
    font-size: var(--fs-14);
    font-weight: var(--fw-semibold);
    cursor: pointer;
    transition:
      border-color 0.15s,
      background 0.15s,
      color 0.15s;
  }

  .month-chip:hover {
    border-color: var(--brand-300);
    color: var(--color-brand);
    background: var(--brand-50);
  }

  .month-chip.is-active {
    border-color: var(--brand-500);
    background: var(--brand-500);
    color: white;
  }

  .chip-count {
    font-size: var(--fs-11);
    font-weight: var(--fw-bold);
    background: color-mix(in srgb, currentColor 15%, transparent);
    border-radius: 100px;
    padding: 1px 6px;
    line-height: 1.6;
  }

  /* ── Уровень 2: пробники ── */
  .exam-chips {
    display: none;
    flex-wrap: wrap;
    gap: 6px;
    padding: 12px 0 20px;
    border-bottom: 1px solid var(--color-border);
    margin-bottom: 20px;
  }

  .exam-chips.is-active {
    display: flex;
  }

  .exam-chip {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    gap: 1px;
    padding: 8px 14px;
    border-radius: 8px;
    border: 1.5px solid var(--color-border);
    background: white;
    color: var(--color-text-secondary);
    cursor: pointer;
    transition:
      border-color 0.15s,
      background 0.15s,
      color 0.15s;
    text-align: left;
  }

  .exam-chip:hover {
    border-color: var(--brand-300);
    background: var(--brand-50);
    color: var(--color-brand);
  }

  .exam-chip.is-active {
    border-color: var(--brand-500);
    background: var(--brand-50);
    color: var(--color-brand);
  }

  .exam-chip-label {
    font-size: var(--fs-14);
    font-weight: var(--fw-semibold);
    line-height: var(--lh-ui);
  }

  .exam-chip-date {
    font-size: var(--fs-11);
    font-weight: var(--fw-medium);
    color: var(--color-text-muted);
    line-height: 1.3;
  }

  .exam-chip.is-active .exam-chip-date {
    color: var(--brand-400);
  }

  /* ── Уровень 3: панель учеников ── */
  .exam-panel {
    display: none;
  }

  .exam-panel.is-active {
    display: block;
  }

  /* ── Ученики ── */
  .students-grid {
    display: flex;
    flex-direction: column;
    gap: 10px;
  }

  .student-block {
    border: 1px solid var(--color-border);
    border-radius: 10px;
    overflow: hidden;
    transition: box-shadow 0.15s;
  }

  .student-block:has(.student-results:not([hidden])) {
    border-color: var(--brand-200);
    box-shadow: 0 2px 12px color-mix(in srgb, var(--brand-500) 8%, transparent);
  }

  .student-header {
    width: 100%;
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 14px 18px;
    background: var(--gray-50);
    border: none;
    cursor: pointer;
    text-align: left;
    transition: background 0.15s;
    gap: 12px;
  }

  .student-header:hover {
    background: var(--brand-50);
  }

  .student-block:has(.student-results:not([hidden])) .student-header {
    background: var(--brand-50);
  }

  .student-meta {
    display: flex;
    align-items: center;
    gap: 14px;
    flex-wrap: wrap;
  }

  .student-name {
    font-size: var(--fs-16);
    font-weight: var(--fw-semibold);
    color: var(--color-text);
    min-width: 60px;
  }

  .student-scores {
    display: flex;
    gap: 6px;
    flex-wrap: wrap;
    align-items: center;
  }

  .score-pill {
    font-size: var(--fs-12);
    font-weight: var(--fw-semibold);
    padding: 2px 10px;
    border-radius: 100px;
    line-height: 1.6;
    white-space: nowrap;
  }

  .score-primary {
    background: var(--gray-100);
    color: var(--gray-700);
  }
  .score-test {
    background: var(--brand-100);
    color: var(--brand-700);
  }
  .grade-5 {
    background: var(--success-100);
    color: var(--success-700);
  }
  .grade-4 {
    background: var(--brand-100);
    color: var(--brand-700);
  }
  .grade-3 {
    background: var(--accent-100);
    color: var(--accent-700);
  }

  .toggle-icon {
    color: var(--color-text-muted);
    flex-shrink: 0;
    transition: transform 0.2s;
    display: flex;
  }

  .student-header[aria-expanded="true"] .toggle-icon {
    transform: rotate(180deg);
    color: var(--color-brand);
  }

  /* ── Результаты ── */
  .student-results {
    padding: 20px 18px;
    border-top: 1px solid var(--color-border);
  }

  .summary-row {
    display: flex;
    background: var(--gray-50);
    border: 1px solid var(--color-border);
    border-radius: 8px;
    overflow: hidden;
    margin-bottom: 24px;
  }

  .summary-stat {
    flex: 1;
    display: flex;
    flex-direction: column;
    align-items: center;
    padding: 14px 12px;
    gap: 4px;
    border-right: 1px solid var(--color-border);
  }

  .summary-stat:last-child {
    border-right: none;
  }

  .stat-value {
    font-size: var(--fs-24);
    font-weight: var(--fw-bold);
    color: var(--success-600);
    line-height: 1.1;
  }

  .stat-test { color: var(--brand-600); }
  .stat-p1   { color: var(--gray-700); }
  .stat-p2   { color: var(--accent-700); }
  .stat-grade.grade-5 {
    color: var(--success-600);
  }
  .stat-grade.grade-4 {
    color: var(--brand-600);
  }
  .stat-grade.grade-3 {
    color: var(--accent-600);
  }

  .stat-label {
    font-size: var(--fs-11);
    font-weight: var(--fw-semibold);
    color: var(--color-text-muted);
    text-transform: uppercase;
    letter-spacing: 0.06em;
    text-align: center;
  }

  .section-title {
    font-size: var(--fs-14);
    font-weight: var(--fw-semibold);
    color: var(--color-text-secondary);
    text-transform: uppercase;
    letter-spacing: 0.06em;
    margin: 0 0 10px;
  }

  .table-wrap {
    overflow-x: auto;
    margin-bottom: 24px;
    border-radius: 8px;
    border: 1px solid var(--color-border);
  }

  table {
    width: 100%;
    border-collapse: collapse;
    font-size: var(--fs-13);
    min-width: 480px;
  }

  thead tr {
    background: var(--brand-500);
  }

  th {
    padding: 10px 12px;
    color: white;
    font-weight: var(--fw-semibold);
    font-size: var(--fs-12);
    text-align: center;
    white-space: nowrap;
  }

  td {
    padding: 9px 12px;
    border-top: 1px solid var(--color-border);
    text-align: center;
    vertical-align: middle;
  }

  tbody tr:nth-child(even) td {
    background: var(--gray-50);
  }

  .cell-num {
    font-weight: var(--fw-semibold);
    color: var(--color-text-secondary);
    white-space: nowrap;
  }

  .cell-comment {
    text-align: left;
    color: var(--color-text-secondary);
    font-style: italic;
    font-size: var(--fs-12);
  }

  .score-badge {
    display: inline-block;
    padding: 2px 8px;
    border-radius: 6px;
    font-weight: var(--fw-bold);
    font-size: var(--fs-12);
    line-height: 1.5;
  }

  .badge-max {
    background: var(--success-100);
    color: var(--success-700);
  }
  .badge-zero {
    background: var(--danger-100);
    color: var(--danger-700);
  }
  .badge-partial {
    background: var(--accent-100);
    color: var(--accent-700);
  }

  .status-tag {
    display: inline-block;
    padding: 2px 10px;
    border-radius: 100px;
    font-size: var(--fs-12);
    font-weight: var(--fw-semibold);
    white-space: nowrap;
  }

  .status-full {
    background: var(--success-100);
    color: var(--success-700);
  }
  .status-none {
    background: var(--danger-100);
    color: var(--danger-700);
  }
  .status-partial {
    background: var(--accent-100);
    color: var(--accent-700);
  }
</style>

<script>
  // Месяцы
  document.querySelectorAll<HTMLButtonElement>(".month-chip").forEach((btn) => {
    btn.addEventListener("click", () => {
      const monthId = btn.dataset.month!;

      document
        .querySelectorAll(".month-chip")
        .forEach((b) => b.classList.remove("is-active"));
      document
        .querySelectorAll(".exam-chips")
        .forEach((p) => p.classList.remove("is-active"));
      document
        .querySelectorAll(".exam-panel")
        .forEach((p) => p.classList.remove("is-active"));

      btn.classList.add("is-active");

      const chipsPanel = document.querySelector<HTMLElement>(
        `[data-month-panel="${monthId}"]`,
      );
      chipsPanel?.classList.add("is-active");

      // Активируем первый пробник этого месяца
      const firstChip =
        chipsPanel?.querySelector<HTMLButtonElement>(".exam-chip");
      if (firstChip) {
        firstChip.classList.add("is-active");
        const firstExamId = firstChip.dataset.exam!;
        document
          .querySelector<HTMLElement>(`[data-exam-panel="${firstExamId}"]`)
          ?.classList.add("is-active");
      }
    });
  });

  // Пробники
  document.querySelectorAll<HTMLButtonElement>(".exam-chip").forEach((btn) => {
    btn.addEventListener("click", () => {
      const examId = btn.dataset.exam!;
      const monthId = btn.dataset.month!;

      document
        .querySelectorAll<HTMLButtonElement>(
          `.exam-chip[data-month="${monthId}"]`,
        )
        .forEach((b) => b.classList.remove("is-active"));
      document
        .querySelectorAll(".exam-panel")
        .forEach((p) => p.classList.remove("is-active"));

      btn.classList.add("is-active");
      document
        .querySelector<HTMLElement>(`[data-exam-panel="${examId}"]`)
        ?.classList.add("is-active");
    });
  });

  // Аккордеон учеников
  document
    .querySelectorAll<HTMLButtonElement>(".student-header")
    .forEach((btn) => {
      btn.addEventListener("click", () => {
        const id = btn.dataset.toggle!;
        const results = document.getElementById(`results-${id}`);
        if (!results) return;
        const isOpen = !results.hidden;
        results.hidden = isOpen;
        btn.setAttribute("aria-expanded", String(!isOpen));
      });
    });
</script>
