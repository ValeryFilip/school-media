---
const href =
  "https://t.me/chemistry_examBot?start=s=3272321-utm_source=cite-utm_content=main";
---

<div class="tg-banner">
  <p class="tg-banner__text">
    Забери бесплатные курсы по подготовке к ЕГЭ по химии в нашем ТГ-канале
  </p>
  <a
    href={href}
    target="_blank"
    rel="noopener noreferrer"
    class="tg-banner__btn"
  >
    Перейти в Telegram
  </a>
</div>

<style>
  .tg-banner {
    display: flex;
    flex-direction: column;
    gap: var(--space-16);
    width: 100%;
    border-radius: var(--radius-24);
    padding: var(--space-20);
    background: linear-gradient(145deg, #1a6ef5 0%, #0d4fb8 60%, #083a8a 100%);
    color: white;
  }

  .tg-banner__text {
    margin: 0;
    font-size: clamp(14px, 1.1vw, 18px);
    font-weight: 700;
    line-height: 1.3;
    color: white;
  }

  .tg-banner__btn {
    display: block;
    background-color: white;
    color: #1a6ef5;
    font-weight: 700;
    font-size: clamp(13px, 1vw, 15px);
    border-radius: 10px;
    padding: 12px 0;
    text-align: center;
    width: 100%;
    text-decoration: none;
    transition:
      background-color 0.2s,
      transform 0.15s;
  }

  .tg-banner__btn:hover {
    background-color: rgba(255, 255, 255, 0.9);
    transform: translateY(-1px);
  }

  .tg-banner__btn:active {
    transform: translateY(0);
  }
</style>
