---
const href =
  "https://t.me/chemistry_examBot?start=s=3272321-utm_source=cite-utm_content=main";
---

<a href={href} target="_blank" rel="noopener noreferrer" class="tg-banner">
  <img
    src="/images/technical/vert-ad-tg-banner.webp"
    alt="Telegram-канал по химии"
    loading="lazy"
    width="272"
    height="400"
  />
</a>

<style>
  .tg-banner {
    display: block;
    border-radius: var(--radius-24);
    overflow: hidden;
    transition: transform 0.2s var(--easing);
  }

  .tg-banner:hover {
    transform: translateY(-4px);
  }

  .tg-banner img {
    width: 100%;
    height: auto;
    display: block;
  }
</style>
