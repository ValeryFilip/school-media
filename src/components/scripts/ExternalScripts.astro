---
/**
 * ExternalScripts.astro - Загрузчик внешних скриптов
 *
 * Загружает критичные внешние скрипты проекта:
 * - popup.js - управление модальными окнами
 * - forms.js - единый обработчик обычных форм
 *
 * Все скрипты загружаются асинхронно для оптимизации производительности.
 */

interface Props {
  loadPopup?: boolean;
  loadForms?: boolean;
  loadCaptcha?: boolean;
  popupPath?: string;
  formsPath?: string;
}

const {
  loadPopup = true,
  loadForms = true,
  loadCaptcha = true,
  popupPath = "/js/popup.js",
  formsPath = "/js/forms.js",
} = Astro.props;
---

{loadPopup && <script src={popupPath} defer />}

{loadForms && <script src={formsPath} defer />}

{loadCaptcha && (
  <script is:inline src="https://smartcaptcha.yandexcloud.net/captcha.js" defer />
)}
