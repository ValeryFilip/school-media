---
interface Props {
  loadPopup?: boolean;
  loadForms?: boolean;
  popupPath?: string;
  formsPath?: string;
}

const {
  loadPopup = true,
  loadForms = true,
  popupPath = "/js/popup.js",
  formsPath = "/js/forms.js",
} = Astro.props;
---

{loadPopup && <script src={popupPath} defer />}

{loadForms && <script src={formsPath} defer />}
