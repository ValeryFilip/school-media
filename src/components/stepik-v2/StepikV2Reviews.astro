---
import EgeH2 from "../ege/EgeH2.astro";

interface Props {
  data: {
    section: string;
    title: { text: string; marks?: readonly any[] };
    stats: ReadonlyArray<{ value: string; label: string }>;
    images: readonly ({ src: string; alt?: string } | string)[];
    moreHref: string;
  };
}

const { data } = Astro.props as Props;
const images = data.images.map((item) =>
  typeof item === "string" ? { src: item, alt: "Скриншот отзыва ученика" } : item,
);
const row1 = images.slice(0, Math.ceil(images.length / 2));
const row2 = images.slice(Math.ceil(images.length / 2));
const counterValue = (value: string) => {
  const match = value.match(/^(\d+(?:[.,]\d+)?)(.*)$/);
  if (!match) return null;
  return {
    value: match[1].replace(",", "."),
    suffix: match[2] || "",
    decimals: match[1].includes(".") || match[1].includes(",") ? "1" : "0",
  };
};
---

<section class="section relative overflow-hidden" id="reviews">
  <div class="gutter pt-20 md:pt-28 pb-8 md:pb-10">
    <div class="grid grid-cols-12 gap-6 mb-12">
      <div class="col-span-12 md:col-span-3"><div class="sec-num">{data.section}</div></div>
      <div class="col-span-12 md:col-span-9"><EgeH2 text={data.title.text} marks={data.title.marks} class="titrate" /></div>
    </div>
    <div class="grid grid-cols-1 md:grid-cols-3 gap-px bg-line border border-line mb-10">
      {data.stats.map((stat, i) => (
        <div class="bg-ink p-6">
          <div class:list={["font-display font-bold text-5xl", i === 0 && "text-acid", i === 2 && "text-fuchsia2"]} aria-label={stat.value}>
            {counterValue(stat.value) ? (
              <>
                <span
                  data-counter={counterValue(stat.value)?.value}
                  data-suffix={counterValue(stat.value)?.suffix}
                  data-decimals={counterValue(stat.value)?.decimals}
                >0</span>
                {stat.value === "4.9" && <span class="star" aria-hidden="true">⭐</span>}
              </>
            ) : (
              stat.value
            )}
          </div>
          <div class="label mt-3">{stat.label}</div>
        </div>
      ))}
    </div>

    {/* Фрейм для ленты отзывов: правило Stepik про 80% — единственный
        способ верифицировать честность отзывов в маркетплейс-модели.
        Плюс — позиционирование «70 на 3500+, потому что мы не выжималка». */}
    <div class="review-note">
      <div class="font-mono text-[11px] text-acid uppercase tracking-widest mb-3">// почему этим отзывам можно верить</div>
      <p class="font-mono text-[13px] text-paper leading-snug max-w-4xl">
        Все отзывы оставлены теми, кто прошёл больше&nbsp;<span class="text-acid font-bold">80% курса</span> —
        это правило Stepik, оно не зависит от автора. То, что ты увидишь ниже — голоса тех, кто реально
        дошёл до конца. <span class="text-dim">(80% этого курса — это больше 1000 заданий.)</span>
      </p>
      <p class="mt-4 font-mono text-[12px] text-dim leading-snug max-w-4xl">
        <span class="text-fuchsia2">70 отзывов на 3500+ учеников</span> — это не баг, а свойство платформы:
        отзыв нельзя оставить, не пройдя курс. Мы делаем качественное обучение, а не сотни &laquo;отзывов&raquo;
        через 5 минут после покупки.
      </p>
    </div>
  </div>

  {[row1, row2].map((row, rowIndex) => (
    <div class:list={["overflow-hidden", rowIndex === 1 && "mt-4"]}>
      {/* Двухслойная обёртка: внешний review-nudge получает inline
          transform по клику кнопки (с CSS transition) — едет плавно
          относительно той точки, где сейчас рисует marquee. Внутренний
          review-strip продолжает свой CSS-цикл, не рестартует. */}
      <div class:list={["review-nudge", rowIndex === 1 && "is-reverse-nudge"]}>
        <div class:list={["review-strip", rowIndex === 1 && "is-reverse"]}>
          {/* НЕ оборачивай <img> в <button> с data-* атрибутами на src —
              это триггерит Kaspersky/Adblock «native-ad gallery» эвристики. */}
          {[...row, ...row].map((image) => (
            <figure class="review-shot">
              <img src={image.src} alt={image.alt || "Скриншот отзыва ученика"} decoding="async" />
            </figure>
          ))}
        </div>
      </div>
    </div>
  ))}

  <div class="gutter mt-8 pb-20 md:pb-28 flex flex-wrap items-center gap-6 justify-between">
    <div class="flex items-center gap-3">
      <button
        type="button"
        class="review-nav"
        data-review-boost="-1"
        aria-label="Ускорить ленту назад"
      >←</button>
      <button
        type="button"
        class="review-nav"
        data-review-boost="1"
        aria-label="Ускорить ленту вперёд"
      >→</button>
    </div>
    <a href={data.moreHref} class="inline-flex items-center gap-3 font-mono text-[12px] uppercase tracking-widest text-paper/80 hover:text-acid">
      смотреть больше отзывов <span>↗</span>
    </a>
  </div>

  <div class="review-modal" data-review-modal hidden role="dialog" aria-modal="true" aria-label="Просмотр отзыва">
    <button type="button" class="review-modal__close" data-review-close aria-label="Закрыть отзыв">×</button>
    <button type="button" class="review-modal__backdrop" data-review-close aria-label="Закрыть отзыв"></button>
    <img class="review-modal__image" data-review-image alt="" />
  </div>
</section>

<script is:inline>
  // Marquee едет своим CSS-циклом, не трогаем. По клику двигаем
  // внешний review-nudge на ±400px относительно его текущей позиции.
  // Transition в CSS делает движение плавным.
  document.addEventListener("DOMContentLoaded", function () {
    var STEP = 400; // px на одно нажатие
    var nudgeOffsets = []; // массив cumulative offsets per nudge
    var nudges = document.querySelectorAll(".review-nudge");
    nudges.forEach(function (_, i) { nudgeOffsets[i] = 0; });

    document.querySelectorAll("[data-review-boost]").forEach(function (btn) {
      btn.addEventListener("click", function () {
        var dir = Number(btn.dataset.reviewBoost) || 1;
        nudges.forEach(function (nudge, i) {
          // Forward-лента (i=0) едет влево; кнопка → должна визуально
          // двинуть её ещё левее = transform: negative.
          // Reverse-лента (i=1) едет вправо; кнопка → двинуть правее = positive.
          var sign = i === 0 ? -1 : 1;
          nudgeOffsets[i] += dir * sign * STEP;
          nudge.style.transform = "translate3d(" + nudgeOffsets[i] + "px, 0, 0)";
        });
      });
    });

    document.querySelectorAll("[data-review-modal]").forEach(function (modal) {
      const image = modal.querySelector("[data-review-image]");
      const closeButtons = modal.querySelectorAll("[data-review-close]");
      const section = modal.closest("section");
      if (!(image instanceof HTMLImageElement) || !section) return;

      const close = () => {
        modal.setAttribute("hidden", "");
        image.removeAttribute("src");
        image.alt = "";
        document.documentElement.classList.remove("review-modal-open");
      };

      // Читаем src/alt напрямую с <img> при клике — никаких data-* атрибутов
      // с URL в DOM, иначе security-scanner'ы (Kaspersky, AdGuard) видят
      // URL дважды и фоном фетчат каждую картинку.
      section.querySelectorAll(".review-shot img").forEach((img) => {
        if (!(img instanceof HTMLImageElement)) return;
        img.addEventListener("click", () => {
          image.src = img.src;
          image.alt = img.alt || "Скриншот отзыва ученика";
          modal.removeAttribute("hidden");
          document.documentElement.classList.add("review-modal-open");
        });
      });

      closeButtons.forEach((button) => button.addEventListener("click", close));
      document.addEventListener("keydown", (event) => {
        if (event.key === "Escape" && !modal.hasAttribute("hidden")) close();
      });
    });
  });
</script>

<style>
  /* Внешний nudge-слой — JS пишет inline transform: translateX(--Npx).
     Transition делает движение плавным. Marquee внутри не трогается,
     поэтому CSS-анимация не рестартует. */
  .review-nudge {
    transition: transform 600ms cubic-bezier(0.2, 0, 0.2, 1);
    will-change: transform;
  }

  .review-strip {
    display: flex;
    width: max-content;
    gap: 16px;
    /* GPU-композит-слой — Kaspersky не видит DOM как «постоянно меняющийся». */
    will-change: transform;
    transform: translate3d(0, 0, 0);
    backface-visibility: hidden;
    /* 180s/200s соответствуют новой ширине shot (720px) — px/s остаются
       прежние, как с шириной 380. */
    animation: review-marquee 180s linear infinite;
  }
  .review-strip.is-reverse {
    animation-name: review-marquee-reverse;
    animation-duration: 200s;
  }

  .review-nav {
    width: 44px;
    height: 44px;
    display: grid;
    place-items: center;
    border: 1px solid var(--line);
    background: var(--ink);
    color: var(--paper);
    font-family: "JetBrains Mono", monospace;
    font-size: 16px;
    cursor: pointer;
    transition: background 150ms ease, border-color 150ms ease, color 150ms ease;
  }
  .review-nav:hover {
    background: var(--acid);
    border-color: var(--acid);
    color: var(--ink);
  }
  .review-nav:focus-visible {
    outline: 2px solid var(--acid);
    outline-offset: 2px;
  }
  .review-shot {
    /* Реальные скриншоты отзывов — 1800×~300, соотношение ~6:1.
       Раньше контейнер был 380×260 (1.5:1) → object-fit:contain
       fit'ил картинку в ширину и оставлял ~75% пустоты сверху-снизу.
       Делаем контейнер по аспекту контента. */
    flex: 0 0 auto;
    width: 720px;
    aspect-ratio: 6 / 1;
    margin: 0;
    padding: 0;
    background: transparent;
    transition: transform .18s ease;
    overflow: hidden;
  }
  .review-shot:hover { transform: translateY(-2px); }
  .review-shot img {
    display: block;
    width: 100%;
    height: 100%;
    object-fit: cover;
    cursor: zoom-in;
  }
  @media (max-width: 600px) {
    .review-shot {
      width: 360px;
    }
  }
  .review-note {
    border: 1px solid var(--line);
    background: var(--ink);
    padding: 20px;
  }
  .review-modal[hidden] { display: none; }
  .review-modal {
    position: fixed;
    inset: 0;
    z-index: 9999;
    display: grid;
    place-items: center;
    padding: clamp(16px, 4vw, 48px);
  }
  .review-modal__backdrop {
    position: absolute;
    inset: 0;
    background: rgba(10, 10, 10, .86);
    backdrop-filter: blur(4px);
  }
  .review-modal__image {
    position: relative;
    z-index: 1;
    max-width: min(1180px, 94vw);
    max-height: 88vh;
    width: auto;
    height: auto;
    object-fit: contain;
  }
  .review-modal__close {
    position: fixed;
    top: 18px;
    right: 18px;
    z-index: 2;
    width: 52px;
    height: 52px;
    border: 1px solid var(--paper);
    background: var(--ink);
    color: var(--paper);
    font-family: "JetBrains Mono", monospace;
    font-size: 30px;
    line-height: 1;
  }
  .review-modal__close:hover {
    background: var(--acid);
    color: var(--ink);
    border-color: var(--acid);
  }
  :global(.review-modal-open) { overflow: hidden; }
  @keyframes review-marquee {
    from { transform: translate3d(0, 0, 0); }
    to   { transform: translate3d(-50%, 0, 0); }
  }
  @keyframes review-marquee-reverse {
    from { transform: translate3d(-50%, 0, 0); }
    to   { transform: translate3d(0, 0, 0); }
  }
</style>
