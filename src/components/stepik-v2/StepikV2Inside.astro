---
import EgeH2 from "../ege/EgeH2.astro";
import EgeAcidButton from "../ege/EgeAcidButton.astro";

interface Slide {
  media: { src: string; alt: string };
  kicker: string;
  title: string;
  text: string;
}

interface Props {
  data: {
    section: string;
    title: { text: string; marks?: readonly any[] };
    cta: { href: string; label: string };
    slides: Slide[];
  };
}

const { data } = Astro.props as Props;
const pad = (n: number) => String(n + 1).padStart(2, "0");
---

<section class="section relative" id="inside" data-stepik-inside>
  <div class="gutter py-24 md:py-32">
    <div class="grid grid-cols-12 gap-6 mb-14">
      <div class="col-span-12 md:col-span-3">
        <div class="sec-num">{data.section}</div>
      </div>
      <div class="col-span-12 md:col-span-9">
        <EgeH2 text={data.title.text} marks={data.title.marks} class="titrate" />
      </div>
    </div>
    <div class="border border-line">
      <div class="grid grid-cols-12">
        <div class="col-span-12 md:col-span-7 border-b md:border-b-0 md:border-r border-line bg-ink relative aspect-[4/3] md:aspect-auto md:min-h-[520px]">
          {data.slides.map((slide, i) => (
            <div class:list={["inside-media absolute inset-0", i === 0 && "is-active"]} data-panel={i}>
              <div class="absolute inset-6 md:inset-10 border border-line p-5 flex flex-col">
                <div class="flex items-center gap-1 mb-4">
                  <span class="w-2.5 h-2.5 bg-fuchsia2 rounded-full"></span>
                  <span class="w-2.5 h-2.5 bg-acid rounded-full"></span>
                  <span class="w-2.5 h-2.5 bg-dim rounded-full"></span>
                  <span class="ml-auto font-mono text-[10px] text-dim">stepik.org / {pad(i)} / organic</span>
                </div>
                <div class="flex-1 bg-coal border border-line relative overflow-hidden">
                  {slide.media.src.endsWith(".webm") || slide.media.src.endsWith(".mp4") ? (
                    <video
                      src={slide.media.src}
                      class="absolute inset-0 w-full h-full object-cover"
                      autoplay
                      muted
                      loop
                      playsinline
                      preload="metadata"
                      aria-label={slide.media.alt}
                    />
                  ) : (
                    <img src={slide.media.src} alt={slide.media.alt} class="absolute inset-0 w-full h-full object-cover" loading="lazy" decoding="async" />
                  )}
                </div>
              </div>
            </div>
          ))}
        </div>

        <div class="col-span-12 md:col-span-5 p-8 md:p-12 flex flex-col justify-between bg-ink">
          <div>
            <div class="inside-counter font-mono text-[12px] text-acid uppercase tracking-widest mb-6">01 / {String(data.slides.length).padStart(2, "0")}</div>
            <div class="inside-content min-h-[180px]">
              <div class="font-mono text-[11px] text-dim uppercase tracking-widest mb-4">{data.slides[0].kicker}</div>
              <h3 class="font-display font-bold text-2xl md:text-3xl leading-tight mb-4">{data.slides[0].title}</h3>
              <p class="text-paper/80 leading-snug">{data.slides[0].text}</p>
            </div>
          </div>

          <div class="mt-10 pt-8 border-t border-line">
            <div class="flex items-center justify-between gap-4">
              <EgeAcidButton href={data.cta.href} label={data.cta.label} arrow="→" class="px-5 py-4 text-sm" />
              <div class="flex gap-2">
                <button type="button" class="prev-inside w-12 h-12 border border-paper grid place-items-center hover:bg-paper hover:text-ink transition font-mono" aria-label="Предыдущий слайд">←</button>
                <button type="button" class="next-inside w-12 h-12 border border-paper grid place-items-center hover:bg-paper hover:text-ink transition font-mono" aria-label="Следующий слайд">→</button>
              </div>
            </div>
            <div class="inside-dots mt-4 flex gap-1.5">
              {data.slides.map((_, i) => <button type="button" data-i={i} class:list={["h-1 flex-1 transition", i === 0 ? "bg-acid" : "bg-line"]} aria-label={`Слайд ${i + 1}`}></button>)}
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<script define:vars={{ slides: data.slides }}>
  document.addEventListener("DOMContentLoaded", function () {
    document.querySelectorAll("[data-stepik-inside]").forEach(function (root) {
      var panels = root.querySelectorAll(".inside-media");
      var prev = root.querySelector(".prev-inside");
      var next = root.querySelector(".next-inside");
      var counter = root.querySelector(".inside-counter");
      var content = root.querySelector(".inside-content");
      var dots = root.querySelectorAll(".inside-dots button");
      var idx = 0;
      function render() {
        panels.forEach(function (panel, i) { panel.classList.toggle("is-active", i === idx); });
        if (counter) counter.textContent = String(idx + 1).padStart(2, "0") + " / " + String(slides.length).padStart(2, "0");
        if (content) {
          var d = slides[idx];
          content.innerHTML =
            '<div class="font-mono text-[11px] text-dim uppercase tracking-widest mb-4">' + d.kicker + '</div>' +
            '<h3 class="font-display font-bold text-2xl md:text-3xl leading-tight mb-4">' + d.title + '</h3>' +
            '<p class="text-paper/80 leading-snug">' + d.text + '</p>';
        }
        dots.forEach(function (dot, i) {
          dot.classList.toggle("bg-acid", i === idx);
          dot.classList.toggle("bg-line", i !== idx);
        });
      }
      function go(nextIndex) {
        idx = (nextIndex + slides.length) % slides.length;
        render();
      }
      if (prev) prev.addEventListener("click", function () { go(idx - 1); });
      if (next) next.addEventListener("click", function () { go(idx + 1); });
      dots.forEach(function (dot) {
        dot.addEventListener("click", function () { go(Number(dot.getAttribute("data-i") || 0)); });
      });
    });
  });
</script>

<style>
  .inside-media { display: none; }
  .inside-media.is-active { display: block; }
</style>
