---
import EgeH2 from "../ege/EgeH2.astro";

interface Props {
  data: any;
}

const { data } = Astro.props as Props;
---

<section class="pricing-section relative" id="price">
  <div class="gutter py-24 md:py-32">
    <div class="grid grid-cols-12 gap-6 mb-12">
      <div class="col-span-12 md:col-span-3">
        <div class="font-mono text-[12px] tracking-wider uppercase text-ink/70">{data.section}</div>
      </div>
      <div class="col-span-12 md:col-span-9">
        <EgeH2 text={data.title.text} marks={data.title.marks} class="text-[clamp(40px,7vw,128px)] text-ink titrate" />
        <div class="mt-6 inline-flex items-center gap-3 bg-ink text-paper px-4 py-2 font-mono text-xs" set:html={`<span class="w-2 h-2 bg-acid"></span>${data.badgeHtml}`} />
      </div>
    </div>

    <div class="border-2 border-ink relative bg-ink text-paper">
      <div class="bg-acid text-ink font-mono text-[11px] tracking-widest py-2 px-5 uppercase font-bold flex flex-wrap items-center justify-between gap-2">
        <span>{data.featured.ribbonLeft}</span><span class="hidden md:inline">{data.featured.ribbonRight}</span>
      </div>
      <div class="grid grid-cols-12">
        <div class="col-span-12 lg:col-span-5 p-8 md:p-12 border-b lg:border-b-0 lg:border-r border-line">
          <div class="flex items-center justify-between mb-3">
            <div class="font-mono text-[12px] text-acid">{data.featured.metaLeft}</div>
            <div class="font-mono text-[11px] text-dim">{data.featured.metaRight}</div>
          </div>
          <div class="font-display font-bold text-[clamp(44px,5.2vw,76px)] leading-[0.9] tracking-[-0.025em] whitespace-pre-line break-words">{data.featured.title}</div>
          <div class="font-mono text-sm text-dim mt-3 mb-8">{data.featured.subtitle}</div>
          <div class="relative mb-2">
            <div class="font-mono text-base text-dim line-through inline-block">{data.featured.oldPrice}</div>
            <span class="inline-block ml-3 bg-fuchsia2 text-ink font-mono text-[10px] px-2 py-1 align-middle font-bold tracking-widest">{data.featured.discount}</span>
          </div>
          <div class="flex items-baseline gap-3 mb-2">
            <div class="font-display font-bold text-[clamp(48px,7vw,96px)] leading-none text-acid">{data.featured.price}</div>
            <div class="font-mono text-sm text-dim">{data.featured.period}</div>
          </div>
          <div class="font-mono text-xs text-dim mb-8">{data.featured.installment}</div>
          <div class="border border-fuchsia2 p-4 mb-6">
            <div class="flex items-center justify-between font-mono text-[11px] mb-2">
              <span class="text-fuchsia2">{data.featured.placesLabel}</span>
              <span><span class="text-fuchsia2 font-bold">{data.featured.placesCurrent}</span> <span class="text-dim">{data.featured.placesTotal}</span></span>
            </div>
            <div class="h-1.5 bg-line relative overflow-hidden">
              <div class="absolute inset-y-0 left-0 bg-fuchsia2" style={`width:${data.featured.placesWidth}`}></div>
            </div>
          </div>
          <div class="grid gap-3">
            <button type="button" data-payment-url={data.featured.paymentUrl} data-ym-goal="payment_main" class="cta-pulse relative block w-full cursor-pointer border-0 text-center bg-acid text-ink py-5 font-display font-bold uppercase tracking-tight text-lg hover:bg-paper transition overflow-hidden">
              <span class="bub" style="width:6px;height:6px;left:20px;bottom:10px;"></span>
              <span class="bub" style="width:4px;height:4px;left:40px;bottom:16px;"></span>
              {data.featured.cta}
            </button>
            <a href={data.featured.stepikUrl} target="_blank" rel="noopener" data-ym-goal="stepik_main" class="block w-full text-center border border-line py-4 font-mono text-[12px] uppercase tracking-widest text-paper hover:bg-paper hover:text-ink transition">
              {data.featured.directCta ?? "Курс на Stepik"}
            </a>
          </div>
          <div class="mt-4 border-l-2 border-acid pl-3 py-1 font-mono text-[12px] text-paper leading-snug">{data.featured.note}</div>
        </div>

        <div class="col-span-12 lg:col-span-7">
          <div class="grid grid-cols-1 sm:grid-cols-2 gap-px bg-line border-b border-line">
            {data.bonuses.map((bonus: string[]) => (
              <div class="bg-ink p-5">
                <div class="font-mono text-[10px] text-acid uppercase mb-2">{bonus[0]}</div>
                <div class="font-display font-bold text-xl leading-tight">{bonus[1]}</div>
                <p class="font-mono text-[11px] text-dim mt-2 leading-snug">{bonus[2]}</p>
              </div>
            ))}
          </div>
          <div class="p-8 md:p-10">
            <div class="font-mono text-[11px] text-dim uppercase tracking-widest mb-5">// что входит в курс</div>
            <ul class="grid grid-cols-1 md:grid-cols-2 gap-x-6 gap-y-3 font-mono text-sm text-paper/90">
              {data.includes.map((item: string) => <li class="flex gap-3"><span class="text-acid">✓</span><span>{item}</span></li>)}
            </ul>
          </div>
        </div>
      </div>
    </div>

    <div class="mt-6 grid grid-cols-1 md:grid-cols-2 gap-6">
      {data.packages.map((pack: any) => (
        <article class="bg-ink text-paper p-6 md:p-8 border border-ink hover:border-fuchsia2 transition group">
          <div class="flex items-start justify-between gap-4 mb-4">
            <div class="font-mono text-[11px] text-fuchsia2">{pack.label}</div>
            <div class="font-mono text-[11px] text-dim group-hover:text-fuchsia2 transition">{pack.side}</div>
          </div>
          <div class="font-display font-bold text-3xl md:text-4xl mb-1 leading-tight">{pack.title}</div>
          <div class="font-mono text-xs text-dim mb-6">{pack.subtitle}</div>
          <div class="flex items-baseline gap-3 mb-4">
            <div class="font-display font-bold text-3xl">{pack.price}</div>
            <div class="font-mono text-[11px] text-dim line-through">{pack.oldPrice}</div>
            <div class="font-mono text-[11px] text-fuchsia2 font-bold">{pack.discount}</div>
          </div>
          <p class="font-mono text-xs text-paper/80 leading-snug mb-5">{pack.text}</p>

          <div class="grid grid-cols-1 sm:grid-cols-2 gap-2">
            {pack.paymentUrl && (
              <button
                type="button"
                data-payment-url={pack.paymentUrl}
                data-ym-goal="payment_upsell"
                class="block w-full cursor-pointer border-0 text-center bg-acid text-ink py-3 font-mono font-bold uppercase tracking-widest text-[12px] hover:bg-paper transition"
              >
                {pack.payCta ?? "Оплатить со скидкой 5%"}
              </button>
            )}
            <a
              href={pack.href}
              target={pack.href?.startsWith("http") ? "_blank" : undefined}
              rel={pack.href?.startsWith("http") ? "noopener" : undefined}
              class="block w-full text-center border border-line py-3 font-mono uppercase tracking-widest text-[11px] text-paper hover:bg-paper hover:text-ink transition"
            >
              {pack.detailsCta ?? "Подробнее"}
            </a>
          </div>
        </article>
      ))}
    </div>

    <div class="mt-6 grid grid-cols-1 md:grid-cols-3 gap-px bg-ink/15 border border-ink/20">
      {data.facts.map((fact: string[]) => (
        <div class="bg-acid p-6 md:p-7">
          <div class="font-mono text-[11px] text-ink/60 uppercase tracking-wider mb-3">{fact[0]}</div>
          <div class="font-display font-bold text-xl md:text-2xl leading-tight">{fact[1]}</div>
          <p class="font-mono text-[12px] text-ink/70 mt-3 leading-snug">{fact[2]}</p>
        </div>
      ))}
    </div>
  </div>
</section>

<style>
  .pricing-section { background: var(--fuchsia2); color: var(--ink); }
</style>
