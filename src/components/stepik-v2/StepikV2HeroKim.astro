---
/**
 * Hero-визуал для лендинга авторских вариантов ЕГЭ.
 * «Живой КИМ»: номер варианта прокручивается (из 15), сетка заданий части 1
 * заполняется и автопроверяется волной (галочки), часть 2 и прогресс-бар.
 * Полностью на CSS, самодостаточный (без EgeScripts). Декоративный — aria-hidden
 * ставится на стейдж в StepikV2Hero.
 */
const cells = Array.from({ length: 28 }, (_, i) => i + 1);
const reel = ["01", "04", "07", "11", "02", "13", "06", "09", "01"];
---

<div class="kim">
  <div class="kim__card">
    <div class="kim__head">
      <div class="kim__eyebrow">
        <span>// тренировочный КИМ</span>
        <span class="kim__live"><i></i> авто</span>
      </div>
      <div class="kim__title">Химия · ЕГЭ</div>
      <div class="kim__meta">
        <span class="kim__variant">
          ВАРИАНТ №&nbsp;<span class="kim__reel"><span class="kim__reel-track">{reel.map((n) => <span>{n}</span>)}</span></span>
        </span>
        <span class="kim__of">/ из 15</span>
      </div>
    </div>

    <div class="kim__label">// часть 1 · автопроверка</div>
    <div class="kim__grid">
      {cells.map((n, i) => (
        <span class="kim__cell" style={`--i:${i}`}><b>{n}</b></span>
      ))}
    </div>

    <div class="kim__label kim__label--f">// часть 2 · № 29–34 · развёрнутый</div>
    <div class="kim__lines">
      <div class="kim__line" style="--i:0"></div>
      <div class="kim__line" style="--i:1; width:82%"></div>
    </div>

    <div class="kim__foot">
      <span class="kim__foot-t">15 вариантов · ФИПИ 2027</span>
      <span class="kim__bar"><i></i></span>
    </div>
  </div>
</div>

<style>
  .kim {
    position: absolute;
    inset: 0;
    display: flex;
    align-items: center;
    justify-content: center;
  }
  .kim__card {
    position: relative;
    width: 100%;
    height: 100%;
    display: flex;
    flex-direction: column;
    gap: 8px;
    padding: 16px clamp(14px, 2.4vw, 22px);
    background:
      linear-gradient(135deg, rgba(167, 255, 74, 0.06), transparent 42%),
      var(--coal, #14130f);
    border: 1px solid var(--line);
    box-shadow: 0 0 0 1px rgba(167, 255, 74, 0.1), 0 24px 60px rgba(0, 0, 0, 0.45);
    overflow: hidden;
  }
  /* бегущая «развёртка» поверх карточки */
  .kim__card::after {
    content: "";
    position: absolute;
    left: 0;
    right: 0;
    top: 0;
    height: 38%;
    background: linear-gradient(180deg, rgba(167, 255, 74, 0.1), transparent);
    pointer-events: none;
    animation: kimScan 5.6s linear infinite;
  }

  .kim__head { display: flex; flex-direction: column; gap: 6px; }
  .kim__eyebrow {
    display: flex; align-items: center; justify-content: space-between;
    font-family: "JetBrains Mono", monospace;
    font-size: 9.5px; letter-spacing: 0.14em; text-transform: uppercase;
    color: var(--dim);
  }
  .kim__live { display: inline-flex; align-items: center; gap: 5px; color: var(--acid); }
  .kim__live i {
    width: 6px; height: 6px; background: var(--acid); border-radius: 50%;
    animation: kimBlink 1.1s steps(1) infinite;
  }
  .kim__title {
    font-family: var(--font-display, inherit);
    font-weight: 800; font-size: clamp(16px, 2.4vw, 23px);
    line-height: 1; color: var(--paper);
  }
  .kim__meta {
    display: flex; align-items: baseline; justify-content: space-between;
    font-family: "JetBrains Mono", monospace; font-size: 11px;
  }
  .kim__variant { color: var(--fuchsia2, #ff4fd8); font-weight: 700; letter-spacing: 0.04em; }
  .kim__of { color: var(--dim); font-size: 10px; }

  /* реел с номером варианта */
  .kim__reel {
    display: inline-block; height: 14px; line-height: 14px; overflow: hidden;
    vertical-align: bottom;
  }
  .kim__reel-track {
    display: flex; flex-direction: column;
    animation: kimReel 7.2s steps(8) infinite;
  }
  .kim__reel-track > span { height: 14px; line-height: 14px; }

  .kim__label {
    font-family: "JetBrains Mono", monospace;
    font-size: 9px; letter-spacing: 0.12em; text-transform: uppercase;
    color: var(--dim);
  }
  .kim__label--f { color: var(--fuchsia2, #ff4fd8); opacity: 0.8; }

  .kim__grid {
    flex: 1 1 auto;
    min-height: 0;
    display: grid; grid-template-columns: repeat(7, 1fr);
    grid-auto-rows: 1fr; gap: 5px;
  }
  .kim__cell {
    position: relative;
    min-height: 0; min-width: 0;
    display: grid; place-items: center;
    border: 1px solid var(--line);
    background: rgba(244, 239, 223, 0.03);
    color: var(--dim);
    font-family: "JetBrains Mono", monospace; font-size: 9px;
    animation: kimFill 4.6s ease-in-out infinite;
    animation-delay: calc(var(--i) * 0.11s);
  }
  .kim__cell b { font-weight: 500; transition: opacity 0.2s; }
  .kim__cell::after {
    content: "✓";
    position: absolute; inset: 0;
    display: grid; place-items: center;
    color: var(--ink); font-size: 11px; font-weight: 800;
    opacity: 0;
    animation: kimCheck 4.6s ease-in-out infinite;
    animation-delay: calc(var(--i) * 0.11s);
  }

  .kim__lines { display: flex; flex-direction: column; gap: 5px; }
  .kim__line {
    height: 7px; width: 100%;
    background: linear-gradient(90deg, var(--line) 0 0) no-repeat;
    background-size: 0% 100%;
    border-bottom: 1px solid rgba(244, 239, 223, 0.12);
    animation: kimWrite 4.6s ease-in-out infinite;
    animation-delay: calc(var(--i) * 0.5s + 1.4s);
  }

  .kim__foot {
    flex: none;
    display: flex; align-items: center; justify-content: space-between; gap: 10px;
    padding-top: 8px; border-top: 1px solid var(--line);
    font-family: "JetBrains Mono", monospace; font-size: 9px; color: var(--dim);
  }
  .kim__foot-t {
    min-width: 0; white-space: nowrap; overflow: hidden; text-overflow: ellipsis;
  }
  .kim__bar {
    flex: none; width: 84px; height: 4px; background: var(--line); overflow: hidden;
  }
  .kim__bar i {
    display: block; height: 100%; width: 100%;
    background: var(--acid); transform-origin: left;
    animation: kimBar 4.6s ease-in-out infinite;
  }

  @keyframes kimFill {
    0%, 100% { background: rgba(244, 239, 223, 0.03); border-color: var(--line); color: var(--dim); }
    18% { background: var(--acid); border-color: var(--acid); color: transparent; }
    70% { background: var(--acid); border-color: var(--acid); color: transparent; }
    84% { background: rgba(244, 239, 223, 0.03); border-color: var(--line); color: var(--dim); }
  }
  @keyframes kimCheck {
    0%, 12% { opacity: 0; transform: scale(0.6); }
    20%, 70% { opacity: 1; transform: scale(1); }
    84%, 100% { opacity: 0; transform: scale(0.6); }
  }
  @keyframes kimWrite {
    0% { background-size: 0% 100%; }
    45%, 80% { background-size: 100% 100%; }
    100% { background-size: 0% 100%; }
  }
  @keyframes kimBar {
    0% { transform: scaleX(0); }
    70%, 84% { transform: scaleX(1); }
    100% { transform: scaleX(0); }
  }
  @keyframes kimReel {
    to { transform: translateY(-112px); }
  }
  @keyframes kimScan {
    0% { transform: translateY(-100%); }
    100% { transform: translateY(320%); }
  }
  @keyframes kimBlink {
    0%, 60% { opacity: 1; }
    61%, 100% { opacity: 0.2; }
  }

  @media (prefers-reduced-motion: reduce) {
    .kim__card::after,
    .kim__reel-track,
    .kim__cell,
    .kim__cell::after,
    .kim__line,
    .kim__bar i,
    .kim__live i { animation: none; }
    .kim__cell:nth-child(3n) { background: var(--acid); border-color: var(--acid); color: transparent; }
    .kim__cell:nth-child(3n)::after { opacity: 1; }
  }
</style>
