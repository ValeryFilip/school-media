---
/**
 * Единая модалка просмотра картинок в стиле лендинга (тёмная тема).
 * Открывается по клику на любой элемент с атрибутом data-lightbox-src
 * (опционально data-lightbox-alt). Достаточно одного экземпляра на странице.
 *
 * Если триггер находится внутри контейнера с data-lightbox-group,
 * модалка собирает все картинки группы и работает как слайдер
 * (стрелки, счётчик, клавиши ← →, свайп).
 */
---

<div class="ege-lb" id="egeLightbox" aria-hidden="true" role="dialog" aria-modal="true">
  <div class="ege-lb__bar font-mono">
    <span class="ege-lb__tag" id="egeLightboxCap">// скриншот</span>
    <div class="ege-lb__nav" id="egeLightboxNav" hidden>
      <button class="ege-lb__navbtn" type="button" data-lb-prev aria-label="Предыдущее изображение">←</button>
      <span class="ege-lb__count" aria-live="polite">
        <span id="egeLightboxCurrent">1</span> / <span id="egeLightboxTotal">1</span>
      </span>
      <button class="ege-lb__navbtn" type="button" data-lb-next aria-label="Следующее изображение">→</button>
    </div>
    <button class="ege-lb__close" type="button" aria-label="Закрыть">[ ЗАКРЫТЬ ✕ ]</button>
  </div>
  <div class="ege-lb__viewport" id="egeLightboxViewport">
    <button class="ege-lb__edge ege-lb__edge--prev" type="button" data-lb-prev aria-label="Предыдущее изображение" hidden>←</button>
    <img class="ege-lb__img" id="egeLightboxImg" src="" alt="" />
    <button class="ege-lb__edge ege-lb__edge--next" type="button" data-lb-next aria-label="Следующее изображение" hidden>→</button>
  </div>
</div>

<style>
  .ege-lb {
    position: fixed;
    inset: 0;
    z-index: 99999;
    display: none;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 16px;
    padding: 24px;
    background: rgba(10, 10, 10, 0.92);
    background: color-mix(in srgb, var(--ink) 92%, transparent);
    backdrop-filter: blur(4px);
    opacity: 0;
    transition: opacity 0.2s ease;
  }
  .ege-lb.is-open {
    display: flex;
    opacity: 1;
  }
  .ege-lb__bar {
    width: 100%;
    max-width: 90vw;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 16px;
    font-size: 11px;
    letter-spacing: 0.05em;
  }
  .ege-lb__tag {
    color: var(--dim);
    flex: 1 1 0;
    min-width: 0;
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
  }
  .ege-lb__nav {
    display: grid;
    grid-template-columns: 40px auto 40px;
    align-items: center;
    border: 1px solid var(--line);
  }
  .ege-lb__nav[hidden] {
    display: none;
  }
  .ege-lb__navbtn {
    height: 34px;
    border: 0;
    background: transparent;
    color: var(--acid);
    cursor: pointer;
    font-size: 16px;
    line-height: 1;
    transition:
      background 0.15s ease,
      color 0.15s ease;
  }
  .ege-lb__navbtn:hover,
  .ege-lb__navbtn:focus-visible {
    background: var(--acid);
    color: var(--ink);
  }
  .ege-lb__count {
    min-width: 62px;
    text-align: center;
    color: var(--paper);
    font-size: 10px;
    font-weight: 700;
    letter-spacing: 0.1em;
  }
  .ege-lb__close {
    color: var(--acid);
    border: 1px solid var(--line);
    background: transparent;
    padding: 8px 12px;
    cursor: pointer;
    white-space: nowrap;
    transition:
      background 0.2s ease,
      color 0.2s ease;
  }
  .ege-lb__close:hover {
    background: var(--acid);
    color: var(--ink);
  }
  .ege-lb__viewport {
    position: relative;
    width: 90vw;
    height: 80vh;
    display: flex;
    align-items: center;
    justify-content: center;
    overflow: auto;
  }
  .ege-lb__viewport.is-zoomed {
    align-items: flex-start;
    justify-content: flex-start;
  }
  .ege-lb__img {
    max-width: 100%;
    max-height: 100%;
    width: auto;
    height: auto;
    object-fit: contain;
    border: 1px solid var(--line);
    background: var(--ink);
    display: block;
    cursor: zoom-in;
    user-select: none;
    -webkit-user-drag: none;
  }
  .ege-lb__viewport.is-zoomed .ege-lb__img {
    max-width: none;
    max-height: none;
    cursor: zoom-out;
  }
  .ege-lb__edge {
    position: absolute;
    top: 50%;
    transform: translateY(-50%);
    z-index: 2;
    width: 48px;
    height: 64px;
    display: flex;
    align-items: center;
    justify-content: center;
    border: 1px solid var(--line);
    background: color-mix(in srgb, var(--ink) 80%, transparent);
    color: var(--acid);
    font-size: 22px;
    line-height: 1;
    cursor: pointer;
    transition:
      background 0.15s ease,
      color 0.15s ease;
  }
  .ege-lb__edge[hidden] {
    display: none;
  }
  .ege-lb__edge--prev {
    left: 8px;
  }
  .ege-lb__edge--next {
    right: 8px;
  }
  .ege-lb__edge:hover,
  .ege-lb__edge:focus-visible {
    background: var(--acid);
    color: var(--ink);
  }
  .ege-lb__viewport.is-zoomed .ege-lb__edge {
    display: none;
  }
</style>

<script>
  (function () {
    const lb = document.getElementById("egeLightbox");
    if (!lb) return;
    const img = document.getElementById("egeLightboxImg") as HTMLImageElement | null;
    const cap = document.getElementById("egeLightboxCap");
    const viewport = document.getElementById("egeLightboxViewport");
    const nav = document.getElementById("egeLightboxNav");
    const currentEl = document.getElementById("egeLightboxCurrent");
    const totalEl = document.getElementById("egeLightboxTotal");
    const closeBtn = lb.querySelector(".ege-lb__close");
    const prevBtns = Array.from(lb.querySelectorAll("[data-lb-prev]"));
    const nextBtns = Array.from(lb.querySelectorAll("[data-lb-next]"));
    const edgeBtns = Array.from(lb.querySelectorAll(".ege-lb__edge")) as HTMLElement[];
    if (!img || !viewport) return;

    let zoomed = false;
    let items: Array<{ src: string; alt: string }> = [];
    let index = 0;

    function resetZoom() {
      zoomed = false;
      viewport!.classList.remove("is-zoomed");
      img!.style.width = "";
      img!.style.height = "";
      viewport!.scrollTo(0, 0);
    }

    function render() {
      const item = items[index];
      if (!item) return;
      resetZoom();
      img!.src = item.src;
      img!.alt = item.alt;
      if (cap) cap.textContent = item.alt ? `// ${item.alt}` : "// скриншот";

      const multiple = items.length > 1;
      if (nav) nav.hidden = !multiple;
      edgeBtns.forEach((btn) => {
        btn.hidden = !multiple;
      });
      if (currentEl) currentEl.textContent = String(index + 1);
      if (totalEl) totalEl.textContent = String(items.length);
    }

    function go(delta: number) {
      if (items.length < 2) return;
      index = (index + delta + items.length) % items.length;
      render();
    }

    function openGroup(list: Array<{ src: string; alt: string }>, start: number) {
      items = list;
      index = start;
      render();
      lb!.classList.add("is-open");
      lb!.setAttribute("aria-hidden", "false");
      document.body.style.overflow = "hidden";
    }

    function close() {
      resetZoom();
      lb!.classList.remove("is-open");
      lb!.setAttribute("aria-hidden", "true");
      document.body.style.overflow = "";
      setTimeout(() => {
        if (!lb!.classList.contains("is-open")) img!.removeAttribute("src");
      }, 200);
    }

    img.addEventListener("click", (e) => {
      e.stopPropagation();

      if (zoomed) {
        resetZoom();
        return;
      }

      const rect = img.getBoundingClientRect();
      const xRatio = (e.clientX - rect.left) / rect.width;
      const yRatio = (e.clientY - rect.top) / rect.height;

      zoomed = true;
      viewport.classList.add("is-zoomed");
      img.style.width = `${rect.width * 2}px`;
      img.style.height = `${rect.height * 2}px`;

      requestAnimationFrame(() => {
        viewport.scrollLeft = Math.max(
          0,
          xRatio * img.offsetWidth - viewport.clientWidth / 2,
        );
        viewport.scrollTop = Math.max(
          0,
          yRatio * img.offsetHeight - viewport.clientHeight / 2,
        );
      });
    });

    document.addEventListener("click", (e) => {
      const trigger = (e.target as HTMLElement)?.closest(
        "[data-lightbox-src]",
      ) as HTMLElement | null;
      if (!trigger) return;
      e.preventDefault();

      const group = trigger.closest("[data-lightbox-group]");
      const triggers = group
        ? (Array.from(
            group.querySelectorAll("[data-lightbox-src]"),
          ) as HTMLElement[])
        : [trigger];
      const list = triggers.map((el) => ({
        src: el.dataset.lightboxSrc || "",
        alt: el.dataset.lightboxAlt || "",
      }));
      const start = Math.max(0, triggers.indexOf(trigger));
      openGroup(list, start);
    });

    prevBtns.forEach((btn) =>
      btn.addEventListener("click", (e) => {
        e.stopPropagation();
        go(-1);
      }),
    );
    nextBtns.forEach((btn) =>
      btn.addEventListener("click", (e) => {
        e.stopPropagation();
        go(1);
      }),
    );

    closeBtn?.addEventListener("click", close);
    lb.addEventListener("click", (e) => {
      if (e.target === lb || e.target === viewport) close();
    });
    document.addEventListener("keydown", (e) => {
      if (!lb.classList.contains("is-open")) return;
      if (e.key === "Escape") close();
      else if (e.key === "ArrowLeft") go(-1);
      else if (e.key === "ArrowRight") go(1);
    });

    // Свайп по картинке на тач-устройствах
    let touchX = 0;
    let touchY = 0;
    viewport.addEventListener(
      "touchstart",
      (e) => {
        if (zoomed) return;
        touchX = e.changedTouches[0].clientX;
        touchY = e.changedTouches[0].clientY;
      },
      { passive: true },
    );
    viewport.addEventListener(
      "touchend",
      (e) => {
        if (zoomed) return;
        const dx = e.changedTouches[0].clientX - touchX;
        const dy = e.changedTouches[0].clientY - touchY;
        if (Math.abs(dx) > 50 && Math.abs(dx) > Math.abs(dy)) {
          go(dx < 0 ? 1 : -1);
        }
      },
      { passive: true },
    );
  })();
</script>
