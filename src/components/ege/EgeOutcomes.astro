---
const {
  section = "[02] / СТАТИСТИКА",
  title = "Цифры,",
  mutedTitle = "которые не&nbsp;стыдно показывать родителям.",
  stats = [],
  note = "",
} = Astro.props;
---

<!-- ============== 02. СТАТИСТИКА ============== -->
<section class="section relative">
      <div class="gutter py-20 md:py-28">
        <div class="grid grid-cols-12 gap-6 mb-12">
          <div class="col-span-12 md:col-span-3">
            <div class="sec-num">{section}</div>
          </div>
          <div class="col-span-12 md:col-span-9">
            <h2
              class="font-display font-bold text-[clamp(34px,5vw,72px)] leading-[0.95] tracking-[-0.02em] titrate"
            >
              {title}
              <span class="text-dim" set:html={mutedTitle} />
            </h2>
          </div>
        </div>

        <div
          class="ege-outcomes-grid grid gap-px bg-line border border-line"
        >
          {stats.map((stat) => (
            <div class="bg-ink p-6">
              {stat.valueText ? (
                <div
                  class:list={[
                    "font-display font-bold text-4xl md:text-5xl",
                    stat.accent === "acid" && "text-acid",
                    stat.accent === "fuchsia2" && "text-fuchsia2",
                  ]}
                >
                  {stat.valueText}
                </div>
              ) : (
                <div
                  class:list={[
                    "font-display font-bold text-4xl md:text-5xl",
                    stat.accent === "acid" && "text-acid",
                    stat.accent === "fuchsia2" && "text-fuchsia2",
                  ]}
                  data-counter={stat.value}
                  data-suffix={stat.suffix}
                  data-decimals={stat.decimals}
                >
                  0
                </div>
              )}
              <div class="label mt-3 flex items-center gap-2">
                <span>{stat.label}</span>
                {stat.note && (
                  <span class="group relative inline-grid h-5 w-5 place-items-center border border-line text-[10px] text-acid">
                    ?
                    <span class="pointer-events-none absolute left-0 top-7 z-20 hidden w-64 border border-line bg-ink p-3 font-mono text-[10px] leading-snug text-paper/80 normal-case tracking-normal group-hover:block">
                      {stat.note}
                    </span>
                  </span>
                )}
              </div>
            </div>
          ))}
        </div>

        <div class="mt-6 font-mono text-xs text-dim">
          <Fragment set:html={note} />
        </div>
      </div>
    </section>

    <style>
      .ege-outcomes-grid {
        grid-template-columns: repeat(auto-fit, minmax(min(100%, 220px), 1fr));
      }

      @media (max-width: 520px) {
        .ege-outcomes-grid {
          grid-template-columns: 1fr;
        }
      }
    </style>
