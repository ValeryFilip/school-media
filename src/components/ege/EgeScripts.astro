---
import { egeLandingFaqItems } from "../../lib/egeLandingSeo";

const { data = {} } = Astro.props;
const runtimeData = { ...data, faq: data.faq ?? egeLandingFaqItems };
---

<script type="application/json" id="egeLandingRuntimeData" set:html={JSON.stringify(runtimeData)}></script>

<script is:inline>
      const __egeRuntime = (() => {
        const node = document.getElementById("egeLandingRuntimeData");
        if (!node) return {};
        try {
          return JSON.parse(node.textContent || "{}");
        } catch {
          return {};
        }
      })();
      const __egeAfterPaint = (fn) =>
        requestAnimationFrame(() => requestAnimationFrame(fn));
      const __egeIdle = (fn, timeout = 1200) => {
        if ("requestIdleCallback" in window) {
          window.requestIdleCallback(fn, { timeout });
        } else {
          setTimeout(fn, 1);
        }
      };

      // ====================== PT BG ======================
      __egeAfterPaint(function buildPTBg() {
        const grid = document.getElementById("ptBg");
        if (!grid || grid.dataset.ready === "true") return;
        grid.dataset.ready = "true";
        for (let i = 0; i < 18 * 5; i++)
          grid.appendChild(document.createElement("div"));
      });

      // ====================== MOLECULE ======================
      (function buildMolecule() {
        const stage = document.getElementById("molecule");
        if (!stage) return;
        const R = 38;
        const atoms = [];
        for (let i = 0; i < 6; i++) {
          const a = (Math.PI * 2 * i) / 6 - Math.PI / 2;
          atoms.push({
            type: "C",
            x: 50 + Math.cos(a) * R,
            y: 50 + Math.sin(a) * R,
            label: "C",
          });
        }
        for (let i = 0; i < 6; i++) {
          const a = (Math.PI * 2 * i) / 6 - Math.PI / 2;
          atoms.push({
            type: "H",
            x: 50 + Math.cos(a) * (R + 18),
            y: 50 + Math.sin(a) * (R + 18),
            label: "H",
          });
        }
        atoms[6] = { type: "O", x: atoms[6].x, y: atoms[6].y, label: "OH" };

        atoms.forEach((a) => {
          const el = document.createElement("div");
          el.className = `atom ${a.type}`;
          const size = a.type === "C" ? 36 : a.type === "O" ? 38 : 28;
          el.style.width = el.style.height = size + "px";
          el.style.left = `calc(${a.x}% - ${size / 2}px)`;
          el.style.top = `calc(${a.y}% - ${size / 2}px)`;
          el.style.fontSize = (a.type === "C" ? 14 : 11) + "px";
          el.textContent = a.label;
          stage.appendChild(el);
        });

        function bond(x1, y1, x2, y2, double = false) {
          const dx = x2 - x1;
          const dy = y2 - y1;
          const dist = Math.sqrt(dx * dx + dy * dy);
          const angle = (Math.atan2(dy, dx) * 180) / Math.PI;
          const b = document.createElement("div");
          b.className = "bond";
          b.style.width = dist + "%";
          b.style.left = x1 + "%";
          b.style.top = y1 + "%";
          b.style.transform = `rotate(${angle}deg)`;
          stage.appendChild(b);
          if (double) {
            const b2 = b.cloneNode();
            b2.style.top = y1 + 0.8 + "%";
            stage.appendChild(b2);
          }
        }
        for (let i = 0; i < 6; i++) {
          const a = atoms[i];
          const b = atoms[(i + 1) % 6];
          bond(a.x, a.y, b.x, b.y, i % 2 === 0);
        }
        for (let i = 0; i < 6; i++)
          bond(atoms[i].x, atoms[i].y, atoms[i + 6].x, atoms[i + 6].y);

        const moleculeStage = document.getElementById("moleculeStage");
        // На v2-страницах (lattice/cascade/electrons) #molecule может
        // быть, а #moleculeStage — нет; не валим скрипт.
        if (!moleculeStage) return;
        const xEl = document.getElementById("moleculeX");
        const yEl = document.getElementById("moleculeY");
        let tx = 0;
        let ty = 0;
        let cx = 0;
        let cy = 0;
        moleculeStage.addEventListener("mousemove", (e) => {
          const r = moleculeStage.getBoundingClientRect();
          const nx = (e.clientX - r.left) / r.width - 0.5;
          const ny = (e.clientY - r.top) / r.height - 0.5;
          tx = nx * 44;
          ty = ny * -44;
          if (xEl) xEl.textContent = `X: ${(nx * 2).toFixed(2)}`;
          if (yEl) yEl.textContent = `Y: ${(-ny * 2).toFixed(2)}`;
        });
        let auto = 0;
        function loop() {
          cx += (tx - cx) * 0.08;
          cy += (ty - cy) * 0.08;
          auto += 0.15;
          stage.style.transform = `rotateY(${cx + auto}deg) rotateX(${cy}deg)`;
          requestAnimationFrame(loop);
        }
        loop();
      })();

      // ====================== HERO CHAOS 100 ======================
      (function assembly() {
        const scene = document.getElementById("assembly");
        if (!scene) return;
        const stateEl = document.getElementById("aState");
        const countEl = document.getElementById("aCount");
        const cap = document.getElementById("aCap");
        const pool = ["H", "O", "C", "N", "e⁻", "+", "·", "Na", "Cl", "S", "K", "O₂"];

        // Храним id текущего рAF, чтобы при resize → build() убить старый
        // бесконечный цикл. Без этого каждый resize плодит новый
        // rAF-loop, старые продолжают мутировать style.transform на
        // несуществующих уже частицах → стек циклов растёт линейно.
        let heroChaosFrameId = null;

        const mouse = { x: -999, y: -999, active: false };
        scene.addEventListener("mousemove", (e) => {
          const r = scene.getBoundingClientRect();
          mouse.x = e.clientX - r.left;
          mouse.y = e.clientY - r.top;
          mouse.active = true;
        });
        scene.addEventListener("mouseleave", () => {
          mouse.active = false;
        });

        function build() {
          // Убиваем старый rAF, если был. Без этого resize-стек растёт.
          if (heroChaosFrameId !== null) {
            cancelAnimationFrame(heroChaosFrameId);
            heroChaosFrameId = null;
          }
          const W = scene.clientWidth || 380;
          const H = scene.clientHeight || 380;
          scene.innerHTML = "";

          const cw = 360;
          const ch = 200;
          const cv = document.createElement("canvas");
          cv.width = cw;
          cv.height = ch;
          const ctx = cv.getContext("2d");
          if (!ctx) return;
          ctx.fillStyle = "#fff";
          ctx.textAlign = "center";
          ctx.textBaseline = "middle";
          ctx.font = "700 150px 'Space Grotesk', sans-serif";
          ctx.fillText("100", cw / 2, ch / 2);

          const img = ctx.getImageData(0, 0, cw, ch).data;
          const pts = [];
          const step = 7;
          for (let y = 0; y < ch; y += step) {
            for (let x = 0; x < cw; x += step) {
              if (img[(y * cw + x) * 4 + 3] > 128) pts.push([x, y]);
            }
          }

          const boxW = W * 0.82;
          const scale = boxW / cw;
          const offX = (W - cw * scale) / 2;
          const offY = (H - ch * scale) / 2;

          const fragment = document.createDocumentFragment();
          const particles = pts.map((p) => {
            const el = document.createElement("div");
            el.className = "pnode" + (Math.random() < 0.18 ? " fx" : "");
            el.textContent = pool[(Math.random() * pool.length) | 0];
            fragment.appendChild(el);
            return {
              el,
              x: Math.random() * W,
              y: Math.random() * H,
              vx: (Math.random() - 0.5) * 2.4,
              vy: (Math.random() - 0.5) * 2.4,
              tx: offX + p[0] * scale,
              ty: offY + p[1] * scale,
              ph: Math.random() * Math.PI * 2,
            };
          });
          scene.appendChild(fragment);

          if (countEl) countEl.textContent = String(particles.length);

          const cycle = 8200;
          const start = performance.now();
          function frame(now) {
            const t = (now - start) % cycle;
            let mode;
            if (t < 3000) mode = "chaos";
            else if (t < 4700) mode = "assemble";
            else if (t < 7200) mode = "hold";
            else mode = "scatter";

            if (mode === "chaos") {
              if (stateEl) {
                stateEl.textContent = "[CHAOS]";
                stateEl.style.color = "var(--fuchsia2)";
              }
              cap?.classList.remove("show");
              particles.forEach((p) => {
                p.el.classList.remove("on");
                p.x += p.vx;
                p.y += p.vy;
                if (p.x < 0 || p.x > W) p.vx *= -1;
                if (p.y < 0 || p.y > H) p.vy *= -1;
              });
            } else if (mode === "assemble") {
              if (stateEl) {
                stateEl.textContent = "[ASSEMBLING]";
                stateEl.style.color = "var(--acid)";
              }
              particles.forEach((p) => {
                p.x += (p.tx - p.x) * 0.14;
                p.y += (p.ty - p.y) * 0.14;
                p.el.classList.add("on");
              });
            } else if (mode === "hold") {
              if (stateEl) {
                stateEl.textContent = "[100 / 100]";
                stateEl.style.color = "var(--acid)";
              }
              cap?.classList.add("show");
              particles.forEach((p) => {
                p.ph += 0.05;
                p.x += (p.tx + Math.cos(p.ph) * 1.2 - p.x) * 0.2;
                p.y += (p.ty + Math.sin(p.ph) * 1.2 - p.y) * 0.2;
              });
            } else {
              if (!particles._scattered) {
                particles.forEach((p) => {
                  const a = Math.random() * Math.PI * 2;
                  const s = 2 + Math.random() * 3;
                  p.vx = Math.cos(a) * s;
                  p.vy = Math.sin(a) * s;
                });
                particles._scattered = true;
              }
              cap?.classList.remove("show");
              particles.forEach((p) => {
                p.el.classList.remove("on");
                p.x += p.vx;
                p.y += p.vy;
                if (p.x < 0 || p.x > W) p.vx *= -1;
                if (p.y < 0 || p.y > H) p.vy *= -1;
              });
            }

            if (mode !== "scatter") particles._scattered = false;

            if (mouse.active) {
              const R = 80;
              const R2 = R * R;
              particles.forEach((p) => {
                const dx = p.x - mouse.x;
                const dy = p.y - mouse.y;
                const d2 = dx * dx + dy * dy;
                if (d2 < R2 && d2 > 0.01) {
                  const d = Math.sqrt(d2);
                  const f = (1 - d / R) * 26;
                  p.x += (dx / d) * f;
                  p.y += (dy / d) * f;
                }
              });
            }

            particles.forEach((p) => {
              p.el.style.transform = `translate(${p.x}px, ${p.y}px) translate(-50%, -50%)`;
            });
            heroChaosFrameId = requestAnimationFrame(frame);
          }
          __egeAfterPaint(() => {
            heroChaosFrameId = requestAnimationFrame(frame);
          });
        }

        if (document.fonts && document.fonts.ready) {
          document.fonts.ready.then(() => __egeAfterPaint(build));
          setTimeout(() => {
            if (!scene.children.length) build();
          }, 1500);
        } else {
          __egeAfterPaint(build);
        }
        window.addEventListener("resize", () => {
          clearTimeout(window.__heroChaosResize);
          window.__heroChaosResize = setTimeout(build, 250);
        });
      })();

      // ====================== HERO PERIODIC CLUSTER ======================
      function spin3D(stageId, sceneId, opts = {}) {
        const stage = document.getElementById(stageId);
        const scene = document.getElementById(sceneId);
        if (!stage || !scene) return;
        const speed = opts.speed ?? 0.1;
        const baseX = opts.baseX ?? 0;
        let tx = 0;
        let ty = 0;
        let cx = 0;
        let cy = 0;
        let auto = 0;
        stage.addEventListener("mousemove", (e) => {
          const r = stage.getBoundingClientRect();
          tx = ((e.clientX - r.left) / r.width - 0.5) * 44;
          ty = ((e.clientY - r.top) / r.height - 0.5) * -44;
        });
        (function loop() {
          cx += (tx - cx) * 0.08;
          cy += (ty - cy) * 0.08;
          auto += speed;
          scene.style.transform = `rotateY(${cx + auto}deg) rotateX(${baseX + cy}deg)`;
          requestAnimationFrame(loop);
        })();
      }

      function makeHeroBond(scene, x1, y1, x2, y2, color) {
        const dx = x2 - x1;
        const dy = y2 - y1;
        const dist = Math.sqrt(dx * dx + dy * dy);
        const angle = (Math.atan2(dy, dx) * 180) / Math.PI;
        const b = document.createElement("div");
        b.className = "bond";
        b.style.width = dist + "%";
        b.style.left = x1 + "%";
        b.style.top = y1 + "%";
        b.style.transform = `rotate(${angle}deg)`;
        if (color) b.style.background = color;
        scene.appendChild(b);
      }

      __egeAfterPaint(function buildCluster() {
        const scene = document.getElementById("sceneB");
        if (!scene) return;
        const center = { sym: "C", num: 6, mass: "12.01", cls: "" };
        const ring = [
          { sym: "H", num: 1, mass: "1.008", cls: "" },
          { sym: "O", num: 8, mass: "16.00", cls: "fx" },
          { sym: "N", num: 7, mass: "14.01", cls: "ac" },
          { sym: "Na", num: 11, mass: "22.99", cls: "" },
          { sym: "Cl", num: 17, mass: "35.45", cls: "" },
          { sym: "Fe", num: 26, mass: "55.85", cls: "" },
        ];
        const size = 78;
        const R = 36;
        const nodes = [];
        nodes.push({ ...center, x: 50, y: 50, z: 34 });
        ring.forEach((e, i) => {
          const a = (Math.PI * 2 * i) / 6 - Math.PI / 2;
          nodes.push({
            ...e,
            x: 50 + Math.cos(a) * R,
            y: 50 + Math.sin(a) * R,
            z: i % 2 === 0 ? 30 : -30,
          });
        });

        for (let i = 1; i <= 6; i++) makeHeroBond(scene, nodes[0].x, nodes[0].y, nodes[i].x, nodes[i].y);
        for (let i = 1; i <= 6; i++) {
          const a = nodes[i];
          const b = nodes[(i % 6) + 1];
          makeHeroBond(scene, a.x, a.y, b.x, b.y, "rgba(242,242,242,0.4)");
        }

        const fragment = document.createDocumentFragment();
        nodes.forEach((n) => {
          const c = document.createElement("div");
          c.className = "cell";
          c.style.width = c.style.height = size + "px";
          c.style.left = `calc(${n.x}% - ${size / 2}px)`;
          c.style.top = `calc(${n.y}% - ${size / 2}px)`;
          c.style.transform = `translateZ(${n.z}px)`;
          let symColor = "var(--paper)";
          if (n.cls === "fx") symColor = "var(--fuchsia2)";
          if (n.cls === "ac") symColor = "var(--acid)";
          c.innerHTML = `<span class="cell-num">${n.num}</span>
            <span class="cell-sym" style="color:${symColor}">${n.sym}</span>
            <span class="cell-mass">${n.mass}</span>`;
          fragment.appendChild(c);
        });
        scene.appendChild(fragment);
        spin3D("stageB", "sceneB", { speed: 0.1 });
      });

      // ====================== FLOATING FORMULAS ======================
      __egeIdle(function floatingFormulas() {
        const field = document.getElementById("formulaField");
        if (!field || field.dataset.ready === "true") return;
        if (!window.gsap) {
          // Ограничиваем ретраи (max ~12 секунд ожидания GSAP).
          // Без cap бесконечный setTimeout-loop тратил бы CPU вечно.
          floatingFormulas._gsapTries = (floatingFormulas._gsapTries || 0) + 1;
          if (floatingFormulas._gsapTries < 100) {
            setTimeout(floatingFormulas, 120);
          }
          return;
        }
        field.dataset.ready = "true";
        const formulas = [
          "H₂O",
          "NaCl",
          "CO₂",
          "HCl",
          "NH₃",
          "O₂",
          "H₂SO₄",
          "NaOH",
          "CH₄",
          "CaCO₃",
          "KOH",
          "C₂H₅OH",
          "Fe₂O₃",
        ];
        for (let i = 0; i < 18; i++) {
          const el = document.createElement("div");
          el.className = "formula-particle";
          el.textContent =
            formulas[Math.floor(Math.random() * formulas.length)];
          el.style.left = Math.random() * 100 + "%";
          el.style.top = Math.random() * 100 + "%";
          el.style.fontSize = 10 + Math.random() * 8 + "px";
          el.style.opacity = 0.15 + Math.random() * 0.25;
          field.appendChild(el);
          gsap.to(el, {
            x: (Math.random() - 0.5) * 60,
            y: (Math.random() - 0.5) * 60,
            duration: 8 + Math.random() * 8,
            yoyo: true,
            repeat: -1,
            ease: "sine.inOut",
          });
        }
      });

      // ====================== 03. PAIN POINTS (interactive) ======================
      __egeIdle(function buildPain() {
        const grid = document.getElementById("painGrid");
        if (!grid) return;
        const symptoms = __egeRuntime.symptoms ?? [
          {
            id: 1,
            anx: 140,
            t: "«На уроке вроде понятно, а в варианте — пустота».",
            d: "Учитель объясняет тему, ты киваешь, записываешь, даже думаешь: «ну вроде легко». А потом открываешь задание ЕГЭ — и не понимаешь, с какого вещества вообще начинать.",
          },
          {
            id: 2,
            anx: 220,
            t: "«Я готовлюсь, но пробники всё равно на 40–50 баллов».",
            d: "Видео смотрятся, конспекты пишутся, задания иногда решаются. Но на пробнике всё разваливается: где-то забыл формулу, где-то не узнал реакцию, где-то тупо не понял условие.",
          },
          {
            id: 3,
            anx: 180,
            t: "«Органика — это какой-то отдельный язык».",
            d: "Ты видишь структурную формулу и не понимаешь, куда смотреть: где главная цепь, что от чего отщепляется, почему тут именно эта реакция. Кажется, что все вокруг «просто видят», а ты нет.",
          },
          {
            id: 4,
            anx: 200,
            t: "«Я постоянно что-то учу, но баллы не растут».",
            d: "Сегодня повторил теорию, завтра посмотрел разбор, послезавтра начал новый блок. Но ошибок меньше не становится, потому что нет системы: что уже закрыто, что проседает, что нужно добить прямо сейчас.",
          },
          {
            id: 6,
            anx: 190,
            t: "«Я боюсь, что начал слишком поздно».",
            d: "Кажется, что все уже прошли органику, решают пробники и разбирают сложные задачи, а ты ещё путаешь оксиды, кислоты и соли. Из-за этого хочется не ускориться, а вообще закрыть вкладку и сделать вид, что ЕГЭ не существует.",
          },
          {
            id: 7,
            anx: 160,
            t: "«В онлайн-школе я просто один из сотен учеников».",
            d: "Вебинары идут, домашки есть, чат шумит, но лично тебя никто не вытаскивает, если ты выпал. А когда замечаешь, что отстал, уже страшно даже спросить.",
          },
        ];

        symptoms.forEach((s, i) => {
          const num = String(i + 1).padStart(2, "0");
          const btn = document.createElement("button");
          btn.type = "button";
          btn.dataset.anx = s.anx;
          btn.dataset.selected = "false";
          btn.className =
            "pain-card col-span-12 md:col-span-4 bg-ink p-8 group text-left transition relative border-l-4 border-transparent";
          btn.innerHTML = `
      <div class="flex items-center justify-between mb-4">
        <div class="font-mono text-xs text-fuchsia2">// СИМПТОМ ${num}</div>
        <div class="pain-check w-5 h-5 border border-paper/40 grid place-items-center font-mono text-[10px] shrink-0">+</div>
      </div>
      <div class="font-display font-bold text-2xl md:text-3xl leading-tight mb-4">${s.t}</div>
      <p class="text-dim text-sm">${s.d}</p>
      <div class="mt-8 h-2 bg-line relative overflow-hidden">
        <div class="pain-bar absolute inset-y-0 left-0 bg-fuchsia2 transition-all duration-500" style="width:${Math.min(100, s.anx / 3)}%"></div>
      </div>
      <div class="flex items-center justify-between font-mono text-[10px] mt-2">
        <span class="pain-label text-dim">У МЕНЯ ТАК?</span>
        <span class="text-fuchsia2">+${s.anx} ТРЕВОГИ</span>
      </div>
    `;
          btn.addEventListener("click", () => {
            const on = btn.dataset.selected === "true";
            btn.dataset.selected = on ? "false" : "true";
            btn.classList.toggle("is-selected", !on);
            updateAggregate();
          });
          grid.appendChild(btn);
        });

        const score = document.getElementById("anxScore");
        const bar = document.getElementById("anxBar");
        const zone = document.getElementById("anxZone");
        const diag = document.getElementById("anxDiag");
        const rx = document.getElementById("anxRx");

        function updateAggregate() {
          const selected = Array.from(
            grid.querySelectorAll('[data-selected="true"]'),
          );
          const total = selected.reduce((a, b) => a + Number(b.dataset.anx), 0);
          const max = 600;
          const pct = (total / max) * 100;
          const count = selected.length;

          // Animate score
          const cur = parseInt(score.textContent.replace(/\D/g, "")) || 0;
          gsap.to(
            { v: cur },
            {
              v: total,
              duration: 0.6,
              ease: "expo.out",
              onUpdate: function () {
                score.textContent = Math.round(this.targets()[0].v);
              },
            },
          );
          bar.style.width = pct + "%";

          // Zone classification
          let zoneText, diagText, rxText, barColor;
          if (count === 0) {
            zoneText = "— SAFE ZONE";
            diagText = "[ выбери симптомы выше ]";
            rxText =
              "// потыкай в карточки сверху — посмотрим, что у&nbsp;тебя болит на&nbsp;самом деле.";
            barColor = "var(--fuchsia2)";
          } else if (total < 200) {
            zoneText = "НОРМА · ЗЕЛЁНАЯ ЗОНА";
            diagText = "[ диагноз: лёгкая тревожность ]";
            rxText =
              '// Тебе хватит платформы и&nbsp;тренажёра. <a href="#prices" class="text-acid hover:underline">Тариф «Самостоятельный» →</a>';
            barColor = "var(--acid)";
