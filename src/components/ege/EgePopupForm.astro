---
interface Props {
  popupId?: string;
  title?: string;
  eyebrow?: string;
  submitText?: string;
  action?: string;
  formType?: string;
  theme?: "landing" | "academy";
}

const {
  popupId = "lead-popup",
  title = "Пробный урок",
  eyebrow = "// заявка · 40 секунд",
  submitText = "Отправить заявку →",
  action = "/api/lead.php",
  formType = "popup",
  theme = "landing",
} = Astro.props as Props;
---

<div
  id={popupId}
  class:list={["ege-popup", theme === "academy" && "ege-popup--academy"]}
  data-popup
  role="dialog"
  aria-modal="true"
  aria-labelledby={`${popupId}-title`}
  aria-hidden="true"
>
  <div class="ege-popup__backdrop" data-popup-close></div>
  <div class="ege-popup__card">
    <button class="ege-popup__close" type="button" aria-label="Закрыть" data-popup-close>
      ×
    </button>

    <div class="label mb-4">{eyebrow}</div>
    <h3 id={`${popupId}-title`} class="ege-popup__title">{title}</h3>
    <p class="ege-popup__copy">
      Оставь контакт, и куратор напишет в удобное время. Без спама и звонков в 9 утра.
    </p>

    <form
      class="ege-popup__form"
      data-endpoint={action}
      data-form
      data-form-type={formType}
      data-form-id={popupId}
      data-success-message="Заявка отправлена! Мы напишем в Telegram."
      data-success-redirect="/thank-you"
      data-success-delay="1200"
      data-required-any="phone,telegram"
      novalidate
    >
      <label class="ege-popup__field">
        <span class="field-label"><span class="field-num">[01]</span> Имя</span>
        <input name="name" type="text" placeholder="Например — Артём" autocomplete="name" />
      </label>

      <label class="ege-popup__field">
        <span class="field-label"><span class="field-num">[02]</span> Telegram</span>
        <input name="telegram" type="text" placeholder="@username" autocomplete="off" />
      </label>

      <label class="ege-popup__field">
        <span class="field-label"><span class="field-num">[03]</span> Телефон</span>
        <input name="phone" type="tel" inputmode="tel" placeholder="+7 ___ ___-__-__" autocomplete="tel" />
      </label>

      <div class="ege-popup__docs">
        <label>
          <input name="consent_privacy" type="checkbox" required value="true" />
          <span>Согласен с <a href="/docs/privacy/" target="_blank" rel="noopener">политикой конфиденциальности</a></span>
        </label>
        <label>
          <input name="consent_personal_data" type="checkbox" required value="true" />
          <span>Согласен на <a href="/docs/agreement/" target="_blank" rel="noopener">обработку персональных данных</a></span>
        </label>
        <label>
          <input name="consent_marketing" type="checkbox" required value="true" />
          <span>Согласен на <a href="/docs/marketing-consent/" target="_blank" rel="noopener">рекламную рассылку</a></span>
        </label>
      </div>

      <button class="ege-popup__submit cta-pulse" type="submit">{submitText}</button>
      <div class="ege-popup__status" data-form-status hidden></div>
      <pre class="ege-popup__debug" data-form-debug hidden></pre>
    </form>
  </div>
</div>

<style>
  .ege-popup {
    position: fixed;
    inset: 0;
    z-index: 10000;
    display: grid;
    place-items: center;
    padding: 16px;
    opacity: 0;
    pointer-events: none;
    transition: opacity 0.18s ease;
  }

  .ege-popup.is-open {
    opacity: 1;
    pointer-events: auto;
  }

  .ege-popup__backdrop {
    position: absolute;
    inset: 0;
    background:
      linear-gradient(rgba(10, 10, 10, 0.9), rgba(10, 10, 10, 0.9)),
      repeating-linear-gradient(135deg, rgba(204, 255, 0, 0.14) 0 1px, transparent 1px 12px);
    backdrop-filter: blur(6px);
  }

  .ege-popup__card {
    position: relative;
    width: min(100%, 580px);
    max-height: calc(100vh - 32px);
    overflow: visible;
    border: 1px solid var(--paper);
    background: var(--ink);
    color: var(--paper);
    padding: clamp(20px, 3vw, 32px);
    box-shadow: 0 24px 80px rgba(0, 0, 0, 0.45);
    transform: translateY(10px);
    transition: transform 0.18s ease;
  }

  .ege-popup.is-open .ege-popup__card {
    transform: translateY(0);
  }

  .ege-popup__close {
    position: absolute;
    top: 14px;
    right: 14px;
    width: 40px;
    height: 40px;
    border: 1px solid var(--line);
    background: var(--ink);
    color: var(--paper);
    font: 700 24px/1 "JetBrains Mono", monospace;
    cursor: pointer;
  }

  .ege-popup__close:hover {
    background: var(--acid);
    color: var(--ink);
    border-color: var(--acid);
  }

  .ege-popup__title {
    margin: 0;
    font-family: "Space Grotesk", sans-serif;
    font-size: clamp(34px, 6vw, 60px);
    line-height: 0.9;
    letter-spacing: -0.025em;
    font-weight: 700;
  }

  .ege-popup__copy {
    max-width: 460px;
    margin: 14px 0 20px;
    color: rgba(242, 242, 242, 0.8);
    line-height: 1.4;
  }

  .ege-popup__form {
    display: grid;
    gap: 12px;
  }

  .ege-popup__field {
    display: grid;
    gap: 6px;
  }

  .ege-popup__field input {
    width: 100%;
    border: 1px solid rgba(255, 255, 255, 0.22);
    background: rgba(255, 255, 255, 0.04);
    color: var(--paper);
    padding: 16px 18px;
    font-family: "JetBrains Mono", monospace;
    font-size: 14px;
    line-height: 1.5;
    transition:
      border-color 150ms ease,
      background 150ms ease,
      box-shadow 150ms ease;
  }

  .ege-popup__field input:hover {
    border-color: rgba(255, 255, 255, 0.42);
    background: rgba(255, 255, 255, 0.06);
  }

  .ege-popup__field input:focus {
    outline: none;
    border-color: var(--acid);
    background: rgba(204, 255, 0, 0.04);
    box-shadow: inset 0 0 0 1px var(--acid);
  }

  .ege-popup__field input::placeholder {
    color: rgba(255, 255, 255, 0.34);
  }

  .field-label {
    display: flex;
    align-items: center;
    gap: 8px;
    font-family: "JetBrains Mono", monospace;
    font-size: 12px;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--paper);
  }

  .field-num {
    color: var(--acid);
    font-weight: 700;
  }

  .ege-popup__docs {
    display: grid;
    gap: 8px;
    padding: 12px;
    border: 1px solid var(--line);
    font-family: "JetBrains Mono", monospace;
    font-size: 11px;
    color: var(--dim);
  }

  .ege-popup__docs label {
    display: flex;
    gap: 10px;
    align-items: flex-start;
  }

  .ege-popup__docs input {
    width: auto;
    margin-top: 2px;
    accent-color: var(--acid);
  }

  .ege-popup__docs a {
    color: var(--paper);
    text-decoration: underline;
    text-decoration-color: var(--line);
  }

  .ege-popup__submit {
    width: 100%;
    border: 0;
    background: var(--acid);
    color: var(--ink);
    padding: 15px 18px;
    font-family: "Space Grotesk", sans-serif;
    font-weight: 700;
    font-size: 18px;
    text-transform: uppercase;
    cursor: pointer;
  }

  .ege-popup__submit:hover {
    background: var(--paper);
  }

  .ege-popup__submit:disabled {
    cursor: wait;
    opacity: 0.75;
  }

  .ege-popup__status {
    font-family: "JetBrains Mono", monospace;
    font-size: 12px;
    color: var(--paper);
  }

  .ege-popup__status.ok {
    color: var(--acid);
  }

  .ege-popup__status.err {
    color: var(--fuchsia2);
  }

  .ege-popup--academy .ege-popup__backdrop {
    background:
      linear-gradient(rgba(239, 233, 218, 0.86), rgba(239, 233, 218, 0.86)),
      repeating-linear-gradient(135deg, rgba(178, 58, 20, 0.12) 0 1px, transparent 1px 12px);
  }

  .ege-popup--academy .ege-popup__card {
    border-color: var(--line);
    background: #fffdf7;
    color: var(--ink);
    box-shadow: none;
  }

  .ege-popup--academy .ege-popup__close {
    border-color: var(--line);
    background: var(--paper);
    color: var(--ink);
  }

  .ege-popup--academy .ege-popup__close:hover {
    background: var(--rust);
    color: var(--paper);
    border-color: var(--rust);
  }

  .ege-popup--academy .ege-popup__copy {
    color: var(--inkSoft);
  }

  .ege-popup--academy .ege-popup__field input {
    border-color: var(--line);
    background: var(--paper);
    color: var(--ink);
  }

  .ege-popup--academy .ege-popup__field input:hover {
    border-color: var(--dim);
    background: var(--milk);
  }

  .ege-popup--academy .ege-popup__field input:focus {
    border-color: var(--rust);
    background: #fffdf7;
    box-shadow: inset 0 0 0 1px var(--rust);
  }

  .ege-popup--academy .ege-popup__field input::placeholder {
    color: var(--dim);
  }

  .ege-popup--academy .field-label {
    color: var(--ink);
  }

  .ege-popup--academy .field-num {
    color: var(--rust);
  }

  .ege-popup--academy .ege-popup__docs {
    border-color: var(--line);
    background: var(--milk);
    color: var(--dim);
  }

  .ege-popup--academy .ege-popup__docs input {
    accent-color: var(--rust);
  }

  .ege-popup--academy .ege-popup__docs a {
    color: var(--ink);
    text-decoration-color: var(--rust);
  }

  .ege-popup--academy .ege-popup__submit {
    background: var(--rust);
    color: var(--paper);
  }

  .ege-popup--academy .ege-popup__submit:hover {
    background: var(--ink);
  }

  .ege-popup--academy .ege-popup__status {
    color: var(--ink);
  }

  .ege-popup--academy .ege-popup__status.ok {
    color: var(--rust);
  }

  .ege-popup--academy .ege-popup__status.err {
    color: var(--rustDark);
  }

  .ege-popup__debug {
    white-space: pre-wrap;
    color: var(--dim);
    font-size: 10px;
  }

  @media (max-width: 560px) {
    .ege-popup {
      padding: 10px;
      align-items: end;
    }

    .ege-popup__card {
      width: 100%;
      max-height: calc(100vh - 20px);
      padding: 20px 16px;
    }
  }
</style>
