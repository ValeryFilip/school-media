---
import EgeAcidButton from "./EgeAcidButton.astro";

interface FooterLink {
  href?: string;
  label: string;
  external?: boolean;
  rel?: string;
}
interface FooterColumn {
  title?: string;
  titleHref?: string;
  links?: FooterLink[];
  groups?: { title?: string; links?: FooterLink[] }[];
}
interface FooterCta {
  label?: string;
  popupId?: string;
  source?: string;
  variant?: string;
  campaign?: string;
}
interface SocialGroup {
  title?: string;
  links?: FooterLink[];
}
interface Props {
  brand?: string;
  description?: string;
  addressHtml?: string;
  legalLinks?: FooterLink[];
  columns?: FooterColumn[];
  cta?: FooterCta;
  socialGroups?: SocialGroup[];
  copyright?: string;
  bottomLinks?: FooterLink[];
  disclaimer?: string;
}

const {
  brand = "ХИМ.LAB",
  description = "",
  addressHtml = "",
  legalLinks = [],
  columns = [],
  cta,
  socialGroups = [],
  copyright = "",
  bottomLinks = [],
  disclaimer = "",
} = Astro.props as Props;
---

<footer class="border-t border-line">
      <div class="gutter py-12">
        <div class="grid grid-cols-12 gap-px bg-line border border-line mb-10">
          <div class="col-span-12 lg:col-span-3 bg-ink p-6 md:p-8">
            <div class="flex items-center gap-3 mb-4">
              <div class="w-7 h-7 border border-paper grid place-items-center">
                <span class="font-mono text-[10px]">Ch</span>
              </div>
              <span class="font-display font-bold">{brand}</span>
            </div>
            <p class="font-mono text-xs text-dim max-w-xs">
              <Fragment set:html={description} />
            </p>
            {addressHtml && (
              <address class="font-mono text-xs text-dim max-w-xs mt-4 not-italic leading-relaxed">
                <Fragment set:html={addressHtml} />
              </address>
            )}
            {legalLinks.length > 0 && (
              <nav class="font-mono text-xs text-paper/70 mt-5 space-y-2" aria-label="Юридическая информация">
                {legalLinks.map((link) => (
                  <a
                    class="block hover:text-acid transition"
                    href={link.href}
                    rel={link.rel}
                  >
                    {link.label}
                  </a>
                ))}
              </nav>
            )}
          </div>
          {columns.slice(0, 2).map((column) => (
            <div class="col-span-12 sm:col-span-6 lg:col-span-3 bg-ink p-6 md:p-8">
              {column.titleHref ? (
                <a
                  href={column.titleHref}
                  class="label mb-3 inline-flex items-center gap-1 hover:text-acid transition"
                >
                  {column.title}
                  <span aria-hidden="true">↗</span>
                </a>
              ) : (
                <div class="label mb-3">{column.title}</div>
              )}
              {column.groups ? (
                column.groups.map((group, groupIndex) => (
                  <div class={groupIndex === 0 ? "" : "mt-5"}>
                    {group.title && (
                      <div class="font-mono text-[10px] uppercase tracking-wider text-dim mb-2">
                        {group.title}
                      </div>
                    )}
                    <ul class="font-mono text-sm space-y-2 text-paper/80">
                      {group.links?.map((link) => (
                        <li>
                          <a
                            class="hover:text-acid transition"
                            href={link.href}
                            target={link.external ? "_blank" : undefined}
                            rel={link.external ? "noopener noreferrer" : link.rel}
                          >
                            {link.label}
                          </a>
                        </li>
                      ))}
                    </ul>
                  </div>
                ))
              ) : (
                <ul class="font-mono text-sm space-y-2 text-paper/80">
                  {column.links?.map((link) => (
                    <li>
                      <a
                        class="hover:text-acid transition"
                        href={link.href}
                        target={link.external ? "_blank" : undefined}
                        rel={link.external ? "noopener noreferrer" : link.rel}
                      >
                        {link.label}
                      </a>
                    </li>
                  ))}
                </ul>
              )}
            </div>
          ))}
          <div class="col-span-12 lg:col-span-3 bg-ink p-6 md:p-8">
            {cta && (
              <EgeAcidButton
                as="button"
                type="button"
                label={cta.label}
                popupId={cta.popupId}
                source={cta.source}
                variant={cta.variant}
                campaign={cta.campaign}
                class="w-full px-5 py-5"
              />
            )}
            {socialGroups.map((group, groupIndex) => (
              <div class={groupIndex === 0 ? "mt-5" : "mt-7"}>
                <div class="label mb-3">{group.title}</div>
                <div class="grid grid-cols-3 gap-px bg-line border border-line">
                  {group.links?.map((link) => (
                    <a
                      href={link.href}
                      target="_blank"
                      rel="noopener noreferrer"
                      class="font-mono text-xs bg-ink px-3 py-4 text-paper/80 text-center hover:bg-acid hover:text-ink transition"
                    >
                      {link.label}
                    </a>
                  ))}
                </div>
              </div>
            ))}
          </div>
        </div>
        <div
          class="pt-6 border-t border-line flex flex-wrap items-center justify-between gap-4 font-mono text-[10px] text-dim uppercase tracking-wider"
        >
          <div>{copyright}</div>
          <div class="flex flex-wrap gap-x-4 gap-y-2">
            {bottomLinks.map((link) => (
              <a class="hover:text-acid transition" href={link.href} rel={link.rel}>{link.label}</a>
            ))}
          </div>
        </div>
        {disclaimer && (
          <p class="mt-4 font-mono text-[10px] text-dim/80 max-w-4xl">
            {disclaimer}
          </p>
        )}
      </div>
    </footer>
