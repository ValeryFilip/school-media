---
import AcademyCard from "./AcademyCard.astro";
import AcademyBreadcrumbs from "./AcademyBreadcrumbs.astro";

interface Crumb {
  label: string;
  href?: string;
}
interface Stat {
  value: number | string;
  label: string;
  accent?: "rust" | "inkBlue" | null;
}
interface Props {
  breadcrumb?: Crumb[];
  label?: string;
  elMark?: { symbol: string; n: string; mass: string } | null;
  titleTop: string;
  titleAccent?: string;
  description?: string;
  stats?: Stat[];
  featured?: any | null;
  tags?: { name: string; count: number; href: string; active?: boolean }[];
  marquee?: string[];
}
const {
  breadcrumb = [],
  label = "",
  elMark = null,
  titleTop,
  titleAccent = "",
  description = "",
  stats = [],
  featured = null,
  tags = [],
  marquee = [],
} = Astro.props as Props;
const leftCol = featured ? "lg:col-span-7" : "lg:col-span-9";
---

<section class="relative overflow-hidden">
  <div
    class="absolute inset-0 pt-grid opacity-[0.5] pointer-events-none"
    id="ptBg"
    aria-hidden="true"
  >
  </div>

  <div class="relative gutter pt-10 md:pt-14 pb-14 md:pb-20">
    {breadcrumb.length > 0 && <AcademyBreadcrumbs items={breadcrumb} />}

    <div class="grid grid-cols-12 gap-8">
      <div class={`col-span-12 ${leftCol}`}>
        {
          label && (
            <div class="flex items-center gap-3 mb-6">
              <span class="w-2 h-2 bg-rust" />
              <span class="label">{label}</span>
            </div>
          )
        }

        <div class="flex items-start gap-6 md:gap-8 mb-8">
          {
            elMark && (
              <div class="el-mark" data-n={elMark.n} data-mass={elMark.mass}>
                {elMark.symbol}
              </div>
            )
          }
          <h1
            class="font-display font-bold tracking-[-0.03em] leading-[0.92] text-[clamp(44px,7vw,128px)]"
          >
            {titleTop}
            {titleAccent && <><br /><span class="text-rust">{titleAccent}</span></>}<span
              class="text-ochre">_</span
            >
          </h1>
        </div>

        {description && <p class="body-serif max-w-2xl" set:html={description} />}

        {
          stats.length > 0 && (
            <div
              class:list={[
                "mt-10 grid grid-cols-2 gap-px bg-aline border border-aline",
                stats.length === 3 && "md:grid-cols-3",
                stats.length === 4 && "md:grid-cols-4",
                stats.length >= 5 && "md:grid-cols-4",
                stats.length === 2 && "md:grid-cols-2",
              ]}
            >
              {stats.map((s) => (
                <div class="bg-amilk p-5">
                  <div
                    class={`font-display font-bold text-3xl ${s.accent === "rust" ? "text-rust" : s.accent === "inkBlue" ? "text-inkBlue" : ""}`}
                    data-counter={typeof s.value === "number" ? String(s.value) : undefined}
                    aria-label={typeof s.value === "number" ? String(s.value) : undefined}
                  >
                    {typeof s.value === "number" ? 0 : s.value}
                  </div>
                  <div class="label mt-1">{s.label}</div>
                </div>
              ))}
            </div>
          )
        }
      </div>

      {
        featured && (
          <div class="col-span-12 lg:col-span-5">
            <AcademyCard {...featured} />
          </div>
        )
      }
    </div>

    {
      tags.length > 0 && (
        <div class="mt-14">
          <div class="font-mono text-[11px] text-adim uppercase tracking-widest mb-4">
            // темы в&nbsp;категории
          </div>
          <div class="flex flex-wrap gap-2">
            {tags.map((t) => (
              <a href={t.href} class={`tag-pill${t.active ? " is-active" : ""}`}>
                <span>{t.name}</span>
                <span class="tag-count">{t.count}</span>
              </a>
            ))}
          </div>
        </div>
      )
    }
  </div>

  {
    marquee.length > 0 && (
      <div class="border-t border-aline py-3 overflow-hidden">
        <div class="marquee font-mono text-sm text-adim whitespace-nowrap">
          {[0, 1].map((dup) => (
            <div class="flex items-center gap-12" aria-hidden={dup === 1}>
              {marquee.map((m, i) => (
                <>
                  <span set:html={m} />
                  <span class={i % 2 === 0 ? "text-rust" : "text-inkBlue"}>●</span>
                </>
              ))}
            </div>
          ))}
        </div>
      </div>
    )
  }
</section>
