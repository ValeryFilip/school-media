---
interface Cat {
  num: string;
  sym: string;
  name: string;
  count: number;
  href: string;
  meta?: string;
  highlight?: boolean;
}
const { categories = [], total = 0 } = Astro.props as {
  categories: Cat[];
  total: number;
};
const word =
  categories.length === 1
    ? "раздел"
    : categories.length < 5
      ? "раздела"
      : "разделов";
---

<section class="section relative" id="categories">
  <div class="gutter py-20 md:py-28">
    <div class="grid grid-cols-12 gap-6 mb-14">
      <div class="col-span-12 md:col-span-3">
        <div class="sec-num">[02] / КАТЕГОРИИ</div>
      </div>
      <div class="col-span-12 md:col-span-9">
        <h2
          class="font-display font-bold text-[clamp(34px,5vw,72px)] leading-[0.95] tracking-[-0.02em] titrate"
        >
          {categories.length}&nbsp;{word}.
          <span class="text-adim">{total} материалов. Найди свою тему.</span>
        </h2>
      </div>
    </div>

    <div
      class="grid grid-cols-2 md:grid-cols-4 gap-px bg-aline border border-aline"
    >
      {
        categories.map((c) => (
          <a
            href={c.href}
            class="cell aspect-square md:aspect-[5/4] p-5 flex flex-col justify-between"
          >
            <div class="cell-num">№ {c.num}</div>
            {c.meta && <div class="cell-mass">{c.meta}</div>}
            <div class="flex items-center justify-center flex-1">
              <div class="text-center">
                <div
                  class={`font-display font-bold text-[clamp(40px,7vw,72px)] leading-none ${c.highlight ? "text-rust cell-rust" : ""}`}
                >
                  {c.sym}
                </div>
                <div class="font-mono text-xs mt-3 cell-meta text-adim">
                  {c.name}
                </div>
              </div>
            </div>
            <div class="flex items-center justify-between text-[10px] font-mono">
              <span class="text-rust cell-rust font-bold">{c.count} статей</span>
              <span class="text-adim cell-meta">→</span>
            </div>
          </a>
        ))
      }
    </div>
  </div>
</section>
