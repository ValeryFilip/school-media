const trajs = [
  { tag: "11 класс · с нуля", steps: 8, weeks: "36 нед", title: "Сдать ЕГЭ на&nbsp;80+&nbsp;за&nbsp;9&nbsp;месяцев", desc: "Стартовая траектория для&nbsp;тех, кто в&nbsp;марте 11&nbsp;класса понял, что время пришло.", illo: "traj1", href: "/ege/" },
  { tag: "мед, фарм, био", steps: 12, weeks: "12 мес", title: "Поступить в&nbsp;медицинский — 90+", desc: "Полная программа под&nbsp;1-й&nbsp;Мед, РНИМУ и&nbsp;СПбГМУ. С&nbsp;упором на&nbsp;задачи&nbsp;34.", illo: "traj2", href: "/ege/" },
  { tag: "ВОШ · Менделеевская", steps: 14, weeks: "18 мес", title: "Выйти в&nbsp;заключительный этап олимпиады", desc: "Нестандартные задачи на&nbsp;3–5&nbsp;ходов, экспериментальный тур, синтезы.", illo: "traj3", href: "/tutor/" },
  { tag: "выпускники", steps: 6, weeks: "4 мес", title: "Пересдать ЕГЭ × 2", desc: "Интенсив для&nbsp;тех, кто сдал на&nbsp;55–65 и&nbsp;идёт на&nbsp;повторение через год.", illo: "traj4", href: "/ege/" },
  { tag: "8–10 класс", steps: 9, weeks: "24 мес", title: "Закладываем базу заранее", desc: "Длинный путь: за&nbsp;два года выйти на&nbsp;уровень, при&nbsp;котором ЕГЭ — это формальность.", illo: "traj5", href: "/10-klass/" },
  { tag: "студенты 1–4 курс", steps: 5, weeks: "по запросу", title: "Дотянуть химию в&nbsp;вузе", desc: "Общая, орг, аналитика, физхимия — материалы для&nbsp;коллоквиумов и&nbsp;госов.", illo: "traj6", href: "/tutor/" },
];
---

<section class="section relative" id="trajectories">
  <div class="gutter py-20 md:py-28">
    <div class="grid grid-cols-12 gap-6 mb-14">
      <div class="col-span-12 md:col-span-3">
        <div class="sec-num">[04] / ТРАЕКТОРИИ</div>
      </div>
      <div class="col-span-12 md:col-span-9">
        <h2
          class="font-display font-bold text-[clamp(34px,5vw,72px)] leading-[0.95] tracking-[-0.02em] titrate"
        >
          С&nbsp;чего начать? <span class="text-adim"
            >Шесть готовых путей под&nbsp;твою ситуацию.</span
          >
        </h2>
      </div>
    </div>

    <div
      class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-px bg-aline border border-aline"
    >
      {
        trajs.map((t) => (
          <a href={t.href} class="traj-card flex flex-col">
            <div class="aspect-[5/3] border-b border-aline overflow-hidden" set:html={trajIllos[t.illo]} />
            <div class="p-7 flex-1 flex flex-col">
              <div class="flex items-center justify-between mb-5 font-mono text-[11px]">
                <span class="text-rust uppercase tracking-wider">{t.tag}</span>
                <span class="text-adim">
                  {t.steps} шагов · {t.weeks}
                </span>
              </div>
              <h3
                class="font-display font-bold text-2xl md:text-[28px] leading-[1.1] tracking-tight mb-4 flex-1"
                set:html={t.title}
              />
              <p
                class="font-mono text-[13px] text-ainkSoft leading-snug mb-6"
                set:html={t.desc}
              />
              <div class="flex items-center justify-between pt-4 border-t border-aline">
                <span class="font-mono text-[12px] uppercase tracking-wider">
                  Открыть план
                </span>
                <span class="font-mono text-lg traj-arrow">→</span>
              </div>
            </div>
          </a>
        ))
      }
    </div>
  </div>
</section>
