    <svg viewBox="0 0 400 240" class="w-full h-full">
      <rect width="400" height="240" fill="#EFE9DA"/>
      ${[0, 1, 2, 3, 4]
        .map(
          (i) =>
            `<rect x="${100 + i * 8}" y="${60 + i * 20}" width="200" height="22" fill="${["#EFE9DA", "#1A3556", "#EFE9DA", "#B23A14", "#EFE9DA"][i]}" stroke="#1A1410" stroke-width="1.5"/><text x="${110 + i * 8}" y="${76 + i * 20}" font-family="JetBrains Mono" font-size="11" fill="${[1, 3].includes(i) ? "#EFE9DA" : "#1A1410"}">${["общая", "неорг.", "органика", "аналитика", "физхимия"][i]}</text>`,
