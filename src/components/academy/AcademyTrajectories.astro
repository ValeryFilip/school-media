---
// Курируемые «траектории» — статический блок (не из статей).
const trajIllos: Record<string, string> = {
  traj1: `
    <svg viewBox="0 0 400 240" class="w-full h-full">
      <rect width="400" height="240" fill="#E6DFCC"/>
      ${[0, 1, 2, 3, 4, 5, 6, 7]
        .map(
          (i) =>
            `<rect x="${30 + i * 44}" y="${180 - i * 16}" width="34" height="${16 + i * 16}" fill="${i === 7 ? "#B23A14" : "#EFE9DA"}" stroke="#1A1410" stroke-width="1"/>`,
        )
        .join("")}
      <text x="30" y="220" font-family="JetBrains Mono" font-size="12" fill="#8A7F70">сентябрь</text>
      <text x="350" y="220" font-family="JetBrains Mono" font-size="12" fill="#B23A14" text-anchor="end">июнь · 87</text>
      <text x="200" y="40" font-family="Space Grotesk" font-weight="700" font-size="36" fill="#1A1410" text-anchor="middle" letter-spacing="-1">+40 баллов</text>
    </svg>`,
  traj2: `
    <svg viewBox="0 0 400 240" class="w-full h-full">
      <rect width="400" height="240" fill="#EFE9DA"/>
      <g transform="translate(200, 120)">
        <rect x="-15" y="-65" width="30" height="130" fill="#B23A14"/>
        <rect x="-65" y="-15" width="130" height="30" fill="#B23A14"/>
      </g>
      <text x="100" y="60" font-family="JetBrains Mono" font-size="14" fill="#8A7F70">Hb</text>
      <text x="300" y="60" font-family="JetBrains Mono" font-size="14" fill="#8A7F70">Fe²⁺</text>
      <text x="100" y="200" font-family="JetBrains Mono" font-size="14" fill="#8A7F70">C₆H₁₂O₆</text>
      <text x="300" y="200" font-family="JetBrains Mono" font-size="14" fill="#8A7F70" text-anchor="end">H₂O</text>
      <text x="20" y="225" font-family="JetBrains Mono" font-size="11" fill="#1A3556">// 1st Med · РНИМУ · СПбГМУ</text>
    </svg>`,
  traj3: `
    <svg viewBox="0 0 400 240" class="w-full h-full">
      <rect width="400" height="240" fill="#E6DFCC"/>
      <g transform="translate(200, 110)">
        <rect x="-35" y="-50" width="70" height="100" fill="none" stroke="#1A1410" stroke-width="1.5"/>
        <rect x="-30" y="-45" width="60" height="90" fill="#C9882B"/>
        <text x="0" y="14" font-family="Space Grotesk" font-weight="700" font-size="46" fill="#1A1410" text-anchor="middle">Au</text>
      </g>
      <text x="20" y="225" font-family="JetBrains Mono" font-size="11" fill="#8A7F70">// ВОШ · Менделеевская · IChO</text>
      <text x="380" y="225" font-family="JetBrains Mono" font-size="11" fill="#B23A14" text-anchor="end">14 шагов</text>
    </svg>`,
  traj4: `
    <svg viewBox="0 0 400 240" class="w-full h-full">
      <rect width="400" height="240" fill="#EFE9DA"/>
      <g transform="translate(110, 120)">
        <circle r="60" fill="none" stroke="#8A7F70" stroke-width="1" stroke-dasharray="4 4"/>
        <text y="6" font-family="Space Grotesk" font-weight="700" font-size="40" fill="#8A7F70" text-anchor="middle">58</text>
      </g>
      <line x1="180" y1="120" x2="240" y2="120" stroke="#B23A14" stroke-width="2"/>
      <line x1="240" y1="120" x2="225" y2="110" stroke="#B23A14" stroke-width="2"/>
      <line x1="240" y1="120" x2="225" y2="130" stroke="#B23A14" stroke-width="2"/>
      <g transform="translate(310, 120)">
        <circle r="60" fill="#B23A14"/>
        <text y="8" font-family="Space Grotesk" font-weight="700" font-size="40" fill="#EFE9DA" text-anchor="middle">92</text>
      </g>
      <text x="200" y="40" font-family="JetBrains Mono" font-size="12" fill="#8A7F70" text-anchor="middle">2024 → 2025</text>
      <text x="200" y="220" font-family="JetBrains Mono" font-size="11" fill="#1A1410" text-anchor="middle">пересдать · +34 балла</text>
    </svg>`,
  traj5: `
    <svg viewBox="0 0 400 240" class="w-full h-full">
      <rect width="400" height="240" fill="#E6DFCC"/>
      <line x1="40" y1="120" x2="360" y2="120" stroke="#1A1410" stroke-width="1.5"/>
      ${[8, 9, 10, 11]
        .map(
          (cls, i) =>
            `<g transform="translate(${60 + i * 90}, 120)"><line x1="0" y1="-12" x2="0" y2="12" stroke="#1A1410" stroke-width="1.5"/><text y="-22" font-family="Space Grotesk" font-weight="700" font-size="24" fill="${cls === 11 ? "#B23A14" : "#1A1410"}" text-anchor="middle">${cls}</text><text y="36" font-family="JetBrains Mono" font-size="10" fill="#8A7F70" text-anchor="middle">класс</text></g>`,
        )
        .join("")}
      <text x="200" y="80" font-family="JetBrains Mono" font-size="12" fill="#1A3556" text-anchor="middle">// долгий путь · 24 месяца</text>
