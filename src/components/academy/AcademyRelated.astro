---
import { academyPath } from "../../lib/academyPaths";

interface Cat {
  n: string;
  sym: string;
  name: string;
  count: number;
  href: string;
}
const {
  categories = [],
  total = 0,
  allHref = academyPath(),
} = Astro.props as { categories: Cat[]; total: number; allHref: string };
---

{
  categories.length > 0 && (
    <section class="section">
      <div class="gutter py-16 md:py-24">
        <div class="grid grid-cols-12 gap-6 mb-10 items-end">
          <div class="col-span-12 md:col-span-3">
            <div class="sec-num">[06] / СОСЕДНИЕ</div>
          </div>
          <div class="col-span-12 md:col-span-6">
            <h2 class="font-display font-bold text-[clamp(28px,4vw,56px)] leading-[0.95] tracking-[-0.02em] titrate">
              Связанные категории.
            </h2>
          </div>
          <div class="col-span-12 md:col-span-3 md:text-right">
            <a
              href={allHref}
              class="font-mono text-[12px] uppercase tracking-wider hover:text-rust transition"
            >
              все {total} категорий →
            </a>
          </div>
        </div>

        <div class="grid grid-cols-2 md:grid-cols-3 lg:grid-cols-3 gap-px bg-aline border border-aline">
          {categories.map((c) => (
            <a href={c.href} class="block bg-amilk p-6 md:p-7 group transition hover:bg-apaper">
              <div class="flex items-start justify-between mb-4">
                <span class="font-mono text-[11px] text-adim">№ {c.n}</span>
                <span class="font-mono text-[10px] text-adim">{c.count} статей</span>
              </div>
              <div class="font-display font-bold text-[clamp(40px,7vw,72px)] leading-none mb-4 group-hover:text-rust transition">
                {c.sym}
              </div>
              <div class="flex items-center justify-between pt-4 border-t border-aline">
                <span class="font-display font-bold text-lg">{c.name}</span>
                <span class="font-mono text-base group-hover:translate-x-1 transition">→</span>
              </div>
            </a>
          ))}
        </div>
      </div>
    </section>
  )
}
