---
interface Props {
  title: string;
  prose: string; // HTML
  secNum?: string;
}
const {
  title,
  prose,
  secNum = "[03] / О КАТЕГОРИИ",
} = Astro.props as Props;
---

<section class="section bg-apaper2">
  <div class="gutter py-16 md:py-24">
    <div class="mb-8">
      <div class="sec-num mb-4">{secNum}</div>
      <h2
        class="font-display font-bold text-[clamp(34px,5vw,72px)] leading-[0.95] tracking-[-0.02em] titrate"
        set:html={title}
      />
    </div>
    <div class="desc-prose max-w-4xl" set:html={prose} />
  </div>
</section>
