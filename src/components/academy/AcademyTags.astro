---
interface Tag {
  name: string;
  count: number;
  href: string;
  active?: boolean;
}
interface Props {
  tags?: Tag[];
  secNum?: string;
  titleHtml?: string;
}
const {
  tags = [],
  secNum = "[06] / ТЕГИ",
  titleHtml = 'Темы, которые читают <span class="text-adim">больше всего.</span>',
} = Astro.props as Props;
---

<section class="section relative">
  <div class="gutter py-20 md:py-28">
    <div class="grid grid-cols-12 gap-6 mb-10">
      <div class="col-span-12 md:col-span-3">
        <div class="sec-num">{secNum}</div>
      </div>
      <div class="col-span-12 md:col-span-9">
        <h2
          class="font-display font-bold text-[clamp(34px,5vw,72px)] leading-[0.95] tracking-[-0.02em] titrate"
          set:html={titleHtml}
        />
      </div>
    </div>

    <div class="flex flex-wrap gap-3">
      {
        tags.map((t) => (
          <a href={t.href} class={`tag-pill${t.active ? " is-active" : ""}`}>
            <span>{t.name}</span>
            <span class="tag-count">{t.count}</span>
          </a>
        ))
      }
    </div>
  </div>
</section>
