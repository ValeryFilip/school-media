---
interface Tag {
  name: string;
  count: number;
  href: string;
}
const { tags = [] } = Astro.props as { tags: Tag[] };
---

<section class="section relative">
  <div class="gutter py-20 md:py-28">
    <div class="grid grid-cols-12 gap-6 mb-10">
      <div class="col-span-12 md:col-span-3">
        <div class="sec-num">[06] / ТЕГИ</div>
      </div>
      <div class="col-span-12 md:col-span-9">
        <h2
          class="font-display font-bold text-[clamp(32px,4.5vw,64px)] leading-[0.95] tracking-[-0.02em] titrate"
        >
          Темы, которые читают <span class="text-adim">больше всего.</span>
        </h2>
      </div>
    </div>

    <div class="flex flex-wrap gap-3">
      {
        tags.map((t) => (
          <a href={t.href} class="tag-pill">
            <span>{t.name}</span>
            <span class="tag-count">{t.count}</span>
          </a>
        ))
      }
    </div>
  </div>
</section>
