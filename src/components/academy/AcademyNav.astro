---
import type { CollectionEntry } from "astro:content";
import { academyArticlesPath, academyCategoryPath } from "../../lib/academyPaths";
import AcademyArticleSearch from "./AcademyArticleSearch.astro";

type Article = CollectionEntry<"articles">;

interface Props {
  articlesCount?: number;
  searchArticles?: Article[];
  categories?: { label: string; href: string }[];
}

const { articlesCount = 0, searchArticles = [], categories = [] } = Astro.props as Props;

const courseColumns = [
  {
    title: "Годовые курсы",
    links: [
      {
        href: "/#courses-tabs",
        title: "Годовой курс ЕГЭ",
        subtitle: "Полный курс подготовки к ЕГЭ",
      },
      {
        href: "/#courses-tabs",
        title: "Годовой курс для 10 класса",
        subtitle: "Подготовка к ЕГЭ с 10 класса",
      },
      {
        href: "/#courses-tabs",
        title: "Годовой курс ОГЭ",
        subtitle: "Подготовка к ОГЭ",
      },
    ],
  },
  {
    title: "Самостоятельные курсы",
    links: [
      { href: "/allcourses/", title: "Все курсы", subtitle: "Полный каталог курсов ЕГЭХИМ" },
      { href: "/obschaya/", title: "Курс по общей химии", subtitle: "Основы химии" },
      { href: "/organika/", title: "Курс по органической химии", subtitle: "Органическая химия" },
      { href: "/neorganika/", title: "Курс по неорганической химии", subtitle: "Неорганическая химия" },
      { href: "/ovr/", title: "Курс по ОВР", subtitle: "Окислительно-восстановительные реакции" },
      {
        href: "https://stepik.org/a/140949?utm_source=cite&utm_medium=menu",
        title: "Авторские варианты ЕГЭ",
        subtitle: "Практические задания ЕГЭ",
        external: true,
      },
    ],
  },
];

const fallbackCategories = searchArticles
  .reduce((acc, article) => {
    const label = String(article.data.category || "").trim();
    if (label && !acc.some((item) => item.label === label)) {
      acc.push({ label, href: academyCategoryPath(label) });
    }
    return acc;
  }, [] as { label: string; href: string }[])
  .sort((a, b) => a.label.localeCompare(b.label, "ru"));

const categoryLinks = categories.length ? categories : fallbackCategories;
---

<header class="academy-nav">
  <div class="academy-nav__inner gutter">
    <div class="academy-nav__left">
      <a href="/" class="academy-nav__brand" aria-label="ЕГЭХИМ — главная">
        <img
          src="/images/technical/egehim(academy).webp"
          alt="ЕГЭХИМ"
          width="118"
          height="42"
          class="academy-nav__logo"
          loading="eager"
          decoding="async"
        />
        <span class="academy-nav__meta">/ Академия</span>
      </a>

      <nav class="academy-nav__site" aria-label="Основная навигация">
        <a href="/">Главная</a>
        <a href={academyArticlesPath()}>Все статьи</a>

        <details class="academy-nav__details">
          <summary>Категории</summary>
          <div class="academy-nav__dropdown academy-nav__dropdown--categories">
            {categoryLinks.map((category) => (
              <a href={category.href} class="academy-nav__dropdown-link">
                <span>{category.label}</span>
              </a>
            ))}
          </div>
        </details>

        <details class="academy-nav__details">
          <summary>Наши курсы</summary>
          <div class="academy-nav__dropdown academy-nav__dropdown--courses">
            {courseColumns.map((column) => (
              <div class="academy-nav__dropdown-column">
                <div class="academy-nav__dropdown-title">{column.title}</div>
                {column.links.map((link) => (
                  <a
                    href={link.href}
                    class="academy-nav__dropdown-link"
                    target={link.external ? "_blank" : undefined}
                    rel={link.external ? "noopener noreferrer" : undefined}
                  >
                    <span>{link.title}</span>
                    <small>{link.subtitle}</small>
                  </a>
                ))}
              </div>
            ))}
          </div>
        </details>

      </nav>
    </div>

    <div class="academy-nav__right">
      <div class="academy-nav__search">
        <AcademyArticleSearch
          articles={searchArticles}
          variant="nav"
          showShortcut={false}
          placeholder={`поиск по ${articlesCount} статьям...`}
        />
      </div>
      <button
        type="button"
        class="academy-nav__cta popup-btn"
        data-popup-id="lead-popup"
        data-source="academy-menu"
        data-variant="desktop"
        data-campaign="academy"
      >
        Учиться бесплатно
      </button>
    </div>

    <details class="academy-nav__mobile">
      <summary aria-label="Открыть меню"><span></span><span></span><span></span></summary>
      <div class="academy-nav__panel">
        <div class="academy-nav__panel-head">
          <div class="academy-nav__panel-kicker">// меню</div>
          <button
            type="button"
            class="academy-nav__panel-close"
            data-academy-menu-close
            aria-label="Закрыть меню"
          >
            <span>Закрыть</span>
            <b aria-hidden="true">×</b>
          </button>
        </div>

        <div class="academy-nav__panel-search">
          <AcademyArticleSearch
            articles={searchArticles}
            variant="nav"
            showShortcut={false}
            placeholder="поиск по статьям..."
          />
        </div>

        <div class="academy-nav__panel-body">
          <section class="academy-nav__panel-section">
            <div class="academy-nav__panel-kicker">// разделы</div>
            <nav class="academy-nav__panel-list" aria-label="Разделы">
              <a href="/"><span>Главная</span></a>
              <a href={academyArticlesPath()}><span>Все статьи</span></a>
            </nav>
          </section>

          {categoryLinks.length > 0 && (
            <section class="academy-nav__panel-section">
              <div class="academy-nav__panel-kicker">// категории</div>
              <nav class="academy-nav__panel-list" aria-label="Категории">
                {categoryLinks.map((category) => (
                  <a href={category.href}><span>{category.label}</span></a>
                ))}
              </nav>
            </section>
          )}

          {courseColumns.length > 0 && (
            <section class="academy-nav__panel-section">
              <div class="academy-nav__panel-kicker">// наши курсы</div>
              {courseColumns.map((column) => (
                <div class="academy-nav__panel-group">
                  {column.title && (
                    <div class="academy-nav__panel-group-label">{column.title}</div>
                  )}
                  <nav class="academy-nav__panel-list" aria-label={column.title}>
                    {column.links.map((link) => (
                      <a
                        href={link.href}
                        target={link.external ? "_blank" : undefined}
                        rel={link.external ? "noopener noreferrer" : undefined}
                      >
                        <span>{link.title}</span>
                        {link.subtitle && <small>{link.subtitle}</small>}
                      </a>
                    ))}
                  </nav>
                </div>
              ))}
            </section>
          )}
        </div>

        <div class="academy-nav__panel-footer">
          <button
            type="button"
            class="academy-nav__panel-cta popup-btn"
            data-popup-id="lead-popup"
            data-source="academy-menu"
            data-variant="mobile"
            data-campaign="academy"
          >
            Учиться бесплатно
          </button>
        </div>
      </div>
    </details>
  </div>
</header>

<style>
  .academy-nav {
    position: sticky;
    top: 0;
    z-index: 2000;
    background: color-mix(in srgb, var(--paper) 92%, transparent);
    border-bottom: 1px solid var(--line);
    backdrop-filter: blur(14px);
  }
  /* При открытом моб-меню скролл блокируется (overflow:hidden на html/body),
     а это ломает position:sticky — шапка «отлипает» и уезжает за экран.
     Пиним её через fixed, чтобы верх оставался на месте под панелью. */
  .academy-nav.is-menu-open {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
  }
  /* На мобиле убираем backdrop-filter — он создаёт containing block
     для position:fixed внутри, и панель меню перестаёт быть viewport-fixed. */
  @media (max-width: 980px) {
    .academy-nav {
      background: var(--paper);
      backdrop-filter: none;
    }
  }

  .academy-nav__inner {
    min-height: 68px;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 22px;
  }

  .academy-nav__left,
  .academy-nav__right {
    display: flex;
    align-items: center;
    gap: 24px;
    min-width: 0;
  }

  .academy-nav__brand {
    display: flex;
    align-items: center;
    gap: 12px;
    flex-shrink: 0;
    color: var(--ink);
    text-decoration: none;
  }

  .academy-nav__logo {
    display: block;
    width: 118px;
    height: auto;
  }

  .academy-nav__meta {
    font-family: "JetBrains Mono", monospace;
    font-size: 10px;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: var(--dim);
    white-space: nowrap;
  }

  .academy-nav__site {
    display: flex;
    align-items: center;
    gap: 18px;
    font-family: "JetBrains Mono", monospace;
    font-size: 11px;
    letter-spacing: 0.12em;
    text-transform: uppercase;
  }

  .academy-nav__site a,
  .academy-nav__details summary {
    color: var(--inkSoft);
    text-decoration: none;
    transition: color 150ms ease;
  }

  .academy-nav__site a:hover,
  .academy-nav__details:hover summary,
  .academy-nav__details[open] summary {
    color: var(--rust);
  }

  .academy-nav__details {
    position: relative;
  }

  .academy-nav__details summary {
    display: flex;
    align-items: center;
    gap: 6px;
    cursor: pointer;
    list-style: none;
  }

  .academy-nav__details summary::-webkit-details-marker {
    display: none;
  }

  .academy-nav__details summary::after {
    content: "↓";
    font-size: 12px;
    line-height: 1;
  }

  .academy-nav__details[open] summary::after {
    transform: rotate(180deg);
  }

  .academy-nav__dropdown {
    position: absolute;
    top: calc(100% + 18px);
    left: -18px;
    z-index: 2100;
    min-width: 320px;
    padding: 16px;
    border: 1px solid var(--line);
    border-top: 4px solid var(--rust);
    background: #fffdf7;
  }

  .academy-nav__dropdown--courses {
    width: min(680px, calc(100vw - 32px));
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 16px;
  }

  .academy-nav__dropdown--categories {
    display: grid;
    gap: 6px;
  }

  .academy-nav__dropdown-column {
    display: flex;
    flex-direction: column;
    gap: 6px;
  }

  .academy-nav__dropdown-title,
  .academy-nav__panel-label {
    margin-bottom: 6px;
    font-family: "JetBrains Mono", monospace;
    font-size: 10px;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: var(--rust);
  }

  .academy-nav__dropdown-link {
    display: grid;
    gap: 3px;
    padding: 10px 12px;
    border: 1px solid transparent;
    color: var(--ink);
    text-decoration: none;
    text-transform: none;
    letter-spacing: 0;
  }

  .academy-nav__dropdown-link:hover {
    border-color: var(--line);
    background: var(--milk);
    color: var(--ink);
  }

  .academy-nav__dropdown-link span {
    font-family: "Space Grotesk", sans-serif;
    font-size: 15px;
    font-weight: 700;
    line-height: 1.1;
  }

  .academy-nav__dropdown-link small {
    font-family: "JetBrains Mono", monospace;
    font-size: 11px;
    line-height: 1.35;
    color: var(--dim);
  }

  .academy-nav__search {
    width: min(28vw, 360px);
    min-width: 240px;
  }

  .academy-nav__cta,
  .academy-nav__panel-cta {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-height: 38px;
    padding: 0 14px;
    border: 1px solid var(--ink);
    background: var(--ink);
    color: var(--paper);
    font-family: "JetBrains Mono", monospace;
    font-size: 11px;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    text-decoration: none;
    white-space: nowrap;
    cursor: pointer;
    transition:
      background 150ms ease,
      color 150ms ease,
      border-color 150ms ease;
  }

  .academy-nav__cta:hover,
  .academy-nav__panel-cta:hover {
    border-color: var(--rust);
    background: var(--rust);
    color: var(--paper);
  }

  .academy-nav__mobile {
    display: none;
    position: relative;
  }

  .academy-nav__mobile > summary {
    width: 42px;
    height: 38px;
    display: grid;
    place-items: center;
    gap: 4px;
    border: 1px solid var(--line);
    background: #fffdf7;
    cursor: pointer;
    list-style: none;
  }

  .academy-nav__mobile > summary::-webkit-details-marker {
    display: none;
  }

  .academy-nav__mobile > summary span {
    width: 18px;
    height: 1px;
    background: var(--ink);
    transform-origin: center;
    transition:
      transform 200ms ease,
      opacity 150ms ease;
  }

  /* Бургер → X при открытии */
  .academy-nav__mobile[open] > summary {
    background: var(--rust);
    border-color: var(--rust);
  }
  .academy-nav__mobile[open] > summary span {
    background: var(--paper);
  }
  .academy-nav__mobile[open] > summary span:nth-child(1) {
    transform: translateY(5px) rotate(45deg);
  }
  .academy-nav__mobile[open] > summary span:nth-child(2) {
    opacity: 0;
  }
  .academy-nav__mobile[open] > summary span:nth-child(3) {
    transform: translateY(-5px) rotate(-45deg);
  }

  /* Панель — фуллскрин под навигацией: flex-col c липким хедером (search)
     и липким футером (CTA), скроллится только тело. */
  .academy-nav__panel {
    position: fixed;
    top: 68px;
    left: 0;
    right: 0;
    bottom: 0;
    z-index: 2200;
    display: flex;
    flex-direction: column;
    background: var(--paper);
    border-top: 1px solid var(--line);
  }

  .academy-nav__panel-head {
    flex-shrink: 0;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 16px;
    padding: 14px 16px;
    border-bottom: 1px solid var(--line);
    background: #fffdf7;
  }

  .academy-nav__panel-close {
    display: inline-flex;
    align-items: center;
    gap: 10px;
    min-height: 38px;
    padding: 0 0 0 12px;
    border: 1px solid var(--ink);
    background: var(--ink);
    color: var(--paper);
    font-family: "JetBrains Mono", monospace;
    font-size: 11px;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    cursor: pointer;
  }

  .academy-nav__panel-close b {
    width: 38px;
    height: 36px;
    display: grid;
    place-items: center;
    border-left: 1px solid color-mix(in srgb, var(--paper) 26%, transparent);
    font-family: "Space Grotesk", sans-serif;
    font-size: 24px;
    line-height: 1;
  }

  .academy-nav__panel-close:hover {
    border-color: var(--rust);
    background: var(--rust);
  }

  .academy-nav__panel-search {
    flex-shrink: 0;
    padding: 14px 16px;
    border-bottom: 1px solid var(--line);
    background: var(--milk);
    position: relative;
    z-index: 1;
  }

  .academy-nav__panel-body {
    flex: 1;
    min-height: 0;
    overflow-y: auto;
    padding: 22px 16px 28px;
    display: flex;
    flex-direction: column;
    gap: 26px;
    -webkit-overflow-scrolling: touch;
    overscroll-behavior: contain;
  }

  .academy-nav__panel-kicker {
    font-family: "JetBrains Mono", monospace;
    font-size: 11px;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--rust);
    margin-bottom: 10px;
  }

  .academy-nav__panel-list {
    display: flex;
    flex-direction: column;
    gap: 1px;
    background: var(--line);
    border: 1px solid var(--line);
  }

  .academy-nav__panel-list a {
    display: grid;
    grid-template-columns: 1fr auto;
    align-items: center;
    column-gap: 12px;
    row-gap: 2px;
    padding: 14px 14px;
    background: #fffdf7;
    color: var(--ink);
    text-decoration: none;
    font-family: "Space Grotesk", sans-serif;
    font-weight: 600;
    font-size: 15px;
    line-height: 1.2;
    transition: background 150ms ease;
  }
  .academy-nav__panel-list a > span {
    grid-column: 1;
  }
  .academy-nav__panel-list a > small {
    grid-column: 1;
    font-family: "JetBrains Mono", monospace;
    font-size: 11px;
    font-weight: 400;
    color: var(--dim);
    margin-top: 1px;
  }
  .academy-nav__panel-list a::after {
    content: "→";
    grid-column: 2;
    grid-row: 1 / -1;
    align-self: center;
    color: var(--rust);
    font-family: "JetBrains Mono", monospace;
    font-size: 13px;
  }
  .academy-nav__panel-list a:hover {
    background: var(--milk);
  }

  .academy-nav__panel-group + .academy-nav__panel-group {
    margin-top: 14px;
  }
  .academy-nav__panel-group-label {
    font-family: "JetBrains Mono", monospace;
    font-size: 10px;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: var(--dim);
    margin-bottom: 6px;
    padding-left: 2px;
  }

  .academy-nav__panel-footer {
    flex-shrink: 0;
    padding: 14px 16px calc(14px + env(safe-area-inset-bottom));
    border-top: 1px solid var(--line);
    background: var(--paper);
  }

  .academy-nav__panel-cta {
    width: 100%;
    min-height: 52px;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    border: 1px solid var(--rust);
    background: var(--rust);
    color: var(--paper);
    font-family: "JetBrains Mono", monospace;
    font-size: 12px;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    font-weight: 500;
    cursor: pointer;
    transition:
      background 150ms ease,
      color 150ms ease;
  }
  .academy-nav__panel-cta:hover {
    background: var(--rustDark);
    border-color: var(--rustDark);
  }

  @media (max-width: 1200px) {
    .academy-nav__site {
      gap: 12px;
    }

    .academy-nav__search {
      width: 260px;
      min-width: 220px;
    }
  }

  @media (max-width: 1060px) {
    .academy-nav__site,
    .academy-nav__right {
      display: none;
    }

    .academy-nav__mobile {
      display: block;
    }
  }

  @media (max-width: 640px) {
    .academy-nav__inner {
      min-height: 60px;
    }

    .academy-nav__logo {
      width: 104px;
    }

    .academy-nav__meta {
      display: none;
    }

    .academy-nav__panel {
      top: 60px;
    }
  }
</style>

<script is:inline>
  /* Мобильное меню академии: scroll-lock body, Escape, клик-по-ссылке. */
  (function () {
    var menus = document.querySelectorAll(".academy-nav__mobile");
    if (!menus.length) return;

    var lock = function (yes) {
      document.body.style.overflow = yes ? "hidden" : "";
      document.documentElement.style.overflow = yes ? "hidden" : "";
    };

    var closeAll = function () {
      menus.forEach(function (d) {
        if (d.open) d.open = false;
      });
      lock(false);
    };

    menus.forEach(function (d) {
      var header = d.closest(".academy-nav");
      d.addEventListener("toggle", function () {
        lock(d.open);
        if (header) header.classList.toggle("is-menu-open", d.open);
      });
      d.querySelectorAll(".academy-nav__panel a").forEach(function (a) {
        a.addEventListener("click", function () {
          d.open = false;
          lock(false);
        });
      });
      d.querySelectorAll("[data-academy-menu-close], .academy-nav__panel .popup-btn").forEach(function (button) {
        button.addEventListener("click", function () {
          d.open = false;
          lock(false);
        });
      });
    });

    document.addEventListener("keydown", function (e) {
      if (e.key === "Escape") closeAll();
    });
  })();
</script>
