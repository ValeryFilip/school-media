<div id="trailWrap" aria-hidden="true"></div>

<script>
  if (!window.matchMedia("(hover: none)").matches) {
    const wrap = document.getElementById("trailWrap");
    const formulas = ["H2O", "CO2", "Cu", "Fe", "NaCl", "NH3", "HCl", "CH4"];
    let last = 0;

    document.addEventListener("mousemove", (event) => {
      const now = performance.now();
      if (now - last < 110 || !wrap) return;

      last = now;
      const node = document.createElement("div");
      node.className = "trail";
      node.textContent = formulas[Math.floor(Math.random() * formulas.length)];
      node.style.left = `${event.clientX}px`;
      node.style.top = `${event.clientY}px`;
      wrap.appendChild(node);

      const g = (window as any).gsap;
      if (!g) {
        node.remove();
        return;
      }

      g.fromTo(
        node,
        { opacity: 0.7, y: 0, scale: 1 },
        {
          opacity: 0,
          y: -34,
          scale: 0.7,
          duration: 1,
          ease: "power1.out",
          onComplete: () => node.remove(),
        },
      );
    });
  }
</script>
