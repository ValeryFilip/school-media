---
const stats = [
  {
    value: "10 лет",
    desc: "опыта подготовки\nк ЕГЭ по химии",
    icon: "cap",
    accent: "violet",
  },
  {
    value: "1000+",
    desc: "учеников\nподготовлено",
    icon: "users",
    accent: "lime",
  },
  {
    value: "82,6",
    desc: "средний балл\nнаших учеников",
    icon: "star",
    accent: "butter",
  },
  {
    value: "80+",
    desc: "у каждого второго\nна курсе",
    icon: "cup",
    accent: "violet",
  },
];

const points = [
  "Объясняю сложное простым языком",
  "Разбираем ошибки и слабые места",
  "Даю систему, а не хаос",
  "Поддерживаю до экзамена",
];
---

<section class="teacher" aria-labelledby="teacher-title">
  <div class="teacher__shell">
    <div class="teacher__media" aria-hidden="true">
      <div class="teacher__blob"></div>

      <span class="teacher__label">Преподаватель химии</span>

      <svg class="teacher__arrow" viewBox="0 0 140 90" fill="none">
        <path d="M4 8c26 0 37 14 40 31 3 18 14 33 36 35h42" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" />
        <path d="m112 66 10 8-10 8" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" />
      </svg>

      <svg class="teacher__molecule" viewBox="0 0 148 172" fill="none">
        <path d="M46 18 68 52M68 52 104 48M68 52 54 92M54 92 88 116M88 116 118 100M88 116 78 154" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" />
        <circle cx="40" cy="12" r="10" />
        <circle cx="72" cy="58" r="12" />
        <circle cx="112" cy="46" r="10" />
        <circle cx="50" cy="100" r="10" />
        <circle cx="92" cy="124" r="10" />
        <circle cx="124" cy="96" r="9" />
        <circle cx="76" cy="160" r="8" />
      </svg>

      <span class="teacher__spark teacher__spark--star">
        <svg viewBox="0 0 40 40" fill="none">
          <path d="m20 3 4.9 11.1L37 16l-9 7.9L30.5 37 20 30.4 9.5 37 12 23.9 3 16l12.1-1.9L20 3Z" stroke="currentColor" stroke-width="2" stroke-linejoin="round" />
        </svg>
      </span>

      <span class="teacher__spark teacher__spark--dots">
        <svg viewBox="0 0 38 24" fill="currentColor">
          <circle cx="4" cy="5" r="2.2" />
          <circle cx="15" cy="16" r="2.2" />
          <circle cx="27" cy="10" r="2.2" />
          <circle cx="34" cy="20" r="2.2" />
        </svg>
      </span>

      <span class="teacher__flask">
        <svg viewBox="0 0 170 240" fill="none">
          <path d="M64 12h42M72 12v58L24 186.5C16.2 201.2 26.8 219 43.3 219h85.4c16.5 0 27.1-17.8 19.3-32.5L106 70V12" stroke="currentColor" stroke-width="4.5" stroke-linecap="round" stroke-linejoin="round" />
          <path d="M44 160c12 8.4 25.8 12.6 41 12.6s29-4.2 41-12.6v38H44v-38Z" fill="url(#teacher-flask-fill)" />
          <path d="M55 144c8.8 5 18.7 7.5 30 7.5s21.2-2.5 30-7.5" stroke="currentColor" stroke-width="4.5" stroke-linecap="round" />
          <circle cx="58" cy="167" r="5" fill="currentColor" opacity=".25" />
          <circle cx="113" cy="179" r="6" fill="currentColor" opacity=".22" />
          <circle cx="96" cy="158" r="4.5" fill="currentColor" opacity=".22" />
          <defs>
            <linearGradient id="teacher-flask-fill" x1="85" x2="85" y1="160" y2="198">
              <stop stop-color="#8D6AF5" />
              <stop offset="1" stop-color="#5E38E4" />
            </linearGradient>
          </defs>
        </svg>
      </span>

      <span class="teacher__brush"></span>

      <figure class="teacher__portrait">
        <img
          src="/images/valerii-filipenko.webp"
          alt="Валерий Филипенко"
          width="800"
          height="1200"
          loading="lazy"
        />
      </figure>
    </div>

    <div class="teacher__content">
      <span class="teacher__eyebrow">О преподавателе</span>

      <h2 class="teacher__title" id="teacher-title">Валерий Филипенко</h2>

      <p class="teacher__lead">
        Преподаватель химии, который помогает понять предмет, выстроить систему
        и дойти до высокого балла на ЕГЭ.
      </p>

      <div class="teacher__note">
        <span class="teacher__note-lines" aria-hidden="true"></span>
        <p>
          Не просто объясняю темы — веду к результату
        </p>
        <span class="teacher__note-smile" aria-hidden="true">
          <svg viewBox="0 0 36 36" fill="none">
            <circle cx="18" cy="18" r="15" stroke="currentColor" stroke-width="2" stroke-dasharray="5 5" />
            <path d="M12.5 21c1.8 2 3.7 3 5.5 3s3.7-1 5.5-3M13 14.5h.01M23 14.5h.01" stroke="currentColor" stroke-width="2" stroke-linecap="round" />
          </svg>
        </span>
      </div>

      <ul class="teacher__stats">
        {
          stats.map((stat) => (
            <li class:list={["teacher-stat", `teacher-stat--${stat.accent}`]}>
              <span class="teacher-stat__icon" aria-hidden="true">
                {stat.icon === "cap" && (
                  <svg viewBox="0 0 24 24" fill="none">
                    <path d="m3 9 9-4 9 4-9 4-9-4ZM6 11.5V15l6 3 6-3v-3.5" stroke="currentColor" stroke-width="2" stroke-linejoin="round" />
                  </svg>
                )}
                {stat.icon === "users" && (
                  <svg viewBox="0 0 24 24" fill="none">
                    <circle cx="9" cy="8" r="3" stroke="currentColor" stroke-width="2" />
                    <circle cx="16.5" cy="9.5" r="2.5" stroke="currentColor" stroke-width="2" />
                    <path d="M4.5 19c0-2.8 2.4-5 5.5-5s5.5 2.2 5.5 5M13.5 18.5c.2-1.9 1.8-3.5 4.2-3.5 1 0 2 .3 2.8.9" stroke="currentColor" stroke-width="2" stroke-linecap="round" />
                  </svg>
                )}
                {stat.icon === "star" && (
                  <svg viewBox="0 0 24 24" fill="none">
                    <path d="m12 3 2.7 5.6 6.1.9-4.4 4.3 1 6.1L12 17l-5.4 2.9 1-6.1L3.2 9.5l6.1-.9L12 3Z" stroke="currentColor" stroke-width="2" stroke-linejoin="round" />
                  </svg>
                )}
                {stat.icon === "cup" && (
                  <svg viewBox="0 0 24 24" fill="none">
                    <path d="M8 4h8v3a4 4 0 0 1-8 0V4ZM7 4H4a3 3 0 0 0 3 3M17 4h3a3 3 0 0 1-3 3M12 11v5M8 20h8" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" />
                  </svg>
                )}
              </span>
              <strong class="teacher-stat__value">{stat.value}</strong>
              <p class="teacher-stat__desc" set:html={stat.desc.replace("\n", "<br />")} />
            </li>
          ))
        }
      </ul>

      <div class="teacher__approach">
        <h3 class="teacher__approach-title">Мой подход к подготовке</h3>
        <ul class="teacher__approach-list">
          {
            points.map((point) => (
              <li class="teacher__approach-item">
                <span class="teacher__approach-check" aria-hidden="true">
                  <svg viewBox="0 0 20 20" fill="none">
                    <circle cx="10" cy="10" r="9" stroke="currentColor" stroke-width="1.8" />
                    <path d="m6.2 10.3 2.5 2.6 5.2-5.5" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" />
                  </svg>
                </span>
                {point}
              </li>
            ))
          }
        </ul>
      </div>

      <div class="teacher__actions">
        <button type="button" class="teacher__cta">
          Записаться на пробный урок
          <svg viewBox="0 0 24 24" fill="none" aria-hidden="true">
            <path d="M5 12h14m0 0-6-6m6 6-6 6" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" />
          </svg>
        </button>

        <div class="teacher__trial">
          <span class="teacher__trial-icon" aria-hidden="true">
            <svg viewBox="0 0 24 24" fill="none">
              <path d="M12 2 4 5v6c0 5 3.4 9.7 8 11 4.6-1.3 8-6 8-11V5l-8-3Z" stroke="currentColor" stroke-width="2" stroke-linejoin="round" />
              <path d="m9 12 2 2 4-4" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" />
            </svg>
          </span>
          <p>Первое занятие бесплатно<br />и ни к чему не обязывает</p>
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  .teacher {
    --nd-page: #f3f1f8;
    --nd-surface: #ffffff;
    --nd-text: #1a1b2e;
    --nd-text-muted: #6e7185;

    --nd-primary: #7a5cf0;
    --nd-primary-hover: #6a49e8;
    --nd-primary-soft: #ede7fd;
    --nd-primary-tint: #f2eefe;

    --nd-lime: #d8e998;
    --nd-lime-soft: #eef5d5;
    --nd-lime-icon: #9dba38;

    --nd-butter-soft: #fff6de;
    --nd-butter-icon: #ffbf00;

    --nd-r-sm: 12px;
    --nd-r-md: 18px;
    --nd-r-lg: 22px;
    --nd-r-xl: 28px;
    --nd-r-pill: 999px;

    --nd-ease: cubic-bezier(0.2, 0.7, 0.3, 1);

    background: var(--nd-page);
    color: var(--nd-text);
    font-family:
      "Manrope",
      -apple-system,
      BlinkMacSystemFont,
      "Segoe UI",
      sans-serif;
    -webkit-font-smoothing: antialiased;
  }

  .teacher__shell {
    max-width: 1280px;
    margin: 0 auto;
    padding: 0 40px 80px;
    display: grid;
    grid-template-columns: minmax(420px, 0.92fr) minmax(0, 1.08fr);
    gap: 34px;
    background: rgba(255, 255, 255, 0.46);
    border-radius: 36px;
    box-shadow:
      inset 0 1px 0 rgba(255, 255, 255, 0.85),
      0 18px 42px rgba(122, 92, 240, 0.06);
    overflow: hidden;
  }

  .teacher__media {
    position: relative;
    min-height: 760px;
    overflow: hidden;
  }

  .teacher__blob {
    position: absolute;
    left: 34px;
    right: 48px;
    top: 170px;
    bottom: 116px;
    border-radius: 45% 55% 52% 48% / 32% 33% 67% 68%;
    background: linear-gradient(180deg, rgba(236, 231, 255, 0.95) 0%, rgba(232, 225, 252, 0.92) 100%);
  }

  .teacher__label,
  .teacher__arrow,
  .teacher__molecule,
  .teacher__spark,
  .teacher__flask,
  .teacher__brush {
    position: absolute;
    z-index: 3;
  }

  .teacher__label {
    left: 44px;
    top: 178px;
    font-size: 19px;
    line-height: 1.3;
    font-weight: 700;
    color: rgba(26, 27, 46, 0.88);
    max-width: 150px;
    transform: rotate(-9deg);
  }

  .teacher__arrow {
    left: 84px;
    top: 232px;
    width: 146px;
    color: rgba(26, 27, 46, 0.78);
  }

  .teacher__molecule {
    right: 42px;
    top: 166px;
    width: 140px;
    color: rgba(122, 92, 240, 0.78);
  }

  .teacher__molecule circle {
    stroke: currentColor;
    stroke-width: 2.4;
  }

  .teacher__spark {
    color: rgba(122, 92, 240, 0.64);
  }

  .teacher__spark--star {
    left: 116px;
    top: 400px;
    width: 44px;
    height: 44px;
  }

  .teacher__spark--dots {
    left: 22px;
    bottom: 156px;
    width: 38px;
    height: 24px;
  }

  .teacher__flask {
    left: 36px;
    bottom: 66px;
    width: 158px;
    color: rgba(122, 92, 240, 0.94);
    filter: drop-shadow(0 14px 24px rgba(122, 92, 240, 0.12));
  }

  .teacher__brush {
    left: 254px;
    bottom: 74px;
    width: 200px;
    height: 20px;
    border-radius: 999px;
    background:
      linear-gradient(90deg, rgba(171, 124, 255, 0) 0%, rgba(171, 124, 255, 0.94) 34%, rgba(171, 124, 255, 0.86) 78%, rgba(171, 124, 255, 0) 100%);
    filter: blur(0.4px);
    transform: rotate(-11deg);
  }

  .teacher__portrait {
    position: absolute;
    inset: auto 0 0 0;
    z-index: 2;
    margin: 0;
    display: flex;
    align-items: flex-end;
    justify-content: center;
    pointer-events: none;
  }

  .teacher__portrait img {
    width: min(100%, 640px);
    height: auto;
    display: block;
    object-fit: cover;
    object-position: center top;
    mix-blend-mode: multiply;
  }

  .teacher__content {
    padding: 48px 40px 48px 0;
    min-width: 0;
  }

  .teacher__eyebrow {
    display: inline-flex;
    align-items: center;
    min-height: 38px;
    padding: 0 22px;
    border-radius: var(--nd-r-pill);
    background: linear-gradient(180deg, #eff6b8 0%, #dfe98e 100%);
    color: var(--nd-text);
    font-size: 13px;
    font-weight: 700;
  }

  .teacher__title {
    margin: 24px 0 0;
    font-size: clamp(40px, 5.2vw, 76px);
    line-height: 0.95;
    letter-spacing: -0.04em;
    font-weight: 800;
  }

  .teacher__lead {
    max-width: 680px;
    margin: 24px 0 0;
    color: var(--nd-text-muted);
    font-size: clamp(18px, 2vw, 22px);
    line-height: 1.55;
  }

  .teacher__note {
    position: relative;
    margin-top: 28px;
    margin-left: auto;
    max-width: 320px;
    padding: 18px 22px 20px;
    background: linear-gradient(180deg, #fff2cb 0%, #fff6dc 100%);
    border-radius: 10px;
    box-shadow:
      0 8px 18px rgba(26, 27, 46, 0.04),
      inset 0 1px 0 rgba(255, 255, 255, 0.85);
    transform: rotate(-3.5deg);
  }

  .teacher__note p {
    margin: 0;
    font-size: 22px;
    line-height: 1.55;
    letter-spacing: -0.02em;
    font-weight: 600;
  }

  .teacher__note-lines {
    position: absolute;
    right: 0;
    top: -18px;
    width: 76px;
    height: 24px;
    border-radius: 3px;
    background: linear-gradient(180deg, rgba(122, 92, 240, 0.96) 0%, rgba(154, 114, 250, 0.92) 100%);
    transform: rotate(14deg);
  }

  .teacher__note-smile {
    position: absolute;
    right: 20px;
    bottom: 16px;
    width: 36px;
    height: 36px;
    color: rgba(122, 92, 240, 0.8);
  }

  .teacher__stats {
    display: grid;
    grid-template-columns: repeat(4, minmax(0, 1fr));
    gap: 14px;
    margin: 22px 0 0;
    padding: 0;
    list-style: none;
  }

  .teacher-stat {
    min-height: 214px;
    padding: 18px 14px 16px;
    border-radius: 24px;
    background: var(--nd-surface);
    text-align: center;
    box-shadow:
      0 12px 30px rgba(122, 92, 240, 0.06),
      inset 0 1px 0 rgba(255, 255, 255, 0.92);
  }

  .teacher-stat--violet {
    background: linear-gradient(180deg, #faf8ff 0%, #f5f1ff 100%);
  }

  .teacher-stat--lime {
    background: linear-gradient(180deg, #f5f8ea 0%, #f0f5df 100%);
  }

  .teacher-stat--butter {
    background: linear-gradient(180deg, #fff8e9 0%, #fff4dd 100%);
  }

  .teacher-stat__icon {
    width: 72px;
    height: 72px;
    margin: 0 auto 12px;
    border-radius: 24px;
    display: grid;
    place-items: center;
  }

  .teacher-stat--violet .teacher-stat__icon {
    background: rgba(122, 92, 240, 0.08);
    color: var(--nd-primary);
  }

  .teacher-stat--lime .teacher-stat__icon {
    background: rgba(216, 233, 152, 0.24);
    color: #8cae28;
  }

  .teacher-stat--butter .teacher-stat__icon {
    background: rgba(255, 203, 76, 0.18);
    color: var(--nd-butter-icon);
  }

  .teacher-stat__icon svg {
    width: 36px;
    height: 36px;
    display: block;
  }

  .teacher-stat__value {
    display: block;
    margin: 0;
    font-size: clamp(28px, 2.4vw, 32px);
    line-height: 1.05;
    letter-spacing: -0.03em;
    font-weight: 800;
  }

  .teacher-stat__desc {
    margin: 10px 0 0;
    color: var(--nd-text);
    font-size: 14px;
    line-height: 1.5;
  }

  .teacher__approach {
    margin-top: 30px;
    padding: 20px 28px 24px;
    border-radius: 24px;
    background: var(--nd-surface);
    border: 1px solid rgba(122, 92, 240, 0.18);
    box-shadow: inset 0 1px 0 rgba(255, 255, 255, 0.92);
  }

  .teacher__approach-title {
    margin: 0;
    color: var(--nd-primary);
    font-size: 18px;
    line-height: 1.3;
    font-weight: 800;
  }

  .teacher__approach-list {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 14px 26px;
    margin: 18px 0 0;
    padding: 0;
    list-style: none;
  }

  .teacher__approach-item {
    display: flex;
    align-items: center;
    gap: 12px;
    font-size: 16px;
    line-height: 1.45;
  }

  .teacher__approach-check {
    width: 24px;
    height: 24px;
    color: var(--nd-primary);
    flex: 0 0 auto;
  }

  .teacher__approach-check svg {
    width: 100%;
    height: 100%;
    display: block;
  }

  .teacher__actions {
    display: grid;
    grid-template-columns: minmax(0, 1fr) 300px;
    gap: 18px;
    margin-top: 26px;
  }

  .teacher__cta {
    min-height: 78px;
    padding: 0 28px;
    border: none;
    border-radius: 20px;
    background: linear-gradient(90deg, var(--nd-primary) 0%, #6b43eb 100%);
    color: #fff;
    font-size: 17px;
    font-weight: 700;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 16px;
    font-family: inherit;
    cursor: pointer;
    transition:
      transform 180ms var(--nd-ease),
      background 180ms var(--nd-ease);
  }

  .teacher__cta:hover {
    background: linear-gradient(90deg, var(--nd-primary-hover) 0%, #5d35dd 100%);
  }

  .teacher__cta:active {
    transform: translateY(1px);
  }

  .teacher__cta svg {
    width: 22px;
    height: 22px;
    display: block;
  }

  .teacher__trial {
    min-height: 78px;
    padding: 14px 18px;
    border-radius: 20px;
    background: linear-gradient(180deg, #faf9ff 0%, #f3f0ff 100%);
    display: flex;
    align-items: center;
    gap: 14px;
  }

  .teacher__trial p {
    margin: 0;
    font-size: 15px;
    line-height: 1.45;
  }

  .teacher__trial-icon {
    width: 44px;
    height: 44px;
    border-radius: 16px;
    display: grid;
    place-items: center;
    background: rgba(216, 233, 152, 0.34);
    color: var(--nd-lime-icon);
    flex: 0 0 auto;
  }

  .teacher__trial-icon svg {
    width: 24px;
    height: 24px;
    display: block;
  }

  @media (max-width: 1180px) {
    .teacher__shell {
      grid-template-columns: 1fr;
      padding-top: 24px;
    }

    .teacher__content {
      padding: 12px 28px 36px;
    }

    .teacher__media {
      min-height: 620px;
    }
  }

  @media (max-width: 900px) {
    .teacher__shell {
      padding: 0 24px 64px;
      border-radius: 30px;
    }

    .teacher__stats {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }

    .teacher__actions {
      grid-template-columns: 1fr;
    }

    .teacher__approach-list {
      grid-template-columns: 1fr;
    }
  }

  @media (max-width: 640px) {
    .teacher__shell {
      padding: 0 16px 48px;
      border-radius: 24px;
    }

    .teacher__media {
      min-height: 470px;
    }

    .teacher__blob {
      left: 18px;
      right: 18px;
      top: 110px;
      bottom: 92px;
    }

    .teacher__label,
    .teacher__arrow,
    .teacher__molecule,
    .teacher__note {
      display: none;
    }

    .teacher__spark--star {
      left: 36px;
      top: 150px;
    }

    .teacher__flask {
      left: 10px;
      bottom: 36px;
      width: 116px;
    }

    .teacher__brush {
      left: 146px;
      bottom: 52px;
      width: 120px;
    }

    .teacher__portrait img {
      width: min(100%, 420px);
    }

    .teacher__content {
      padding: 4px 20px 24px;
    }

    .teacher__title {
      font-size: 40px;
    }

    .teacher__stats {
      grid-template-columns: 1fr;
    }

    .teacher-stat {
      min-height: 0;
    }

    .teacher__approach {
      padding: 18px 18px 20px;
    }
  }
</style>
