---
const stats = [
  {
    value: "10 лет",
    desc: "опыта подготовки\nк ЕГЭ по химии",
    icon: "cap",
    accent: "violet",
  },
  {
    value: "1000+",
    desc: "учеников\nподготовлено",
    icon: "users",
    accent: "lime",
  },
  {
    value: "82,6",
    desc: "средний балл\nнаших учеников",
    icon: "star",
    accent: "butter",
  },
  {
    value: "80+",
    desc: "у каждого второго\nна курсе",
    icon: "cup",
    accent: "violet",
  },
];

const points = [
  "Объясняю сложное простым языком",
  "Разбираем ошибки и слабые места",
  "Даю систему, а не хаос",
  "Поддерживаю до экзамена",
];
---

<section class="teacher" aria-labelledby="teacher-title">
  <div class="teacher__shell">
    <div class="teacher__media" aria-hidden="true">
      <div class="teacher__blob"></div>

      <span class="teacher__label">Преподаватель химии</span>

      <svg class="teacher__arrow" viewBox="0 0 140 90" fill="none">
        <path d="M4 8c26 0 37 14 40 31 3 18 14 33 36 35h42" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" />
        <path d="m112 66 10 8-10 8" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" />
      </svg>

      <svg class="teacher__molecule" viewBox="0 0 148 172" fill="none">
        <path d="M46 18 68 52M68 52 104 48M68 52 54 92M54 92 88 116M88 116 118 100M88 116 78 154" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" />
        <circle cx="40" cy="12" r="10" />
        <circle cx="72" cy="58" r="12" />
        <circle cx="112" cy="46" r="10" />
        <circle cx="50" cy="100" r="10" />
        <circle cx="92" cy="124" r="10" />
        <circle cx="124" cy="96" r="9" />
        <circle cx="76" cy="160" r="8" />
      </svg>

      <span class="teacher__spark teacher__spark--star">
        <svg viewBox="0 0 40 40" fill="none">
          <path d="m20 3 4.9 11.1L37 16l-9 7.9L30.5 37 20 30.4 9.5 37 12 23.9 3 16l12.1-1.9L20 3Z" stroke="currentColor" stroke-width="2" stroke-linejoin="round" />
        </svg>
      </span>

      <span class="teacher__spark teacher__spark--dots">
        <svg viewBox="0 0 38 24" fill="currentColor">
          <circle cx="4" cy="5" r="2.2" />
          <circle cx="15" cy="16" r="2.2" />
          <circle cx="27" cy="10" r="2.2" />
          <circle cx="34" cy="20" r="2.2" />
        </svg>
      </span>

      <span class="teacher__flask">
        <svg viewBox="0 0 170 240" fill="none">
          <path d="M64 12h42M72 12v58L24 186.5C16.2 201.2 26.8 219 43.3 219h85.4c16.5 0 27.1-17.8 19.3-32.5L106 70V12" stroke="currentColor" stroke-width="4.5" stroke-linecap="round" stroke-linejoin="round" />
          <path d="M44 160c12 8.4 25.8 12.6 41 12.6s29-4.2 41-12.6v38H44v-38Z" fill="url(#teacher-flask-fill)" />
          <path d="M55 144c8.8 5 18.7 7.5 30 7.5s21.2-2.5 30-7.5" stroke="currentColor" stroke-width="4.5" stroke-linecap="round" />
          <circle cx="58" cy="167" r="5" fill="currentColor" opacity=".25" />
          <circle cx="113" cy="179" r="6" fill="currentColor" opacity=".22" />
          <circle cx="96" cy="158" r="4.5" fill="currentColor" opacity=".22" />
          <defs>
            <linearGradient id="teacher-flask-fill" x1="85" x2="85" y1="160" y2="198">
              <stop stop-color="var(--ege-primary)" />
              <stop offset="1" stop-color="var(--ege-primary-hover)" />
            </linearGradient>
          </defs>
        </svg>
      </span>

      <span class="teacher__brush"></span>

      <figure class="teacher__portrait">
        <img
          src="/images/valerii-filipenko.webp"
          alt="Валерий Филипенко"
          width="800"
          height="1200"
          loading="lazy"
        />
      </figure>
    </div>

    <div class="teacher__content">
      <span class="teacher__eyebrow ege-course-chip ege-course-chip--lime">О преподавателе</span>

      <h2 class="teacher__title" id="teacher-title">Валерий Филипенко</h2>

      <p class="teacher__lead">
        Преподаватель химии, который помогает понять предмет, выстроить систему
        и дойти до высокого балла на ЕГЭ.
      </p>

      <div class="teacher__note">
        <span class="teacher__note-lines" aria-hidden="true"></span>
        <p>
          Не просто объясняю темы — веду к результату
        </p>
        <span class="teacher__note-smile" aria-hidden="true">
          <svg viewBox="0 0 36 36" fill="none">
            <circle cx="18" cy="18" r="15" stroke="currentColor" stroke-width="2" stroke-dasharray="5 5" />
            <path d="M12.5 21c1.8 2 3.7 3 5.5 3s3.7-1 5.5-3M13 14.5h.01M23 14.5h.01" stroke="currentColor" stroke-width="2" stroke-linecap="round" />
          </svg>
        </span>
      </div>

      <div class="teacher__info-card">
        <ul class="teacher__stats">
        {
          stats.map((stat) => (
            <li class:list={["teacher-stat", `teacher-stat--${stat.accent}`]}>
              <span class="teacher-stat__icon" aria-hidden="true">
                {stat.icon === "cap" && (
                  <svg viewBox="0 0 24 24" fill="none">
                    <path d="m3 9 9-4 9 4-9 4-9-4ZM6 11.5V15l6 3 6-3v-3.5" stroke="currentColor" stroke-width="2" stroke-linejoin="round" />
                  </svg>
                )}
                {stat.icon === "users" && (
                  <svg viewBox="0 0 24 24" fill="none">
                    <circle cx="9" cy="8" r="3" stroke="currentColor" stroke-width="2" />
                    <circle cx="16.5" cy="9.5" r="2.5" stroke="currentColor" stroke-width="2" />
                    <path d="M4.5 19c0-2.8 2.4-5 5.5-5s5.5 2.2 5.5 5M13.5 18.5c.2-1.9 1.8-3.5 4.2-3.5 1 0 2 .3 2.8.9" stroke="currentColor" stroke-width="2" stroke-linecap="round" />
                  </svg>
                )}
                {stat.icon === "star" && (
                  <svg viewBox="0 0 24 24" fill="none">
                    <path d="m12 3 2.7 5.6 6.1.9-4.4 4.3 1 6.1L12 17l-5.4 2.9 1-6.1L3.2 9.5l6.1-.9L12 3Z" stroke="currentColor" stroke-width="2" stroke-linejoin="round" />
                  </svg>
                )}
                {stat.icon === "cup" && (
                  <svg viewBox="0 0 24 24" fill="none">
                    <path d="M8 4h8v3a4 4 0 0 1-8 0V4ZM7 4H4a3 3 0 0 0 3 3M17 4h3a3 3 0 0 1-3 3M12 11v5M8 20h8" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" />
                  </svg>
                )}
              </span>
              <strong class="teacher-stat__value">{stat.value}</strong>
              <p class="teacher-stat__desc" set:html={stat.desc.replace("\n", "<br />")} />
            </li>
          ))
        }
        </ul>

        <div class="teacher__approach">
        <h3 class="teacher__approach-title">Мой подход к подготовке</h3>
        <ul class="teacher__approach-list">
          {
            points.map((point) => (
              <li class="teacher__approach-item">
                <span class="teacher__approach-check" aria-hidden="true">
                  <svg viewBox="0 0 20 20" fill="none">
                    <circle cx="10" cy="10" r="9" stroke="currentColor" stroke-width="1.8" />
                    <path d="m6.2 10.3 2.5 2.6 5.2-5.5" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" />
                  </svg>
                </span>
                {point}
              </li>
            ))
          }
        </ul>
        </div>

        <div class="teacher__actions">
        <button type="button" class="teacher__cta">
          Записаться на пробный урок
          <svg viewBox="0 0 24 24" fill="none" aria-hidden="true">
            <path d="M5 12h14m0 0-6-6m6 6-6 6" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" />
          </svg>
        </button>

        <div class="teacher__trial">
          <span class="teacher__trial-icon" aria-hidden="true">
            <svg viewBox="0 0 24 24" fill="none">
              <path d="M12 2 4 5v6c0 5 3.4 9.7 8 11 4.6-1.3 8-6 8-11V5l-8-3Z" stroke="currentColor" stroke-width="2" stroke-linejoin="round" />
              <path d="m9 12 2 2 4-4" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" />
            </svg>
          </span>
          <p>Первое занятие бесплатно<br />и ни к чему не обязывает</p>
        </div>
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  .teacher {
    width: 100vw;
    margin-inline: calc(50% - 50vw);
    padding: var(--ege-section-gap) var(--ege-section-pad-x) 0;
    background: var(--ege-page);
    color: var(--ege-text);
    font-family: var(--ege-font-family);
    -webkit-font-smoothing: antialiased;
  }

  .teacher__shell {
    max-width: var(--ege-section-wide);
    margin: 0 auto;
    padding: 44px 40px;
    display: grid;
    grid-template-columns: minmax(420px, 0.95fr) minmax(0, 1.05fr);
    gap: 34px;
    background:
      radial-gradient(circle at 26% 24%, rgba(255, 255, 255, 0.72) 0 18%, transparent 18.4%),
      linear-gradient(180deg, var(--ege-butter-soft-2) 0%, var(--ege-butter-soft) 100%);
    border-radius: var(--ege-radius-section);
    box-shadow:
      inset 0 1px 0 rgba(255, 255, 255, 0.85),
      0 18px 42px rgba(var(--ege-primary-rgb), 0.06);
    overflow: hidden;
  }

  .teacher__media {
    position: relative;
    min-height: 690px;
    overflow: hidden;
  }

  .teacher__blob {
    position: absolute;
    left: 34px;
    right: 48px;
    top: 170px;
    bottom: 116px;
    border-radius: 45% 55% 52% 48% / 32% 33% 67% 68%;
    background: linear-gradient(
      180deg,
      rgba(255, 243, 214, 0.96) 0%,
      rgba(255, 195, 107, 0.34) 100%
    );
  }

  .teacher__label,
  .teacher__arrow,
  .teacher__molecule,
  .teacher__spark,
  .teacher__flask,
  .teacher__brush {
    position: absolute;
    z-index: 3;
  }

  .teacher__label {
    left: 44px;
    top: 178px;
    font-size: var(--ege-card-title);
    line-height: 1.3;
    font-weight: 700;
    color: rgba(26, 27, 46, 0.88);
    max-width: 150px;
    transform: rotate(-9deg);
  }

  .teacher__arrow {
    left: 84px;
    top: 232px;
    width: 146px;
    color: rgba(26, 27, 46, 0.78);
  }

  .teacher__molecule {
    right: 42px;
    top: 166px;
    width: 140px;
    color: rgba(var(--ege-primary-rgb), 0.78);
  }

  .teacher__molecule circle {
    stroke: currentColor;
    stroke-width: 2.4;
  }

  .teacher__spark {
    color: rgba(var(--ege-primary-rgb), 0.64);
  }

  .teacher__spark--star {
    left: 116px;
    top: 400px;
    width: 44px;
    height: 44px;
  }

  .teacher__spark--dots {
    left: 22px;
    bottom: 156px;
    width: 38px;
    height: 24px;
  }

  .teacher__flask {
    left: 36px;
    bottom: 66px;
    width: 158px;
    color: rgba(var(--ege-primary-rgb), 0.94);
    filter: drop-shadow(0 14px 24px rgba(var(--ege-primary-rgb), 0.12));
  }

  .teacher__brush {
    left: 254px;
    bottom: 74px;
    width: 200px;
    height: 20px;
    border-radius: 999px;
    background:
      linear-gradient(90deg, rgba(171, 124, 255, 0) 0%, rgba(171, 124, 255, 0.94) 34%, rgba(171, 124, 255, 0.86) 78%, rgba(171, 124, 255, 0) 100%);
    filter: blur(0.4px);
    transform: rotate(-11deg);
  }

  .teacher__portrait {
    position: absolute;
    inset: auto 0 0 0;
    z-index: 2;
    margin: 0;
    display: flex;
    align-items: flex-end;
    justify-content: center;
    pointer-events: none;
  }

  .teacher__portrait img {
    width: min(100%, 640px);
    height: auto;
    display: block;
    object-fit: cover;
    object-position: center top;
    mix-blend-mode: multiply;
  }

  .teacher__content {
    padding: 4px 0;
    min-width: 0;
  }

  .teacher__title {
    margin: 24px 0 0;
    font-size: var(--ege-h2);
    line-height: var(--ege-lh-title);
    letter-spacing: var(--ege-track-title);
    font-weight: 800;
  }

  .teacher__lead {
    max-width: 680px;
    margin: 24px 0 0;
    color: var(--ege-muted);
    font-size: var(--ege-lead);
    line-height: var(--ege-lh-body);
  }

  .teacher__note {
    position: relative;
    margin-top: 28px;
    margin-left: auto;
    max-width: 320px;
    padding: 18px 22px 20px;
    background: var(--ege-note-gradient);
    border-radius: 10px;
    box-shadow:
      0 8px 18px rgba(26, 27, 46, 0.04),
      inset 0 1px 0 rgba(255, 255, 255, 0.85);
    transform: rotate(-3.5deg);
  }

  .teacher__note p {
    margin: 0;
    font-size: var(--ege-card-title);
    line-height: 1.55;
    letter-spacing: -0.02em;
    font-weight: 600;
  }

  .teacher__note-lines {
    position: absolute;
    right: 0;
    top: -18px;
    width: 76px;
    height: 24px;
    border-radius: 3px;
    background: linear-gradient(
      180deg,
      rgba(var(--ege-primary-rgb), 0.96) 0%,
      rgba(var(--ege-primary-mark-rgb), 0.92) 100%
    );
    transform: rotate(14deg);
  }

  .teacher__note-smile {
    position: absolute;
    right: 20px;
    bottom: 16px;
    width: 36px;
    height: 36px;
    color: rgba(var(--ege-primary-rgb), 0.8);
  }

  .teacher__info-card {
    display: grid;
    gap: 28px;
    margin-top: 30px;
    padding: 28px;
    border-radius: var(--ege-radius-xl);
    background: var(--ege-surface);
    box-shadow:
      0 12px 30px rgba(26, 27, 46, 0.05),
      inset 0 1px 0 rgba(255, 255, 255, 0.96);
  }

  .teacher__stats {
    display: grid;
    grid-template-columns: repeat(4, minmax(0, 1fr));
    gap: 14px;
    margin: 0;
    padding: 0;
    list-style: none;
  }

  .teacher-stat {
    min-height: 214px;
    padding: 18px 14px 16px;
    border-radius: 24px;
    background: var(--ege-surface);
    text-align: center;
    box-shadow:
      0 12px 30px rgba(var(--ege-primary-rgb), 0.06),
      inset 0 1px 0 rgba(255, 255, 255, 0.92);
  }

  .teacher-stat--violet {
    background: linear-gradient(180deg, var(--ege-surface) 0%, var(--ege-primary-tint) 100%);
  }

  .teacher-stat--lime {
    background: linear-gradient(180deg, #f5f8ea 0%, #f0f5df 100%);
  }

  .teacher-stat--butter {
    background: var(--ege-stat-butter-gradient);
  }

  .teacher-stat__icon {
    width: 72px;
    height: 72px;
    margin: 0 auto 12px;
    border-radius: 24px;
    display: grid;
    place-items: center;
  }

  .teacher-stat--violet .teacher-stat__icon {
    background: rgba(var(--ege-primary-rgb), 0.08);
    color: var(--ege-primary);
  }

  .teacher-stat--lime .teacher-stat__icon {
    background: rgba(216, 233, 152, 0.24);
    color: var(--ege-lime-icon-2);
  }

  .teacher-stat--butter .teacher-stat__icon {
    background: rgba(255, 203, 76, 0.18);
    color: var(--ege-butter-icon);
  }

  .teacher-stat__icon svg {
    width: 36px;
    height: 36px;
    display: block;
  }

  .teacher-stat__value {
    display: block;
    margin: 0;
    font-size: var(--ege-h3);
    line-height: 1.05;
    letter-spacing: -0.03em;
    font-weight: 800;
  }

  .teacher-stat__desc {
    margin: 10px 0 0;
    color: var(--ege-text);
    font-size: var(--ege-caption);
    line-height: 1.5;
  }

  .teacher__approach {
    padding: 0;
    border-radius: 0;
    background: transparent;
    border: 0;
    box-shadow: none;
  }

  .teacher__approach-title {
    margin: 0;
    color: var(--ege-primary);
    font-size: var(--ege-card-title);
    line-height: 1.3;
    font-weight: 800;
  }

  .teacher__approach-list {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 22px 34px;
    margin: 26px 0 0;
    padding: 0;
    list-style: none;
  }

  .teacher__approach-item {
    display: flex;
    align-items: center;
    gap: 12px;
    font-size: var(--ege-body);
    line-height: 1.45;
  }

  .teacher__approach-check {
    width: 24px;
    height: 24px;
    color: var(--ege-primary);
    flex: 0 0 auto;
  }

  .teacher__approach-check svg {
    width: 100%;
    height: 100%;
    display: block;
  }

  .teacher__actions {
    display: grid;
    grid-template-columns: minmax(0, 1fr) 300px;
    gap: 18px;
    margin-top: 0;
  }

  .teacher__cta {
    min-height: 78px;
    padding: 0 28px;
    border: none;
    border-radius: 20px;
    background: linear-gradient(90deg, var(--ege-primary) 0%, var(--ege-primary-hover) 100%);
    color: var(--ege-inverse);
    font-size: var(--ege-button);
    font-weight: 700;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 16px;
    font-family: inherit;
    cursor: pointer;
    transition:
      transform 180ms var(--ege-ease),
      background 180ms var(--ege-ease);
  }

  .teacher__cta:hover {
    background: linear-gradient(90deg, var(--ege-primary-hover) 0%, var(--ege-primary-deep) 100%);
  }

  .teacher__cta:active {
    transform: translateY(1px);
  }

  .teacher__cta svg {
    width: 22px;
    height: 22px;
    display: block;
  }

  .teacher__trial {
    min-height: 78px;
    padding: 14px 18px;
    border-radius: 20px;
    background: linear-gradient(180deg, var(--ege-surface) 0%, var(--ege-primary-tint) 100%);
    display: flex;
    align-items: center;
    gap: 14px;
  }

  .teacher__trial p {
    margin: 0;
    font-size: var(--ege-body-sm);
    line-height: 1.45;
  }

  .teacher__trial-icon {
    width: 44px;
    height: 44px;
    border-radius: 16px;
    display: grid;
    place-items: center;
    background: rgba(216, 233, 152, 0.34);
    color: var(--ege-lime-icon);
    flex: 0 0 auto;
  }

  .teacher__trial-icon svg {
    width: 24px;
    height: 24px;
    display: block;
  }

  @media (max-width: 1180px) {
    .teacher__shell {
      grid-template-columns: 1fr;
    }

    .teacher__content {
      padding: 0;
    }

    .teacher__media {
      min-height: 620px;
    }
  }

  @media (max-width: 900px) {
    .teacher__shell {
      padding: 34px 28px;
      border-radius: 30px;
    }

    .teacher__stats {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }

    .teacher__actions {
      grid-template-columns: 1fr;
    }

    .teacher__approach-list {
      grid-template-columns: 1fr;
    }
  }

  @media (max-width: 640px) {
    .teacher__shell {
      padding: 32px 18px 24px;
      border-radius: 24px;
    }

    .teacher__media {
      min-height: 470px;
    }

    .teacher__blob {
      left: 18px;
      right: 18px;
      top: 110px;
      bottom: 92px;
    }

    .teacher__label,
    .teacher__arrow,
    .teacher__molecule,
    .teacher__note {
      display: none;
    }

    .teacher__spark--star {
      left: 36px;
      top: 150px;
    }

    .teacher__flask {
      left: 10px;
      bottom: 36px;
      width: 116px;
    }

    .teacher__brush {
      left: 146px;
      bottom: 52px;
      width: 120px;
    }

    .teacher__portrait img {
      width: min(100%, 420px);
    }

    .teacher__content {
      padding: 4px 20px 24px;
    }

    .teacher__title {
      font-size: var(--ege-h2);
    }

    .teacher__stats {
      grid-template-columns: 1fr;
    }

    .teacher-stat {
      min-height: 0;
    }

    .teacher__approach {
      padding: 0;
    }
  }
</style>
