---
const items = [
  {
    title: "Чёткое расписание",
    desc: "Регулярные занятия без хаоса и пропусков.",
    icon: "calendar",
    accent: "violet",
  },
  {
    title: "Домашние задания и контроль",
    desc: "Ребёнок не просто слушает, а системно закрепляет темы.",
    icon: "clipboard",
    accent: "lime",
  },
  {
    title: "Пробники и зачёты",
    desc: "Проверяем прогресс и вовремя видим слабые места.",
    icon: "chart",
    accent: "violet",
  },
  {
    title: "Обратная связь",
    desc: "Понятно объясняем, как идёт подготовка и на что обратить внимание.",
    icon: "message",
    accent: "violet",
  },
  {
    title: "Связь с родителями",
    desc: "При необходимости держим контакт и отвечаем на вопросы.",
    icon: "family",
    accent: "lime",
  },
  {
    title: "Подготовка до экзамена",
    desc: "Сопровождаем ученика до самого ЕГЭ, а не бросаем на полпути.",
    icon: "cap",
    accent: "violet",
  },
];
---

<section class="parents" aria-labelledby="parents-title">
  <div class="parents__shell">
    <div class="parents__grid">
      <div class="parents__content">
        <span class="parents__eyebrow ege-course-chip ege-course-chip--lime">для родителей</span>

        <h2 class="parents__title" id="parents-title">
          Почему родителям <span>спокойно</span> за подготовку
        </h2>

        <p class="parents__lead">
          Мы выстраиваем подготовку так, чтобы родитель видел процесс,
          понимал прогресс и был уверен, что ребёнок идёт к результату системно.
        </p>

        <ul class="parents__list">
          {
            items.map((item) => (
              <li class="parent-card">
                <span class:list={["parent-card__icon", `parent-card__icon--${item.accent}`]} aria-hidden="true">
                  {item.icon === "calendar" && (
                    <svg viewBox="0 0 24 24" fill="none">
                      <path d="M7 2v4M17 2v4M3 9h18" stroke="currentColor" stroke-width="2" stroke-linecap="round" />
                      <rect x="4" y="5" width="16" height="15" rx="3" stroke="currentColor" stroke-width="2" />
                      <path d="M8 13h2M14 13h2M8 17h2M14 17h2" stroke="currentColor" stroke-width="2" stroke-linecap="round" />
                    </svg>
                  )}
                  {item.icon === "clipboard" && (
                    <svg viewBox="0 0 24 24" fill="none">
                      <rect x="6" y="4" width="12" height="17" rx="3" stroke="currentColor" stroke-width="2" />
                      <path d="M9 4.5h6a1.5 1.5 0 0 0-3 0H9Z" stroke="currentColor" stroke-width="2" stroke-linejoin="round" />
                      <path d="m9 11 1.8 1.8L15 8.7M9 16h6" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" />
                    </svg>
                  )}
                  {item.icon === "chart" && (
                    <svg viewBox="0 0 24 24" fill="none">
                      <path d="M4 19h16" stroke="currentColor" stroke-width="2" stroke-linecap="round" />
                      <path d="M7 19v-7M12 19V6M17 19v-11" stroke="currentColor" stroke-width="2" stroke-linecap="round" />
                    </svg>
                  )}
                  {item.icon === "message" && (
                    <svg viewBox="0 0 24 24" fill="none">
                      <path d="M8 18.5c-3.2 0-5.5-2.4-5.5-5.8S4.8 7 8 7h8c3.2 0 5.5 2.4 5.5 5.7S19.2 18.5 16 18.5h-2.4L9.7 21v-2.5H8Z" stroke="currentColor" stroke-width="2" stroke-linejoin="round" />
                    </svg>
                  )}
                  {item.icon === "family" && (
                    <svg viewBox="0 0 24 24" fill="none">
                      <circle cx="9" cy="8" r="3" stroke="currentColor" stroke-width="2" />
                      <circle cx="16.5" cy="9.5" r="2.5" stroke="currentColor" stroke-width="2" />
                      <path d="M4.5 19c0-2.8 2.4-5 5.5-5s5.5 2.2 5.5 5M13.5 18.5c.2-1.9 1.8-3.5 4.2-3.5 1 0 2 .3 2.8.9" stroke="currentColor" stroke-width="2" stroke-linecap="round" />
                    </svg>
                  )}
                  {item.icon === "cap" && (
                    <svg viewBox="0 0 24 24" fill="none">
                      <path d="m3 9 9-4 9 4-9 4-9-4ZM6 11.5V15l6 3 6-3v-3.5" stroke="currentColor" stroke-width="2" stroke-linejoin="round" />
                    </svg>
                  )}
                </span>
                <div class="parent-card__body">
                  <h3 class="parent-card__title">{item.title}</h3>
                  <p class="parent-card__desc">{item.desc}</p>
                </div>
              </li>
            ))
          }
        </ul>
      </div>

      <div class="parents__visual" aria-hidden="true">
        <div class="parents__blob"></div>

        <svg class="parents__molecule" viewBox="0 0 120 100" fill="none">
          <path d="M24 22 46 42M52 44 76 40M80 38 94 18M48 48 42 74" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" />
          <circle cx="20" cy="18" r="8" />
          <circle cx="50" cy="46" r="9" />
          <circle cx="82" cy="40" r="8" />
          <circle cx="98" cy="14" r="7" />
          <circle cx="40" cy="82" r="8" />
        </svg>

        <span class="parents__spark parents__spark--star">
          <svg viewBox="0 0 40 40" fill="none">
            <path d="m20 3 4.9 11.1L37 16l-9 7.9L30.5 37 20 30.4 9.5 37 12 23.9 3 16l12.1-1.9L20 3Z" stroke="currentColor" stroke-width="2" stroke-linejoin="round" />
          </svg>
        </span>

        <span class="parents__spark parents__spark--dots">
          <svg viewBox="0 0 36 24" fill="currentColor">
            <circle cx="4" cy="4" r="2.2" />
            <circle cx="18" cy="12" r="2.2" />
            <circle cx="30" cy="6" r="2.2" />
            <circle cx="24" cy="20" r="2.2" />
          </svg>
        </span>

        <figure class="parents__hero-image parents__hero-image--main">
          <img
            src="/images/ege-course/f2.png"
            alt=""
            width="620"
            height="470"
            loading="lazy"
          />
        </figure>

        <figure class="parents__hero-image parents__hero-image--progress">
          <img
            src="/images/ege-course/f7.png"
            alt=""
            width="360"
            height="240"
            loading="lazy"
          />
        </figure>

        <figure class="parents__hero-image parents__hero-image--support">
          <img
            src="/images/ege-course/f6.png"
            alt=""
            width="320"
            height="220"
            loading="lazy"
          />
        </figure>
      </div>
    </div>

    <aside class="parents__note">
      <div class="parents__note-icon" aria-hidden="true">
        <svg viewBox="0 0 64 64" fill="none">
          <path d="M32 6 14 13.4v13.8c0 12 7.6 22.9 18 26.8 10.4-3.9 18-14.8 18-26.8V13.4L32 6Z" fill="url(#shield-fill)" />
          <path d="M32 6 14 13.4v13.8c0 12 7.6 22.9 18 26.8 10.4-3.9 18-14.8 18-26.8V13.4L32 6Z" stroke="#B7D655" stroke-width="2.5" stroke-linejoin="round" />
          <path d="m24.5 31.8 5.1 5.1 10-10.1" stroke="var(--ege-primary)" stroke-width="4" stroke-linecap="round" stroke-linejoin="round" />
          <defs>
            <linearGradient id="shield-fill" x1="32" x2="32" y1="6" y2="53">
              <stop stop-color="#E9F2C4"></stop>
              <stop offset="1" stop-color="#C8E55D"></stop>
            </linearGradient>
          </defs>
        </svg>
      </div>
      <p class="parents__note-text">
        Родителю спокойно, когда подготовка — это не хаос, а понятная система
        с контролем, практикой и движением к результату.
      </p>
      <span class="parents__note-flask" aria-hidden="true">
        <svg viewBox="0 0 64 64" fill="none">
          <path d="M26 8h12M28 8v15L16.5 50.2A4 4 0 0 0 20 56h24a4 4 0 0 0 3.5-5.8L36 23V8" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" />
          <path d="M24 42c2 1.4 4.8 2.2 8 2.2s6-.8 8-2.2" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" />
          <path d="M22 46c2.8 2.2 6.2 3.4 10 3.4S39.2 48.2 42 46" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" />
        </svg>
      </span>
    </aside>
  </div>
</section>

<style>
  .parents {
    width: 100vw;
    margin-inline: calc(50% - 50vw);
    background: var(--ege-page);
    color: var(--ege-text);
    font-family: var(--ege-font-family);
    -webkit-font-smoothing: antialiased;
  }

  .parents__shell {
    max-width: var(--ege-section-wide);
    margin: 0 auto;
    padding: 32px var(--ege-section-pad-x) var(--ege-section-pad-y);
  }

  .parents__grid {
    display: grid;
    grid-template-columns: minmax(0, 1.1fr) minmax(420px, 0.9fr);
    gap: 36px;
    align-items: start;
    background: rgba(255, 255, 255, 0.46);
    border-radius: var(--ege-radius-section);
    padding: 40px;
    box-shadow:
      inset 0 1px 0 rgba(255, 255, 255, 0.8),
      0 18px 42px rgba(var(--ege-primary-rgb), 0.06);
  }

  .parents__content {
    min-width: 0;
  }

  .parents__title {
    margin: 22px 0 0;
    max-width: 720px;
    font-size: var(--ege-h2);
    line-height: var(--ege-lh-title);
    letter-spacing: var(--ege-track-title);
    font-weight: 800;
  }

  .parents__title span {
    color: var(--ege-primary);
  }

  .parents__lead {
    max-width: 560px;
    margin: 24px 0 0;
    color: var(--ege-muted);
    font-size: var(--ege-lead);
    line-height: var(--ege-lh-body);
  }

  .parents__list {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 14px;
    margin: 32px 0 0;
    padding: 0;
    list-style: none;
  }

  .parent-card {
    min-height: 216px;
    padding: 20px 18px 18px;
    border-radius: var(--ege-radius-lg);
    background: var(--ege-surface);
    box-shadow:
      0 12px 30px rgba(var(--ege-primary-rgb), 0.06),
      inset 0 1px 0 rgba(255, 255, 255, 0.9);
  }

  .parent-card__icon {
    width: 64px;
    height: 64px;
    border-radius: 22px;
    display: grid;
    place-items: center;
    margin-bottom: 16px;
  }

  .parent-card__icon svg {
    width: 30px;
    height: 30px;
    display: block;
  }

  .parent-card__icon--violet {
    background: var(--ege-primary-tint);
    color: var(--ege-primary);
  }

  .parent-card__icon--lime {
    background: var(--ege-lime-soft);
    color: var(--ege-lime-icon);
  }

  .parent-card__body {
    display: grid;
    gap: 10px;
  }

  .parent-card__title {
    margin: 0;
    font-size: var(--ege-card-title);
    line-height: 1.25;
    font-weight: 800;
    letter-spacing: -0.02em;
  }

  .parent-card__desc {
    margin: 0;
    color: var(--ege-muted);
    font-size: var(--ege-body-sm);
    line-height: 1.55;
  }

  .parents__visual {
    position: relative;
    min-height: 690px;
    overflow: hidden;
  }

  .parents__blob {
    position: absolute;
    inset: 42px 20px 132px 34px;
    background:
      radial-gradient(circle at 28% 42%, rgba(255, 255, 255, 0.92) 0 16%, transparent 16.2%),
      linear-gradient(180deg, var(--ege-primary-tint) 0%, var(--ege-primary-soft) 100%);
    border-radius: 44% 56% 52% 48% / 32% 35% 65% 68%;
    opacity: 0.96;
  }

  .parents__molecule,
  .parents__spark {
    position: absolute;
    color: rgba(var(--ege-primary-rgb), 0.62);
  }

  .parents__molecule {
    top: 14px;
    right: 10px;
    width: 118px;
    height: auto;
  }

  .parents__molecule circle {
    stroke: currentColor;
    stroke-width: 2.5;
  }

  .parents__spark--star {
    left: 24px;
    top: 250px;
    width: 42px;
    height: 42px;
  }

  .parents__spark--dots {
    top: 168px;
    right: 6px;
    width: 38px;
    height: 26px;
  }

  .parents__hero-image {
    position: absolute;
    margin: 0;
  }

  .parents__hero-image img {
    width: 100%;
    height: auto;
    display: block;
  }

  .parents__hero-image--main {
    left: 10px;
    right: 12px;
    top: 108px;
    z-index: 2;
  }

  .parents__hero-image--progress {
    left: -10px;
    bottom: 100px;
    width: 230px;
    z-index: 3;
    filter: drop-shadow(0 16px 30px rgba(var(--ege-primary-rgb), 0.12));
  }

  .parents__hero-image--support {
    right: -6px;
    bottom: 166px;
    width: 210px;
    z-index: 3;
    filter: drop-shadow(0 16px 30px rgba(var(--ege-primary-rgb), 0.12));
  }

  .parents__note {
    position: relative;
    display: grid;
    grid-template-columns: auto minmax(0, 1fr) auto;
    align-items: center;
    gap: 22px;
    margin-top: 18px;
    padding: 22px 28px;
    border-radius: var(--ege-radius-xl);
    background: linear-gradient(180deg, rgba(237, 231, 253, 0.96) 0%, rgba(232, 238, 255, 0.88) 100%);
    overflow: hidden;
  }

  .parents__note::after {
    content: "";
    position: absolute;
    right: 12px;
    top: 50%;
    width: 140px;
    height: 140px;
    border-radius: 42%;
    background: rgba(var(--ege-primary-rgb), 0.08);
    transform: translateY(-50%);
  }

  .parents__note-icon {
    position: relative;
    z-index: 1;
    width: 112px;
    height: 112px;
    display: grid;
    place-items: center;
  }

  .parents__note-icon svg {
    width: 100%;
    height: 100%;
    display: block;
  }

  .parents__note-text {
    position: relative;
    z-index: 1;
    margin: 0;
    max-width: 840px;
    font-size: var(--ege-h3);
    line-height: 1.4;
    letter-spacing: -0.02em;
  }

  .parents__note-flask {
    position: relative;
    z-index: 1;
    width: 96px;
    height: 96px;
    color: rgba(var(--ege-primary-rgb), 0.4);
  }

  .parents__note-flask svg {
    width: 100%;
    height: 100%;
    display: block;
  }

  @media (max-width: 1180px) {
    .parents__grid {
      grid-template-columns: 1fr;
    }

    .parents__visual {
      min-height: 560px;
    }
  }

  @media (max-width: 900px) {
    .parents__shell {
      padding: 24px var(--ege-section-pad-x) var(--ege-section-pad-y);
    }

    .parents__grid {
      padding: 28px;
      border-radius: 30px;
    }

    .parents__list {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }

    .parents__visual {
      min-height: 500px;
    }

    .parents__note {
      grid-template-columns: 1fr;
      justify-items: start;
    }

    .parents__note::after,
    .parents__note-flask {
      display: none;
    }
  }

  @media (max-width: 640px) {
    .parents__shell {
      padding: 16px var(--ege-section-pad-x) var(--ege-section-pad-y);
    }

    .parents__grid {
      gap: 26px;
      padding: 20px;
      border-radius: 24px;
    }

    .parents__lead {
      font-size: var(--ege-body);
    }

    .parents__list {
      grid-template-columns: 1fr;
    }

    .parent-card {
      min-height: 0;
    }

    .parents__visual {
      min-height: 380px;
    }

    .parents__blob {
      inset: 32px 0 80px;
    }

    .parents__molecule,
    .parents__spark--dots,
    .parents__hero-image--support {
      display: none;
    }

    .parents__hero-image--main {
      left: -8px;
      right: -8px;
      top: 70px;
    }

    .parents__hero-image--progress {
      width: 170px;
      left: -12px;
      bottom: 46px;
    }

    .parents__note {
      padding: 18px 18px 20px;
    }

    .parents__note-icon {
      width: 84px;
      height: 84px;
    }
  }
</style>
