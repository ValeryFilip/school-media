---
const items = [
  {
    title: "Чёткое расписание",
    desc: "Регулярные занятия без хаоса и пропусков.",
    icon: "calendar",
    accent: "violet",
    image: "/images/ege-course/parent-calendar-trim.png",
  },
  {
    title: "Домашние задания и контроль",
    desc: "Ребёнок не просто слушает, а системно закрепляет темы.",
    icon: "clipboard",
    accent: "lime",
    image: "/images/ege-course/parent-checklist-trim.png",
  },
  {
    title: "Пробники и зачёты",
    desc: "Проверяем прогресс и вовремя видим слабые места.",
    icon: "chart",
    accent: "violet",
    image: "/images/ege-course/parent-chart-trim.png",
  },
  {
    title: "Обратная связь",
    desc: "Понятно объясняем, как идёт подготовка и на что обратить внимание.",
    icon: "message",
    accent: "violet",
    image: "/images/ege-course/parent-message-trim.png",
  },
  {
    title: "Связь с родителями",
    desc: "При необходимости держим контакт и отвечаем на вопросы.",
    icon: "family",
    accent: "lime",
    image: "/images/ege-course/parent-family-trim.png",
  },
  {
    title: "Подготовка до экзамена",
    desc: "Сопровождаем ученика до самого ЕГЭ, а не бросаем на полпути.",
    icon: "cap",
    accent: "violet",
    image: "/images/ege-course/parent-cap-trim.png",
  },
];
---

<section class="parents" aria-labelledby="parents-title">
  <div class="parents__shell">
    <figure class="parents__background" aria-hidden="true">
      <img
        src="/images/ege-course/parent-main-trim.png"
        alt=""
        width="1044"
        height="979"
        loading="lazy"
      />
    </figure>

    <div class="parents__grid">
      <div class="parents__content">
        <span class="parents__eyebrow ege-course-chip ege-course-chip--lime">для родителей</span>

        <h2 class="parents__title" id="parents-title">
          Почему родителям <span>спокойно</span> за подготовку
        </h2>

        <p class="parents__lead">
          Мы выстраиваем подготовку так, чтобы родитель видел процесс,
          понимал прогресс и был уверен, что ребёнок идёт к результату системно.
        </p>

        <ul class="parents__list">
          {
            items.map((item) => (
              <li class="parent-card">
                <span class:list={["parent-card__icon", `parent-card__icon--${item.accent}`]} aria-hidden="true">
                  <img src={item.image} alt="" width="128" height="128" loading="lazy" />
                </span>
                <div class="parent-card__body">
                  <h3 class="parent-card__title">{item.title}</h3>
                  <p class="parent-card__desc">{item.desc}</p>
                </div>
              </li>
            ))
          }
        </ul>
      </div>

      <div class="parents__visual" aria-hidden="true"></div>
    </div>

    <aside class="parents__note">
      <div class="parents__note-icon" aria-hidden="true">
        <svg viewBox="0 0 64 64" fill="none">
          <path d="M32 6 14 13.4v13.8c0 12 7.6 22.9 18 26.8 10.4-3.9 18-14.8 18-26.8V13.4L32 6Z" fill="url(#shield-fill)" />
          <path d="M32 6 14 13.4v13.8c0 12 7.6 22.9 18 26.8 10.4-3.9 18-14.8 18-26.8V13.4L32 6Z" stroke="#B7D655" stroke-width="2.5" stroke-linejoin="round" />
          <path d="m24.5 31.8 5.1 5.1 10-10.1" stroke="var(--ege-primary)" stroke-width="4" stroke-linecap="round" stroke-linejoin="round" />
          <defs>
            <linearGradient id="shield-fill" x1="32" x2="32" y1="6" y2="53">
              <stop stop-color="#E9F2C4"></stop>
              <stop offset="1" stop-color="#C8E55D"></stop>
            </linearGradient>
          </defs>
        </svg>
      </div>
      <p class="parents__note-text">
        Родителю спокойно, когда подготовка — это не хаос, а понятная система
        с контролем, практикой и движением к результату.
      </p>
      <span class="parents__note-flask" aria-hidden="true">
        <svg viewBox="0 0 64 64" fill="none">
          <path d="M26 8h12M28 8v15L16.5 50.2A4 4 0 0 0 20 56h24a4 4 0 0 0 3.5-5.8L36 23V8" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" />
          <path d="M24 42c2 1.4 4.8 2.2 8 2.2s6-.8 8-2.2" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" />
          <path d="M22 46c2.8 2.2 6.2 3.4 10 3.4S39.2 48.2 42 46" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" />
        </svg>
      </span>
    </aside>
  </div>
</section>

<style>
  .parents {
    width: 100vw;
    margin-inline: calc(50% - 50vw);
    padding: var(--ege-section-gap) var(--ege-section-pad-x) 0;
    background: var(--ege-page);
    color: var(--ege-text);
    font-family: var(--ege-font-family);
    -webkit-font-smoothing: antialiased;
  }

  .parents__shell {
    position: relative;
    max-width: var(--ege-section-wide);
    margin: 0 auto;
    padding: 40px;
    border-radius: var(--ege-radius-section);
    background: var(--ege-primary-tint);
    box-shadow: var(--ege-shadow-section);
    overflow: hidden;
  }

  .parents__background {
    position: absolute;
    right: 24px;
    top: 34px;
    bottom: 92px;
    z-index: 0;
    width: min(52%, 760px);
    margin: 0;
    pointer-events: none;
  }

  .parents__background img {
    width: 100%;
    height: 100%;
    object-fit: contain;
    object-position: center right;
    display: block;
  }

  .parents__grid {
    position: relative;
    display: grid;
    grid-template-columns: minmax(0, 1.1fr) minmax(420px, 0.9fr);
    gap: 36px;
    align-items: start;
    z-index: 1;
  }

  .parents__content {
    position: relative;
    z-index: 2;
    min-width: 0;
  }

  .parents__title {
    margin: 22px 0 0;
    max-width: 720px;
    font-size: var(--ege-h2);
    line-height: var(--ege-lh-title);
    letter-spacing: var(--ege-track-title);
    font-weight: 800;
  }

  .parents__title span {
    color: var(--ege-primary);
  }

  .parents__lead {
    max-width: 560px;
    margin: 24px 0 0;
    color: var(--ege-muted);
    font-size: var(--ege-lead);
    line-height: var(--ege-lh-body);
  }

  .parents__list {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 14px;
    margin: 32px 0 0;
    padding: 0;
    list-style: none;
  }

  .parent-card {
    min-height: 216px;
    padding: 20px 18px 18px;
    border-radius: var(--ege-radius-lg);
    background: var(--ege-surface);
    box-shadow:
      0 12px 30px rgba(var(--ege-primary-rgb), 0.06),
      inset 0 1px 0 rgba(255, 255, 255, 0.9);
  }

  .parent-card__icon {
    width: 86px;
    height: 86px;
    display: grid;
    place-items: center;
    margin-bottom: 16px;
  }

  .parent-card__icon img {
    width: 100%;
    height: 100%;
    object-fit: contain;
    display: block;
  }

  .parent-card__icon--violet {
    color: inherit;
  }

  .parent-card__icon--lime {
    color: inherit;
  }

  .parent-card__body {
    display: grid;
    gap: 10px;
  }

  .parent-card__title {
    margin: 0;
    font-size: var(--ege-card-title);
    line-height: 1.25;
    font-weight: 800;
    letter-spacing: -0.02em;
  }

  .parent-card__desc {
    margin: 0;
    color: var(--ege-muted);
    font-size: var(--ege-body-sm);
    line-height: 1.55;
  }

  .parents__visual {
    position: relative;
    min-height: 690px;
    pointer-events: none;
  }

  .parents__note {
    position: relative;
    z-index: 2;
    display: grid;
    grid-template-columns: auto minmax(0, 1fr) auto;
    align-items: center;
    gap: 22px;
    margin-top: 18px;
    padding: 22px 28px;
    border-radius: var(--ege-radius-xl);
    background: var(--ege-dark-surface);
    color: var(--ege-dark-text);
    box-shadow: var(--ege-shadow-dark);
    overflow: hidden;
  }

  .parents__note::after {
    content: "";
    position: absolute;
    right: 12px;
    top: 50%;
    width: 140px;
    height: 140px;
    border-radius: 42%;
    background: rgba(var(--ege-primary-mark-rgb), 0.16);
    transform: translateY(-50%);
  }

  .parents__note-icon {
    position: relative;
    z-index: 1;
    width: 112px;
    height: 112px;
    display: grid;
    place-items: center;
  }

  .parents__note-icon svg {
    width: 100%;
    height: 100%;
    display: block;
  }

  .parents__note-text {
    position: relative;
    z-index: 1;
    margin: 0;
    max-width: 840px;
    font-size: var(--ege-h3);
    line-height: 1.4;
    letter-spacing: -0.02em;
  }

  .parents__note-flask {
    position: relative;
    z-index: 1;
    width: 96px;
    height: 96px;
    color: rgba(216, 233, 152, 0.58);
  }

  .parents__note-flask svg {
    width: 100%;
    height: 100%;
    display: block;
  }

  @media (max-width: 1180px) {
    .parents__grid {
      grid-template-columns: minmax(0, 1.1fr) minmax(320px, 0.9fr);
    }

    .parents__background {
      width: min(52%, 620px);
      opacity: 0.72;
    }
  }

  @media (max-width: 900px) {
    .parents__shell {
      padding: 28px;
    }

    .parents__list {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }

    .parents__background {
      top: 120px;
      right: -12px;
      bottom: 150px;
      width: 58%;
      opacity: 0.45;
    }

    .parents__note {
      grid-template-columns: 1fr;
      justify-items: start;
    }

    .parents__note::after,
    .parents__note-flask {
      display: none;
    }
  }

  @media (max-width: 640px) {
    .parents__shell {
      padding: 20px;
      border-radius: 24px;
    }

    .parents__grid {
      grid-template-columns: 1fr;
      gap: 26px;
    }

    .parents__lead {
      font-size: var(--ege-body);
    }

    .parents__list {
      grid-template-columns: 1fr;
    }

    .parent-card {
      min-height: 0;
    }

    .parents__visual {
      display: none;
    }

    .parents__background {
      top: 230px;
      right: -38px;
      bottom: auto;
      width: 86%;
      height: 330px;
      opacity: 0.36;
    }

    .parents__note {
      padding: 18px 18px 20px;
    }

    .parents__note-icon {
      width: 84px;
      height: 84px;
    }
  }
</style>
