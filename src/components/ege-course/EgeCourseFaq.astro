---
const faqs = [
  {
    question: "Можно ли подготовиться с нуля?",
    answer:
      "Да. Курс выстроен по системе: начинаем с базы, постепенно закрываем пробелы, отрабатываем задания и доводим до уверенного результата на экзамене.",
  },
  {
    question: "Сколько человек в минигруппе?",
    answer:
      "В минигруппе до 8 учеников. Такой формат сохраняет живую динамику занятия и оставляет время на вопросы каждого.",
  },
  {
    question: "Будут ли домашние задания и проверка?",
    answer:
      "Да. После тем ученики получают практику, а преподаватель и куратор помогают разобрать ошибки и закрепить материал.",
  },
  {
    question: "Если я пропущу занятие?",
    answer:
      "Материалы и записи остаются в личном кабинете, поэтому тему можно догнать и задать вопросы по непонятным моментам.",
  },
  {
    question: "Можно ли оплачивать в рассрочку?",
    answer:
      "Да, доступна оплата в рассрочку без переплаты. Условия можно уточнить перед записью на пробное занятие.",
  },
];
---

<section class="course-faq" aria-labelledby="course-faq-title">
  <div class="course-faq__shell">
    <div class="course-faq__content">
      <span class="course-faq__eyebrow ege-course-chip ege-course-chip--lime"
        >FAQ</span
      >
      <h2 class="course-faq__title" id="course-faq-title">
        Вопросы<br />
        <span>и ответы</span>
      </h2>
      <p class="course-faq__lead">
        Собрали ответы на самые частые вопросы о годовом курсе, формате занятий
        и подготовке к ЕГЭ по химии.
      </p>

      <a
        class="course-faq__telegram"
        href="https://t.me/egehim"
        target="_blank"
        rel="noopener noreferrer"
      >
        <span class="course-faq__telegram-icon" aria-hidden="true">
          <svg viewBox="0 0 24 24" fill="currentColor">
            <path
              d="M21.9 4.6 18.6 20c-.2 1.1-.8 1.3-1.6.8l-5-3.7-2.4 2.3c-.3.3-.5.5-1 .5l.4-5.1 9.3-8.4c.4-.4-.1-.6-.6-.2L6.3 13.4l-4.9-1.5c-1.1-.3-1.1-1 .2-1.5L20.3 3c.9-.3 1.7.2 1.6 1.6Z"
            ></path>
          </svg>
        </span>
        <span>Если останутся вопросы —<br />ответим в Telegram</span>
      </a>

      <div class="course-faq__decor" aria-hidden="true">
        <img
          src="/images/ege-course/faq-trim.png"
          alt=""
          width="1394"
          height="937"
          loading="lazy"
        />
      </div>
    </div>

    <div class="course-faq__items">
      {
        faqs.map((item, index) => (
          <details class="course-faq__item" open={index === 0}>
            <summary class="course-faq__question">
              <h3 class="course-faq__question-title">{item.question}</h3>
              <span class="course-faq__toggle" aria-hidden="true" />
            </summary>
            <p class="course-faq__answer">{item.answer}</p>
          </details>
        ))
      }
    </div>
  </div>
</section>

<style>
  .course-faq {
    width: 100vw;
    margin-inline: calc(50% - 50vw);
    padding: var(--ege-section-gap) var(--ege-section-pad-x)
      var(--ege-section-pad-y);
    background: var(--ege-page);
    color: var(--ege-text);
    font-family: var(--ege-font-family);
  }

  .course-faq__shell {
    position: relative;
    display: grid;
    grid-template-columns: minmax(0, 0.9fr) minmax(0, 1.1fr);
    gap: 54px;
    max-width: var(--ege-section-wide);
    margin: 0 auto;
    padding: 72px 64px;
    border-radius: var(--ege-radius-section);
    background: linear-gradient(180deg, var(--ege-surface) 0%, #f7f3ff 100%);
    overflow: hidden;
  }

  .course-faq__content {
    position: relative;
    min-height: 620px;
    z-index: 1;
  }

  .course-faq__title {
    margin-top: 26px;
    font-size: var(--ege-h2);
    line-height: var(--ege-lh-title);
    letter-spacing: var(--ege-track-title);
    font-weight: 800;
  }

  .course-faq__title span {
    color: var(--ege-primary);
  }

  .course-faq__lead {
    max-width: 430px;
    margin-top: 28px;
    color: var(--ege-muted);
    font-size: var(--ege-lead);
    line-height: var(--ege-lh-body);
  }

  .course-faq__telegram {
    position: relative;
    z-index: 2;
    display: inline-flex;
    align-items: center;
    gap: 18px;
    margin-top: 34px;
    padding: 18px 24px 18px 18px;
    border-radius: var(--ege-radius-lg);
    background: var(--ege-surface);
    color: var(--ege-text);
    text-decoration: none;
    font-size: var(--ege-body);
    line-height: 1.35;
    font-weight: 600;
    box-shadow: var(--ege-shadow-card);
  }

  .course-faq__telegram-icon {
    width: 58px;
    height: 58px;
    display: grid;
    place-items: center;
    border-radius: var(--ege-radius-md);
    background: var(--ege-lime-soft);
    color: var(--ege-lime-icon);
    flex: 0 0 auto;
  }

  .course-faq__telegram-icon svg {
    width: 34px;
    height: 34px;
    transform: translate(-1px, 1px);
  }

  .course-faq__decor {
    position: absolute;
    left: -70px;
    bottom: -80px;
    width: min(58vw, 620px);
    margin: 0;
    pointer-events: none;
  }

  .course-faq__decor img {
    width: 100%;
    height: auto;
    display: block;
  }

  .course-faq__items {
    position: relative;
    z-index: 1;
    display: grid;
    align-content: start;
    gap: 14px;
    padding-top: 40px;
  }

  .course-faq__item {
    border: 1px solid var(--ege-primary-soft);
    border-radius: var(--ege-radius-lg);
    background: var(--ege-surface);
    overflow: hidden;
    box-shadow: var(--ege-shadow-card);
  }

  .course-faq__item[open] {
    background: var(--ege-dark-surface);
    border-color: rgba(var(--ege-primary-mark-rgb), 0.34);
    color: var(--ege-dark-text);
    box-shadow: var(--ege-shadow-dark);
  }

  .course-faq__question {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 24px;
    min-height: 76px;
    padding: 0 28px 0 34px;
    cursor: pointer;
    list-style: none;
  }

  .course-faq__question::-webkit-details-marker {
    display: none;
  }

  .course-faq__question-title {
    font-size: var(--ege-h3);
    line-height: var(--ege-lh-heading);
    font-weight: 800;
    letter-spacing: var(--ege-track-tight);
  }

  .course-faq__toggle {
    position: relative;
    width: 38px;
    height: 38px;
    border: 2px solid var(--ege-primary);
    border-radius: 50%;
    color: var(--ege-primary);
    flex: 0 0 auto;
  }

  .course-faq__toggle::before,
  .course-faq__toggle::after {
    content: "";
    position: absolute;
    left: 50%;
    top: 50%;
    width: 18px;
    height: 3px;
    border-radius: var(--ege-radius-pill);
    background: currentColor;
    transform: translate(-50%, -50%);
  }

  .course-faq__toggle::after {
    transform: translate(-50%, -50%) rotate(90deg);
  }

  .course-faq__item[open] .course-faq__toggle {
    background: var(--ege-lime);
    border-color: var(--ege-lime);
    color: var(--ege-text);
  }

  .course-faq__item[open] .course-faq__toggle::after {
    opacity: 0;
  }

  .course-faq__answer {
    max-width: 560px;
    padding: 0 88px 34px 34px;
    color: var(--ege-muted);
    font-size: var(--ege-lead);
    line-height: var(--ege-lh-body);
  }

  .course-faq__item[open] .course-faq__answer {
    color: var(--ege-dark-muted);
  }

  @media (max-width: 1024px) {
    .course-faq__shell {
      grid-template-columns: 1fr;
      padding: 48px 36px;
    }

    .course-faq__content {
      min-height: 520px;
    }

    .course-faq__items {
      padding-top: 0;
    }
  }

  @media (max-width: 640px) {
    .course-faq__shell {
      padding: 32px 20px;
      border-radius: 24px;
    }

    .course-faq__content {
      min-height: 0;
      padding-bottom: 190px;
    }

    .course-faq__title {
      font-size: var(--ege-h2);
    }

    .course-faq__lead {
      max-width: none;
    }

    .course-faq__telegram {
      width: 100%;
    }

    .course-faq__decor {
      left: -42px;
      bottom: -18px;
      width: 360px;
    }

    .course-faq__question {
      min-height: 68px;
      padding: 0 18px 0 20px;
    }

    .course-faq__toggle {
      width: 34px;
      height: 34px;
    }

    .course-faq__answer {
      padding: 0 20px 24px;
    }
  }
</style>
