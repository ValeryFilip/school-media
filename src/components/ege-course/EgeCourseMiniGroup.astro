---
const rows = [
  {
    label: "Размер группы",
    mini: "6-8 человек",
    mass: "сотни и тысячи учеников",
    icon: "users",
  },
  {
    label: "Обратная связь",
    mini: "личная и быстрая",
    mass: "ограниченная",
    icon: "chat",
  },
  {
    label: "Можно задавать вопросы",
    mini: "да, прямо на занятии",
    mass: "не всегда",
    icon: "question",
  },
  {
    label: "Контроль прогресса",
    mini: "преподаватель видит каждого",
    mass: "легко потеряться",
    icon: "chart",
  },
  {
    label: "Домашние задания",
    mini: "с проверкой и разбором",
    mass: "часто без детального разбора",
    icon: "clipboard",
  },
  {
    label: "Дисциплина и расписание",
    mini: "выше вовлечённость",
    mass: "ниже вовлечённость",
    icon: "calendar",
  },
  {
    label: "Шанс остаться без внимания",
    mini: "минимальный",
    mass: "высокий",
    icon: "shield",
  },
];
---

<section class="course-minigroup ege-course-section" aria-labelledby="course-minigroup-title">
  <div class="course-minigroup__shell ege-course-panel ege-course-panel--wide ege-course-panel--pastel-primary">
    <header class="course-minigroup__header">
      <span class="ege-course-chip ege-course-chip--lime">сравнение форматов</span>
      <h2 class="course-minigroup__title ege-course-section-title" id="course-minigroup-title">
        Почему минигруппа выигрывает
      </h2>
      <p class="course-minigroup__lead ege-course-section-lead">
        Сравни формат минигруппы и обычной онлайн-школы на тысячи учеников.
      </p>
    </header>

    <div class="course-minigroup__table" aria-label="Сравнение форматов обучения">
      <div class="course-minigroup__criteria">
        <div class="course-minigroup__criteria-spacer" aria-hidden="true"></div>
        {
          rows.map((row) => (
            <div class="course-minigroup__criteria-row">
              <span class="course-minigroup__icon" aria-hidden="true">
                {row.icon === "users" && (
                  <svg viewBox="0 0 36 36" fill="none">
                    <path d="M14 18a5 5 0 1 1 0-10 5 5 0 0 1 0 10ZM6 29c1-4.5 4-7 8-7s7 2.5 8 7" stroke="currentColor" stroke-width="2.3" stroke-linecap="round" />
                    <path d="M25 18a4 4 0 1 0 0-8M25 22c3.4.5 5.6 2.8 6.3 7" stroke="currentColor" stroke-width="2.3" stroke-linecap="round" />
                  </svg>
                )}
                {row.icon === "chat" && (
                  <svg viewBox="0 0 36 36" fill="none">
                    <path d="M7 15a8 8 0 0 1 8-8h5a8 8 0 0 1 0 16h-2l-6 5v-6.3A8 8 0 0 1 7 15Z" stroke="currentColor" stroke-width="2.3" stroke-linejoin="round" />
                    <path d="M14 15h.1M18 15h.1M22 15h.1" stroke="currentColor" stroke-width="3" stroke-linecap="round" />
                  </svg>
                )}
                {row.icon === "question" && (
                  <svg viewBox="0 0 36 36" fill="none">
                    <circle cx="18" cy="18" r="13" stroke="currentColor" stroke-width="2.3" />
                    <path d="M14.5 14a4 4 0 0 1 7.5 2c0 3-4 3.1-4 6M18 27h.1" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" />
                  </svg>
                )}
                {row.icon === "chart" && (
                  <svg viewBox="0 0 36 36" fill="none">
                    <path d="M7 29h23M11 29V20h4v9M17 29V15h4v14M23 29V11h4v18" stroke="currentColor" stroke-width="2.3" stroke-linecap="round" stroke-linejoin="round" />
                    <path d="m8 16 8-5 5 3 8-8" stroke="currentColor" stroke-width="2.3" stroke-linecap="round" stroke-linejoin="round" />
                  </svg>
                )}
                {row.icon === "clipboard" && (
                  <svg viewBox="0 0 36 36" fill="none">
                    <path d="M12 6h12l2 4v20H10V10l2-4Z" stroke="currentColor" stroke-width="2.3" stroke-linejoin="round" />
                    <path d="M15 16h7M15 22h7M23 24l2 2 4-5" stroke="currentColor" stroke-width="2.3" stroke-linecap="round" stroke-linejoin="round" />
                  </svg>
                )}
                {row.icon === "calendar" && (
                  <svg viewBox="0 0 36 36" fill="none">
                    <path d="M12 6v5M24 6v5M8 15h20" stroke="currentColor" stroke-width="2.3" stroke-linecap="round" />
                    <rect x="8" y="9" width="20" height="21" rx="4" stroke="currentColor" stroke-width="2.3" />
                    <path d="M25 24a5 5 0 1 1-10 0 5 5 0 0 1 10 0ZM20 21v3l2 1.4" stroke="currentColor" stroke-width="2.1" stroke-linecap="round" />
                  </svg>
                )}
                {row.icon === "shield" && (
                  <svg viewBox="0 0 36 36" fill="none">
                    <path d="M18 5 8 9v8c0 7 4.2 11.5 10 14 5.8-2.5 10-7 10-14V9L18 5Z" stroke="currentColor" stroke-width="2.3" stroke-linejoin="round" />
                    <path d="M14 18a4 4 0 0 1 8 0M15 15a3 3 0 1 0 6 0" stroke="currentColor" stroke-width="2.3" stroke-linecap="round" />
                  </svg>
                )}
              </span>
              <b>{row.label}</b>
            </div>
          ))
        }
      </div>

      <div class="course-minigroup__format course-minigroup__format--mini">
        <div class="course-minigroup__format-head">
          <span class="course-minigroup__head-icon" aria-hidden="true">
            <svg viewBox="0 0 28 28" fill="none">
              <path d="M9 12v10M9 12l4.2-7.2a2.2 2.2 0 0 1 4.1 1.4L16.4 11H22a3 3 0 0 1 3 3l-1 5.5A4 4 0 0 1 20.1 23H9M5 12h4v11H5V12Z" fill="currentColor" />
            </svg>
          </span>
          <h3>Минигруппа</h3>
          <span class="course-minigroup__badge">лучший выбор</span>
        </div>
        {
          rows.map((row) => (
            <div class="course-minigroup__format-row">
              <span class="course-minigroup__check" aria-hidden="true">✓</span>
              <b>{row.mini}</b>
              <i aria-hidden="true"></i>
            </div>
          ))
        }
      </div>

      <div class="course-minigroup__format course-minigroup__format--mass">
        <div class="course-minigroup__format-head">
          <span class="course-minigroup__head-icon" aria-hidden="true">
            <svg viewBox="0 0 28 28" fill="none">
              <circle cx="14" cy="8" r="4" stroke="currentColor" stroke-width="2.2" />
              <path d="M6 23c.8-5 4-8 8-8s7.2 3 8 8" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" />
            </svg>
          </span>
          <h3>Обычная онлайн-школа</h3>
        </div>
        {
          rows.map((row) => (
            <div class="course-minigroup__format-row">
              <span class="course-minigroup__minus" aria-hidden="true">−</span>
              <b>{row.mass}</b>
              <i aria-hidden="true"></i>
            </div>
          ))
        }
      </div>
    </div>

    <div class="course-minigroup__callout">
      <span aria-hidden="true">
        <svg viewBox="0 0 42 42" fill="none">
          <circle cx="21" cy="21" r="18" stroke="currentColor" stroke-width="2.4" />
          <path d="m21 9 3.3 7 7.7 1.1-5.6 5.4 1.3 7.6L21 26.5l-6.8 3.6 1.3-7.6-5.5-5.4 7.6-1.1L21 9Z" fill="var(--ege-lime)" stroke="currentColor" stroke-width="2" stroke-linejoin="round" />
        </svg>
      </span>
      <p>В минигруппе легче держать темп, получать помощь и стабильно идти к высоким баллам.</p>
      <a href="#course-pricing">Выбрать минигруппу</a>
    </div>
  </div>
</section>

<style>
  .course-minigroup__shell {
    padding: 36px 42px 34px;
  }

  .course-minigroup__header {
    margin-bottom: 30px;
  }

  .course-minigroup__title {
    max-width: 900px;
    margin-top: 24px;
  }

  .course-minigroup__lead {
    max-width: 900px;
    margin-top: 18px;
  }

  .course-minigroup__table {
    display: grid;
    grid-template-columns: 0.72fr 1.08fr 1fr;
    gap: 14px;
    align-items: end;
  }

  .course-minigroup__criteria,
  .course-minigroup__format {
    overflow: hidden;
    border-radius: var(--ege-radius-lg);
    background: rgb(255 255 255 / 0.82);
    box-shadow: var(--ege-shadow-card);
  }

  .course-minigroup__criteria-spacer {
    height: 96px;
    background: transparent;
  }

  .course-minigroup__criteria-row,
  .course-minigroup__format-row {
    min-height: 86px;
    display: grid;
    align-items: center;
    border-top: 1px solid rgb(60 40 120 / 0.11);
  }

  .course-minigroup__criteria-row {
    grid-template-columns: 58px minmax(0, 1fr);
    gap: 18px;
    padding: 16px 24px;
  }

  .course-minigroup__icon,
  .course-minigroup__head-icon {
    display: grid;
    place-items: center;
    border-radius: 50%;
    background: var(--ege-primary-soft);
    color: var(--ege-primary);
  }

  .course-minigroup__icon {
    width: 50px;
    height: 50px;
  }

  .course-minigroup__icon svg {
    width: 32px;
    height: 32px;
  }

  .course-minigroup__criteria-row b,
  .course-minigroup__format-row b {
    color: var(--ege-text);
    font-size: var(--ege-card-title);
    line-height: var(--ege-lh-heading);
    letter-spacing: var(--ege-track-tight);
    font-weight: 800;
  }

  .course-minigroup__format {
    position: relative;
  }

  .course-minigroup__format--mini {
    border: 2px solid var(--ege-primary);
    box-shadow: 0 22px 50px rgb(111 72 232 / 0.2);
  }

  .course-minigroup__format-head {
    min-height: 96px;
    display: grid;
    grid-template-columns: auto minmax(0, 1fr) auto;
    gap: 18px;
    align-items: center;
    padding: 22px 30px;
  }

  .course-minigroup__format--mini .course-minigroup__format-head {
    background: linear-gradient(135deg, var(--ege-primary), var(--ege-primary-deep));
    color: var(--ege-inverse);
  }

  .course-minigroup__format--mass .course-minigroup__format-head {
    background: rgb(255 255 255 / 0.58);
  }

  .course-minigroup__head-icon {
    width: 52px;
    height: 52px;
  }

  .course-minigroup__format--mini .course-minigroup__head-icon {
    background: rgb(255 255 255 / 0.17);
    color: var(--ege-inverse);
  }

  .course-minigroup__format--mass .course-minigroup__head-icon {
    color: var(--ege-primary);
  }

  .course-minigroup__head-icon svg {
    width: 30px;
    height: 30px;
  }

  .course-minigroup__format-head h3 {
    color: inherit;
    font-size: clamp(24px, 2vw, 34px);
    line-height: var(--ege-lh-heading);
    letter-spacing: var(--ege-track-tight);
    font-weight: 900;
  }

  .course-minigroup__badge {
    padding: 12px 20px;
    border-radius: var(--ege-radius-pill);
    background: var(--ege-lime);
    color: var(--ege-text);
    font-size: var(--ege-body-sm);
    line-height: 1;
    font-weight: 800;
    white-space: nowrap;
  }

  .course-minigroup__format-row {
    grid-template-columns: auto minmax(0, 1fr) 76px;
    gap: 22px;
    padding: 16px 30px;
    background: rgb(255 255 255 / 0.82);
  }

  .course-minigroup__format--mini .course-minigroup__format-row {
    background: var(--ege-surface);
  }

  .course-minigroup__format--mass .course-minigroup__format-row b {
    color: var(--ege-muted);
    font-size: var(--ege-body);
    font-weight: 700;
  }

  .course-minigroup__check,
  .course-minigroup__minus {
    width: 42px;
    height: 42px;
    display: grid;
    place-items: center;
    border-radius: 50%;
    font-size: 34px;
    line-height: 1;
    font-weight: 500;
  }

  .course-minigroup__check {
    border: 2px solid var(--ege-lime-icon);
    color: var(--ege-lime-icon);
  }

  .course-minigroup__minus {
    background: rgb(107 116 141 / 0.42);
    color: var(--ege-inverse);
  }

  .course-minigroup__format-row i {
    width: 58px;
    height: 36px;
    justify-self: end;
    border-radius: 999px 999px 18px 18px;
    background: linear-gradient(135deg, rgb(232 246 170 / 0.32), rgb(255 255 255 / 0.12));
    transform: skewX(-14deg);
  }

  .course-minigroup__format--mass .course-minigroup__format-row i {
    background: linear-gradient(135deg, rgb(221 224 234 / 0.5), rgb(255 255 255 / 0.18));
  }

  .course-minigroup__callout {
    width: 100%;
    min-height: 104px;
    display: grid;
    grid-template-columns: auto minmax(0, 1fr) auto;
    gap: 24px;
    align-items: center;
    margin-top: 34px;
    padding: 20px 28px;
    border: 1px solid rgb(164 213 34 / 0.36);
    border-radius: var(--ege-radius-lg);
    background: linear-gradient(135deg, rgb(232 246 170 / 0.95), rgb(248 255 214 / 0.86));
    box-shadow: 0 18px 36px rgb(164 213 34 / 0.18);
  }

  .course-minigroup__callout span {
    width: 72px;
    height: 72px;
    display: grid;
    place-items: center;
    border-radius: 50%;
    color: var(--ege-primary);
  }

  .course-minigroup__callout svg {
    width: 72px;
    height: 72px;
  }

  .course-minigroup__callout p {
    color: var(--ege-text);
    font-size: var(--ege-card-title);
    line-height: var(--ege-lh-card);
    letter-spacing: var(--ege-track-tight);
    font-weight: 800;
  }

  .course-minigroup__callout a {
    display: inline-flex;
    min-height: 52px;
    align-items: center;
    justify-content: center;
    padding: 0 26px;
    border-radius: var(--ege-radius-pill);
    background: var(--ege-primary);
    color: var(--ege-inverse);
    font-size: var(--ege-body);
    line-height: 1;
    font-weight: 800;
    text-decoration: none;
    box-shadow: 0 14px 30px rgb(111 72 232 / 0.24);
    white-space: nowrap;
  }

  @media (max-width: 1180px) {
    .course-minigroup__table {
      grid-template-columns: 1fr;
    }

    .course-minigroup__criteria-spacer {
      display: none;
    }
  }

  @media (max-width: 640px) {
    .course-minigroup__shell {
      padding: 32px 18px 22px;
    }

    .course-minigroup__criteria-row,
    .course-minigroup__format-row {
      min-height: 0;
    }

    .course-minigroup__format-head,
    .course-minigroup__format-row {
      grid-template-columns: auto minmax(0, 1fr);
    }

    .course-minigroup__badge,
    .course-minigroup__format-row i {
      display: none;
    }

    .course-minigroup__callout {
      grid-template-columns: 1fr;
      justify-items: center;
      text-align: center;
    }
  }
</style>
