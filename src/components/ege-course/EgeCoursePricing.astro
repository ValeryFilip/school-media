---
const planFeatures = [
  "8 занятий в месяц",
  "минигруппа до 8 человек",
  "домашние задания и проверка",
  "пробники и зачёты",
  "конспекты и записи",
  "чат поддержки",
  "контроль прогресса",
  "связь с родителями",
];

const benefits = [
  {
    mod: "lime",
    title: "Рассрочка без переплат",
    text: "Удобные платежи на весь период обучения",
    icon: `<svg viewBox="0 0 24 24" fill="none"><circle cx="7" cy="7" r="2.5" stroke="currentColor" stroke-width="2"/><circle cx="17" cy="17" r="2.5" stroke="currentColor" stroke-width="2"/><path d="M19 5 5 19" stroke="currentColor" stroke-width="2" stroke-linecap="round"/></svg>`,
  },
  {
    mod: "violet",
    title: "Налоговый вычет",
    text: "Вернём 13% от стоимости обучения",
    icon: `<svg viewBox="0 0 24 24" fill="none"><path d="M6 3h9l4 4v14a0 0 0 0 1 0 0H6a0 0 0 0 1 0 0V3Z" stroke="currentColor" stroke-width="2" stroke-linejoin="round"/><path d="M14 3v5h5M9 13h6M9 17h6" stroke="currentColor" stroke-width="2" stroke-linecap="round"/></svg>`,
  },
  {
    mod: "butter",
    title: "Возврат за непройденные занятия",
    text: "Пропустили занятие по нашей вине — вернём деньги",
    icon: `<svg viewBox="0 0 24 24" fill="none"><path d="M12 2 4 5v6c0 5 3.4 9.7 8 11 4.6-1.3 8-6 8-11V5l-8-3Z" stroke="currentColor" stroke-width="2" stroke-linejoin="round"/><path d="m9 12 2 2 4-4" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>`,
  },
];
---

<section class="pricing" aria-labelledby="pricing-title">

  <header class="pricing__header">
    <span class="pricing__eyebrow ege-course-chip ege-course-chip--lime">Стоимость</span>
    <h2 class="pricing__title" id="pricing-title">
      Тариф, с которым готовимся к&nbsp;ЕГЭ весь год
    </h2>
    <p class="pricing__subtitle">
      Наш основной продукт — годовой курс в&nbsp;минигруппе.<br>
      Система, практика и поддержка до&nbsp;самого экзамена.
    </p>
  </header>

  <article class="plan" aria-labelledby="plan-main-title">

    <div class="plan__gift">
      <svg class="plan__gift-icon" viewBox="0 0 24 24" fill="none" aria-hidden="true">
        <path d="M20 12v8a1 1 0 0 1-1 1H5a1 1 0 0 1-1-1v-8" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
        <rect x="2" y="7" width="20" height="5" rx="1" stroke="currentColor" stroke-width="2"/>
        <path d="M12 21V7M12 7s-1.5-4-4-4a2 2 0 0 0 0 4h4Zm0 0s1.5-4 4-4a2 2 0 0 1 0 4h-4Z" stroke="currentColor" stroke-width="2" stroke-linejoin="round"/>
      </svg>
      <span>2 бесплатных<br>курса в подарок</span>
    </div>

    <figure class="plan__icon-box" aria-hidden="true">
      <svg viewBox="0 0 24 24" fill="none">
        <path d="M9 3h6M10 3v5.5L5.5 17a2 2 0 0 0 1.8 3h9.4a2 2 0 0 0 1.8-3L14 8.5V3" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
        <circle cx="11.5" cy="15" r="1" fill="currentColor"/>
        <circle cx="13.5" cy="17" r="0.8" fill="currentColor"/>
      </svg>
    </figure>

    <div class="plan__body">
      <div class="plan__heading">
        <h3 class="plan__title" id="plan-main-title">Годовой курс в&nbsp;минигруппе</h3>
        <span class="plan__tag ege-course-chip ege-course-chip--primary">Основной тариф</span>
      </div>

      <div class="plan__pricing">
        <div class="plan__price">
          <span class="plan__price-prefix">от</span>
          <span class="plan__price-value">5&nbsp;990&nbsp;₽</span>
          <span class="plan__price-suffix">/&nbsp;мес</span>
        </div>
        <p class="plan__price-full">или 47&nbsp;900 ₽ за курс</p>
      </div>

      <div class="plan__installment">
        <svg viewBox="0 0 24 24" fill="none" aria-hidden="true">
          <path d="M12 2 4 5v6c0 5 3.4 9.7 8 11 4.6-1.3 8-6 8-11V5l-8-3Z" stroke="currentColor" stroke-width="2" stroke-linejoin="round"/>
          <path d="m9 12 2 2 4-4" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
        Можно в&nbsp;рассрочку
      </div>

      <button type="button" class="plan__cta">
        Записаться на&nbsp;пробный урок
        <svg class="plan__cta-arrow" viewBox="0 0 24 24" fill="none" aria-hidden="true">
          <path d="M5 12h14m0 0-6-6m6 6-6 6" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
      </button>

      <div class="plan__trial">
        <svg viewBox="0 0 24 24" fill="none" aria-hidden="true">
          <path d="m12 3 2.7 5.6 6.1.9-4.4 4.3 1 6.1L12 17l-5.4 2.9 1-6.1L3.2 9.5l6.1-.9L12 3Z" stroke="currentColor" stroke-width="2" stroke-linejoin="round"/>
        </svg>
        Первое занятие бесплатно
      </div>
    </div>

    <ul class="plan__features" aria-label="Что входит в тариф">
      {planFeatures.map((f) => (
        <li class="feature">
          <span class="feature__check" aria-hidden="true">
            <svg viewBox="0 0 12 12" fill="none">
              <path d="m2 6 3 3 5-6" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
          </span>
          {f}
        </li>
      ))}
    </ul>
  </article>

  <div class="plans-alt">

    <article class="plan-alt">
      <figure class="plan-alt__icon plan-alt__icon--violet" aria-hidden="true">
        <svg viewBox="0 0 24 24" fill="none">
          <circle cx="12" cy="8" r="4" stroke="currentColor" stroke-width="2"/>
          <path d="M4 21c0-4.4 3.6-8 8-8s8 3.6 8 8" stroke="currentColor" stroke-width="2" stroke-linecap="round"/>
        </svg>
      </figure>
      <div class="plan-alt__body">
        <h3 class="plan-alt__title">Индивидуальные занятия</h3>
        <div class="plan-alt__row">
          <p class="plan-alt__text">Нужен персональный темп<br>и&nbsp;точечная работа?</p>
          <a href="#" class="plan-alt__link">
            Перейти на&nbsp;страницу
            <svg viewBox="0 0 24 24" fill="none" aria-hidden="true">
              <path d="M5 12h14m0 0-6-6m6 6-6 6" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
          </a>
        </div>
      </div>
    </article>

    <article class="plan-alt">
      <figure class="plan-alt__icon plan-alt__icon--mint" aria-hidden="true">
        <svg viewBox="0 0 24 24" fill="none">
          <path d="M3 4h6a3 3 0 0 1 3 3v13a2 2 0 0 0-2-2H3V4ZM21 4h-6a3 3 0 0 0-3 3v13a2 2 0 0 1 2-2h7V4Z" stroke="currentColor" stroke-width="2" stroke-linejoin="round"/>
        </svg>
      </figure>
      <div class="plan-alt__body">
        <h3 class="plan-alt__title">Самостоятельная подготовка</h3>
        <div class="plan-alt__row">
          <p class="plan-alt__text">Если хочешь заниматься<br>в&nbsp;своём темпе</p>
          <a href="#" class="plan-alt__link">
            Перейти на&nbsp;страницу
            <svg viewBox="0 0 24 24" fill="none" aria-hidden="true">
              <path d="M5 12h14m0 0-6-6m6 6-6 6" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
          </a>
        </div>
      </div>
    </article>

  </div>

  <ul class="benefits" aria-label="Дополнительные условия">
    {benefits.map((b) => (
      <li class="benefit">
        <span class={`benefit__icon benefit__icon--${b.mod}`} aria-hidden="true" set:html={b.icon} />
        <div class="benefit__body">
          <p class="benefit__title">{b.title}</p>
          <p class="benefit__text">{b.text}</p>
        </div>
      </li>
    ))}
  </ul>

</section>

<style>
  .pricing {
    /* ---- layout ---- */
    width: 100vw;
    max-width: none;
    margin-inline: calc(50% - 50vw);
    padding: var(--ege-section-pad-y) var(--ege-section-pad-x);
    font-family: var(--ege-font-family);
    background:
      var(--ege-dark-page)
      url("/concepts/_new-design/images/ChatGPT Image 27 апр. 2026 г., 17_02_50.png")
      center / cover no-repeat;
    color: var(--ege-text);
    font-weight: 500;
    line-height: 1.4;
    -webkit-font-smoothing: antialiased;
    text-rendering: optimizeLegibility;
  }

  /* ---- Header ---- */
  .pricing__header {
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    gap: 24px;
    margin-bottom: 40px;
  }

  .pricing__title {
    color: var(--ege-dark-text);
    font-size: var(--ege-h2);
    font-weight: 800;
    line-height: var(--ege-lh-title);
    letter-spacing: var(--ege-track-title);
    max-width: 1080px;
    margin: 0;
  }

  .pricing__subtitle {
    color: var(--ege-dark-muted);
    font-size: var(--ege-lead);
    font-weight: 500;
    line-height: 1.55;
    max-width: 640px;
    margin: 0;
  }

  /* ---- Primary plan ---- */
  .plan {
    position: relative;
    background: var(--ege-surface);
    border-radius: var(--ege-radius-xl);
    padding: 40px 48px;
    display: grid;
    grid-template-columns: auto minmax(0, 1fr) auto;
    gap: 40px;
    align-items: start;
    margin-bottom: 16px;
  }

  .plan__gift {
    position: absolute;
    top: 28px;
    right: 28px;
    display: inline-flex;
    align-items: center;
    gap: 10px;
    background: var(--ege-butter-soft);
    padding: 10px 16px 10px 12px;
    border-radius: var(--ege-radius-sm);
    font-size: var(--ege-caption);
    font-weight: 600;
    line-height: 1.25;
    color: var(--ege-text);
  }

  .plan__gift-icon {
    width: 22px;
    height: 22px;
    color: var(--ege-sand);
    flex-shrink: 0;
    display: block;
  }

  .plan__icon-box {
    width: 140px;
    height: 140px;
    border-radius: var(--ege-radius-lg);
    background: var(--ege-primary-tint);
    display: grid;
    place-items: center;
    margin: 0;
  }

  .plan__icon-box svg {
    width: 64px;
    height: 64px;
    color: var(--ege-primary);
    display: block;
  }

  .plan__body {
    display: flex;
    flex-direction: column;
    gap: 20px;
    min-width: 0;
    max-width: 520px;
  }

  .plan__heading {
    display: flex;
    flex-direction: column;
    gap: 6px;
  }

  .plan__title {
    font-size: var(--ege-h3);
    font-weight: 800;
    line-height: 1.15;
    letter-spacing: -0.01em;
    margin: 0;
  }

  .plan__pricing {
    display: flex;
    flex-direction: column;
    gap: 8px;
    margin-top: 8px;
  }

  .plan__price {
    display: flex;
    align-items: baseline;
    gap: 12px;
    font-variant-numeric: tabular-nums;
  }

  .plan__price-prefix {
    font-size: var(--ege-card-title);
    font-weight: 500;
    color: var(--ege-muted);
  }

  .plan__price-value {
    font-size: var(--ege-price);
    font-weight: 800;
    color: var(--ege-primary);
    letter-spacing: -0.015em;
    line-height: 1;
    white-space: nowrap;
  }

  .plan__price-suffix {
    font-size: var(--ege-card-title);
    font-weight: 500;
    color: var(--ege-muted);
  }

  .plan__price-full {
    font-size: var(--ege-button);
    color: var(--ege-muted);
    font-weight: 500;
    margin: 0;
  }

  .plan__installment {
    align-self: flex-start;
    display: inline-flex;
    align-items: center;
    gap: 10px;
    background: var(--ege-lime-soft);
    padding: 10px 18px 10px 14px;
    border-radius: var(--ege-radius-pill);
    font-size: var(--ege-body-sm);
    font-weight: 600;
  }

  .plan__installment svg {
    width: 18px;
    height: 18px;
    color: var(--ege-lime-icon);
    display: block;
  }

  .plan__cta {
    background: var(--ege-primary);
    color: var(--ege-inverse);
    font-size: var(--ege-button);
    font-weight: 600;
    padding: 20px 28px;
    border-radius: 14px;
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 16px;
    border: none;
    cursor: pointer;
    font-family: inherit;
    transition: background 180ms var(--ege-ease), transform 180ms var(--ege-ease);
  }

  .plan__cta:hover  { background: var(--ege-primary-hover); }
  .plan__cta:active { transform: translateY(1px); }

  .plan__cta-arrow {
    width: 22px;
    height: 22px;
    display: block;
  }

  .plan__trial {
    display: flex;
    align-items: center;
    gap: 12px;
    background: var(--ege-primary-soft);
    padding: 16px 20px;
    border-radius: 14px;
    font-size: var(--ege-body-sm);
    font-weight: 500;
  }

  .plan__trial svg {
    width: 20px;
    height: 20px;
    color: var(--ege-primary);
    display: block;
  }

  .plan__features {
    display: flex;
    flex-direction: column;
    gap: 18px;
    padding: 4px 0 0;
    margin: 0;
    list-style: none;
    min-width: 260px;
  }

  .feature {
    display: flex;
    align-items: center;
    gap: 14px;
    font-size: var(--ege-button);
    font-weight: 500;
    color: var(--ege-text);
  }

  .feature__check {
    width: 26px;
    height: 26px;
    border-radius: 50%;
    background: var(--ege-primary-soft);
    display: grid;
    place-items: center;
    flex-shrink: 0;
  }

  .feature__check svg {
    width: 12px;
    height: 12px;
    color: var(--ege-primary);
    display: block;
  }

  /* ---- Secondary plans ---- */
  .plans-alt {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 16px;
    margin-bottom: 16px;
  }

  .plan-alt {
    background: var(--ege-surface);
    border-radius: var(--ege-radius-xl);
    padding: 24px 28px;
    display: grid;
    grid-template-columns: auto 1fr;
    gap: 22px;
    align-items: center;
  }

  .plan-alt__icon {
    width: 72px;
    height: 72px;
    border-radius: var(--ege-radius-md);
    display: grid;
    place-items: center;
    flex-shrink: 0;
    margin: 0;
  }

  .plan-alt__icon svg {
    width: 34px;
    height: 34px;
    display: block;
  }

  .plan-alt__icon--violet { background: var(--ege-primary-tint); color: var(--ege-primary); }
  .plan-alt__icon--mint   { background: var(--ege-mint);         color: var(--ege-mint-ink); }

  .plan-alt__body {
    display: flex;
    flex-direction: column;
    gap: 10px;
    min-width: 0;
  }

  .plan-alt__title {
    font-size: var(--ege-card-title);
    font-weight: 700;
    letter-spacing: -0.005em;
    margin: 0;
  }

  .plan-alt__row {
    display: flex;
    justify-content: space-between;
    align-items: flex-end;
    gap: 16px;
  }

  .plan-alt__text {
    color: var(--ege-muted);
    font-size: var(--ege-body-sm);
    font-weight: 500;
    line-height: 1.4;
    margin: 0;
  }

  .plan-alt__link {
    color: var(--ege-primary);
    font-weight: 600;
    font-size: var(--ege-body-sm);
    display: inline-flex;
    align-items: center;
    gap: 8px;
    white-space: nowrap;
    text-decoration: none;
    transition: gap 180ms var(--ege-ease);
  }

  .plan-alt__link:hover { gap: 12px; }

  .plan-alt__link svg {
    width: 16px;
    height: 16px;
    display: block;
  }

  /* ---- Benefits ---- */
  .benefits {
    background: var(--ege-surface);
    border-radius: var(--ege-radius-xl);
    padding: 28px 36px;
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 32px;
    margin: 0;
    list-style: none;
  }

  .benefit {
    display: grid;
    grid-template-columns: auto 1fr;
    gap: 18px;
    align-items: center;
  }

  .benefit__icon {
    width: 54px;
    height: 54px;
    border-radius: var(--ege-radius-sm);
    display: grid;
    place-items: center;
    flex-shrink: 0;
  }

  .benefit__icon :global(svg) {
    width: 24px;
    height: 24px;
    display: block;
  }

  .benefit__icon--lime   { background: var(--ege-lime-soft);   color: var(--ege-lime-icon); }
  .benefit__icon--violet { background: var(--ege-primary-soft); color: var(--ege-primary); }
  .benefit__icon--butter { background: var(--ege-butter-soft);  color: var(--ege-butter-ink); }

  .benefit__body {
    display: flex;
    flex-direction: column;
    gap: 4px;
    min-width: 0;
  }

  .benefit__title {
    font-size: var(--ege-body-sm);
    font-weight: 700;
    letter-spacing: -0.005em;
    margin: 0;
  }

  .benefit__text {
    font-size: var(--ege-caption);
    font-weight: 500;
    line-height: 1.45;
    color: var(--ege-muted);
    margin: 0;
  }

  /* ---- Responsive ---- */
  @media (max-width: 1024px) {
    .plan {
      grid-template-columns: auto 1fr;
      gap: 32px;
    }
    .plan__features {
      grid-column: 1 / -1;
      padding-top: 0;
    }
  }

  @media (max-width: 720px) {
    .pricing { padding: var(--ege-section-pad-y) var(--ege-section-pad-x); }
    .plan {
      grid-template-columns: 1fr;
      padding: 28px;
    }
    .plan__gift { position: static; align-self: start; }
    .plans-alt,
    .benefits   { grid-template-columns: 1fr; }
    .benefits   { padding: 20px; }
  }
</style>
