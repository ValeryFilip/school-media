---
const items = [
  {
    title: "Живые занятия<br>в&nbsp;мини-группе",
    desc: "8 занятий в&nbsp;месяц, до&nbsp;6–8 человек, можно задавать вопросы и&nbsp;разбирать сложные темы.",
    variant: "live",
    img: "/images/ege-course/f2.png",
  },
  {
    title: "Домашние задания<br>и&nbsp;разбор ошибок",
    desc: "Практика после каждой темы, проверка и&nbsp;понятная обратная связь.",
    variant: "homework",
    img: "/images/ege-course/f3.png",
  },
  {
    title: "Пробники и&nbsp;зачёты",
    desc: "Регулярная проверка прогресса, формат ЕГЭ и&nbsp;работа над слабыми местами.",
    variant: "mock",
    img: "/images/ege-course/f4.png",
  },
  {
    title: "Конспекты, материалы<br>и&nbsp;записи",
    desc: "Всё хранится в&nbsp;личном кабинете и&nbsp;помогает повторять темы в&nbsp;удобное время.",
    variant: "notes",
    img: "/images/ege-course/f5.png",
  },
  {
    title: "Поддержка преподавателя<br>и&nbsp;куратора",
    desc: "Можно задать вопрос, получить помощь и&nbsp;не&nbsp;остаться одному с&nbsp;трудностями.",
    variant: "support",
    img: "/images/ege-course/f6.png",
  },
  {
    title: "Контроль прогресса<br>и&nbsp;связь с&nbsp;родителями",
    desc: "Видно динамику, проблемы и&nbsp;результаты обучения.",
    variant: "progress",
    img: "/images/ege-course/f7.png",
  },
];
---

<section class="features" aria-labelledby="features-title">
  <div class="features__inner">
    <header class="features__header">
      <div class="features__intro">
        <span class="features__eyebrow">что входит в курс</span>
        <h2 class="features__title" id="features-title">
          Что входит в&nbsp;курс
        </h2>
        <p class="features__subtitle">
          Курс даёт всё, что нужно для системной подготовки к&nbsp;ЕГЭ
          по&nbsp;химии в&nbsp;течение года.
        </p>
      </div>

      <figure class="features__hero" aria-hidden="true">
        <img
          src="/images/ege-course/f1.png"
          alt=""
          width="320"
          height="200"
          loading="lazy"
        />
      </figure>
    </header>

    <ol class="features__list">
      {
        items.map((item) => (
          <li class:list={["feature-card", `feature-card--${item.variant}`]}>
            <div class="feature-card__content">
              <div class="feature-card__num-wrap">
                <span class="feature-card__num" aria-hidden="true" />
              </div>
              <div class="feature-card__text">
                <h3 class="feature-card__title" set:html={item.title} />
                <p class="feature-card__desc" set:html={item.desc} />
              </div>
            </div>
            <figure class="feature-card__img" aria-hidden="true">
              <img
                src={item.img}
                alt=""
                width="460"
                height="220"
                loading="lazy"
              />
            </figure>
          </li>
        ))
      }
    </ol>

    <aside class="gift-card" aria-label="Бонус при записи">
      <figure class="gift-card__img" aria-hidden="true">
        <img
          src="/images/ege-course/f8.png"
          alt=""
          width="280"
          height="180"
          loading="lazy"
        />
      </figure>
      <div class="gift-card__body">
        <h3 class="gift-card__title">Подарок при записи</h3>
        <p class="gift-card__desc">
          2 бесплатных курса для старта&nbsp;+ полезные материалы
          по&nbsp;подготовке к&nbsp;ЕГЭ
        </p>
        <button type="button" class="gift-card__cta">
          <svg viewBox="0 0 24 24" fill="none" aria-hidden="true">
            <path
              d="M20 12v8a1 1 0 0 1-1 1H5a1 1 0 0 1-1-1v-8"
              stroke="currentColor"
              stroke-width="2"
              stroke-linecap="round"
              stroke-linejoin="round"></path>
            <rect
              x="2"
              y="7"
              width="20"
              height="5"
              rx="1"
              stroke="currentColor"
              stroke-width="2"></rect>
            <path
              d="M12 21V7M12 7s-1.5-4-4-4a2 2 0 0 0 0 4h4Zm0 0s1.5-4 4-4a2 2 0 0 1 0 4h-4Z"
              stroke="currentColor"
              stroke-width="2"
              stroke-linejoin="round"></path>
          </svg>
          Получить бонус
        </button>
      </div>
    </aside>
  </div>
</section>

<style>
  .features {
    /* ---- feature illustration controls ---- */
    --feature-art-width: 700px;
    --feature-art-height: 400px;
    --feature-art-offset: 12px;
    --feature-card-pad-left: 28px;
    --feature-card-pad-right: 600px;
    --feature-card-pad-y: 34px;

    /* ---- layout ---- */
    width: 100%;
    font-family:
      "Manrope",
      -apple-system,
      BlinkMacSystemFont,
      "Segoe UI",
      sans-serif;
    color: var(--ege-dark-text, #ece9f5);
    font-weight: 500;
    line-height: 1.4;
    -webkit-font-smoothing: antialiased;
  }

  .features__inner {
    padding: 0;
  }

  /* ---- Header ---- */
  .features__header {
    display: grid;
    grid-template-columns: minmax(0, 1fr) auto;
    gap: 40px;
    align-items: center;
    margin-bottom: 48px;
  }

  .features__intro {
    display: flex;
    flex-direction: column;
    gap: 20px;
    max-width: 560px;
  }

  .features__eyebrow {
    align-self: flex-start;
    background: var(--ege-dark-lime, #d8e998);
    color: #1a1b2e;
    font-size: 13px;
    font-weight: 600;
    padding: 10px 22px;
    border-radius: 999px;
  }

  .features__title {
    font-size: clamp(40px, 4.4vw, 56px);
    font-weight: 800;
    letter-spacing: -0.02em;
    line-height: 1.05;
    color: var(--ege-dark-text, #ece9f5);
    margin: 0;
  }

  .features__subtitle {
    color: var(--ege-dark-muted, #9a96b2);
    font-size: 18px;
    font-weight: 500;
    line-height: 1.55;
    max-width: 460px;
    margin: 0;
  }

  .features__hero {
    width: 320px;
    display: grid;
    place-items: center;
    background: radial-gradient(
      ellipse at center,
      var(--ege-dark-surface-soft, #2b2541) 0%,
      transparent 70%
    );
    border-radius: 999px;
    margin: 0;
  }

  .features__hero img {
    width: 100%;
    height: auto;
  }

  /* ---- Feature cards ---- */
  .features__list {
    display: flex;
    flex-direction: column;
    gap: 14px;
    margin: 0 0 16px;
    padding: 0;
    list-style: none;
    counter-reset: feat;
  }

  .feature-card {
    --feature-card-pad-left-current: var(--feature-card-pad-left);
    --feature-card-pad-right-current: var(--feature-card-pad-right);
    --feature-art-width-current: var(--feature-art-width);
    --feature-art-height-current: var(--feature-art-height);
    --feature-art-left: auto;
    --feature-art-right: var(--feature-art-offset);
    --feature-art-top: 50%;
    --feature-art-bottom: auto;
    --feature-art-translate-x: 0;
    --feature-art-translate-y: -50%;
    --feature-art-mobile-bottom: -22px;
    position: relative;
    background: var(--ege-dark-surface, #221d36);
    border-radius: 28px;
    padding: var(--feature-card-pad-y) var(--feature-card-pad-right-current)
      var(--feature-card-pad-y) var(--feature-card-pad-left-current);
    display: block;
    counter-increment: feat;
    min-height: 244px;
    overflow: hidden;
    border: 1px solid rgba(255, 255, 255, 0.08);
    box-shadow: inset 0 1px 0 rgba(255, 255, 255, 0.03);
  }

  .feature-card__content {
    position: relative;
    z-index: 1;
    display: grid;
    grid-template-columns: auto minmax(0, 1fr);
    align-items: flex-start;
    column-gap: 18px;
  }

  .feature-card__num-wrap {
    display: flex;
    align-items: flex-start;
    justify-content: center;
  }

  .feature-card__num {
    width: 52px;
    height: 52px;
    border-radius: 50%;
    background: var(--ege-dark-primary, #7a5cf0);
    color: #fff;
    display: grid;
    place-items: center;
    font-size: 35px;
    font-weight: 700;
    flex-shrink: 0;
  }
  .feature-card__num::before {
    content: counter(feat);
  }

  .feature-card__text {
    display: flex;
    flex-direction: column;
    gap: 16px;
    min-width: 0;
  }

  .feature-card__title {
    font-size: clamp(42px, 2.3vw, 48px);
    font-weight: 700;
    line-height: 1.2;
    letter-spacing: -0.01em;
    color: var(--ege-dark-text, #ece9f5);
    margin: 0;
  }

  .feature-card__desc {
    color: var(--ege-dark-muted, #9a96b2);
    font-size: 24px;
    font-weight: 500;
    line-height: 1.65;
    margin: 0;
  }

  .feature-card__img {
    position: absolute;
    top: var(--feature-art-top);
    right: var(--feature-art-right);
    bottom: var(--feature-art-bottom);
    left: var(--feature-art-left);
    z-index: 0;
    width: var(--feature-art-width-current);
    height: var(--feature-art-height-current);
    transform: translate(var(--feature-art-translate-x), var(--feature-art-translate-y));
    background: radial-gradient(
      ellipse at center,
      rgba(73, 65, 106, 0.72) 0%,
      rgba(73, 65, 106, 0) 72%
    );
    border-radius: 999px;
    margin: 0;
    overflow: hidden;
    padding: 4px;
    pointer-events: none;
  }

  .feature-card__img img {
    width: 100%;
    height: 100%;
    object-fit: contain;
  }

  .feature-card--live {
    --feature-card-pad-right-current: 360px;
    --feature-art-width-current: 430px;
    --feature-art-height-current: 250px;
    --feature-art-right: -10px;
  }

  .feature-card--homework {
    --feature-card-pad-left-current: 350px;
    --feature-card-pad-right-current: 40px;
    --feature-art-width-current: 390px;
    --feature-art-height-current: 260px;
    --feature-art-left: -6px;
    --feature-art-right: auto;
  }

  .feature-card--mock {
    --feature-card-pad-right-current: 360px;
    --feature-art-width-current: 395px;
    --feature-art-height-current: 250px;
    --feature-art-right: 4px;
  }

  .feature-card--notes {
    --feature-card-pad-left-current: 360px;
    --feature-card-pad-right-current: 36px;
    --feature-art-width-current: 395px;
    --feature-art-height-current: 240px;
    --feature-art-left: -2px;
    --feature-art-right: auto;
  }

  .feature-card--support {
    --feature-card-pad-right-current: 380px;
    --feature-art-width-current: 360px;
    --feature-art-height-current: 215px;
    --feature-art-right: 12px;
    --feature-art-top: auto;
    --feature-art-bottom: -4px;
    --feature-art-translate-y: 0;
  }

  .feature-card--progress {
    --feature-card-pad-left-current: 372px;
    --feature-card-pad-right-current: 34px;
    --feature-art-width-current: 410px;
    --feature-art-height-current: 225px;
    --feature-art-left: -8px;
    --feature-art-right: auto;
    --feature-art-top: auto;
    --feature-art-bottom: -2px;
    --feature-art-translate-y: 0;
  }

  /* ---- Gift card ---- */
  .gift-card {
    background: var(--ege-dark-surface, #221d36);
    border-radius: 28px;
    padding: 36px 56px 36px 40px;
    display: grid;
    grid-template-columns: 280px minmax(0, 1fr);
    gap: 40px;
    align-items: center;
  }

  .gift-card__img {
    width: 100%;
    height: 220px;
    display: flex;
    align-items: center;
    justify-content: center;
    background: radial-gradient(
      ellipse at center,
      var(--ege-dark-surface-soft, #2b2541) 0%,
      transparent 70%
    );
    border-radius: 999px;
    margin: 0;
    overflow: hidden;
    padding: 16px;
  }

  .gift-card__img img {
    width: 100%;
    height: 100%;
    object-fit: contain;
  }

  .gift-card__body {
    display: flex;
    flex-direction: column;
    gap: 12px;
    min-width: 0;
    max-width: 640px;
  }

  .gift-card__title {
    font-size: 32px;
    font-weight: 800;
    letter-spacing: -0.01em;
    line-height: 1.15;
    margin: 0;
  }

  .gift-card__desc {
    color: var(--ege-dark-muted, #9a96b2);
    font-size: 16px;
    font-weight: 500;
    line-height: 1.55;
    margin: 0 0 12px;
  }

  .gift-card__cta {
    align-self: flex-start;
    background: var(--ege-dark-primary, #7a5cf0);
    color: #fff;
    font-size: 16px;
    font-weight: 600;
    padding: 16px 28px 16px 22px;
    border-radius: 14px;
    display: inline-flex;
    align-items: center;
    gap: 12px;
    border: none;
    cursor: pointer;
    font-family: inherit;
    transition:
      background 180ms ease,
      transform 180ms ease;
  }
  .gift-card__cta:hover {
    background: var(--ege-dark-primary-hover, #6a49e8);
  }
  .gift-card__cta:active {
    transform: translateY(1px);
  }
  .gift-card__cta svg {
    width: 20px;
    height: 20px;
    display: block;
  }

  /* ---- Responsive ---- */
  @media (max-width: 900px) {
    .features {
      --feature-art-width: 290px;
      --feature-art-height: 190px;
      --feature-art-offset: 8px;
      --feature-card-pad-left: 24px;
      --feature-card-pad-right: 250px;
      --feature-card-pad-y: 28px;
    }

    .features__inner {
      padding: 0;
    }

    .features__header {
      grid-template-columns: 1fr;
    }
    .features__hero {
      justify-self: start;
    }

    .feature-card {
      min-height: 220px;
    }

    .feature-card--live {
      --feature-card-pad-right-current: 260px;
      --feature-art-width-current: 310px;
      --feature-art-height-current: 200px;
      --feature-art-right: -16px;
    }

    .feature-card--homework {
      --feature-card-pad-left-current: 250px;
      --feature-card-pad-right-current: 24px;
      --feature-art-width-current: 300px;
      --feature-art-height-current: 206px;
      --feature-art-left: -18px;
      --feature-art-right: auto;
    }

    .feature-card--mock {
      --feature-card-pad-right-current: 252px;
      --feature-art-width-current: 300px;
      --feature-art-height-current: 198px;
      --feature-art-right: -10px;
    }

    .feature-card--notes {
      --feature-card-pad-left-current: 252px;
      --feature-card-pad-right-current: 24px;
      --feature-art-width-current: 300px;
      --feature-art-height-current: 190px;
      --feature-art-left: -10px;
      --feature-art-right: auto;
    }

    .feature-card--support {
      --feature-card-pad-right-current: 252px;
      --feature-art-width-current: 280px;
      --feature-art-height-current: 172px;
      --feature-art-right: 2px;
      --feature-art-bottom: -2px;
    }

    .feature-card--progress {
      --feature-card-pad-left-current: 256px;
      --feature-card-pad-right-current: 24px;
      --feature-art-width-current: 320px;
      --feature-art-height-current: 176px;
      --feature-art-left: -16px;
      --feature-art-right: auto;
      --feature-art-bottom: 0;
    }

    .gift-card {
      grid-template-columns: 1fr;
      padding: 32px;
    }
  }

  @media (max-width: 560px) {
    .features {
      --feature-art-width: min(300px, calc(100% - 20px));
      --feature-art-height: 168px;
    }

    .features__inner {
      padding: 0;
    }
    .feature-card {
      padding: 22px 22px 164px;
      min-height: 0;
    }
    .feature-card:nth-child(even) {
      padding: 22px 22px 164px;
    }
    .feature-card__content {
      max-width: none;
      column-gap: 14px;
    }
    .feature-card__img,
    .feature-card:nth-child(even) .feature-card__img {
      top: auto;
      right: 50%;
      bottom: var(--feature-art-mobile-bottom);
      left: auto;
      width: var(--feature-art-width-current);
      height: var(--feature-art-height-current);
      transform: translateX(50%);
    }
    .feature-card--live {
      --feature-art-width-current: min(310px, calc(100% - 8px));
      --feature-art-height-current: 176px;
    }
    .feature-card--homework {
      --feature-art-width-current: min(286px, calc(100% - 20px));
      --feature-art-height-current: 188px;
    }
    .feature-card--mock {
      --feature-art-width-current: min(290px, calc(100% - 16px));
      --feature-art-height-current: 178px;
    }
    .feature-card--notes {
      --feature-art-width-current: min(290px, calc(100% - 16px));
      --feature-art-height-current: 172px;
    }
    .feature-card--support {
      --feature-art-width-current: min(272px, calc(100% - 24px));
      --feature-art-height-current: 156px;
      --feature-art-mobile-bottom: -8px;
    }
    .feature-card--progress {
      --feature-art-width-current: min(300px, calc(100% - 12px));
      --feature-art-height-current: 168px;
    }
    .feature-card__num {
      width: 48px;
      height: 48px;
      font-size: 18px;
    }
    .feature-card__title {
      font-size: 20px;
    }
    .gift-card {
      padding: 24px;
    }
    .gift-card__title {
      font-size: 26px;
    }
  }
</style>
