---
import EgeLandingLayout from "../layouts/EgeLandingLayout.astro";
import EgeHero from "../components/ege/EgeHero.astro";
import EgeOutcomes from "../components/ege/EgeOutcomes.astro";
import EgePainPoints from "../components/ege/EgePainPoints.astro";
import EgeHowTo from "../components/ege/EgeHowTo.astro";
import EgeAuthor from "../components/ege/EgeAuthor.astro";
import EgeCompare from "../components/ege/EgeCompare.astro";
import EgeProgram from "../components/ege/EgeProgram.astro";
import EgeIncludes from "../components/ege/EgeIncludes.astro";
import EgeReviews from "../components/ege/EgeReviews.astro";
import EgePricing from "../components/ege/EgePricing.astro";
import EgeLeadForm from "../components/ege/EgeLeadForm.astro";
import EgeParents from "../components/ege/EgeParents.astro";
import EgeFaq from "../components/ege/EgeFaq.astro";
import EgeScripts from "../components/ege/EgeScripts.astro";
import StepikV2Universities from "../components/stepik-v2/StepikV2Universities.astro";
import { egeLandingData } from "../data/egeLanding";
import { realReviews } from "../data/realReviews";
import { egeNinthGradeReviews } from "../data/landingReviews";
import { buildEgeLandingSeoSchemas } from "../lib/egeLandingSeo";

const description =
  "Онлайн-подготовка к ЕГЭ по химии 2027 в минигруппе: живые уроки, проверка заданий 33–34, пробники и контроль прогресса.";
const image = "/images/new-design/ege.webp";
const { courseJsonLd, productJsonLd, faqJsonLd, webPageJsonLd } = buildEgeLandingSeoSchemas({
  origin: Astro.url.origin,
  pathname: Astro.url.pathname,
  data: egeLandingData,
  name: "Годовой курс подготовки к ЕГЭ по химии 2027",
  description,
  image,
  keywords: ["ЕГЭ по химии", "подготовка к ЕГЭ по химии", "курс ЕГЭ химия", "химия ЕГЭ 2027"],
});
---

<EgeLandingLayout
  title={egeLandingData.pageTitle}
  description={description}
  image={image}
  url="/ege-year/"
  courseJsonLd={courseJsonLd}
  productJsonLd={productJsonLd}
  faqJsonLd={faqJsonLd}
  webPageJsonLd={webPageJsonLd}
  imageAlt="Подготовка к ЕГЭ по химии в минигруппе ЕГЭХИМ"
  imageWidth={1000}
  imageHeight={563}
  nav={egeLandingData.nav}
  footer={egeLandingData.footer}
  floatingActions={egeLandingData.floatingActions}
  popupForm={egeLandingData.popupForm}
>
  <EgeHero {...egeLandingData.hero} />
  <EgeOutcomes {...egeLandingData.outcomes} />
  <EgePainPoints {...egeLandingData.painPoints} />
  <EgeHowTo {...egeLandingData.howTo} />
  <EgeAuthor />
  <EgeCompare />
  <EgeProgram {...egeLandingData.program} />
  <EgeIncludes {...egeLandingData.includes} />
  <EgeReviews cases={[...realReviews, ...egeNinthGradeReviews]} {...egeLandingData.cases} />
  <EgePricing {...egeLandingData.pricing} />
  <EgeLeadForm {...egeLandingData.leadForm} />
  <EgeParents {...egeLandingData.parents} />
  <StepikV2Universities data={egeLandingData.universities} />
  <EgeFaq {...egeLandingData.faq} supportCta={{ source: "ege-faq", campaign: "ege" }} />
  <EgeScripts slot="after-footer" data={{ ...egeLandingData.runtime, faq: egeLandingData.faq.items }} />
</EgeLandingLayout>
