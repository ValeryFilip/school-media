---
import EgeLandingLayout from "../layouts/EgeLandingLayout.astro";
import { egeLandingData } from "../data/egeLanding";

import ReferHero from "../components/refer-v2/ReferHero.astro";
import ReferMarquee from "../components/refer-v2/ReferMarquee.astro";
import ReferWhyUs from "../components/refer-v2/ReferWhyUs.astro";
import ReferProduct from "../components/refer-v2/ReferProduct.astro";
import ReferChannels from "../components/refer-v2/ReferChannels.astro";
import ReferRules from "../components/refer-v2/ReferRules.astro";
import ReferCalculator from "../components/refer-v2/ReferCalculator.astro";
import ReferHowItWorks from "../components/refer-v2/ReferHowItWorks.astro";
import ReferTestimonials from "../components/refer-v2/ReferTestimonials.astro";
import ReferJoinForm from "../components/refer-v2/ReferJoinForm.astro";
import ReferFinalCta from "../components/refer-v2/ReferFinalCta.astro";
import EgeReviews from "../components/ege/EgeReviews.astro";
import EgeFaq from "../components/ege/EgeFaq.astro";
import { realReviews } from "../data/realReviews";

import {
  referSeo,
  referNavLinks,
  referNavCta,
  referHeroMarquee,
  referTestimonialsMarquee,
  referFaqTitle,
  referFaqItems,
} from "../data/referLanding";

// ── Меню ──────────────────────────────────────────────────────
// сайт-ссылки берём общие из egeLanding (Главная / Курсы / Академия / …),
// ссылки по лендингу — под партнёрку.
const referNav = {
  ...egeLandingData.nav,
  meta: "/ партнёрская программа",
  landingLinks: referNavLinks,
  cta: referNavCta,
};

// ── JSON-LD ───────────────────────────────────────────────────
const webPageJsonLd = {
  "@context": "https://schema.org",
  "@type": "WebPage",
  name: referSeo.title,
  description: referSeo.description,
  url: referSeo.url,
  inLanguage: "ru-RU",
  isPartOf: {
    "@type": "WebSite",
    name: "ЕГЭХИМ",
    url: "https://egehim.ru/",
  },
};

const faqJsonLd = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  mainEntity: referFaqItems.map((it) => ({
    "@type": "Question",
    name: it.q,
    acceptedAnswer: {
      "@type": "Answer",
      text: it.a,
    },
  })),
};
---

<EgeLandingLayout
  title={referSeo.title}
  description={referSeo.description}
  url={referSeo.url}
  nav={referNav}
  footer={egeLandingData.footer}
  floatingActions={egeLandingData.floatingActions}
  popupForm={egeLandingData.popupForm}
  breadcrumbs={[
    { name: "Партнёрская программа", href: "/refer/" },
  ]}
  showBreadcrumbs={true}
  webPageJsonLd={webPageJsonLd}
  faqJsonLd={faqJsonLd}
>
  <ReferHero />
  <ReferMarquee items={referHeroMarquee} />
  <ReferWhyUs />
  <ReferProduct />
  <EgeReviews
    cases={realReviews}
    id="student-reviews"
    section="[04] / РЕЗУЛЬТАТЫ УЧЕНИКОВ"
    title="Продукт, который"
    mutedTitle="не стыдно рекомендовать."
    hint="← / → · реальные результаты учеников ЕГЭХИМ"
    allReviewsHref="/otzyvy-na-kursi/"
    allReviewsText="Смотреть все отзывы"
    animateTitle={false}
  />
  <ReferChannels />
  <ReferRules />
  <ReferCalculator />
  <ReferHowItWorks />
  <ReferTestimonials />
  <ReferMarquee
    items={referTestimonialsMarquee}
    rootClass="border-t border-ink py-4 overflow-hidden"
    textClass="text-paper"
  />
  <ReferJoinForm />
  <EgeFaq
    section="[10] / FAQ"
    title={referFaqTitle}
    items={referFaqItems}
    animateTitle={false}
    supportCta={{
      source: "partner-faq",
      campaign: "partner",
      lead: "Ответим по условиям программы, фиксации рекомендаций, начислениям и выплатам.",
    }}
  />
  <ReferFinalCta />

  <script>
    /* Titrate reveal + счётчики — глобально для страницы. */
    const io = new IntersectionObserver(
      (es) => {
        es.forEach((e) => {
          if (e.isIntersecting) e.target.classList.add("in");
        });
      },
      { threshold: 0.15 },
    );
    document.querySelectorAll(".titrate").forEach((el) => io.observe(el));

    (function () {
      const ease = (t: number) => 1 - Math.pow(1 - t, 3);
      const setFinal = (el: HTMLElement) => {
        const target = parseInt(el.dataset.counter || "0", 10);
        const suffix = el.dataset.suffix || "";
        el.textContent = target.toLocaleString("ru-RU") + suffix;
      };
      // Render final value immediately so numbers are never stuck at 0
      document
        .querySelectorAll<HTMLElement>("[data-counter]")
        .forEach(setFinal);

      const obs = new IntersectionObserver(
        (es) => {
          es.forEach((en) => {
            if (!en.isIntersecting) return;
            const el = en.target as HTMLElement;
            const target = parseInt(el.dataset.counter || "0", 10);
            const suffix = el.dataset.suffix || "";
            const dur = 1400;
            const start = performance.now();
            const step = (t: number) => {
              const p = Math.min(1, (t - start) / dur);
              const v = Math.round(target * ease(p));
              el.textContent = v.toLocaleString("ru-RU") + suffix;
              if (p < 1) requestAnimationFrame(step);
            };
            requestAnimationFrame(step);
            obs.unobserve(el);
          });
        },
        { threshold: 0.4 },
      );
      document
        .querySelectorAll("[data-counter]")
        .forEach((el) => obs.observe(el));
    })();
  </script>
</EgeLandingLayout>
