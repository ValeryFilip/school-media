---
import "../styles/new-global.css";

import MainLayout from "../layouts/MainLayout.astro";
import ReferHero from "../components/partners/ReferHero.astro";
import ReferStats from "../components/partners/ReferStats.astro";
import ReferBenefits from "../components/partners/ReferBenefits.astro";
import ReferTrust from "../components/partners/ReferTrust.astro";
import ReferTrustTabs from "../components/partners/ReferTrustTabs.astro";
import ReferStepikReviews from "../components/partners/ReferStepikReviews.astro";
import ReferHowItWorks from "../components/partners/ReferHowItWorks.astro";
import ReferPlacement from "../components/partners/ReferPlacement.astro";
import ReferRules from "../components/partners/ReferRules.astro";
import ReferCalculator from "../components/partners/ReferCalculator.astro";
import ReferFaq from "../components/partners/ReferFaq.astro";
import ReferFormApply from "../components/partners/ReferFormApply.astro";
import ReferTelegramChecker from "../components/partners/ReferTelegramChecker.astro";

const seo = {
  title: "Партнёрская программа ЕГЭХИМ - помогай друзьям и зарабатывай",
  description:
    "Присоединяйся к партнёрской программе нашей школы химии. Делись материалами и получай 15% комиссии с каждой регистрации.",
};
---

<MainLayout
  title={seo.title}
  description={seo.description}
  showBreadcrumbs={false}
>
  <ReferHero />
  <ReferStats />
  <ReferBenefits />
  <div class="section-separator">
    <ReferTrust />
    <ReferTrustTabs />
    <ReferStepikReviews />
  </div>
  <ReferHowItWorks />
  <ReferPlacement />

  <div class="section-separator">
    <ReferRules />
  </div>
  <ReferCalculator />
  <div class="section-separator">
    <ReferFormApply />
    <ReferTelegramChecker />
  </div>
  <ReferFaq />
</MainLayout>

<style>
  .section-separator {
    display: grid;
    grid-template-columns: 1fr;
    gap: 100px;
    padding: var(--space-40) 20px;
    background:
      radial-gradient(
        circle at 14% 18%,
        color-mix(in srgb, var(--color-brand) 12%, transparent) 0%,
        transparent 16%
      ),
      radial-gradient(
        circle at 97% 24%,
        color-mix(in srgb, var(--color-accent) 40%, transparent) 0%,
        transparent 18%
      ),
      radial-gradient(
        circle at 54% 100%,
        color-mix(in srgb, var(--color-success) 30%, transparent) 0%,
        transparent 24%
      ),
      var(--color-bg-invert);
    border-radius: 48px;
  }

  .section-separator :global(.h2zag-title) {
    color: var(--color-brand);
  }

  .section-separator :global(.h2zag-subtitle) {
    color: color-mix(in srgb, var(--color-text-inverse) 86%, transparent);
  }

  @media (max-width: 900px) {
    .section-separator {
      padding: var(--space-32) 18px;
      border-radius: 36px;
      background:
        radial-gradient(
          circle at 12% 14%,
          color-mix(in srgb, var(--color-brand) 18%, transparent) 0%,
          transparent 24%
        ),
        radial-gradient(
          circle at 90% 28%,
          color-mix(in srgb, var(--color-accent) 14%, transparent) 0%,
          transparent 24%
        ),
        radial-gradient(
          circle at 50% 100%,
          color-mix(in srgb, var(--color-success) 10%, transparent) 0%,
          transparent 28%
        ),
        linear-gradient(
          180deg,
          color-mix(in srgb, var(--gray-800) 88%, var(--color-brand)) 0%,
          var(--gray-800) 100%
        );
    }
  }

  @media (max-width: 600px) {
    .section-separator {
      gap: var(--space-40);
      padding: var(--space-24) 14px;
      border-radius: 28px;
      background:
        radial-gradient(
          circle at 14% 12%,
          color-mix(in srgb, var(--color-brand) 25%, transparent) 0%,
          transparent 20%
        ),
        radial-gradient(
          circle at 88% 34%,
          color-mix(in srgb, var(--color-accent) 22%, transparent) 0%,
          transparent 22%
        ),
        radial-gradient(
          circle at 46% 100%,
          color-mix(in srgb, var(--color-success) 48%, transparent) 0%,
          transparent 24%
        ),
        var(--gray-900);
    }
  }
</style>
