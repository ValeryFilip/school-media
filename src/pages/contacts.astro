---
import AcademyLayout from "../layouts/AcademyLayout.astro";
import AcademyBreadcrumbs from "../components/academy/AcademyBreadcrumbs.astro";
import AcademyFaq from "../components/academy/AcademyFaq.astro";
import EgeH2 from "../components/ege/EgeH2.astro";
import { buildFAQJsonLd } from "../lib/seoData";

const seo = {
  title: "Контакты — ЕГЭХИМ. Написать Валерию Филипенко",
  description:
    "Контакты школы ЕГЭХИМ: Telegram, WhatsApp, ВКонтакте, YouTube. Напишите нам по любому вопросу о подготовке к ЕГЭ и ОГЭ по химии.",
};

const MESSENGERS = [
  {
    href: "https://t.me/valery_chemistry",
    icon: "/images/technical/telegram.webp",
    name: "Telegram",
    handle: "@valery_chemistry",
    desc: "Самый быстрый способ связаться. Ответим на вопросы о форматах, расписании и курсах.",
    cta: "Написать в Telegram",
  },
  {
    href: "https://wa.me/79818364992?text=%D0%9F%D1%80%D0%B8%D0%B2%D0%B5%D1%82!%20",
    icon: "/images/technical/whatsapp.webp",
    name: "Зеленый мессенджер*",
    handle: "+7 981 836-49-92",
    desc: "Подходит, если удобнее общаться по номеру телефона. Отвечаем в рабочее время.",
    cta: "Написать",
  },
  {
    href: "https://vk.me/valeryfilip",
    icon: "/images/technical/vk.webp",
    name: "ВКонтакте",
    handle: "@valeryfilip",
    desc: "Напишите в личные сообщения ВКонтакте — удобно, если вы уже используете VK.",
    cta: "Написать в VK",
  },
];

const SOCIALS = [
  {
    href: "https://www.youtube.com/@chemistry_exam",
    icon: "/images/technical/youtube.webp",
    name: "YouTube",
    handle: "@chemistry_exam",
    desc: "Бесплатные видео-уроки по химии для ЕГЭ: теория, разборы задач и советы по подготовке.",
    cta: "Перейти на канал",
  },
  {
    href: "https://vk.com/chemistry_exam",
    icon: "/images/technical/vk.webp",
    name: "Сообщество VK",
    handle: "chemistry_exam",
    desc: "Новости, задачи, анонсы занятий и обновления курсов. Подпишитесь, чтобы ничего не пропустить.",
    cta: "Подписаться",
  },
  {
    href: "https://t.me/+KznfEhtzkeNlZjIy",
    icon: "/images/technical/telegram.webp",
    name: "Telegram-канал",
    handle: "ЕГЭХИМ",
    desc: "Анонсы занятий, полезные материалы и обновления по курсам прямо в Telegram.",
    cta: "Вступить в канал",
  },
];

const OTHER_CONTACTS = [
  {
    href: "mailto:info@egehim.ru",
    icon: "/images/technical/mail.webp",
    label: "Электронная почта",
    value: "info@egehim.ru",
  },
  {
    href: "https://t.me/chemistry_examBot",
    icon: "/images/technical/telegram.webp",
    label: "Telegram-бот",
    value: "@chemistry_examBot — бесплатные курсы",
    external: true,
  },
];

const FAQ = [
  {
    q: "Как быстрее связаться со школой?",
    a: "Лучше всего написать в Telegram или оставить заявку на сайте.",
  },
  {
    q: "Можно ли записаться на индивидуальные занятия по химии?",
    a: "Да, если есть свободные места. Формат и расписание обсуждаются отдельно.",
  },
  {
    q: "Есть ли мини-группы по химии для ЕГЭ?",
    a: "Да, набор в мини-группы открывается по расписанию. Количество мест ограничено.",
  },
  {
    q: "Можно ли заниматься самостоятельно?",
    a: "Да, для этого есть курсы ЕГЭХИМ на Stepik по отдельным разделам химии.",
  },
  {
    q: "Вы работаете онлайн?",
    a: "Да, подготовка проходит онлайн, поэтому заниматься можно из разных городов.",
  },
];

const FORM_FIELDS = [
  {
    label: "ФИО",
    name: "name",
    type: "text",
    placeholder: "Ваше имя и фамилия",
    autocomplete: "name",
    required: true,
  },
  {
    label: "Телефон",
    name: "phone",
    type: "tel",
    placeholder: "+7 (___) ___-__-__",
    autocomplete: "tel",
    required: false,
  },
  {
    label: "Телеграм",
    name: "telegram",
    type: "text",
    placeholder: "@username",
    autocomplete: "off",
    required: false,
  },
];

const CONSENTS = [
  {
    html:
      'Согласен с <a href="/docs/privacy/" target="_blank" rel="noopener">политикой конфиденциальности</a>',
    fieldName: "consent_privacy",
  },
  {
    html:
      'Согласен на <a href="/docs/agreement/" target="_blank" rel="noopener">обработку персональных данных</a>',
    fieldName: "consent_personal_data",
  },
  {
    html:
      'Согласен на <a href="/docs/marketing-consent/" target="_blank" rel="noopener">рекламную рассылку</a>',
    fieldName: "consent_marketing",
  },
];

const STEPS = [
  "Познакомим с онлайн-школой",
  "Расскажем, как проходят занятия",
  "Запишем на бесплатный урок",
];

const pageUrl = `${Astro.url.origin}/contacts/`;

const contactJsonLd = {
  "@context": "https://schema.org",
  "@type": "ContactPage",
  name: seo.title,
  description: seo.description,
  url: pageUrl,
  mainEntity: {
    "@type": "Organization",
    name: "ЕГЭХИМ",
    email: "info@egehim.ru",
    sameAs: SOCIALS.map((item) => item.href),
    contactPoint: [
      {
        "@type": "ContactPoint",
        contactType: "customer support",
        telephone: "+79818364992",
        availableLanguage: "ru",
      },
    ],
  },
};

const faqJsonLd = buildFAQJsonLd(FAQ);
---

<AcademyLayout
  title={seo.title}
  description={seo.description}
  image="/images/new-design/contacts.webp"
  imageAlt="Контакты школы ЕГЭХИМ"
  url={pageUrl}
  addSiteSuffix={false}
  breadcrumbs={[
    { name: "Контакты" },
  ]}
  showBreadcrumbs={true}
  breadcrumbRoot="/"
  jsonLd={[contactJsonLd, faqJsonLd]}
>
  <div class="contacts-v2">
    <section class="contacts-hero" aria-labelledby="contacts-title">
      <div class="gutter contacts-hero__inner">
        <AcademyBreadcrumbs
          class="mb-10"
          items={[
            { label: "ЕГЭХИМ", href: "/" },
            { label: "Контакты" },
          ]}
        />

        <div class="contacts-hero__grid">
          <div>
            <div class="sec-num mb-4">[01] / контакты</div>
            <h1 id="contacts-title" class="contacts-hero__title">
              Написать Валерию Филипенко и связаться со школой ЕГЭХИМ
            </h1>
          </div>
          <div class="contacts-hero__copy">
            <p class="contacts-hero__seo">
              Связаться со школой ЕГЭХИМ можно по почте, в Telegram или через форму
              на сайте. Отвечаем на вопросы по подготовке к ЕГЭ по химии,
              мини-группам, индивидуальным занятиям и самостоятельным курсам.
            </p>
            <div class="contacts-hero__meta">
              <span>онлайн-школа химии</span>
              <span>ЕГЭ В· ОГЭ В· курсы</span>
              <span>ответим в рабочее время</span>
            </div>
          </div>
        </div>
      </div>
    </section>

    <section class="contacts-section" aria-labelledby="direct-title">
      <div class="gutter">
        <EgeH2
          variant="academy"
          secNum="[02] / напрямую"
          text="Написать напрямую"
          id="direct-title"
          description="По вопросам записи на мини-группы, индивидуальные занятия и курсы по химии пишите в Telegram или на электронную почту. Если вы уже проходите курс, укажите имя ученика и формат обучения."
        />

        <div class="contacts-grid">
          {MESSENGERS.map((item) => (
            <a class="contact-card" href={item.href} target="_blank" rel="noopener noreferrer">
              <span class="contact-card__icon">
                <img src={item.icon} alt="" width="40" height="40" loading="lazy" decoding="async" />
              </span>
              <span class="contact-card__name">{item.name}</span>
              <span class="contact-card__handle">{item.handle}</span>
              <span class="contact-card__desc">{item.desc}</span>
              <span class="contact-card__cta">{item.cta}</span>
            </a>
          ))}
        </div>
      </div>
    </section>

    <section class="contacts-section contacts-section--alt" aria-labelledby="social-title">
      <div class="gutter">
        <EgeH2
          variant="academy"
          secNum="[03] / соцсети"
          text="Соцсети и каналы"
          id="social-title"
          description="Полезные материалы, разборы задач и новости курсов."
        />

        <div class="contacts-grid">
          {SOCIALS.map((item) => (
            <a class="contact-card contact-card--light" href={item.href} target="_blank" rel="noopener noreferrer">
              <span class="contact-card__icon">
                <img src={item.icon} alt="" width="40" height="40" loading="lazy" decoding="async" />
              </span>
              <span class="contact-card__name">{item.name}</span>
              <span class="contact-card__handle">{item.handle}</span>
              <span class="contact-card__desc">{item.desc}</span>
              <span class="contact-card__cta">{item.cta}</span>
            </a>
          ))}
        </div>
      </div>
    </section>

    <section class="contacts-section" aria-labelledby="lead-title">
      <div class="gutter">
        <div class="contacts-lead">
          <div class="contacts-lead__intro">
            <EgeH2
              variant="academy"
              secNum="[04] / заявка"
              text="Начни подготовку с пробного бесплатного занятия"
              id="lead-title"
              description="Поможем с выбором формата подготовки и ответим на вопросы о курсах, расписании и стоимости занятий по химии."
              layout="stack"
            />
            <ol class="contacts-steps">
              {STEPS.map((step, index) => (
                <li>
                  <span>{String(index + 1).padStart(2, "0")}</span>
                  {step}
                </li>
              ))}
            </ol>
          </div>

          <form
            class="contacts-form"
            action="/api/lead.php"
            method="post"
            aria-label="Заявка на пробное бесплатное занятие"
            data-form
            data-endpoint="/api/lead.php"
            data-form-type="lead"
            data-form-id="contacts-lead"
            data-success-message="Заявка отправлена!"
            data-success-redirect="/thank-you"
            data-success-delay="1500"
            data-required-any="phone,telegram"
            data-required-all="name"
            novalidate
          >
            {FORM_FIELDS.map((field, index) => (
              <label class="contacts-field">
                <span><b>[{String(index + 1).padStart(2, "0")}]</b> {field.label}</span>
                <input
                  type={field.type as any}
                  name={field.name}
                  placeholder={field.placeholder}
                  autocomplete={field.autocomplete}
                  required={field.required}
                />
              </label>
            ))}

            <div class="contacts-consents">
              {CONSENTS.map((item) => (
                <label>
                  <input type="checkbox" name={item.fieldName} value="true" required />
                  <span set:html={item.html} />
                </label>
              ))}
            </div>

            <button type="submit" class="contacts-submit">Отправить заявку</button>
            <div class="contacts-status" data-form-status hidden></div>
            <pre class="contacts-debug" data-form-debug hidden></pre>

            <div class="contacts-form__messengers">
              <span>Можно написать сразу:</span>
              {MESSENGERS.map((item) => (
                <a href={item.href} target="_blank" rel="noopener noreferrer" aria-label={item.name}>
                  <img src={item.icon} alt="" width="22" height="22" loading="lazy" decoding="async" />
                </a>
              ))}
            </div>
          </form>
        </div>
      </div>
    </section>

    <AcademyFaq
      secNum="[05] / вопросы"
      title="Частые вопросы"
      description="Ответы на популярные вопросы о школе и форматах занятий."
      items={FAQ}
      alignList={true}
    />

    <section class="contacts-section" aria-labelledby="other-title">
      <div class="gutter">
        <EgeH2
          variant="academy"
          secNum="[06] / еще"
          text="Почта и бот"
          id="other-title"
        />

        <div class="contacts-other">
          {OTHER_CONTACTS.map((item) => (
            <a href={item.href} target={item.external ? "_blank" : undefined} rel={item.external ? "noopener noreferrer" : undefined}>
              <span>
                <img src={item.icon} alt="" width="24" height="24" loading="lazy" decoding="async" />
              </span>
              <b>{item.label}</b>
              <em>{item.value}</em>
            </a>
          ))}
        </div>
      </div>
    </section>

    <section class="contacts-seo">
      <div class="gutter">
        <h2>Контакты репетитора по химии и школы ЕГЭХИМ</h2>
        <p>
          ЕГЭХИМ — онлайн-школа подготовки к ЕГЭ и ОГЭ по химии под руководством
          Валерия Филипенко. На этой странице собраны контакты для связи:
          Telegram, WhatsApp, ВКонтакте, электронная почта и форма заявки на сайте.
          Если вы ищете репетитора по химии, хотите записаться на индивидуальные занятия
          или узнать о наборе в мини-группы, напишите в удобный мессенджер.
        </p>
        <p>
          Для самостоятельной подготовки доступны курсы ЕГЭХИМ на Stepik по отдельным
          разделам химии. Также можно подписаться на YouTube-канал, Telegram-канал
          или сообщество VK: там выходят бесплатные материалы, разборы заданий,
          теория и советы по подготовке к экзаменам.
        </p>
        <p class="contacts-note">
          * WhatsApp принадлежит компании Meta, признанной экстремистской организацией
          и запрещённой на территории РФ.
        </p>
      </div>
    </section>
  </div>
</AcademyLayout>

<style>
  .contacts-v2 {
    background: var(--paper);
  }

  .contacts-hero {
    position: relative;
    overflow: hidden;
    border-bottom: 1px solid var(--line);
  }

  .contacts-hero::before {
    content: "";
    position: absolute;
    inset: 0;
    background-image:
      linear-gradient(var(--line) 1px, transparent 1px),
      linear-gradient(90deg, var(--line) 1px, transparent 1px);
    background-size: 56px 56px;
    opacity: 0.38;
    pointer-events: none;
  }

  .contacts-hero__inner {
    position: relative;
    padding-top: var(--academy-hero-y-start);
    padding-bottom: var(--academy-hero-y-end);
  }

  .contacts-hero__grid {
    display: grid;
    grid-template-columns: minmax(0, 1.45fr) minmax(320px, 0.55fr);
    gap: var(--academy-gap-lg);
    align-items: end;
  }

  .contacts-hero__title {
    margin: 0;
    font-family: var(--academy-font-display);
    font-size: var(--academy-hero-title);
    font-weight: 700;
    line-height: 0.9;
    letter-spacing: -0.035em;
    color: var(--ink);
  }

  .contacts-hero__copy {
    display: grid;
    gap: 24px;
  }

  .contacts-hero__seo {
    margin: 0;
    font-family: var(--academy-font-mono);
    font-size: var(--academy-body-sm);
    line-height: 1.65;
    color: var(--inkSoft);
  }

  .contacts-hero__meta {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 1px;
    border: 1px solid var(--line);
    background: var(--line);
  }

  .contacts-hero__meta span {
    min-height: var(--academy-meta-cell-min-h);
    display: flex;
    align-items: center;
    padding: 14px;
    background: #fffdf7;
    font-family: var(--academy-font-mono);
    font-size: var(--academy-micro);
    line-height: 1.35;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--dim);
  }

  .contacts-section {
    border-top: 1px solid var(--line);
    padding: var(--academy-section-y) 0;
  }

  .contacts-section--alt {
    background: var(--milk);
  }

  .contacts-lead h2,
  .contacts-seo h2 {
    margin: 0 0 14px;
    font-family: var(--academy-font-display);
    font-size: var(--academy-section-title);
    font-weight: 700;
    line-height: 0.95;
    letter-spacing: -0.025em;
    color: var(--ink);
  }

  .contacts-lead__intro p {
    margin: 0;
    max-width: var(--academy-lead-max);
    font-family: var(--academy-font-body);
    font-size: var(--academy-lead);
    line-height: 1.55;
    color: var(--inkSoft);
  }

  .contacts-grid {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 1px;
    border: 1px solid var(--line);
    background: var(--line);
  }

  .contact-card {
    min-height: var(--academy-card-min-h);
    display: grid;
    align-content: start;
    gap: 12px;
    padding: var(--academy-card-pad);
    background: #fffdf7;
    color: var(--ink);
    text-decoration: none;
    transition:
      background 150ms ease,
      color 150ms ease;
  }

  .contact-card:hover {
    background: var(--ink);
    color: var(--paper);
  }

  .contact-card--light {
    background: var(--paper);
  }

  .contact-card__icon {
    width: var(--academy-icon-lg);
    height: var(--academy-icon-lg);
    display: grid;
    place-items: center;
    border: 1px solid var(--line);
    background: var(--milk);
    margin-bottom: 8px;
  }

  .contact-card:hover .contact-card__icon {
    background: var(--paper);
  }

  .contact-card__icon img {
    width: var(--academy-icon-sm);
    height: var(--academy-icon-sm);
    object-fit: contain;
  }

  .contact-card__name {
    font-family: var(--academy-font-display);
    font-size: var(--academy-card-title);
    font-weight: 700;
    line-height: 1;
    letter-spacing: -0.02em;
  }

  .contact-card__handle,
  .contact-card__cta {
    font-family: var(--academy-font-mono);
    font-size: var(--academy-meta);
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--rust);
  }

  .contact-card:hover .contact-card__handle,
  .contact-card:hover .contact-card__cta {
    color: var(--paper);
  }

  .contact-card__desc {
    margin-top: 12px;
    font-family: var(--academy-font-mono);
    font-size: var(--academy-body-sm);
    line-height: 1.55;
    color: var(--inkSoft);
  }

  .contact-card:hover .contact-card__desc {
    color: color-mix(in srgb, var(--paper) 76%, transparent);
  }

  .contact-card__cta {
    align-self: end;
    margin-top: 24px;
  }

  .contacts-lead {
    display: grid;
    grid-template-columns: minmax(0, 0.85fr) minmax(360px, 0.65fr);
    gap: 1px;
    border: 1px solid var(--line);
    background: var(--line);
  }

  .contacts-lead__intro,
  .contacts-form {
    padding: var(--academy-panel-pad);
    background: #fffdf7;
  }

  .contacts-steps {
    display: grid;
    gap: 1px;
    margin: 34px 0 0;
    padding: 0;
    list-style: none;
    border: 1px solid var(--line);
    background: var(--line);
  }

  .contacts-steps li {
    display: flex;
    gap: 14px;
    align-items: center;
    min-height: var(--academy-row-min-h);
    padding: 14px 16px;
    background: var(--paper);
    font-family: var(--academy-font-mono);
    font-size: var(--academy-body-sm);
    color: var(--inkSoft);
  }

  .contacts-steps span {
    color: var(--rust);
  }

  .contacts-form {
    display: grid;
    gap: 14px;
  }

  .contacts-field {
    display: grid;
    gap: 7px;
  }

  .contacts-field span,
  .contacts-consents,
  .contacts-status,
  .contacts-form__messengers {
    font-family: var(--academy-font-mono);
  }

  .contacts-field span {
    font-size: var(--academy-meta);
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--ink);
  }

  .contacts-field b {
    color: var(--rust);
    font-weight: 700;
  }

  .contacts-field input {
    width: 100%;
    border: 1px solid var(--line);
    background: var(--paper);
    color: var(--ink);
    padding: 16px 18px;
    font-family: var(--academy-font-mono);
    font-size: var(--academy-control);
    line-height: 1.5;
  }

  .contacts-field input:hover {
    background: var(--milk);
  }

  .contacts-field input:focus {
    outline: none;
    border-color: var(--rust);
