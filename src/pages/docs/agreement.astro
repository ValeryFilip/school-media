---
// src/pages/docs/agreement.astro

import MainLayout from "../../layouts/MainLayout.astro";
import config from "../../config.ts";
import {
  buildWebPageJsonLd,
  getSiteName,
  pageUrlFromPath,
} from "../../lib/seoData";

const title = "Согласие на обработку персональных данных";
const description =
  "Условия и сроки согласия на обработку персональных данных на egehim.ru.";

const breadcrumbs = [{ name: title }];

// Генерация JSON-LD (origin — из Astro.site)
const origin = (Astro.site?.href ?? config.siteUrl).replace(/\/$/, "");
const pageUrl = pageUrlFromPath(origin, Astro.url.pathname);
const siteName = getSiteName(undefined, config.siteName);
const siteUrl = origin;
const webPageJsonLd = buildWebPageJsonLd({
  origin,
  url: pageUrl,
  name: title,
  siteName,
  about: "Согласие на обработку персональных данных",
});
---

<MainLayout
  title={title}
  description={description}
  seoType="website"
  index={false}
  breadcrumbs={breadcrumbs}
  showBreadcrumbs={true}
  webPageJsonLd={webPageJsonLd}
>
  <main class="policy" aria-labelledby="consent-title">
    <div class="container">
      <h1 id="consent-title">{title}</h1>

      <dl class="policy__meta">
        <div>
          <dt>Дата публикации</dt>
          <dd>30 апреля 2026 года</dd>
        </div>
        <div>
          <dt>Адрес сайта</dt>
          <dd><a href="https://egehim.ru">https://egehim.ru</a></dd>
        </div>
      </dl>

      <section class="policy__section">
        <p>
          Настоящим я, заполняя форму на сайте
          <a href="https://egehim.ru">https://egehim.ru</a>, обращаясь к
          Оператору через email, мессенджеры, социальные сети или иные каналы
          связи, даю согласие Филипенко Валерию Юрьевичу, плательщику налога на
          профессиональный доход, владельцу сайта
          <a href="https://egehim.ru">https://egehim.ru</a>, далее — «Оператор»,
          на обработку моих персональных данных.
        </p>
        <p>Согласие даётся свободно, своей волей и в своём интересе.</p>
      </section>

      <section class="policy__section">
        <h2>1. Какие данные могут обрабатываться</h2>
        <p>
          Я даю согласие на обработку следующих персональных данных, если я
          предоставляю их Оператору:
        </p>
        <ul>
          <li>имя;</li>
          <li>номер телефона;</li>
          <li>адрес электронной почты;</li>
          <li>
            никнейм, ссылка на профиль или идентификатор в Telegram, VK,
            WhatsApp или другом канале связи;
          </li>
          <li>
            сведения о выбранном курсе, формате обучения или интересующем
            направлении подготовки;
          </li>
          <li>
            класс обучения, цель подготовки, комментарий или иной текст
            сообщения, который я сам направляю Оператору;
          </li>
          <li>
            технические данные, связанные с отправкой формы: IP-адрес, дата и
            время отправки, сведения о браузере и устройстве.
          </li>
        </ul>
        <p>
          Оператор не требует предоставления избыточных данных. Если я
          самостоятельно направляю Оператору дополнительные сведения, они
          обрабатываются только в объёме, необходимом для ответа на моё
          обращение или исполнения договорённостей.
        </p>
      </section>

      <section class="policy__section">
        <h2>2. Цели обработки данных</h2>
        <p>Согласие даётся для следующих целей:</p>
        <ul>
          <li>обработка моей заявки или обращения;</li>
          <li>связь со мной по указанным контактам;</li>
          <li>консультирование по курсам, форматам обучения, стоимости и условиям участия;</li>
          <li>заключение и исполнение договора, если применимо;</li>
          <li>предоставление доступа к образовательным материалам, курсам, консультациям или сопровождению;</li>
          <li>техническая поддержка и обработка вопросов, связанных с обучением;</li>
          <li>исполнение требований законодательства Российской Федерации;</li>
          <li>фиксация факта получения согласия и защиты прав Оператора.</li>
        </ul>
        <p>
          Настоящее согласие не означает согласие на получение рекламных
          рассылок. Рекламные и информационные сообщения направляются только при
          наличии отдельного согласия.
        </p>
      </section>

      <section class="policy__section">
        <h2>3. Какие действия могут совершаться с данными</h2>
        <p>
          Я даю согласие на совершение Оператором следующих действий с моими
          персональными данными:
        </p>
        <ul>
          <li>сбор;</li>
          <li>запись;</li>
          <li>систематизация;</li>
          <li>накопление;</li>
          <li>хранение;</li>
          <li>уточнение;</li>
          <li>использование;</li>
          <li>передача третьим лицам в случаях, необходимых для достижения целей обработки;</li>
          <li>обезличивание;</li>
          <li>блокирование;</li>
          <li>удаление;</li>
          <li>уничтожение.</li>
        </ul>
        <p>
          Оператор не осуществляет распространение моих персональных данных
          среди неопределённого круга лиц без отдельного согласия.
        </p>
      </section>

      <section class="policy__section">
        <h2>4. Передача данных третьим лицам</h2>
        <p>
          Оператор может передавать мои персональные данные третьим лицам только
          в объёме, необходимом для целей обработки, в том числе:
        </p>
        <ul>
          <li>хостинг-провайдеру и техническим подрядчикам — для обеспечения работы сайта;</li>
          <li>сервисам аналитики — для анализа работы сайта;</li>
          <li>
            сервисам связи, мессенджерам и социальным сетям — если я сам выбрал
            соответствующий способ связи;
          </li>
          <li>
            образовательной платформе Stepik — если я перехожу на Stepik для
            покупки или прохождения курса;
          </li>
          <li>государственным органам — в случаях, предусмотренных законодательством Российской Федерации.</li>
        </ul>
      </section>

      <section class="policy__section">
        <h2>5. Срок действия согласия</h2>
        <p>
          Согласие действует до достижения целей обработки персональных данных
          или до момента его отзыва, если иное не предусмотрено
          законодательством Российской Федерации.
        </p>
        <p>
          Данные, связанные с исполнением договора, оплатой, налоговым или
          бухгалтерским учётом, могут храниться в течение сроков, установленных
          законодательством Российской Федерации.
        </p>
      </section>

      <section class="policy__section">
        <h2>6. Отзыв согласия</h2>
        <p>
          Я могу отозвать согласие на обработку персональных данных, направив
          обращение на email:
          <a href={`mailto:${config.contactEmail}`}>{config.contactEmail}</a>.
        </p>
        <p>
          После получения отзыва Оператор прекращает обработку персональных
          данных и удаляет или обезличивает их, если дальнейшая обработка не
          требуется по закону.
        </p>
      </section>

      <section class="policy__section">
        <h2>7. Способ выражения согласия</h2>
        <p>
          Согласие выражается путём проставления отдельной отметки в форме на
          сайте <a href="https://egehim.ru">https://egehim.ru</a> или иным
          активным действием, позволяющим подтвердить факт получения согласия.
        </p>
      </section>

      <section class="policy__section">
        <h2>8. Связанные документы</h2>
        <ul>
          <li><a href="/docs/privacy/">Политика обработки персональных данных</a></li>
          <li><a href="/docs/cookies/">Политика использования cookie-файлов и систем аналитики</a></li>
          <li><a href="/docs/marketing-consent/">Согласие на рекламные и информационные сообщения</a></li>
          <li><a href="/docs/payment/">Оплата, безопасность платежей и возвраты</a></li>
        </ul>
      </section>
    </div>
  </main>

  <style>
    .policy {
      color: var(--black);
      padding: var(--space-32, 32px) 0;
    }
    .policy .container {
      max-width: var(--container, 900px);
      padding: 0 var(--pad-desktop, 50px);
      margin: 0 auto;
      box-sizing: border-box;
    }

    .policy h1 {
      font-size: var(--h1, 32px);
      line-height: 1.2;
      margin: 0 0 var(--space-16, 16px);
      font-weight: 700;
    }
    .policy h2 {
      font-size: var(--h2, 24px);
      line-height: 1.25;
      margin: 28px 0 12px;
      font-weight: 700;
    }
    .policy p,
    .policy li {
      font-size: 20px;
      line-height: 1.7;
      margin: 0 0 12px;
    }
    .policy ul {
      padding-left: 20px;
    }
    .policy__section + .policy__section {
      margin-top: 16px;
    }

    .policy a {
      color: var(--blue, #0d6efd);
      text-decoration: none;
    }
    .policy a:hover {
      text-decoration: underline;
    }
    .policy__meta {
      display: grid;
      gap: 10px;
      margin: 0 0 24px;
      padding: 16px;
      border: 1px solid var(--border, #e5e7eb);
      border-radius: 14px;
      background: #f8fafc;
    }
    .policy__meta div {
      display: grid;
      grid-template-columns: minmax(150px, 0.32fr) 1fr;
      gap: 12px;
    }
    .policy__meta dt,
    .policy__meta dd {
      margin: 0;
      font-size: 16px;
      line-height: 1.45;
    }
    .policy__meta dt {
      color: var(--muted, #6b7280);
      font-weight: 700;
    }

    @media (max-width: 600px) {
      .policy .container {
        padding: 0 var(--pad-mobile, 20px);
      }
      .policy p,
      .policy li {
        font-size: 16px;
      }
      .policy h1 {
        font-size: clamp(24px, 6.5vw, 32px);
      }
      .policy h2 {
        font-size: clamp(18px, 5vw, 24px);
      }
      .policy__meta div {
        grid-template-columns: 1fr;
        gap: 2px;
      }
    }
  </style>
</MainLayout>
