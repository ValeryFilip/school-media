---
import PartnerRules from "../../components/docs/PartnerRules.md";
import config from "../../config";
import AcademyLayout from "../../layouts/AcademyLayout.astro";
import {
  buildWebPageJsonLd,
  getSiteName,
  pageUrlFromPath,
} from "../../lib/seoData";

const title = "Правила реферальной программы ЕГЭХИМ";
const description =
  "Условия участия в реферальной программе ЕГЭХИМ: фиксация рекомендаций, начисление и выплата вознаграждения, реклама и персональные данные.";
const publishedAt = "15 июня 2026 года";

const breadcrumbs = [{ name: "Документы", href: "/docs/" }, { name: title }];
const origin = (Astro.site?.href ?? config.siteUrl).replace(/\/$/, "");
const pageUrl = pageUrlFromPath(origin, Astro.url.pathname);
const siteName = getSiteName(undefined, config.siteName);
const webPageJsonLd = buildWebPageJsonLd({
  origin,
  url: pageUrl,
  name: title,
  siteName,
  about: "Правила реферальной программы образовательного проекта ЕГЭХИМ",
});
---

<AcademyLayout
  title={title}
  description={description}
  seoType="website"
  index={false}
  breadcrumbs={breadcrumbs}
  showBreadcrumbs={true}
  webPageJsonLd={webPageJsonLd}
>
  <article class="policy" aria-labelledby="partner-rules-title">
    <div class="container">
      <h1 id="partner-rules-title">{title}</h1>

      <dl class="policy__meta">
        <div>
          <dt>Дата публикации</dt>
          <dd>{publishedAt}</dd>
        </div>
        <div>
          <dt>Адрес документа</dt>
          <dd><a href={pageUrl}>{pageUrl}</a></dd>
        </div>
        <div>
          <dt>Организатор</dt>
          <dd>Филипенко Валерий Юрьевич, плательщик НПД</dd>
        </div>
      </dl>

      <div class="policy__content">
        <PartnerRules />
      </div>
    </div>
  </article>

  <style>
    .policy {
      display: block;
      padding: clamp(56px, 8vw, 96px) var(--academy-gutter)
        clamp(56px, 10vw, 120px);
      background: var(--paper);
      color: var(--inkSoft);
    }

    .policy .container {
      max-width: 820px;
      margin: 0 auto;
      padding: 0;
      box-sizing: border-box;
    }

    .policy h1::before {
      content: "// документ";
      display: block;
      margin-bottom: 0.85em;
      font-family: var(--academy-font-mono);
      font-size: 12px;
      letter-spacing: 0.18em;
      text-transform: uppercase;
      color: var(--rust);
    }

    .policy h1 {
      margin: 0 0 clamp(28px, 4vw, 48px);
      font-family: var(--academy-font-display);
      font-size: clamp(40px, 6vw, 72px);
      line-height: 1.02;
      letter-spacing: -0.03em;
      font-weight: 700;
      color: var(--ink);
      text-wrap: balance;
    }

    .policy__meta {
      display: grid;
      margin: 0 0 clamp(24px, 4vw, 40px);
      padding: 0;
      background: var(--milk);
      border: 1px solid var(--line);
    }

    .policy__meta > div {
      display: grid;
      grid-template-columns: minmax(160px, 0.4fr) 1fr;
      gap: 16px;
      padding: 14px 20px;
      border-top: 1px solid var(--line);
      align-items: baseline;
    }

    .policy__meta > div:first-child {
      border-top: 0;
    }

    .policy__meta dt {
      margin: 0;
      font-family: var(--academy-font-mono);
      font-size: 11px;
      letter-spacing: 0.15em;
      text-transform: uppercase;
      color: var(--dim);
      font-weight: 500;
    }

    .policy__meta dd {
      margin: 0;
      font-family: var(--academy-font-body);
      font-size: 16px;
      line-height: 1.5;
      color: var(--ink);
    }

    .policy__content :global(h2) {
      margin: 2.2em 0 0.65em;
      padding-top: 1em;
      border-top: 1px solid var(--line);
      font-family: var(--academy-font-display);
      font-size: clamp(26px, 3.4vw, 38px);
      line-height: 1.08;
      letter-spacing: -0.02em;
      font-weight: 700;
      color: var(--ink);
      scroll-margin-top: 90px;
      text-wrap: balance;
    }

    .policy__content :global(p),
    .policy__content :global(li) {
      margin: 0 0 0.95em;
      font-family: var(--academy-font-body);
      font-size: clamp(17px, 1.25vw, 19px);
      line-height: 1.72;
      color: var(--inkSoft);
    }

    .policy__content :global(strong) {
      color: var(--ink);
      font-weight: 650;
    }

    .policy :global(a) {
      color: var(--rust);
      text-decoration: underline;
      text-decoration-thickness: 1px;
      text-underline-offset: 3px;
      text-decoration-color: var(--rust);
      transition:
        background 0.16s ease,
        color 0.16s ease;
    }

    .policy :global(a:hover) {
      background: var(--rust);
      color: var(--paper);
      text-decoration-color: var(--paper);
    }

    @media (max-width: 600px) {
      .policy__meta > div {
        grid-template-columns: 1fr;
        gap: 4px;
      }
    }

    @media print {
      :global(header),
      :global(nav),
      :global(footer) {
        display: none !important;
      }

      .policy {
        padding: 0;
        background: #fff;
        color: #000;
      }

      .policy h1::before {
        display: none;
      }

      .policy__meta {
        background: transparent;
      }

      .policy :global(a) {
        color: #000;
      }
    }
  </style>
</AcademyLayout>
