---
// src/pages/docs/privacy.astro

import MainLayout from "../../layouts/MainLayout.astro";
import config from "../../config.ts";
import {
  buildWebPageJsonLd,
  getSiteName,
  pageUrlFromPath,
} from "../../lib/seoData";

const title = "Политика конфиденциальности";
const description = "Как мы обрабатываем и защищаем персональные данные.";

// крошки: ваш компонент сам добавит «домой», поэтому здесь только текущая
const breadcrumbs = [{ name: title }];

// Генерация JSON-LD (origin — из Astro.site)
const origin = (Astro.site?.href ?? config.siteUrl).replace(/\/$/, "");
const pageUrl = pageUrlFromPath(origin, Astro.url.pathname);
const siteName = getSiteName(undefined, config.siteName);
const siteUrl = origin;
const webPageJsonLd = buildWebPageJsonLd({
  origin,
  url: pageUrl,
  name: title,
  siteName,
  about: "Политика конфиденциальности",
});
---

<MainLayout
  title={title}
  description={description}
  seoType="website"
  index={false}
  breadcrumbs={breadcrumbs}
  showBreadcrumbs={true}
  webPageJsonLd={webPageJsonLd}
>
  <main class="legal" aria-labelledby="privacy-title">
    <div class="container">
      <h1 id="privacy-title">Политика обработки персональных данных</h1>

      <dl class="legal__meta">
        <div>
          <dt>Дата публикации</dt>
          <dd>30 апреля 2026 года</dd>
        </div>
        <div>
          <dt>Адрес сайта</dt>
          <dd><a href="https://egehim.ru">https://egehim.ru</a></dd>
        </div>
      </dl>

      <section class="legal__section">
        <h2>1. Общие положения</h2>
        <p>
          Настоящая Политика обработки персональных данных определяет порядок
          обработки и защиты персональных данных пользователей сайта
          <a href="https://egehim.ru">https://egehim.ru</a>.
        </p>
        <p>
          Оператор персональных данных: Филипенко Валерий Юрьевич, плательщик
          налога на профессиональный доход, владелец сайта
          <a href="https://egehim.ru">https://egehim.ru</a>. Email для
          обращений по вопросам обработки персональных данных:
          <a href={`mailto:${config.contactEmail}`}>{config.contactEmail}</a>.
        </p>
        <p>
          Настоящая Политика применяется ко всей информации, которую Оператор
          может получить о пользователях сайта <a href="https://egehim.ru"
            >https://egehim.ru</a
          >, а также о лицах, которые обращаются к Оператору через формы на
          сайте, email, мессенджеры, социальные сети или иные каналы связи.
        </p>
        <p>
          Оператор обрабатывает персональные данные в соответствии с Федеральным
          законом от 27.07.2006 № 152-ФЗ «О персональных данных» и иными
          применимыми нормативными актами Российской Федерации.
        </p>
      </section>

      <section class="legal__section">
        <h2>2. Основные понятия</h2>
        <p>
          <strong>Персональные данные</strong> — любая информация, относящаяся
          прямо или косвенно к определённому или определяемому пользователю.
        </p>
        <p>
          <strong>Пользователь</strong> — посетитель сайта
          <a href="https://egehim.ru">https://egehim.ru</a>, лицо, заполнившее
          форму на сайте, направившее обращение Оператору или воспользовавшееся
          каналами связи Оператора.
        </p>
        <p>
          <strong>Оператор</strong> — Филипенко Валерий Юрьевич, самостоятельно
          организующий и осуществляющий обработку персональных данных.
        </p>
        <p>
          <strong>Обработка персональных данных</strong> — любое действие или
          совокупность действий с персональными данными, включая сбор, запись,
          систематизацию, накопление, хранение, уточнение, использование,
          передачу, обезличивание, блокирование, удаление и уничтожение
          персональных данных.
        </p>
        <p>
          <strong>Файлы cookie</strong> — небольшие текстовые файлы, которые
          сохраняются на устройстве пользователя и помогают сайту работать
          корректно, анализировать посещаемость и улучшать материалы сайта.
        </p>
      </section>

      <section class="legal__section">
        <h2>3. Какие персональные данные обрабатывает Оператор</h2>
        <p>Оператор может обрабатывать следующие категории персональных данных:</p>

        <h3>Контактные данные, которые пользователь предоставляет самостоятельно</h3>
        <ul>
          <li>имя;</li>
          <li>номер телефона;</li>
          <li>адрес электронной почты;</li>
          <li>
            никнейм, ссылка на профиль или идентификатор в Telegram, VK,
            WhatsApp или другом канале связи, если пользователь сам предоставил
            такие данные.
          </li>
        </ul>

        <h3>Данные, связанные с обращением или заявкой</h3>
        <ul>
          <li>выбранный курс или интересующее направление обучения;</li>
          <li>класс обучения или цель подготовки;</li>
          <li>текст сообщения пользователя;</li>
          <li>сведения о предпочтительном способе связи;</li>
          <li>
            иная информация, которую пользователь сам указал в форме или
            сообщении, если она необходима для ответа на обращение.
          </li>
        </ul>

        <h3>Технические и аналитические данные</h3>
        <ul>
          <li>IP-адрес;</li>
          <li>дата и время посещения сайта;</li>
          <li>сведения о браузере, устройстве и операционной системе;</li>
          <li>источник перехода на сайт;</li>
          <li>страницы, просмотренные пользователем;</li>
          <li>данные файлов cookie;</li>
          <li>
            сведения о действиях пользователя на сайте, собираемые с помощью
            систем аналитики.
          </li>
        </ul>

        <h3>Данные, связанные с обучением и покупкой курса на сторонней платформе</h3>
        <ul>
          <li>сведения о выбранном курсе;</li>
          <li>сведения о факте покупки или предоставления доступа к курсу;</li>
          <li>
            email или идентификатор пользователя на платформе, если такие
            сведения передаются Оператору платформой в рамках работы с курсом.
          </li>
        </ul>

        <p>
          Оператор не собирает через сайт паспортные данные, данные банковских
          карт, сведения о здоровье, политических взглядах, религиозных
          убеждениях и иные специальные категории персональных данных, если
          пользователь сам не направил такие сведения по собственной инициативе.
        </p>
