---
// src/pages/docs/privacy.astro

import AcademyLayout from "../../layouts/AcademyLayout.astro";
import config from "../../config.ts";
import {
  buildWebPageJsonLd,
  getSiteName,
  pageUrlFromPath,
} from "../../lib/seoData";

const title = "Политика конфиденциальности";
const description = "Как мы обрабатываем и защищаем персональные данные.";

// крошки: ваш компонент сам добавит «домой», поэтому здесь только текущая
const breadcrumbs = [{ name: title }];

// Генерация JSON-LD (origin — из Astro.site)
const origin = (Astro.site?.href ?? config.siteUrl).replace(/\/$/, "");
const pageUrl = pageUrlFromPath(origin, Astro.url.pathname);
const siteName = getSiteName(undefined, config.siteName);
const webPageJsonLd = buildWebPageJsonLd({
  origin,
  url: pageUrl,
  name: title,
  siteName,
  about: "Политика конфиденциальности",
});
---

<AcademyLayout
  title={title}
  description={description}
  seoType="website"
  index={false}
  breadcrumbs={breadcrumbs}
  showBreadcrumbs={true}
  webPageJsonLd={webPageJsonLd}
