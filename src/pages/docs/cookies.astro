---
// src/pages/docs/cookies.astro

import AcademyLayout from "../../layouts/AcademyLayout.astro";
import config from "../../config.ts";
import {
  buildWebPageJsonLd,
  getSiteName,
  pageUrlFromPath,
} from "../../lib/seoData";

const title = "Политика использования cookie-файлов и систем аналитики";
const description =
  "Как сайт ЕГЭХИМ использует cookie-файлы и Яндекс.Метрику для работы сайта и аналитики.";

const breadcrumbs = [{ name: title }];

const origin = (Astro.site?.href ?? config.siteUrl).replace(/\/$/, "");
const pageUrl = pageUrlFromPath(origin, Astro.url.pathname);
const siteName = getSiteName(undefined, config.siteName);
const webPageJsonLd = buildWebPageJsonLd({
  origin,
  url: pageUrl,
  name: title,
  siteName,
  about: "Политика использования cookie-файлов и систем аналитики",
});
---

<AcademyLayout
  title={title}
  description={description}
  seoType="website"
  index={false}
  breadcrumbs={breadcrumbs}
  showBreadcrumbs={true}
  webPageJsonLd={webPageJsonLd}
>
  <article class="policy" aria-labelledby="cookies-title">
    <div class="container">
      <h1 id="cookies-title">{title}</h1>

      <dl class="policy__meta">
        <div>
          <dt>Дата публикации</dt>
          <dd>30 апреля 2026 года</dd>
        </div>
        <div>
          <dt>Адрес сайта</dt>
          <dd><a href="https://egehim.ru">https://egehim.ru</a></dd>
        </div>
        <div>
          <dt>ИНН оператора</dt>
          <dd>026824238284</dd>
        </div>
      </dl>

      <section class="policy__section">
        <p>
          Настоящая Политика описывает, как сайт
          <a href="https://egehim.ru">https://egehim.ru</a> использует файлы
          cookie и системы веб-аналитики.
        </p>
      </section>

      <section class="policy__section">
        <h2>1. Что такое cookie</h2>
        <p>
          Cookie — это небольшие текстовые файлы, которые сайт сохраняет на
          устройстве пользователя: компьютере, смартфоне или планшете.
        </p>
        <p>
          Cookie помогают сайту работать корректно, запоминать настройки
          пользователя, анализировать посещаемость и улучшать материалы.
        </p>
      </section>

      <section class="policy__section">
        <h2>2. Какие cookie используются</h2>
        <p>Сайт может использовать следующие категории cookie:</p>
        <ul>
          <li>
            <strong>Технические cookie</strong> — нужны для корректной работы
            сайта, загрузки страниц, защиты от сбоев и сохранения базовых
            настроек.
          </li>
          <li>
            <strong>Аналитические cookie</strong> — помогают понять, какие
            страницы посещают пользователи, сколько времени проводят на сайте,
            откуда приходят и какие материалы оказываются полезными.
          </li>
          <li>
            <strong>Функциональные cookie</strong> — могут использоваться для
            сохранения пользовательских настроек, если такие функции реализованы
            на сайте.
          </li>
          <li>
            <strong>Маркетинговые cookie</strong> — на момент публикации сайт не
            использует сторонние рекламные пиксели. Если такие инструменты будут
            подключены, информация о них будет добавлена в настоящую Политику.
          </li>
        </ul>
      </section>

      <section class="policy__section">
        <h2>3. Яндекс.Метрика</h2>
        <p>На сайте используется сервис Яндекс.Метрика.</p>
        <p>Яндекс.Метрика помогает Оператору:</p>
        <ul>
          <li>анализировать посещаемость сайта;</li>
          <li>понимать, какие страницы и статьи читают пользователи;</li>
          <li>улучшать структуру сайта;</li>
          <li>находить технические проблемы;</li>
          <li>оценивать эффективность материалов, рекламы и источников переходов;</li>
          <li>улучшать удобство сайта для пользователей.</li>
        </ul>
        <p>
          Яндекс.Метрика может собирать техническую информацию о посещении
          сайта, включая IP-адрес, данные cookie, сведения о браузере,
          устройстве, операционной системе, источнике перехода, просмотренных
          страницах и действиях пользователя на сайте.
        </p>
        <p>
          Подробнее о работе сервиса можно прочитать в официальных документах:
          <a href="https://yandex.ru/legal/metrica_termsofuse/ru/" target="_blank" rel="noopener noreferrer"
            >условия использования Яндекс.Метрики</a
          >,
          <a href="https://yandex.ru/legal/confidential/" target="_blank" rel="noopener noreferrer"
            >политика конфиденциальности Яндекса</a
          >,
          <a href="https://yandex.ru/support/metrica/ru/general/cookie-usage" target="_blank" rel="noopener noreferrer"
            >справка Яндекс.Метрики о cookie и localStorage</a
          >.
        </p>
      </section>

      <section class="policy__section">
        <h2>4. Цели использования cookie и аналитики</h2>
        <p>Cookie и аналитика используются для:</p>
        <ul>
          <li>обеспечения стабильной работы сайта;</li>
          <li>улучшения скорости загрузки и удобства навигации;</li>
          <li>анализа интереса пользователей к статьям, курсам и страницам сайта;</li>
          <li>улучшения качества образовательных материалов;</li>
          <li>оценки эффективности рекламных и информационных кампаний;</li>
          <li>предотвращения технических ошибок и злоупотреблений.</li>
        </ul>
      </section>

      <section class="policy__section">
        <h2>5. Управление cookie</h2>
        <p>Пользователь может управлять cookie в настройках своего браузера:</p>
        <ul>
          <li>разрешить использование cookie;</li>
          <li>запретить использование cookie;</li>
          <li>удалить ранее сохранённые cookie;</li>
          <li>настроить уведомления о сохранении cookie.</li>
        </ul>
        <p>
          Если пользователь ограничит или отключит cookie, отдельные функции
          сайта могут работать некорректно.
        </p>
      </section>

      <section class="policy__section">
        <h2>6. Согласие на использование cookie</h2>
        <p>
          При первом посещении сайта пользователю может быть показано
          уведомление об использовании cookie и систем аналитики.
        </p>
        <p>
          Продолжая пользоваться сайтом после отображения уведомления о cookie,
          пользователь подтверждает, что ознакомлен с использованием cookie и
          систем аналитики.
        </p>
        <p>
          Если на сайте используются маркетинговые cookie или рекламные пиксели,
          их подключение осуществляется с учётом требований законодательства
          Российской Федерации.
        </p>
      </section>

      <section class="policy__section">
        <h2>7. Изменение политики cookie</h2>
        <p>
          Оператор вправе изменять настоящую Политику. Новая редакция вступает
          в силу с момента публикации на сайте.
        </p>
        <p>
          Актуальная версия доступна по адресу:
          <a href="https://egehim.ru/docs/cookies/">https://egehim.ru/docs/cookies/</a>
        </p>
      </section>

      <section class="policy__section">
        <h2>8. Контакты и связанные документы</h2>
        <p>
          По вопросам использования cookie и аналитики можно написать Оператору
          на email: <a href={`mailto:${config.contactEmail}`}>{config.contactEmail}</a>.
        </p>
        <ul>
          <li><a href="/docs/privacy/">Политика обработки персональных данных</a></li>
          <li><a href="/docs/agreement/">Согласие на обработку персональных данных</a></li>
          <li><a href="/docs/marketing-consent/">Согласие на рекламные и информационные сообщения</a></li>
          <li><a href="/docs/payment/">Оплата, безопасность платежей и возвраты</a></li>
        </ul>
      </section>
    </div>
  </article>

    <style>
    /* Док-страница в академной молочной палитре */
    .policy {
      display: block;
      padding: clamp(56px, 8vw, 96px) var(--academy-gutter) clamp(56px, 10vw, 120px);
      background: var(--paper);
      color: var(--inkSoft);
    }
    .policy .container {
      max-width: 820px;
      margin: 0 auto;
      padding: 0;
      box-sizing: border-box;
    }

    /* Кикер над H1 */
    .policy h1::before {
      content: "// документ";
      display: block;
      margin-bottom: 0.85em;
      font-family: var(--academy-font-mono);
      font-size: 12px;
      letter-spacing: 0.18em;
      text-transform: uppercase;
      color: var(--rust);
    }
    .policy h1 {
      margin: 0 0 clamp(28px, 4vw, 48px);
      font-family: var(--academy-font-display);
      font-size: clamp(40px, 6vw, 72px);
      line-height: 1.02;
      letter-spacing: -0.03em;
      font-weight: 700;
      color: var(--ink);
      text-wrap: balance;
    }
    .policy h2 {
      margin: 2.2em 0 0.6em;
      padding-top: 1em;
      border-top: 1px solid var(--line);
      font-family: var(--academy-font-display);
      font-size: clamp(26px, 3.4vw, 38px);
      line-height: 1.08;
      letter-spacing: -0.02em;
      font-weight: 700;
      color: var(--ink);
      scroll-margin-top: 90px;
    }
    .policy h3 {
      margin: 1.6em 0 0.5em;
      font-family: var(--academy-font-display);
      font-size: clamp(20px, 2.2vw, 24px);
      line-height: 1.2;
      letter-spacing: -0.01em;
      font-weight: 650;
      color: var(--ink);
    }
    .policy p,
    .policy li {
      font-family: var(--academy-font-body);
      font-size: clamp(17px, 1.25vw, 19px);
      line-height: 1.7;
      color: var(--inkSoft);
      margin: 0 0 0.85em;
    }
    .policy strong {
      color: var(--ink);
      font-weight: 650;
    }
    .policy ul,
    .policy ol {
      padding-left: 0;
      margin: 0.4em 0 1.2em;
      list-style: none;
    }
    .policy li {
      position: relative;
      padding-left: 28px;
      margin-bottom: 0.45em;
    }
    .policy ul > li::before {
      content: "→";
      position: absolute;
      left: 0;
      top: 0.05em;
      font-family: var(--academy-font-mono);
      color: var(--rust);
      font-size: 0.95em;
    }
    .policy ol {
      counter-reset: docs-li;
    }
    .policy ol > li {
      counter-increment: docs-li;
    }
    .policy ol > li::before {
      content: counter(docs-li, decimal-leading-zero);
      position: absolute;
      left: 0;
      top: 0.2em;
      font-family: var(--academy-font-mono);
      color: var(--rust);
      font-size: 0.8em;
      letter-spacing: 0.05em;
    }

    .policy a {
      color: var(--rust);
      text-decoration: underline;
      text-decoration-thickness: 1px;
      text-underline-offset: 3px;
      text-decoration-color: var(--rust);
      transition:
        background 0.16s ease,
        color 0.16s ease;
    }
    .policy a:hover {
      background: var(--rust);
      color: var(--paper);
      text-decoration-color: var(--paper);
    }

    /* Мета-плашка (дата публикации, адрес сайта) */
    .policy__meta {
      display: grid;
      gap: 0;
      margin: 0 0 clamp(32px, 5vw, 56px);
      padding: 0;
      background: var(--milk);
      border: 1px solid var(--line);
      border-radius: 0;
    }
    .policy__meta > div {
      display: grid;
      grid-template-columns: minmax(160px, 0.4fr) 1fr;
      gap: 16px;
      padding: 14px 20px;
      border-top: 1px solid var(--line);
      align-items: baseline;
    }
    .policy__meta > div:first-child {
      border-top: 0;
    }
    .policy__meta dt {
      margin: 0;
      font-family: var(--academy-font-mono);
      font-size: 11px;
      letter-spacing: 0.15em;
      text-transform: uppercase;
      color: var(--dim);
      font-weight: 500;
    }
    .policy__meta dd {
      margin: 0;
      font-family: var(--academy-font-body);
      font-size: 16px;
      line-height: 1.5;
      color: var(--ink);
    }

    .policy__section + .policy__section {
      margin-top: 0;
    }

    @media (max-width: 600px) {
      .policy__meta > div {
        grid-template-columns: 1fr;
        gap: 4px;
      }
    }

    @media print {
      header,
      nav,
      footer {
        display: none !important;
      }
      .policy {
        padding: 0;
        background: #fff;
        color: #000;
      }
      .policy h1::before {
        display: none;
      }
      .policy__meta {
        background: transparent;
      }
      .policy a {
        color: #000;
      }
    }
  </style>
</AcademyLayout>
