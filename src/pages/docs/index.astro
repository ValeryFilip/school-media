---
import MainLayout from "../../layouts/MainLayout.astro";

const title = "Документы";
const description = "Юридические документы сайта ЕГЭХИМ.";
---

<MainLayout title={title} description={description} index={false}>
  <main class="docs-index" aria-labelledby="docs-title">
    <div class="container">
      <h1 id="docs-title">Документы</h1>
      <p>Юридические документы сайта.</p>

      <ul>
        <li><a href="/docs/privacy/">Политика обработки персональных данных</a></li>
        <li><a href="/docs/agreement/">Согласие на обработку персональных данных</a></li>
        <li><a href="/docs/cookies/">Политика использования cookie-файлов и систем аналитики</a></li>
        <li><a href="/docs/marketing-consent/">Согласие на рекламные и информационные сообщения</a></li>
        <li><a href="/docs/payment/">Оплата, безопасность платежей и возвраты</a></li>
      </ul>
    </div>
  </main>

  <style>
    .docs-index {
      color: var(--black);
      padding: var(--space-32, 32px) 0;
    }
    .docs-index .container {
      max-width: var(--container, 900px);
      padding: 0 var(--pad-desktop, 50px);
      margin: 0 auto;
      box-sizing: border-box;
    }
    .docs-index h1 {
      font-size: var(--h1, 32px);
      line-height: 1.2;
      margin: 0 0 var(--space-16, 16px);
      font-weight: 700;
    }
    .docs-index p,
    .docs-index li {
      font-size: 20px;
      line-height: 1.7;
    }
    .docs-index ul {
      padding-left: 20px;
    }
    .docs-index a {
      color: var(--blue, #0d6efd);
      text-decoration: underline;
      text-underline-offset: 3px;
    }

    @media (max-width: 600px) {
      .docs-index .container {
        padding: 0 var(--pad-mobile, 20px);
      }
      .docs-index p,
      .docs-index li {
        font-size: 16px;
      }
      .docs-index h1 {
        font-size: clamp(24px, 6.5vw, 32px);
      }
    }
  </style>
</MainLayout>
