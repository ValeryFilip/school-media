---
// src/pages/docs/marketing-consent.astro

import AcademyLayout from "../../layouts/AcademyLayout.astro";
import config from "../../config.ts";
import {
  buildWebPageJsonLd,
  getSiteName,
  pageUrlFromPath,
} from "../../lib/seoData";

const title = "Согласие на получение рекламных рассылок";
const siteBase = (Astro.site?.href ?? config.siteUrl).replace(/\/$/, "");
const description = `Условия и порядок получения рекламных сообщений по email, телефону и в мессенджерах на ${siteBase}.`;

const breadcrumbs = [{ name: title }];

// Генерация JSON-LD
const origin = Astro.url.origin;
const pageUrl = pageUrlFromPath(origin, Astro.url.pathname);
const siteName = getSiteName(undefined, config.siteName);
const webPageJsonLd = buildWebPageJsonLd({
  origin,
  url: pageUrl,
  name: title,
  siteName,
  about: "Согласие на получение рекламных рассылок",
});
---

<AcademyLayout
  title={title}
  description={description}
  seoType="website"
  index={false}
  breadcrumbs={breadcrumbs}
  showBreadcrumbs={true}
  webPageJsonLd={webPageJsonLd}
>
  <article class="policy" aria-labelledby="marketing-consent-title">
    <div class="container">
      <h1 id="marketing-consent-title">
        Согласие на получение рекламных и информационных сообщений
      </h1>

      <dl class="policy__meta">
        <div>
          <dt>Дата публикации</dt>
          <dd>30 апреля 2026 года</dd>
        </div>
        <div>
          <dt>Адрес сайта</dt>
          <dd><a href="https://egehim.ru">https://egehim.ru</a></dd>
        </div>
      </dl>

      <section class="policy__section">
        <p>
          Настоящим я даю согласие Филипенко Валерию Юрьевичу, плательщику
          налога на профессиональный доход, владельцу сайта
          <a href="https://egehim.ru">https://egehim.ru</a>, далее — «Оператор»,
          на получение рекламных и информационных сообщений, а также на
          обработку моих персональных данных для направления таких сообщений.
        </p>
        <p>
          Согласие даётся в соответствии с Федеральным законом от 13.03.2006
          № 38-ФЗ «О рекламе» и Федеральным законом от 27.07.2006 № 152-ФЗ
          «О персональных данных».
        </p>
      </section>

      <section class="policy__section">
        <h2>1. Каналы получения сообщений</h2>
        <p>
          Я соглашаюсь получать сообщения по тем каналам связи, которые я сам
          предоставил Оператору или в которых я сам подписался на сообщения
          Оператора:
        </p>
        <ul>
          <li>email;</li>
          <li>Telegram;</li>
          <li>VK;</li>
          <li>WhatsApp;</li>
        </ul>
        <p>
          Сообщения в мессенджерах направляются только если я сам предоставил
          соответствующий контакт, написал Оператору первым, подписался на
          канал, сообщество или бота, либо иным активным действием подтвердил
          желание получать сообщения.
        </p>
      </section>

      <section class="policy__section">
        <h2>2. Содержание сообщений</h2>
        <p>Сообщения могут включать:</p>
        <ul>
          <li>информацию о курсах, занятиях, консультациях и образовательных материалах проекта ЕГЭХИМ;</li>
          <li>напоминания о старте курсов, вебинаров, разборов и мероприятий;</li>
          <li>полезные материалы по химии, подготовке к ЕГЭ и ОГЭ;</li>
          <li>новости проекта;</li>
          <li>специальные предложения, акции, скидки и промокоды;</li>
          <li>приглашения на бесплатные и платные мероприятия.</li>
        </ul>
      </section>

      <section class="policy__section">
        <h2>3. Периодичность сообщений</h2>
        <p>
          Периодичность сообщений определяется Оператором, но обычно не
          превышает 2–4 сообщений в неделю, за исключением важных уведомлений,
          связанных с участием в мероприятии, стартом курса, изменением
          расписания или техническими вопросами.
        </p>
      </section>

      <section class="policy__section">
        <h2>4. Какие данные обрабатываются для рассылок</h2>
        <p>Для направления сообщений Оператор может обрабатывать:</p>
        <ul>
          <li>имя;</li>
          <li>адрес электронной почты;</li>
          <li>номер телефона;</li>
          <li>никнейм, ссылку на профиль или идентификатор в Telegram, VK, WhatsApp;</li>
          <li>сведения о подписке, отписке и выбранном канале связи;</li>
          <li>сведения о взаимодействии с сообщениями: открытия, клики, переходы, ответы;</li>
          <li>технические данные: IP-адрес, дата и время подтверждения согласия, источник подписки.</li>
        </ul>
      </section>

      <section class="policy__section">
        <h2>5. Передача данных сервисам рассылок и связи</h2>
        <p>
          Оператор может поручать обработку данных сервисам рассылок,
          мессенджерам, социальным сетям, почтовым сервисам и иным техническим
          подрядчикам только в объёме, необходимом для отправки сообщений,
          фиксации согласия, учёта отписок и соблюдения требований
          законодательства.
        </p>
      </section>

      <section class="policy__section">
        <h2>6. Срок действия согласия</h2>
        <p>Согласие действует до момента его отзыва.</p>
      </section>

      <section class="policy__section">
        <h2>7. Как отказаться от сообщений</h2>
        <p>
          Я могу отказаться от рекламных и информационных сообщений в любой
          момент:
        </p>
        <ul>
          <li>по ссылке «Отписаться» в письме, если такая ссылка предусмотрена;</li>
          <li>
            отправив письмо на email
            <a href={`mailto:${config.contactEmail}`}>{config.contactEmail}</a> с темой
            «Отписка»;
          </li>
          <li>
            написав «стоп», «отписаться» или аналогичное сообщение в
            мессенджере, если сообщение получено через мессенджер;
          </li>
          <li>отключив уведомления в соответствующем сервисе, канале, сообществе, боте или браузере;</li>
          <li>через личный кабинет, если такая возможность доступна.</li>
        </ul>
        <p>
          После отзыва согласия Оператор прекращает направление рекламных
          сообщений по соответствующему каналу связи.
        </p>
        <p>
          При этом Оператор может продолжить направлять обязательные сервисные
          сообщения, связанные с исполнением договора, доступом к курсу, оплатой,
          изменением расписания, технической поддержкой или иными нерекламными
          вопросами.
        </p>
      </section>

      <section class="policy__section">
        <h2>8. Способ выражения согласия</h2>
        <p>
          Согласие выражается путём проставления отдельной отметки в форме на
          сайте, подписки на рассылку, подписки на канал, бота или сообщество,
          направления сообщения Оператору либо иного активного действия,
          позволяющего подтвердить факт согласия.
        </p>
      </section>

      <section class="policy__section">
        <h2>9. Связанные документы</h2>
        <ul>
          <li><a href="/docs/privacy/">Политика обработки персональных данных</a></li>
          <li><a href="/docs/agreement/">Согласие на обработку персональных данных</a></li>
          <li><a href="/docs/cookies/">Политика использования cookie-файлов и систем аналитики</a></li>
          <li><a href="/docs/payment/">Оплата, безопасность платежей и возвраты</a></li>
        </ul>
      </section>
    </div>
  </article>

    <style>
    /* Док-страница в академной молочной палитре */
    .policy {
      display: block;
      padding: clamp(56px, 8vw, 96px) var(--academy-gutter) clamp(56px, 10vw, 120px);
      background: var(--paper);
      color: var(--inkSoft);
    }
    .policy .container {
      max-width: 820px;
      margin: 0 auto;
      padding: 0;
      box-sizing: border-box;
    }

    /* Кикер над H1 */
    .policy h1::before {
      content: "// документ";
      display: block;
      margin-bottom: 0.85em;
      font-family: var(--academy-font-mono);
      font-size: 12px;
      letter-spacing: 0.18em;
      text-transform: uppercase;
      color: var(--rust);
    }
    .policy h1 {
      margin: 0 0 clamp(28px, 4vw, 48px);
      font-family: var(--academy-font-display);
      font-size: clamp(40px, 6vw, 72px);
      line-height: 1.02;
      letter-spacing: -0.03em;
      font-weight: 700;
      color: var(--ink);
      text-wrap: balance;
    }
    .policy h2 {
      margin: 2.2em 0 0.6em;
      padding-top: 1em;
      border-top: 1px solid var(--line);
      font-family: var(--academy-font-display);
      font-size: clamp(26px, 3.4vw, 38px);
      line-height: 1.08;
      letter-spacing: -0.02em;
      font-weight: 700;
      color: var(--ink);
      scroll-margin-top: 90px;
    }
    .policy h3 {
      margin: 1.6em 0 0.5em;
      font-family: var(--academy-font-display);
      font-size: clamp(20px, 2.2vw, 24px);
      line-height: 1.2;
      letter-spacing: -0.01em;
      font-weight: 650;
      color: var(--ink);
    }
    .policy p,
    .policy li {
      font-family: var(--academy-font-body);
      font-size: clamp(17px, 1.25vw, 19px);
      line-height: 1.7;
      color: var(--inkSoft);
      margin: 0 0 0.85em;
    }
    .policy strong {
      color: var(--ink);
      font-weight: 650;
    }
    .policy ul,
    .policy ol {
      padding-left: 0;
      margin: 0.4em 0 1.2em;
      list-style: none;
    }
    .policy li {
      position: relative;
      padding-left: 28px;
      margin-bottom: 0.45em;
    }
    .policy ul > li::before {
      content: "→";
      position: absolute;
      left: 0;
      top: 0.05em;
      font-family: var(--academy-font-mono);
      color: var(--rust);
      font-size: 0.95em;
    }
    .policy ol {
      counter-reset: docs-li;
    }
    .policy ol > li {
      counter-increment: docs-li;
    }
    .policy ol > li::before {
      content: counter(docs-li, decimal-leading-zero);
      position: absolute;
      left: 0;
      top: 0.2em;
      font-family: var(--academy-font-mono);
      color: var(--rust);
      font-size: 0.8em;
      letter-spacing: 0.05em;
    }

    .policy a {
      color: var(--rust);
      text-decoration: underline;
      text-decoration-thickness: 1px;
      text-underline-offset: 3px;
      text-decoration-color: var(--rust);
      transition:
        background 0.16s ease,
        color 0.16s ease;
    }
    .policy a:hover {
      background: var(--rust);
      color: var(--paper);
      text-decoration-color: var(--paper);
    }

    /* Мета-плашка (дата публикации, адрес сайта) */
    .policy__meta {
      display: grid;
      gap: 0;
      margin: 0 0 clamp(32px, 5vw, 56px);
      padding: 0;
      background: var(--milk);
      border: 1px solid var(--line);
      border-radius: 0;
    }
    .policy__meta > div {
      display: grid;
      grid-template-columns: minmax(160px, 0.4fr) 1fr;
      gap: 16px;
      padding: 14px 20px;
      border-top: 1px solid var(--line);
      align-items: baseline;
    }
    .policy__meta > div:first-child {
      border-top: 0;
    }
    .policy__meta dt {
      margin: 0;
      font-family: var(--academy-font-mono);
      font-size: 11px;
      letter-spacing: 0.15em;
      text-transform: uppercase;
      color: var(--dim);
      font-weight: 500;
    }
    .policy__meta dd {
      margin: 0;
      font-family: var(--academy-font-body);
      font-size: 16px;
      line-height: 1.5;
      color: var(--ink);
    }

    .policy__section + .policy__section {
      margin-top: 0;
    }

    @media (max-width: 600px) {
      .policy__meta > div {
        grid-template-columns: 1fr;
        gap: 4px;
      }
    }

    @media print {
      header,
      nav,
      footer {
        display: none !important;
      }
      .policy {
        padding: 0;
        background: #fff;
        color: #000;
      }
      .policy h1::before {
        display: none;
      }
      .policy__meta {
        background: transparent;
      }
      .policy a {
        color: #000;
      }
    }
  </style>
</AcademyLayout>
