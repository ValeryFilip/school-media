---
import AcademyLayout from "../../../layouts/AcademyLayout.astro";
import AcademyListHero from "../../../components/academy/AcademyListHero.astro";
import AcademyArticleGrid from "../../../components/academy/AcademyArticleGrid.astro";
import config from "../../../config.ts";
import { getCollection } from "astro:content";
import { slugify } from "../../../lib/slugify.ts";
import { articleCard, toDate, readMins } from "../../../lib/academyArticles.ts";
import { ACADEMY_BASE_PATH, academyPath, academyTagPath } from "../../../lib/academyPaths.ts";

export async function getStaticPaths() {
  const posts = await getCollection(
    "articles",
    ({ data }) => data.visible !== false,
  );
  const tagMap = new Map<string, string>(); // slug -> оригинальное имя
  for (const p of posts)
    for (const t of p.data.tags ?? []) {
      const name = String(t).trim();
      if (name) tagMap.set(slugify(name), name);
    }
  return [...tagMap.entries()].map(([slug, name]) => ({
    params: { tag: slug },
    props: { tagName: name },
  }));
}

const { tagName } = Astro.props;

const allPosts = (
  await getCollection("articles", ({ data }) => data.visible !== false)
).sort((a, b) => toDate(b.data.date).getTime() - toDate(a.data.date).getTime());

const tagPosts = allPosts.filter((p) =>
  (p.data.tags ?? []).some((t: string) => String(t).trim() === tagName),
);
const count = tagPosts.length;
const totalMins = tagPosts.reduce((s, p) => s + readMins(p), 0);

const gridArticles = tagPosts.map((post) => articleCard(post, ACADEMY_BASE_PATH));

const stats = [
  { value: count, label: "материалов", accent: "rust" as const },
  { value: totalMins, label: "мин чтения" },
];

const marquee = [
  `// тег · ${tagName.toLowerCase()}`,
  `${count} материалов по&nbsp;теме`,
  "обновляется регулярно",
];

const siteUrl = (Astro.site?.href ?? config.siteUrl).replace(/\/$/, "");
const pageTitle = tagName.charAt(0).toUpperCase() + tagName.slice(1);
const seoTitle = `Все статьи по тегу «${pageTitle}» — Академия ЕГЭХИМ`;
const pageDesc = `Подборка статей по теме «${pageTitle}»: разборы, полезные материалы и практические советы.`;
const pageUrl = `${siteUrl}${academyTagPath(tagName)}`;
const perPage = 8;
const currentPage = Math.max(
  1,
  Number(Astro.url.searchParams.get("page") || "1"),
);
const totalPages = Math.max(1, Math.ceil(tagPosts.length / perPage));
---

<AcademyLayout
  title={seoTitle}
  description={pageDesc}
  addSiteSuffix={false}
  url={pageUrl}
  image={tagPosts[0]?.data?.image || "/images/technical/og-home.png"}
  index={false}
  follow={true}
  prevUrl={currentPage > 1 ? `${pageUrl}?page=${currentPage - 1}` : undefined}
  nextUrl={currentPage < totalPages ? `${pageUrl}?page=${currentPage + 1}` : undefined}
  breadcrumbs={[{ name: pageTitle, href: pageUrl }]}
  showBreadcrumbs={true}
>
  <AcademyListHero
    breadcrumb={[
      { label: "Академия", href: academyPath() },
      { label: "Теги" },
      { label: tagName },
    ]}
    label={`[ тег ] · ${count} материалов`}
    titleTop={`#${tagName}`}
    description={`Все материалы Академии по&nbsp;теме «${tagName}»&nbsp;— разборы, формулы и&nbsp;задачи. Подобраны для&nbsp;подготовки к&nbsp;ЕГЭ и&nbsp;ОГЭ по&nbsp;химии.`}
    stats={stats}
    marquee={marquee}
  />
  <AcademyArticleGrid
    secNum="[02] / МАТЕРИАЛЫ"
    title={`Материалы по&nbsp;теме «${tagName}»`}
    articles={gridArticles}
  />
</AcademyLayout>
