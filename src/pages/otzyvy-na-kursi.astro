---
import AcademyLayout from "../layouts/AcademyLayout.astro";
import AcademyBreadcrumbs from "../components/academy/AcademyBreadcrumbs.astro";
import AcademyFaq from "../components/academy/AcademyFaq.astro";
import EgeH2 from "../components/ege/EgeH2.astro";
import { TUTORING_REVIEWS, STEPIK_COURSES } from "../data/reviews-page";
import { buildFAQJsonLd } from "../lib/seoData";

const featured =
  TUTORING_REVIEWS.find((review) => review.featured) ?? TUTORING_REVIEWS[0];

const rest = TUTORING_REVIEWS.filter((review) => review.id !== featured.id).sort(
  (a, b) => {
    const aHasScore = a.after != null ? 1 : 0;
    const bHasScore = b.after != null ? 1 : 0;
    if (bHasScore !== aHasScore) return bHasScore - aHasScore;

    const aHasScreens = a.hasScreens ? 1 : 0;
    const bHasScreens = b.hasScreens ? 1 : 0;
    if (bHasScreens !== aHasScreens) return bHasScreens - aHasScreens;

    const aAfter = a.after ?? -1;
    const bAfter = b.after ?? -1;
    if (bAfter !== aAfter) return bAfter - aAfter;

    const aDelta = a.before != null && a.after != null ? a.after - a.before : -1;
    const bDelta = b.before != null && b.after != null ? b.after - b.before : -1;
    if (bDelta !== aDelta) return bDelta - aDelta;

    return a.id - b.id;
  },
);

const reviewsWithScreens = TUTORING_REVIEWS.filter((review) => review.hasScreens);
const reviewsWithScores = TUTORING_REVIEWS.filter(
  (review) => review.before != null && review.after != null,
);
const screensModalData = reviewsWithScreens.map((review) => ({
  id: review.id,
  name: review.name,
  screens: review.screens ?? review.screenImages?.length ?? 1,
  images: review.screenImages ?? [],
}));

const totalStepikReviews = STEPIK_COURSES.reduce(
  (sum, course) => sum + course.reviewsCount,
  0,
);
const averageScoreGrowth = Math.round(
  reviewsWithScores.reduce(
    (sum, review) => sum + (review.after! - review.before!),
    0,
  ) / reviewsWithScores.length,
);
const stepikAverageRating = (
  STEPIK_COURSES.reduce(
    (sum, course) => sum + course.rating * course.reviewsCount,
    0,
  ) / totalStepikReviews
).toFixed(1);
const totalReviewCount = TUTORING_REVIEWS.length + totalStepikReviews;

const seo = {
  title:
    "Отзывы о подготовке к ЕГЭ и ОГЭ по химии — репетитор и курсы Stepik | ЕГЭХИМ",
  description:
    "Реальные отзывы учеников о репетиторстве, минигруппах и курсах Stepik по химии. Баллы до и после, скриншоты результатов и отзывы о подготовке к ЕГЭ и ОГЭ.",
};

const pageUrl = `${Astro.url.origin}/otzyvy-na-kursi/`;
const REVIEWS_FAQ = [
  {
    q: "Это реальные отзывы учеников?",
    a: "Да. На странице собраны отзывы учеников о подготовке, мини-группах, репетиторстве и курсах Stepik по химии.",
  },
  {
    q: "Можно посмотреть скриншоты результатов?",
    a: "Да. В отзывах со скриншотами есть кнопка открытия модального окна с подтверждениями и переписками.",
  },
  {
    q: "Отзывы относятся только к ЕГЭ?",
    a: "Нет. На странице есть отзывы по подготовке к ЕГЭ, ОГЭ, мини-группам, индивидуальным занятиям и самостоятельным курсам.",
  },
  {
    q: "Где смотреть отзывы о курсах Stepik?",
    a: "Отзывы и рейтинги курсов Stepik вынесены в отдельный блок на этой странице, рядом со ссылками на сами курсы.",
  },
];
const reviewsFaqJsonLd = buildFAQJsonLd(REVIEWS_FAQ);
const socialIconMap = {
  tg: "/images/technical/telegram.webp",
  vk: "/images/technical/vk.webp",
};
const getInitials = (name: string) =>
  name
    .split(" ")
    .map((part) => part.trim()[0])
    .filter(Boolean)
    .slice(0, 2)
    .join("");
const getReviewHref = (link: string, courseUrl: string, reviewsUrl?: string) =>
  link !== "#" ? link : (reviewsUrl ?? courseUrl);
const getStars = (rating: number) => "★".repeat(Math.round(rating));

const reviewSchema = TUTORING_REVIEWS.map((review, index) => ({
  "@type": "ListItem",
  position: index + 1,
  item: {
    "@type": "CreativeWork",
    name: `Отзыв ученика: ${review.name}`,
    author: {
      "@type": "Person",
      name: review.name,
    },
    text: review.text,
    url: review.socialUrl || pageUrl,
  },
}));

const jsonLd = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "CollectionPage",
      "@id": `${pageUrl}#webpage`,
      url: pageUrl,
      name: seo.title,
      description: seo.description,
      inLanguage: "ru-RU",
      mainEntity: {
        "@id": `${pageUrl}#reviews`,
      },
      about: [
        { "@type": "Thing", name: "ЕГЭ по химии" },
        { "@type": "Thing", name: "ОГЭ по химии" },
        { "@type": "Thing", name: "Отзывы о репетиторе по химии" },
        { "@type": "Thing", name: "Отзывы о курсах Stepik по химии" },
      ],
      primaryImageOfPage: {
        "@type": "ImageObject",
        url: `${Astro.url.origin}${featured.photo ?? "/images/mainpage/reviews/maks-photo.webp"}`,
      },
    },
    {
      "@type": "ItemList",
      "@id": `${pageUrl}#reviews`,
      name: "Отзывы учеников о подготовке к ЕГЭ и ОГЭ по химии",
      numberOfItems: TUTORING_REVIEWS.length,
      itemListElement: reviewSchema,
    },
    {
      "@type": "Course",
      "@id": `${pageUrl}#stepik-courses`,
      name: "Курсы Stepik по химии ЕГЭХИМ",
      provider: {
        "@type": "Person",
        name: "Валерий Филипенко",
      },
      aggregateRating: {
        "@type": "AggregateRating",
        ratingValue: stepikAverageRating,
        reviewCount: totalStepikReviews,
        bestRating: 5,
        worstRating: 1,
      },
    },
  ],
};
---

<AcademyLayout
  title={seo.title}
  description={seo.description}
  url={pageUrl}
  addSiteSuffix={false}
  image={featured.photo ?? "/images/mainpage/reviews/maks-photo.webp"}
  imageAlt="Отзывы учеников о подготовке к ЕГЭ и ОГЭ по химии"
  breadcrumbs={[
    { name: "Отзывы по химии" },
  ]}
  showBreadcrumbs={true}
  breadcrumbRoot="/"
  jsonLd={jsonLd}
  faqJsonLd={reviewsFaqJsonLd}
>
  <div class="reviews-v2">
    <section class="reviews-hero" aria-labelledby="reviews-title">
      <div class="gutter reviews-hero__inner">
        <AcademyBreadcrumbs
          class="mb-10"
          items={[
            { label: "ЕГЭХИМ", href: "/" },
            { label: "Отзывы" },
          ]}
        />

        <div class="reviews-hero__grid">
          <div>
            <div class="sec-num">[01] / отзывы</div>
            <h1 id="reviews-title" class="reviews-hero__title">
              Отзывы учеников о курсах, мини-группах и подготовке по химии
            </h1>
          </div>
          <div class="reviews-hero__copy">
            <p class="reviews-hero__seo">
              Реальные отзывы учеников о репетиторстве, мини-группах и курсах
              Stepik: с баллами до и после, ссылками на соцсети и скриншотами
              результатов.
            </p>
            <div class="reviews-hero__stats" aria-label="Статистика отзывов">
              <div>
                <b>{stepikAverageRating}</b>
                <span>средний рейтинг Stepik</span>
              </div>
              <div>
                <b>+{averageScoreGrowth}</b>
                <span>средний прирост баллов</span>
              </div>
              <div>
                <b>{totalReviewCount}</b>
                <span>отзывов и оценок</span>
              </div>
            </div>
          </div>
        </div>
      </div>
    </section>

    <section class="reviews-section" aria-labelledby="tutor-reviews-title">
      <div class="gutter">
        <EgeH2
          variant="academy"
          secNum="[02] / ученики"
          text="Репетиторство и мини-группы"
          id="tutor-reviews-title"
          description="Отзывы отсортированы так же, как на старой странице: выше идут истории с результатами, скриншотами и самым большим прогрессом."
        />

        {featured && (
          <article class="review-card review-card--featured">
            <div class="review-card__label">история года</div>
            <div class="review-card__head">
              <div class:list={["review-card__avatar", featured.photo && "review-card__avatar--image"]}>
                {featured.photo ? (
                  <img src={featured.photo} alt="" loading="lazy" decoding="async" />
                ) : (
                  getInitials(featured.name)
                )}
              </div>
              <div>
                <h3>{featured.name}</h3>
                <div class="review-card__meta">
                  {featured.tag && <span>{featured.tag}</span>}
                  {featured.exam && <span>{featured.exam}</span>}
                  {featured.socialUrl && (
                    <a href={featured.socialUrl} target="_blank" rel="noopener noreferrer">
                      написать
                    </a>
                  )}
                </div>
              </div>
            </div>

            <blockquote>{featured.text}</blockquote>

            {featured.before != null && featured.after != null && (
              <div class="review-score">
                <div>
                  <span>было</span>
                  <b>{featured.before}</b>
                </div>
                <i aria-hidden="true">→</i>
                <div>
                  <span>стало</span>
                  <b>{featured.after}</b>
                </div>
                <small>
                  прирост +{featured.after - featured.before}
                  {" "}
                  {featured.exam === "ОГЭ" ? "балла" : "баллов"}
                </small>
              </div>
            )}

            {featured.hasScreens && (
              <button
                class="review-screens"
                type="button"
                data-open-review-modal
                data-review-id={featured.id}
              >
                <span>▣</span>
                открыть скриншоты
              </button>
            )}
          </article>
        )}

        <div class="reviews-grid">
          {rest.map((review) => (
            <article class="review-card">
              <div class="review-card__head">
                <div class:list={["review-card__avatar", review.photo && "review-card__avatar--image"]}>
                  {review.photo ? (
                    <img src={review.photo} alt="" loading="lazy" decoding="async" />
                  ) : (
                    getInitials(review.name)
                  )}
                </div>
                <div>
                  <h3>{review.name}</h3>
                  <div class="review-card__meta">
                    {review.tag && <span>{review.tag}</span>}
                    {review.exam && <span>{review.exam}</span>}
                    {review.socialUrl && (
                      <a href={review.socialUrl} target="_blank" rel="noopener noreferrer">
                        {socialIconMap[review.social] && (
                          <img src={socialIconMap[review.social]} alt="" loading="lazy" decoding="async" />
                        )}
                        написать
                      </a>
                    )}
                  </div>
                </div>
              </div>

              <blockquote>{review.text}</blockquote>

              {review.before != null && review.after != null && (
                <div class="review-score">
                  <div>
                    <span>было</span>
                    <b>{review.before}</b>
                  </div>
                  <i aria-hidden="true">→</i>
                  <div>
                    <span>стало</span>
                    <b>{review.after}</b>
                  </div>
                  <small>
                    прирост +{review.after - review.before}
                    {" "}
                    {review.exam === "ОГЭ" ? "балла" : "баллов"}
                  </small>
                </div>
              )}

              {review.hasScreens && (
                <button
                  class="review-screens"
                  type="button"
                  data-open-review-modal
                  data-review-id={review.id}
                >
                  <span>▣</span>
                  {review.screens === 1 ? "скриншот результата" : `${review.screens} скриншота`}
                </button>
              )}
            </article>
          ))}
        </div>
      </div>
    </section>

    <section class="reviews-section reviews-section--alt" aria-labelledby="stepik-title">
      <div class="gutter">
        <EgeH2
          variant="academy"
          secNum="[03] / stepik"
          text="Отзывы о курсах Stepik"
          id="stepik-title"
          description="Курсы, рейтинги и отзывы перенесены из старой страницы. Длинные комментарии раскрываются прямо в карточке."
        />

        <div class="stepik-list">
          {STEPIK_COURSES.map((course) => (
            <section class="stepik-card" aria-labelledby={`${course.id}-title`}>
              <div class="stepik-card__head">
                <div>
                  <div class="stepik-card__kicker">
                    {course.access === "free" ? "бесплатный" : course.access === "paid" ? "платный" : "курс"} · Stepik
                  </div>
                  <h3 id={`${course.id}-title`}>{course.title}</h3>
                  <div class="stepik-card__rating" aria-label={`Рейтинг ${course.rating} из 5`}>
                    <span>{getStars(course.rating)}</span>
                    <b>{course.rating.toFixed(1)}</b>
                    <em>{course.reviewsCount} отзывов</em>
                    {course.studentsCount && <em>{course.studentsCount} учеников</em>}
                  </div>
                </div>
                <a href={course.url} target="_blank" rel="noopener noreferrer">
                  открыть курс
                </a>
              </div>

              <div class="stepik-reviews">
                {course.reviews.map((review, index) => (
                  <article class="stepik-review" data-stepik-review data-expanded="false">
                    <div class="stepik-review__head">
                      <b>{review.nick}</b>
                      <span aria-label={`${review.stars} звезд`}>
                        {"★".repeat(review.stars)}
                      </span>
                      <a
                        href={getReviewHref(review.link, course.url, course.reviewsUrl)}
                        target="_blank"
                        rel="noopener noreferrer"
                      >
                        отзыв
                      </a>
                    </div>
                    <p id={`${course.id}-review-${index}`} data-stepik-text>{review.text}</p>
                    <button
                      type="button"
                      hidden
                      data-stepik-toggle
                      aria-expanded="false"
                      aria-controls={`${course.id}-review-${index}`}
                    >
                      читать далее
                    </button>
                  </article>
                ))}
              </div>
            </section>
          ))}
        </div>
      </div>
    </section>

    <section class="reviews-seo">
      <div class="gutter">
        <h2>Отзывы о подготовке к ЕГЭ и ОГЭ по химии</h2>
        <p>
          На странице собраны отзывы учеников о подготовке к экзаменам по химии
          с Валерием Филипенко: индивидуальные занятия, мини-группы и
          самостоятельные курсы Stepik. В отзывах можно посмотреть стартовый
          уровень, итоговый результат, формат занятий и скриншоты подтверждений.
        </p>
        <p>
          Такой формат помогает заранее понять, кому подходит обучение в
          ЕГЭХИМ: школьникам с нуля, ученикам профильных классов, тем, кто
          готовится к ОГЭ, и выпускникам, которым нужен высокий балл для
          медицинских и химических направлений.
        </p>
      </div>
    </section>

    <AcademyFaq
      secNum="[04] / вопросы"
      title="Частые вопросы"
      description="Ответы на популярные вопросы об отзывах, скриншотах и курсах Stepik."
      items={REVIEWS_FAQ}
      alignList={true}
    />

    <dialog class="reviews-modal" id="reviews-modal" aria-label="Скриншоты отзыва">
      <div class="reviews-modal__box">
        <div class="reviews-modal__head">
          <div>
            <span>скриншоты</span>
            <h2 id="reviews-modal-name"></h2>
          </div>
          <button type="button" id="reviews-modal-close" aria-label="Закрыть">×</button>
        </div>
        <div class="reviews-modal__stage">
          <button type="button" id="reviews-modal-prev" aria-label="Предыдущий скрин">←</button>
          <figure>
            <img id="reviews-modal-image" src="" alt="" />
            <figcaption id="reviews-modal-counter"></figcaption>
          </figure>
          <button type="button" id="reviews-modal-next" aria-label="Следующий скрин">→</button>
        </div>
      </div>
    </dialog>
  </div>
</AcademyLayout>

<script is:inline define:vars={{ screensModalData }}>
  const modal = document.getElementById("reviews-modal");
  const modalName = document.getElementById("reviews-modal-name");
  const modalCounter = document.getElementById("reviews-modal-counter");
  const modalClose = document.getElementById("reviews-modal-close");
  const modalPrev = document.getElementById("reviews-modal-prev");
  const modalNext = document.getElementById("reviews-modal-next");
  const modalImage = document.getElementById("reviews-modal-image");

  let currentIndex = 0;
  let currentReview = null;

  const updateModal = () => {
    if (!currentReview || !modalImage) return;
    const image = currentReview.images[currentIndex] || "";
    modalImage.src = image;
    modalImage.alt = `${currentReview.name} — скриншот ${currentIndex + 1}`;
    if (modalCounter) {
      modalCounter.textContent = `${String(currentIndex + 1).padStart(2, "0")} / ${String(currentReview.screens).padStart(2, "0")}`;
    }
  };

  const openModal = (reviewId) => {
    const review = screensModalData.find((item) => item.id === reviewId);
    if (!review || !modal) return;
    currentReview = review;
    currentIndex = 0;
    if (modalName) modalName.textContent = review.name;
    updateModal();
    modal.showModal();
    document.documentElement.classList.add("is-modal-open");
    document.body.classList.add("is-modal-open");
  };

  const closeModal = () => {
    if (!modal) return;
    modal.close();
    document.documentElement.classList.remove("is-modal-open");
    document.body.classList.remove("is-modal-open");
  };

  const step = (direction) => {
    if (!currentReview) return;
    currentIndex =
      (currentIndex + direction + currentReview.screens) % currentReview.screens;
    updateModal();
  };

  document.addEventListener("click", (event) => {
    const trigger = event.target.closest("[data-open-review-modal]");
    if (!trigger) return;
    openModal(Number(trigger.dataset.reviewId));
  });

  modalClose?.addEventListener("click", closeModal);
  modalPrev?.addEventListener("click", () => step(-1));
  modalNext?.addEventListener("click", () => step(1));
  modal?.addEventListener("click", (event) => {
    if (event.target === modal) closeModal();
  });
  modal?.addEventListener("cancel", closeModal);

  document.addEventListener("keydown", (event) => {
    if (!modal?.open) return;
    if (event.key === "ArrowLeft") step(-1);
    if (event.key === "ArrowRight") step(1);
  });

  const syncStepikReview = (card) => {
    const text = card.querySelector("[data-stepik-text]");
    const toggle = card.querySelector("[data-stepik-toggle]");
    if (!text || !toggle) return;

    const expanded = card.dataset.expanded === "true";
    const overflowing = text.scrollHeight - text.clientHeight > 1;
    toggle.hidden = expanded ? false : !overflowing;
    toggle.textContent = expanded ? "свернуть" : "читать далее";
    toggle.setAttribute("aria-expanded", expanded ? "true" : "false");
  };

  const setupStepikReviews = () => {
    document.querySelectorAll("[data-stepik-review]").forEach((card) => {
      const toggle = card.querySelector("[data-stepik-toggle]");
      if (!toggle || toggle.dataset.bound === "true") {
        syncStepikReview(card);
        return;
      }

      toggle.dataset.bound = "true";
      toggle.addEventListener("click", () => {
        card.dataset.expanded = card.dataset.expanded === "true" ? "false" : "true";
        requestAnimationFrame(() => syncStepikReview(card));
      });
      requestAnimationFrame(() => syncStepikReview(card));
    });
  };

  if (document.readyState === "loading") {
    document.addEventListener("DOMContentLoaded", setupStepikReviews, { once: true });
  } else {
    setupStepikReviews();
  }
  window.addEventListener("resize", setupStepikReviews, { passive: true });
</script>

<style>
  .reviews-v2 {
    background: var(--paper);
  }

  .reviews-hero {
    position: relative;
    overflow: hidden;
    border-bottom: 1px solid var(--line);
  }

  .reviews-hero::before {
    content: "";
    position: absolute;
    inset: 0;
    background-image:
      linear-gradient(var(--line) 1px, transparent 1px),
      linear-gradient(90deg, var(--line) 1px, transparent 1px);
    background-size: 56px 56px;
    opacity: 0.38;
    pointer-events: none;
  }

  .reviews-hero__inner {
    position: relative;
    padding-top: var(--academy-hero-y-start);
    padding-bottom: var(--academy-hero-y-end);
  }

  .reviews-hero__grid {
    display: grid;
    grid-template-columns: minmax(0, 1.45fr) minmax(320px, 0.55fr);
    gap: var(--academy-gap-lg);
    align-items: end;
  }

  .reviews-hero__title {
    margin: 10px 0 0;
    font-family: var(--academy-font-display);
    font-size: var(--academy-hero-title);
    font-weight: 700;
    line-height: 0.9;
    letter-spacing: -0.035em;
    color: var(--ink);
  }

  .reviews-hero__copy {
    display: grid;
    gap: 24px;
  }

  .reviews-hero__seo {
    margin: 0;
    font-family: var(--academy-font-mono);
    font-size: var(--academy-body-sm);
    line-height: 1.65;
    color: var(--inkSoft);
  }

  .reviews-hero__stats {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 1px;
    border: 1px solid var(--line);
    background: var(--line);
  }

  .reviews-hero__stats div {
    min-height: var(--academy-meta-cell-min-h);
    padding: 14px;
    background: #fffdf7;
  }

  .reviews-hero__stats b {
