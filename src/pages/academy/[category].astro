---
// src/pages/academy/[category].astro
import MainLayout from "../../layouts/MainLayout.astro";
import config, { categoryDescriptions } from "../../config.ts";
import { getCollection } from "astro:content";
import CardNew from "../../components/cards/cardNew.astro";
import Pagination from "../../components/Pagination.astro";
import FaqSection from "../../components/mainpage/Faq.astro";
import UnifiedMenu from "../../components/UnifiedMenu.astro";
import H2Zag from "../../components/text/h2zag.astro";
import { slugify } from "../../lib/slugify";

export async function getStaticPaths() {
  const posts = await getCollection("articles", ({ data }) => {
    return data.visible !== false;
  });
  const categories = Array.from(
    new Set(posts.map((p) => p.data.category)),
  ).filter(Boolean);
  return categories.map((original) => ({
    params: { category: slugify(String(original)) },
  }));
}

const { category: slug } = Astro.params;

const allRaw = await getCollection("articles", ({ data }) => {
  return data.visible !== false;
});

const all = allRaw;

// найти оригинальное имя категории по слагу
let originalCategory = undefined as string | undefined;
for (const p of all) {
  const cat = p.data.category;
  if (cat && slugify(String(cat)) === slug) {
    originalCategory = String(cat);
    break;
  }
}

const toDate = (v: any) => (v instanceof Date ? v : new Date(v));
const posts = (
  originalCategory
    ? all.filter((p) => p.data.category === originalCategory)
    : []
).sort((a, b) => toDate(b.data.date).getTime() - toDate(a.data.date).getTime());

// SEO данные (нужны раньше, чтобы взять featuredSlug)
const catKey = String(originalCategory || "").toLowerCase();
const seoData = catKey ? categoryDescriptions[catKey] : null;

// Выбор редакции: по slug из конфига, иначе — первая статья категории
const featuredSlug = seoData?.featuredSlug;
const featuredPost = featuredSlug
  ? (all.find((p) => p.slug === featuredSlug) ?? posts[0])
  : posts[0];

// Основной поток — все статьи категории (featured НЕ убирается)
const streamPosts = posts;

// Пагинация
const PER_PAGE = 8;
const currentPage = Math.max(
  1,
  Number(Astro.url.searchParams.get("page") || "1"),
);
const totalPages = Math.max(1, Math.ceil(streamPosts.length / PER_PAGE));
const pagedCards = streamPosts.slice(
  (currentPage - 1) * PER_PAGE,
  currentPage * PER_PAGE,
);


const siteUrl = (Astro.site?.href ?? config.siteUrl).replace(/\/$/, "");
const pageTitle = originalCategory ?? "";
const seoTitle =
  seoData?.title || `Все статьи в категории «${pageTitle}» — Академия ЕГЭХИМ`;
const pageDesc =
  seoData?.shortDesc ||
  `Все статьи в категории «${originalCategory ?? ""}»: понятные объяснения, примеры, советы и подборки материалов по теме.`;
const pageUrl = `${siteUrl}/academy/${encodeURIComponent(slug)}/`;
const breadcrumbs = [{ name: pageTitle, href: pageUrl }];
const totalArticles = posts.length;

// Топ-8 тегов категории
const allTags = posts.flatMap((p) =>
  Array.isArray(p.data.tags) ? p.data.tags : [],
);
const tagCounts = allTags.reduce<Record<string, number>>(
  (acc, tag) => {
    acc[tag] = (acc[tag] || 0) + 1;
    return acc;
  },
  {},
);
const popularTags = Object.entries(tagCounts)
  .sort((a, b) => b[1] - a[1])
  .slice(0, 8)
  .map((t) => t[0]);

// FAQ + Schema
const faqItems = seoData?.faq ?? [];
let faqJsonLd = null;
if (faqItems.length > 0) {
  faqJsonLd = {
    "@context": "https://schema.org",
    "@type": "FAQPage",
    mainEntity: faqItems.map((item) => ({
      "@type": "Question",
      name: item.q,
      acceptedAnswer: { "@type": "Answer", text: item.a },
    })),
  };
}

// Данные Featured для карточки
const featuredHref = featuredPost
  ? `/academy/${slugify(featuredPost.data.category ?? "")}/${featuredPost.slug}`
  : undefined;
const featuredDate = featuredPost?.data.date
  ? new Date(featuredPost.data.date).toLocaleDateString("ru-RU", {
      day: "2-digit",
      month: "2-digit",
      year: "numeric",
    })
  : undefined;
---

<MainLayout
  title={seoTitle}
  description={pageDesc}
  addSiteSuffix={false}
  url={`${pageUrl}${currentPage > 1 ? `?page=${currentPage}` : ""}`}
  image={posts[0]?.data?.image || "/images/technical/og-home.png"}
  prevUrl={currentPage > 1 ? `${pageUrl}?page=${currentPage - 1}` : undefined}
  nextUrl={currentPage < totalPages
    ? `${pageUrl}?page=${currentPage + 1}`
    : undefined}
  breadcrumbs={breadcrumbs}
  showBreadcrumbs={false}
  showNav={false}
  index={false}
  faqJsonLd={faqJsonLd}
>
  <!-- ===================== BENTO DARK HERO ===================== -->
  <section class="cat-hero" aria-labelledby="category-title">
    <!-- Меню внутри hero -->
    <div class="cat-hero__menu">
      <UnifiedMenu
        context="media"
        logoSrc="/images/technical/egehim(academy).webp"
        logoAlt="ЕГЭХИМ — академия"
        ctaHref="/allcourses"
        pageUtmSource="academy"
      />
    </div>

    <!-- Breadcrumbs внутри hero -->
    <nav class="hero-breadcrumbs container" aria-label="Breadcrumb">
      <ol class="hero-breadcrumbs__list">
        <li class="hero-breadcrumbs__item">
          <a href="/academy/" class="hero-breadcrumbs__link">
            <svg
              xmlns="http://www.w3.org/2000/svg"
              viewBox="0 0 24 24"
              aria-label="Главная"
              class="hero-breadcrumbs__home-icon"
            >
              <path fill="currentColor" d="M12 3l9 8h-3v9h-4v-6H10v6H6v-9H3z"
              ></path>
            </svg>
          </a>
        </li>
        <li class="hero-breadcrumbs__item">
          <a href="/academy/" class="hero-breadcrumbs__link">Академия</a>
        </li>
        <li
          class="hero-breadcrumbs__item hero-breadcrumbs__item--current"
          aria-current="page"
        >
          {pageTitle}
        </li>
      </ol>
    </nav>

    <div class="cat-hero__bento container">
      <!-- ЛЕВАЯ КОЛОНКА: Заголовок + описание -->
      <div class="bento-tile bento-tile--main">
        <span class="bento-badge"
          >Академия ЕГЭХИМ · {totalArticles} материалов</span
        >
        <h1 id="category-title" class="bento-title">{pageTitle}</h1>
        <p class="bento-desc">{pageDesc}</p>
      </div>

      <!-- ПРАВАЯ КОЛОНКА: Featured (сверху) + Теги (снизу) -->
      <div class="bento-right">
        <!-- Выбор редакции -->
        {
          featuredPost && featuredHref && (
            <a
              href={featuredHref}
              class="bento-tile bento-tile--featured"
              aria-label={`Читать: ${featuredPost.data.title}`}
            >
              <div class="bfeat__body">
                <span class="bfeat__label">⭐ Выбор редакции</span>
                <h2 class="bfeat__title">{featuredPost.data.title}</h2>
                {featuredPost.data.description && (
                  <p class="bfeat__desc">{featuredPost.data.description}</p>
                )}
                {featuredDate && (
                  <span class="bfeat__date">{featuredDate}</span>
                )}
              </div>
            </a>
          )
        }

        <!-- Теги -->
        {
          popularTags.length > 0 && (
            <div class="bento-tile bento-tile--tags">
              <span class="bento-tile__label">Популярные темы</span>
              <ul class="btags__list">
                {popularTags.map((tag) => (
                  <li>
                    <a href={`/academy/tags/${slugify(tag)}`} class="btag">
                      {tag}
                    </a>
                  </li>
                ))}
              </ul>
            </div>
          )
        }
      </div>
    </div>
  </section>

  <!-- ===================== СТАТЬИ ===================== -->
  <section class="main-cards" role="region" aria-labelledby="articles-heading">
    <div class="main-cards__inner container">
      <H2Zag title={`Материалы по теме: ${pageTitle}`} subtitle="Популярные статьи и материалы по этой теме для успешной сдачи ЕГЭ по химии!" headingId="articles-heading" />
      <div class="left-block__grid" id="grid-initial">
        {
          pagedCards.map((post) => (
            <div class="ad-media__card">
              <CardNew post={post} basePath="/academy" />
            </div>
          ))
        }
      </div>


    </div>
              <Pagination
        currentPage={currentPage}
        totalPages={totalPages}
        pathname={Astro.url.pathname}
        perPage={PER_PAGE}
      />
  </section>


  {/* Шаблоны карточек */}
  {
    streamPosts.map((post) => (
      <template id={`tmpl-${post.slug}`}>
        <div class="ad-media__card">
          <CardNew post={post} basePath="/academy" />
        </div>
      </template>
    ))
  }


  <!-- ===================== SEO ТЕКСТ ===================== -->
  {
    seoData?.seoText && (
      <section class="seo-block" aria-label="О разделе">
        <div class="seo-block__wrap container">
          <div class="seo-block__card">
            <H2Zag title={`О разделе: ${pageTitle}`} />
            <div class="seo-block__body">
              {seoData.seoText
                .trim()
                .split(/\n\n+/)
                .map((para) => (
                  <p>{para.trim()}</p>
                ))}
            </div>
          </div>
        </div>
      </section>
    )
  }

  <!-- ===================== РОАДМАП ===================== -->
  {
    seoData?.roadmap && (
      <section
        class="roadmap-section"
        aria-labelledby="roadmap-heading"
      >
        <div class="container">
        <div class="roadmap-section__inner">
          <H2Zag
            title={seoData.roadmap.title}
            subtitle={seoData.roadmap.subtitle}
            headingId="roadmap-heading"
          />
          <ol class="roadmap__list">
            {seoData.roadmap.steps.map(({ title, desc }, i) => (
              <li class="roadmap__item">
                <div class="roadmap__step-num">{i + 1}</div>
                <div class="roadmap__connector" aria-hidden="true" />
                <div class="roadmap__content">
                  <span class="roadmap__item-title">{title}</span>
                  <span class="roadmap__item-desc">{desc}</span>
                </div>
              </li>
            ))}
          </ol>
        </div>
        </div>
      </section>
    )
  }

  <!-- ===================== СТАТИСТИКА ЕГЭ ===================== -->
  {
    seoData?.examStats && (
      <section class="examstats">
        <div class="examstats__body container" aria-labelledby="examstats-heading">
        <H2Zag
          title={seoData.examStats.title}
          subtitle={seoData.examStats.subtitle}
          headingId="examstats-heading"
        />

        <!-- Две стат-карточки -->
        <div class="examstats__top">
          <!-- Карточка: кол-во заданий -->
          <div class="examstats__card examstats__card--tasks">
            <div class="examstats__card-body">
              <span class="examstats__big-num">{seoData.examStats.tasksCount}</span>
              <span class="examstats__label">заданий</span>
              <p class="examstats__card-desc">{seoData.examStats.tasksDesc}</p>
            </div>
            <div class="examstats__card-icon" aria-hidden="true">
              <svg viewBox="0 0 64 64" fill="none" xmlns="http://www.w3.org/2000/svg">
                <rect x="8" y="8" width="48" height="48" rx="10" fill="currentColor" opacity="0.12"/>
                <rect x="16" y="20" width="32" height="4" rx="2" fill="currentColor" opacity="0.6"/>
                <rect x="16" y="30" width="24" height="4" rx="2" fill="currentColor" opacity="0.4"/>
                <rect x="16" y="40" width="20" height="4" rx="2" fill="currentColor" opacity="0.25"/>
                <circle cx="48" cy="44" r="10" fill="currentColor" opacity="0.9"/>
                <path d="M44 44l2.5 2.5L52 41" stroke="white" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
              </svg>
            </div>
          </div>

          <!-- Карточка: баллы -->
          <div class="examstats__card examstats__card--points">
            <div class="examstats__card-body">
              <span class="examstats__big-num">{seoData.examStats.maxPoints}</span>
              <span class="examstats__label">первичных баллов</span>
              <p class="examstats__card-desc">{seoData.examStats.pointsDesc}</p>
            </div>
            <div class="examstats__card-icon" aria-hidden="true">
              <svg viewBox="0 0 64 64" fill="none" xmlns="http://www.w3.org/2000/svg">
                <circle cx="32" cy="32" r="26" fill="currentColor" opacity="0.1"/>
                <path d="M32 14v4M32 46v4M14 32h4M46 32h4" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" opacity="0.4"/>
                <circle cx="32" cy="32" r="12" fill="currentColor" opacity="0.2"/>
                <path d="M28 32l3 3 6-6" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"/>
                <path d="M32 22v4M32 38v4M22 32h4M38 32h4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" opacity="0.2"/>
              </svg>
            </div>
          </div>
        </div>

        <!-- Большая карточка: разбивка по заданиям -->
        <div class="examstats__breakdown">
          <div class="examstats__breakdown-header">
            <span class="examstats__breakdown-col examstats__breakdown-col--num">№</span>
            <span class="examstats__breakdown-col examstats__breakdown-col--title">Задание</span>
            <span class="examstats__breakdown-col examstats__breakdown-col--pts">Баллы</span>
          </div>
          <ul class="examstats__task-list">
            {seoData.examStats.tasks.map(({ number, title, points, desc }) => (
              <li class="examstats__task">
                <div class="examstats__task-num">{number}</div>
                <div class="examstats__task-body">
                  <span class="examstats__task-title">{title}</span>
                  <span class="examstats__task-desc" set:html={desc} />
                </div>
                <div class={`examstats__task-pts examstats__task-pts--${points >= 3 ? "high" : points === 2 ? "mid" : "low"}`}>
                  {points}
                </div>
              </li>
            ))}
          </ul>
          <div class="examstats__breakdown-footer">
            <span class="examstats__total-label">Итого по неорганике</span>
            <span class="examstats__total-pts">{seoData.examStats.maxPoints} баллов</span>
          </div>
        </div>
        </div>
      </section>
    )
  }

  <!-- ===================== FAQ ===================== -->

  {
    faqItems.length > 0 && (
      <FaqSection
        id={`faq-${slug}`}
        title="Частые вопросы о разделе"
        subtitle="Вопросы о том, как готовиться к ЕГЭ"
        items={faqItems.map((f) => ({ q: f.q, a: f.a }))}
      />
    )
  }
</MainLayout>
<style>
  :global(body.academy-page) {
    background-color: #eef2ff;
    background-image:
      /* Сетка */
      linear-gradient(rgba(54, 110, 240, 0.055) 1px, transparent 1px),
      linear-gradient(90deg, rgba(54, 110, 240, 0.055) 1px, transparent 1px),
      /* Блок 1 — герой */
      radial-gradient(ellipse 45% 14% at 8% 8%,   rgba(54, 110, 240, 0.13) 0%, transparent 100%),
      radial-gradient(ellipse 40% 12% at 92% 17%,  rgba(100, 149, 255, 0.09) 0%, transparent 100%),
      /* Блок 2 — статьи */
      radial-gradient(ellipse 42% 13% at 90% 30%,  rgba(54, 110, 240, 0.10) 0%, transparent 100%),
      radial-gradient(ellipse 38% 11% at 10% 38%,  rgba(130, 100, 255, 0.08) 0%, transparent 100%),
      /* Блок 3 — роадмап */
      radial-gradient(ellipse 45% 14% at 8% 52%,   rgba(54, 110, 240, 0.10) 0%, transparent 100%),
      radial-gradient(ellipse 40% 12% at 92% 60%,  rgba(100, 149, 255, 0.08) 0%, transparent 100%),
      /* Блок 4 — статистика */
      radial-gradient(ellipse 42% 13% at 88% 72%,  rgba(54, 110, 240, 0.09) 0%, transparent 100%),
      radial-gradient(ellipse 38% 11% at 12% 78%,  rgba(130, 100, 255, 0.07) 0%, transparent 100%),
      /* Блок 5 — SEO текст */
      radial-gradient(ellipse 45% 14% at 10% 90%,  rgba(54, 110, 240, 0.10) 0%, transparent 100%),
      radial-gradient(ellipse 40% 12% at 90% 96%,  rgba(100, 149, 255, 0.08) 0%, transparent 100%),
      /* Базовый градиент */
      linear-gradient(165deg, #eef2ff 0%, #f7faff 40%, #ffffff 65%, #f0f5ff 85%, #edf4ff 100%);
    background-size:
      44px 44px, 44px 44px,
      100% 100%, 100% 100%, 100% 100%, 100% 100%,
      100% 100%, 100% 100%, 100% 100%, 100% 100%,
      100% 100%, 100% 100%, 100% 100%;
  }

  :global(body.academy-page .page-stack) {
    row-gap: 0;
  }

  /* ============================================================
     HERO BREADCRUMBS
  ============================================================ */
  .hero-breadcrumbs {
    position: relative;
    z-index: 2;
    padding-top: 0;
    padding-bottom: 18px;
  }

  .hero-breadcrumbs__list {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 6px;
  }

  .hero-breadcrumbs__item {
    display: inline-flex;
    align-items: center;
    font-size: 12px;
    color: rgba(0, 0, 0, 0.35);
  }

  .hero-breadcrumbs__item::after {
    content: "›";
    margin-left: 6px;
    color: rgba(0, 0, 0, 0.2);
  }

  .hero-breadcrumbs__item:last-child::after {
    content: "";
  }

  .hero-breadcrumbs__item--current {
    color: rgba(0, 0, 0, 0.5);
  }

  .hero-breadcrumbs__link {
    color: rgba(0, 0, 0, 0.4);
    text-decoration: none;
    transition: color 0.15s ease;
    display: inline-flex;
    align-items: center;
  }

  .hero-breadcrumbs__link:hover {
    color: var(--blue, #366ef0);
    text-decoration: none;
  }

  .hero-breadcrumbs__home-icon {
    width: 14px;
    height: 14px;
  }

  /* ============================================================
     LIGHT BENTO HERO
  ============================================================ */
  .cat-hero {
    position: relative;
    overflow: clip;
    width: 100vw;
    margin-inline: calc(50% - 50vw);
    padding-bottom: 48px;
  }

  .cat-hero__menu {
    position: relative;
    z-index: 10;
  }
  .cat-hero__menu :global(header) {

    margin-bottom: 20px;
  }

  /* ---- Bento Grid: 2 колонки ---- */
  .cat-hero__bento {
    position: relative;
    z-index: 2;
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 16px;
    align-items: stretch;
  }

  /* Правая колонка — стек из 2 плиток */
  .bento-right {
    display: flex;
    flex-direction: column;
    gap: 16px;
  }

  /* ---- Общие стили плитки ---- */
  .bento-tile {
    background: rgba(255, 255, 255, 0.7);
    border: 1px solid rgba(54, 110, 240, 0.12);
    border-radius: 20px;
    padding: 28px 28px;
    backdrop-filter: blur(8px);
    transition: border-color 0.2s ease, box-shadow 0.2s ease;
  }

  .bento-tile:hover {
    border-color: rgba(54, 110, 240, 0.3);
    box-shadow: 0 4px 24px rgba(54, 110, 240, 0.08);
  }

  /* ---- ПЛИТКА 1: Заголовок (левая колонка) ---- */
  .bento-tile--main {
    display: flex;
    flex-direction: column;
    justify-content: flex-start;
    min-height: 320px;
  }

  .bento-badge {
    display: inline-block;
    padding: 4px 12px;
    border: 1px solid rgba(54, 110, 240, 0.3);
    border-radius: 999px;
    font-size: 11px;
    font-weight: 600;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--blue, #366ef0);
    margin-bottom: 20px;
    width: fit-content;
    background: rgba(54, 110, 240, 0.06);
  }

  .bento-title {
    font-size: clamp(28px, 4vw, 54px);
    font-weight: 900;
    line-height: 1;
    letter-spacing: -0.02em;
    color: #0d1117;
    margin: 0 0 16px;
    text-transform: uppercase;
  }

  .bento-desc {
    font-size: clamp(13px, 1.2vw, 15px);
    color: rgba(0, 0, 0, 0.5);
    line-height: 1.6;
    margin: 0;
  }

  /* ---- ПЛИТКА 2: Featured Article (правая колонка, верх) ---- */
  .bento-tile--featured {
    display: flex;
    flex-direction: column;
    gap: 0;
    text-decoration: none;
    overflow: hidden;
    cursor: pointer;
    flex: 1;
  }

  .bento-tile--featured:hover {
    text-decoration: none;
  }

  .bfeat__body {
    display: flex;
    flex-direction: column;
    gap: 8px;
    flex: 1;
  }

  .bfeat__label {
    font-size: 11px;
    font-weight: 700;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--blue, #366ef0);
    width: fit-content;
  }

  .bfeat__title {
    font-size: clamp(15px, 1.4vw, 18px);
    font-weight: 700;
    color: #0d1117;
    line-height: 1.3;
    margin: 0;
    display: -webkit-box;
    -webkit-line-clamp: 3;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  .bfeat__desc {
    font-size: 13px;
    color: rgba(0, 0, 0, 0.5);
    line-height: 1.5;
    margin: 0;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  .bfeat__date {
    font-size: 12px;
    color: rgba(0, 0, 0, 0.3);
    margin-top: auto;
  }

  /* ---- ПЛИТКА 3: Теги (правая колонка, низ) ---- */
  .bento-tile--tags {
    display: flex;
    flex-direction: column;
    gap: 14px;
    flex-shrink: 0;
  }

  .bento-tile__label {
    font-size: 11px;
    font-weight: 700;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: rgba(0, 0, 0, 0.35);
