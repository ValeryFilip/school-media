---
import AcademyLayout from "../../layouts/AcademyLayout.astro";
import AcademyHero from "../../components/academy/AcademyHero.astro";
import AcademyCategories from "../../components/academy/AcademyCategories.astro";
import AcademyLatest from "../../components/academy/AcademyLatest.astro";
import AcademyLibrary from "../../components/academy/AcademyLibrary.astro";
import AcademyTags from "../../components/academy/AcademyTags.astro";
import AcademyCoursePromo from "../../components/academy/AcademyCoursePromo.astro";
import { getCollection } from "astro:content";
import {
  academyArticlePath,
  academyArticlesPath,
  academyCategoryPath,
  academyPath,
  academyTagPath,
} from "../../lib/academyPaths";

const toDate = (v: any) => (v instanceof Date ? v : new Date(v));
const allPosts = (
  await getCollection("articles", ({ data }) => data.visible !== false)
).sort((a, b) => toDate(b.data.date).getTime() - toDate(a.data.date).getTime());

const total = allPosts.length;

// --- helpers ---
const pad = (n: number) => String(n).padStart(2, "0");
const fmtFull = (d: Date) =>
  `${pad(d.getDate())}.${pad(d.getMonth() + 1)}.${d.getFullYear()}`;
const fmtShort = (d: Date) => `${pad(d.getDate())}.${pad(d.getMonth() + 1)}`;
const articleHref = (p: any) =>
  academyArticlePath(String(p.data.category), p.slug);
const mins = (p: any) => p.data.readingTime ?? 8;

// --- категории (по реальным статьям) ---
const SYM: Record<string, string> = {
  "Школьникам": "Шк",
  "Новости": "Нв",
  "Родителям": "Рд",
  "Задачи в химии": "34",
  "Экзамен ЕГЭ": "ЕГ",
  "Поступление в ВУЗ": "Вз",
  "Органическая химия": "Ог",
  "Задания из ЕГЭ по химии": "Зэ",
  "Неорганическая химия": "Нг",
  "Общая химия": "Об",
};
const catCounts = new Map<string, number>();
for (const p of allPosts) {
  const c = String(p.data.category || "").trim();
  if (!c) continue;
  catCounts.set(c, (catCounts.get(c) || 0) + 1);
}
const catsSorted = [...catCounts.entries()].sort((a, b) => b[1] - a[1]);
const categories = catsSorted.map(([name, count], i) => ({
  num: pad(i + 1),
  sym: SYM[name] ?? name.slice(0, 2),
  name,
  count,
  href: academyCategoryPath(name),
  highlight: i < 2,
}));

// --- свежая статья ---
const latestPost = allPosts[0];
const latest = latestPost
  ? {
      href: articleHref(latestPost),
      category: latestPost.data.category,
      mins: mins(latestPost),
      title: latestPost.data.title,
      description: latestPost.data.description ?? "",
      date: fmtFull(toDate(latestPost.data.date)),
      image: latestPost.data.image ?? "",
    }
  : null;

// --- последние 8 (исключая свежую) ---
const libraryPosts = allPosts.slice(1, 9);
const library = libraryPosts.map((p, i) => ({
  href: articleHref(p),
  category: p.data.category,
  date: fmtShort(toDate(p.data.date)),
  mins: mins(p),
  title: p.data.title,
  description: p.data.description ?? "",
  image: p.data.image ?? "",
  illoIndex: i,
}));

// --- облако тегов ---
const tagCounts = new Map<string, number>();
for (const p of allPosts) {
  for (const t of p.data.tags ?? []) {
    const k = String(t).trim();
    if (!k) continue;
    tagCounts.set(k, (tagCounts.get(k) || 0) + 1);
  }
}
const tagsSorted = [...tagCounts.entries()].sort((a, b) => b[1] - a[1]);
const tags = tagsSorted.slice(0, 20).map(([name, count]) => ({
  name,
  count,
  href: academyTagPath(name),
}));
const quickTags = tags.slice(0, 6).map((t) => ({ name: t.name, href: t.href }));

const updated = latestPost ? fmtFull(toDate(latestPost.data.date)) : "";

const pageTitle = "Академия ЕГЭХИМ — статьи и разборы по химии для ЕГЭ и ОГЭ";
const pageDesc = `Архив из ${total} материалов: разборы заданий ЕГЭ и ОГЭ, формулы и реакции с выведением, конспекты тем ФИПИ. Пишет Валерий Филипенко — автор курсов с собственным ЕГЭ на 100 баллов.`;

const siteUrl = (Astro.url.origin).replace(/\/$/, "");
const pageUrl = `${siteUrl}${academyPath()}`;

// CollectionPage JSON-LD: помогает Google понять, что это listing-страница
// со списком статей. mainEntity → ItemList из верхних 10 материалов.
const collectionPageJsonLd = {
  "@context": "https://schema.org",
  "@type": "CollectionPage",
  "@id": `${pageUrl}#collection`,
  url: pageUrl,
  name: pageTitle,
  description: pageDesc,
  inLanguage: "ru",
  isPartOf: { "@id": `${siteUrl}/#website` },
  mainEntity: {
    "@type": "ItemList",
    numberOfItems: total,
    itemListElement: allPosts.slice(0, 10).map((p, i) => ({
      "@type": "ListItem",
      position: i + 1,
      url: `${siteUrl}${articleHref(p)}`,
      name: p.data.title,
    })),
  },
};
---

<AcademyLayout
  title={pageTitle}
  description={pageDesc}
  image="/images/new-design/academy-main.webp"
  imageAlt="Академия ЕГЭХИМ — статьи и разборы по химии"
  url={pageUrl}
  addSiteSuffix={false}
  index={true}
  breadcrumbs={[{ name: "Академия", href: pageUrl }]}
  showBreadcrumbs={true}
  jsonLd={[collectionPageJsonLd]}
>
  <AcademyHero
    articlesCount={total}
    categoriesCount={categories.length}
    tagsCount={tags.length}
    updated={updated}
    latest={latest ? { title: latest.title, date: latest.date } : { title: "", date: "" }}
    quickTags={quickTags}
    searchArticles={allPosts}
  />
  <AcademyCategories categories={categories} total={total} />
  {latest && <AcademyLatest {...latest} />}
  <AcademyLibrary articles={library} total={total} allHref={academyArticlesPath()} />
  <AcademyTags tags={tags} />
  <AcademyCoursePromo />
</AcademyLayout>
