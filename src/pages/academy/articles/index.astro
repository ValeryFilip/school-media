---
import AcademyLayout from "../../../layouts/AcademyLayout.astro";
import AcademyListHero from "../../../components/academy/AcademyListHero.astro";
import AcademyArticleGrid from "../../../components/academy/AcademyArticleGrid.astro";
import config from "../../../config.ts";
import { getCollection } from "astro:content";
import { articleCard, toDate, fmtFull, readMins } from "../../../lib/academyArticles.ts";
import { ACADEMY_BASE_PATH, academyArticlesPath, academyPath } from "../../../lib/academyPaths";

const allPosts = (
  await getCollection("articles", ({ data }) => data.visible !== false)
).sort((a, b) => toDate(b.data.date).getTime() - toDate(a.data.date).getTime());

const articles = allPosts.map((post) => articleCard(post, ACADEMY_BASE_PATH));

const categories = Array.from(
  new Set(articles.map((a) => a.category).filter(Boolean)),
).sort((a, b) => a.localeCompare(b, "ru"));
const tags = Array.from(
  new Set(articles.flatMap((a) => a.tags).filter(Boolean)),
).sort((a, b) => a.localeCompare(b, "ru"));

const total = articles.length;
const totalMins = allPosts.reduce((s, p) => s + readMins(p), 0);
const updated = allPosts[0] ? fmtFull(toDate(allPosts[0].data.date)) : "";

const stats = [
  { value: total, label: "материалов", accent: "rust" as const },
  { value: categories.length, label: "категорий" },
  { value: tags.length, label: "тегов", accent: "inkBlue" as const },
  { value: totalMins, label: "мин чтения" },
];

const marquee = [
  "// архив · все материалы академии",
  `${total} статей · ${categories.length} категорий`,
  "фильтруй по теме, категории и дате",
];

const siteUrl = (Astro.site?.href ?? config.siteUrl).replace(/\/$/, "");
// Canonical целится в финальный URL: v2 скоро заедет на /academy/articles/
// (как было с organika/неорганика — старая версия в _old-backup/),
// поэтому ставим целевой путь сейчас, чтобы при переезде не делать
// re-indexing.
const pageUrl = `${siteUrl}${academyArticlesPath()}`;
const pageTitle = "Все статьи по химии";
const pageDesc = `Архив из ${total} материалов Академии ЕГЭХИМ — теория, разборы заданий, формулы и задачи. Фильтруй по категории, тегу, дате или ищи по названию.`;
---

<AcademyLayout
  title={pageTitle}
  siteName="Академия ЕГЭХИМ"
  description={pageDesc}
  url={pageUrl}
  breadcrumbs={[{ name: "Все статьи", href: pageUrl }]}
  showBreadcrumbs={true}
>
  <AcademyListHero
    breadcrumb={[
      { label: "Академия", href: academyPath() },
      { label: "Все статьи" },
    ]}
    label={`[ архив ] · ${total} материалов${updated ? ` · обновлено ${updated}` : ""}`}
    titleTop="Все статьи"
    description="Полный склад материалов Академии&nbsp;— теория, разборы заданий, формулы и&nbsp;задачи. Фильтруй по&nbsp;категории, тегу и&nbsp;дате или ищи по&nbsp;названию."
    stats={stats}
    marquee={marquee}
  />
  <AcademyArticleGrid
    secNum="[02] / СПИСОК"
    title={`Все ${total} материалов`}
    articles={articles}
    filters
    categories={categories}
    tags={tags}
  />
</AcademyLayout>
