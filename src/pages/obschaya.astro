---
import EgeLandingLayout from "../layouts/EgeLandingLayout.astro";
import EgeAuthor from "../components/ege/EgeAuthor.astro";
import EgeFaq from "../components/ege/EgeFaq.astro";
import EgeScripts from "../components/ege/EgeScripts.astro";
import PaymentPopup from "../components/stepik/PaymentPopup.astro";
import StepikV2Hero from "../components/stepik-v2/StepikV2Hero.astro";
import StepikV2Selfpaced from "../components/stepik-v2/StepikV2Selfpaced.astro";
import StepikV2HowTo from "../components/stepik-v2/StepikV2HowTo.astro";
import StepikV2Inside from "../components/stepik-v2/StepikV2Inside.astro";
import StepikV2Program from "../components/stepik-v2/StepikV2Program.astro";
import StepikV2Tiles from "../components/stepik-v2/StepikV2Tiles.astro";
import StepikV2Reviews from "../components/stepik-v2/StepikV2Reviews.astro";
import StepikV2Value from "../components/stepik-v2/StepikV2Value.astro";
import StepikV2Pricing from "../components/stepik-v2/StepikV2Pricing.astro";
import StepikV2Universities from "../components/stepik-v2/StepikV2Universities.astro";
import { stepikGeneralLanding as page } from "../data/stepikGeneralLanding";
import {
  buildCourseJsonLd,
  buildFAQJsonLd,
  buildProductJsonLd,
  buildVideoJsonLd,
  pageUrlFromPath,
} from "../lib/seoData";

const origin = Astro.url.origin;
const url = pageUrlFromPath(origin, Astro.url.pathname);
const courseJsonLd = buildCourseJsonLd({
  origin,
  url,
  name: "Курс по общей химии для ЕГЭ 2027",
  description: page.seo.description,
  ratingValue: 4.9,
  reviewCount: 100,
  keywords: page.seo.keywords,
});
const productJsonLd = buildProductJsonLd({
  origin,
  url,
  name: "Курс по общей химии для ЕГЭ 2027",
  description: page.seo.description,
  image: page.seo.image,
  price: "2390",
  priceCurrency: "RUB",
});
const videoSlide = page.inside.slides.find((slide) => slide.media.src.endsWith(".webm") || slide.media.src.endsWith(".mp4"));
const videoJsonLd = videoSlide
  ? buildVideoJsonLd({
      origin,
      pageUrl: url,
      name: videoSlide.title,
      description: videoSlide.text,
      contentUrl: videoSlide.media.src,
    })
  : null;
const faqJsonLd = buildFAQJsonLd(page.faq.items);
const faqTitle = {
  text: "Часто задаваемые вопросы.",
  marks: [{ text: "вопросы.", color: "dim" as const }],
};
---

<EgeLandingLayout
  title={page.seo.title}
  description={page.seo.description}
  image={page.seo.image}
  url={url}
  nav={page.nav}
  footer={page.footer}
  floatingActions={page.floatingActions}
  popupForm={page.popupForm}
  breadcrumbs={[{ name: "Курс по общей химии для ЕГЭ" }]}
  showBreadcrumbs={true}
  courseJsonLd={courseJsonLd}
  productJsonLd={productJsonLd}
  videoJsonLd={videoJsonLd}
  faqJsonLd={faqJsonLd}
>
  <StepikV2Hero
    data={page.hero}
    breadcrumbs={[
      { label: "Главная", href: "/" },
      { label: "Курс по общей химии для ЕГЭ" },
    ]}
  />
  <StepikV2Selfpaced data={page.selfpaced} />
  <StepikV2Tiles id="self" section={page.self.section} title={page.self.title} items={page.self.cards} mode="paper" />
  <EgeAuthor cta={page.authorCta} />
  <StepikV2Inside data={page.inside} />
  <StepikV2Program data={page.program} />
  <StepikV2Tiles id="skills" section={page.skills.section} title={page.skills.title} items={page.skills.items} hero={{ label: page.skills.heroLabel, title: page.skills.heroTitle, text: page.skills.heroText }} />
  <StepikV2Tiles id="features" section={page.features.section} title={page.features.title} items={page.features.items} mode="paper" />
  <StepikV2Reviews data={page.reviews} />
  <StepikV2Value data={page.value} />
  <StepikV2HowTo />
  <StepikV2Pricing data={page.pricing} />
  <StepikV2Universities data={page.universities} />
  <EgeFaq section={page.faq.section} title={faqTitle} />

  <Fragment slot="after-footer">
    <EgeScripts data={{ faq: page.faq.items }} />
    <PaymentPopup
      theme="dark"
      settleMs={5200}
      title="Оплата курса по общей химии"
      stepikUrl={page.pricing.featured.paymentUrl}
    />
  </Fragment>
</EgeLandingLayout>
