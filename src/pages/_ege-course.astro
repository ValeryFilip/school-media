---
import MainLayout from "../layouts/MainLayout.astro";
import EgeCourseHero from "../components/ege-course/EgeCourseHero.astro";
import EgeCourseFacts from "../components/ege-course/EgeCourseFacts.astro";
import EgeCourseDifficulties from "../components/ege-course/EgeCourseDifficulties.astro";
import EgeCoursePreparation from "../components/ege-course/EgeCoursePreparation.astro";
import EgeCourseMiniGroup from "../components/ege-course/EgeCourseMiniGroup.astro";
import EgeCourseProgram from "../components/ege-course/EgeCourseProgram.astro";
import EgeCourseParents from "../components/ege-course/EgeCourseParents.astro";
import EgeCourseTeacher from "../components/ege-course/EgeCourseTeacher.astro";
import EgeCourseFeatures from "../components/ege-course/EgeCourseFeatures.astro";
import EgeCourseResults from "../components/ege-course/EgeCourseResults.astro";
import EgeCoursePricing from "../components/ege-course/EgeCoursePricing.astro";
import EgeCourseFaq from "../components/ege-course/EgeCourseFaq.astro";
import "../styles/ege-course.css";
---

<MainLayout
  title="Годовой курс ЕГЭ по химии в минигруппе"
  description="Подготовка к ЕГЭ по химии: годовой курс в минигруппе с живыми занятиями, домашними заданиями и поддержкой до самого экзамена."
  showNav={false}
  showBreadcrumbs={false}
>
  <div class="ege-course-page">
    <EgeCourseHero />
    <EgeCourseFacts />
    <EgeCourseDifficulties />
    <EgeCoursePreparation />
    <EgeCourseTeacher />
    <EgeCourseMiniGroup />
    <EgeCourseProgram />
    <section class="ege-course-dark">
      <div class="ege-course-dark__inner">
        <EgeCourseFeatures />
        <EgeCourseResults />
      </div>
    </section>
    <EgeCoursePricing />
    <EgeCourseParents />
    <EgeCourseFaq />
  </div>
</MainLayout>

<style>
  .ege-course-dark {
    width: 100vw;
    margin-inline: calc(50% - 50vw);
    background: var(--ege-dark-page);
    padding: var(--ege-section-pad-y) var(--ege-section-pad-x);
  }

  .ege-course-dark__inner {
    max-width: var(--ege-section-wide);
    margin: 0 auto;
    padding: 36px;
    background: transparent;
    border-radius: var(--ege-radius-section);
    box-shadow: none;
  }

  .ege-course-dark__inner :global(.results) {
    margin-top: 52px;
  }

  @media (max-width: 900px) {
    .ege-course-dark {
      padding: 0 var(--ege-section-pad-x) var(--ege-section-pad-y);
    }

    .ege-course-dark__inner {
      padding: 24px;
      border-radius: 30px;
    }

    .ege-course-dark__inner :global(.results) {
      margin-top: 36px;
    }
  }

  @media (max-width: 640px) {
    .ege-course-dark {
      padding: 0 var(--ege-section-pad-x) var(--ege-section-pad-y);
    }

    .ege-course-dark__inner {
      padding: 18px;
      border-radius: 24px;
    }
  }
</style>
